equential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            data_out_bin <= 16'b0;\n            data_bin_valid <= 0;\n            error_overflow <= 0;\n            valid_sentence <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n            clear_capture <= 0;\n        end else begin\n            state <= next_state;\n            buffer_index <= next_buffer_index;\n            \n            // Pulse clear_capture to acknowledge the captured valid\n            if (eff_valid) begin\n                clear_capture <= 1;\n            end else begin\n                clear_capture <= 0;\n            end\n\n            data_bin_valid <= 0;\n            valid_sentence <= 0;\n\n            case (state)\n                STATE_IDLE: begin\n                    watchdog_counter <= 0;\n                    if (eff_valid && is_start) begin\n                        error_overflow <= 0;\n                        watchdog_timeout <= 0;\n                    end\n                end\n\n                STATE_PARSE: begin\n                    if (watchdog_timeout_en) begin\n                        if (watchdog_counter >= WATCHDOG_LIMIT - 1) begin\n                            watchdog_timeout <= 1;\n                            watchdog_counter <= 0;\n                        end else begin\n                            watchdog_counter <= watchdog_counter + 1;\n                        end\n                    end\n\n                    if (buffer_index >= MAX_BUFFER_SIZE - 1) begin\n                        error_overflow <= 1;\n                        watchdog_counter <= 0;\n                    end\n                end\n\n                STATE_OUTPUT: begin\n                    watchdog_counter <= 0;\n                    if (buffer[0] == 8'h47 &&\n                        buffer[1] == 8'h50 &&\n                        buffer[2] == 8'h52 &&\n                        buffer[3]