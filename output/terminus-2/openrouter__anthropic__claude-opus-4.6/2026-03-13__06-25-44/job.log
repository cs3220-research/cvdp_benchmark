w >>> TOTAL_SHIFT);\n                coeff_imag[k] <= coeff_imag[k] + $signed(prod_imag_w >>> TOTAL_SHIFT);\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
