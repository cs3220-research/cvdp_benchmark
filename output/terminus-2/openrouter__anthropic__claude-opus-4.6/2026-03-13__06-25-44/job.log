Sending keys: ["cat > /code/rtl/jpeg_runlength_rzs.sv << 'ENDOFFILE'\nmodule jpeg_runlength_rzs (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire [3:0]  rlen_in,\n    input  wire [3:0]  size_in,\n    input  wire [11:0] amp_in,\n    input  wire        den_in,\n    input  wire        dc_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dc_out\n);\n\n    // FSM states\n    localparam S_IDLE = 2'd0;\n    localparam S_HOLD = 2'd1;\n    localparam S_EMIT = 2'd2;\n\n    reg [1:0] state, state_nxt;\n\n    // Held ZRL data\n    reg [3:0]  held_rlen, held_rlen_nxt;\n    reg [3:0]  held_size, held_size_nxt;\n    reg [11:0] held_amp,  held_amp_nxt;\n    reg        held_dc,   held_dc_nxt;\n\n    // Pending data\n    reg [3:0]  pend_rlen, pend_rlen_nxt;\n    reg [3:0]  pend_size, pend_size_nxt;\n    reg [11:0] pend_amp,  pend_amp_nxt;\n    reg        pend_dc,   pend_dc_nxt;\n\n    // Combinational output and next-state logic\n    always @(*) begin\n        // Defaults\n        rlen_out     = 4'd0;\n        size_out     = 4'd0;\n        amp_out      = 12'd0;\n        den_out      = 1'b0;\n        dc_out       = 1'b0;\n        state_nxt    = state;\n        held_rlen_nxt = held_rlen;\n        held_size_nxt = held_size;\n        held_amp_nxt  = held_amp;\n        held_dc_nxt   = held_dc;\n        pend_rlen_nxt = pend_rlen;\n        pend_size_nxt = pend_size;\n        pend_amp_nxt  = pend_amp;\n        pend_dc_nxt   = pend_dc;\n\n        case (state)\n            S_IDLE: begin\n                if (den_in) begin\n                    if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                        // ZRL detected - suppress, go to HOLD\n                        state_nxt     = S_HOLD;\n                        held_rlen_nxt = rlen_in;\n                        held_size_nxt = size_in;\n                        held_amp_nxt  = amp_in;\n                        held_dc_nxt   = dc_in;\n                        den_out       = 1'b0;\n                    end else begin\n                        // Pass through combinationally\n                        rlen_out = rlen_in;\n                        size_out = size_in;\n                        amp_out  = amp_in;\n                        den_out  = 1'b1;\n                        dc_out   = dc_in;\n                    end\n                end\n            end\n\n            S_HOLD: begin\n                if (den_in) begin\n                    if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                        // Another ZRL - keep suppressing\n                        held_rlen_nxt = rlen_in;\n                        held_size_nxt = size_in;\n                        held_amp_nxt  = amp_in;\n                        held_dc_nxt   = dc_in;\n                        den_out       = 1'b0;\n                    end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                        // EOB - discard held ZRL, pass EOB\n                        rlen_out  = rlen_in;\n                        size_out  = size_in;\n                        amp_out   = amp_in;\n                        den_out   = 1'b1;\n                        dc_out    = dc_in;\n                        state_nxt = S_IDLE;\n                    end else begin\n                        // Non-ZRL/EOB: emit held ZRL now, save current for next cycle\n                        rlen_out  = held_rlen;\n                        size_out  = held_size;\n                        amp_out   = held_amp;\n                        den_out   = 1'b1;\n                        dc_out    = held_dc;\n                        pend_rlen_nxt = rlen_in;\n                        pend_size_nxt = size_in;\n                        pend_amp_nxt  = amp_in;\n                        pend_dc_nxt   = dc_in;\n                        state_nxt     = S_EMIT;\n                    end\n                end\n            end\n\n            S_EMIT: begin\n                // Emit pending data combinationally\n                rlen_out  = pend_rlen;\n                size_out  = pend_size;\n                amp_out   = pend_amp;\n                den_out   = 1'b1;\n                dc_out    = pend_dc;\n                state_nxt = S_IDLE;\n            end\n\n            default: begin\n                state_nxt = S_IDLE;\n            end\n        endcase\n    end\n\n    // Sequential state update\n    always @(posedge clk_in) begin\n        if (reset_in) begin\n            state     <= S_IDLE;\n            held_rlen <= 4'd0;\n            held_size <= 4'd0;\n            held_amp  <= 12'd0;\n            held_dc   <= 1'b0;\n            pend_rlen <= 4'd0;\n            pend_size <= 4'd0;\n            pend_amp  <= 12'd0;\n            pend_dc   <= 1'b0;\n        end else if (enable_in) begin\n            state     <= state_nxt;\n            held_rlen <= held_rlen_nxt;\n            held_size <= held_size_nxt;\n            held_amp  <= held_amp_nxt;\n            held_dc   <= held_dc_nxt;\n            pend_rlen <= pend_rlen_nxt;\n            pend_size <= pend_size_nxt;\n            pend_amp  <= pend_amp_nxt;\n            pend_dc   <= pend_dc_nxt;\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
