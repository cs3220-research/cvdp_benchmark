Sending keys: ["cat > /code/rtl/hdbn_decoder.sv << 'EOF'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    //--------------------------------------------------------------------------\n    // Decoder Pipeline (6 clock cycles latency)\n    //   Clk 1: Input sync register + normalize to active-high\n    //   Clk 2: Pulse detection, polarity tracking, violation detect\n    //   Clk 3: Shift register stage 1 (for looking back at violation patterns)\n    //   Clk 4: Shift register stage 2 / violation validation\n    //   Clk 5: Data recovery (strip V and B pulses) + error collection\n    //   Clk 6: Output register\n    //--------------------------------------------------------------------------\n\n    // ---- Stage 1: Input Synchronization & Normalization ----\n    logic p_s1, n_s1;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p_s1 <= 1'b0;\n            n_s1 <= 1'b0;\n        end else if (clk_enable_in) begin\n            // Normalize: if pulse_active_state is 0, invert\n            p_s1 <= (pulse_active_state) ? p_in : ~p_in;\n            n_s1 <= (pulse_active_state) ? n_in : ~n_in;\n        end\n    end\n\n    // ---- Stage 2: Pulse Analysis ----\n    // Detect: is there a pulse? Which polarity? Is it a violation?\n    // A violation = consecutive pulses of same polarity (breaks AMI rule)\n    \n    logic has_pulse_s2;      // any pulse present\n    logic is_positive_s2;    // 1=positive, 0=negative\n    logic is_violation_s2;   // same polarity as previous pulse\n    logic pulse_error_s2;    // both P and N active simultaneously\n    logic last_polarity;     // polarity of last pulse: 1=positive, 0=negative\n    logic had_any_pulse;     // have we seen any pulse yet?\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            has_pulse_s2    <= 1'b0;\n            is_positive_s2  <= 1'b0;\n            is_violation_s2 <= 1'b0;\n            pulse_error_s2  <= 1'b0;\n            last_polarity   <= 1'b0;\n            had_any_pulse   <= 1'b0;\n        end else if (clk_enable_in) begin\n            pulse_error_s2 <= p_s1 && n_s1;  // simultaneous pulse error\n            \n            if (p_s1 && !n_s1) begin\n                // Positive pulse\n                has_pulse_s2   <= 1'b1;\n                is_positive_s2 <= 1'b1;\n                is_violation_s2 <= had_any_pulse && (last_polarity == 1'b1);\n                last_polarity  <= 1'b1;\n                had_any_pulse  <= 1'b1;\n            end else if (n_s1 && !p_s1) begin\n                // Negative pulse\n                has_pulse_s2   <= 1'b1;\n                is_positive_s2 <= 1'b0;\n                is_violation_s2 <= had_any_pulse && (last_polarity == 1'b0);\n                last_polarity  <= 1'b0;\n                had_any_pulse  <= 1'b1;\n            end else begin\n                // No pulse (or both, which is error)\n                has_pulse_s2    <= 1'b0;\n                is_positive_s2  <= 1'b0;\n                is_violation_s2 <= 1'b0;\n            end\n        end\n    end\n\n    // ---- Stages 3-4: Shift Register for Pattern Matching ----\n    // We need to look back encoder_type positions to find the B pulse\n    // associated with a violation.\n    // Shift register delays: has_pulse, is_violation by encoder_type-1 stages\n    // so when V comes out, we can check encoder_type-1 positions back for B\n    \n    // For HDB3: V at [0], zeros at [1],[2], B at [3] -> need 3 stages\n    // For HDB2: V at [0], zero at [1], B at [2] -> need 2 stages\n    // But we need encoder_type-1 delay stages between detection and output\n    \n    // Use a simple pipeline of encoder_type-1 stages\n    localparam SR_DEPTH = encoder_type - 1;\n    \n    logic [SR_DEPTH:0] sr_pulse;   // [0]=newest from s2, [SR_DEPTH]=oldest\n    logic [SR_DEPTH:0] sr_viol;    // violation flags\n    logic [SR_DEPTH:0] sr_perr;    // pulse error flags\n    logic [SR_DEPTH:0] sr_pos;     // polarity flags\n\n    integer i;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_pulse <= '0;\n            sr_viol  <= '0;\n            sr_perr  <= '0;\n            sr_pos   <= '0;\n        end else if (clk_enable_in) begin\n            sr_pulse[0] <= has_pulse_s2;\n            sr_viol[0]  <= is_violation_s2;\n            sr_perr[0]  <= pulse_error_s2;\n            sr_pos[0]   <= is_positive_s2;\n            for (i = 1; i <= SR_DEPTH; i = i + 1) begin\n                sr_pulse[i] <= sr_pulse[i-1];\n                sr_viol[i]  <= sr_viol[i-1];\n                sr_perr[i]  <= sr_perr[i-1];\n                sr_pos[i]   <= sr_pos[i-1];\n            end\n        end\n    end\n\n    // ---- Stage 5: Data Recovery & Error Detection ----\n    // Output from SR: sr_*[SR_DEPTH] is the oldest (most delayed)\n    // When we see a violation at sr_viol[0], we need to:\n    //   1. Zero out the V pulse at [0]\n    //   2. Zero out the B pulse at [encoder_type-1] if present\n    //   For HDB3: V at [0], B might be at [encoder_type-1]=[2]\n    //   For HDB2: V at [0], B might be at [encoder_type-1]=[1]\n    //\n    // Actually, the violation comes out at sr_*[SR_DEPTH].\n    // When violation is at SR_DEPTH, the B pulse (if any) was at the\n    // entry point encoder_type-1 clocks earlier, so it already exited.\n    //\n    // Alternative approach: detect violation at sr_viol[0] (newest),\n    // then retroactively clear the B at sr_pulse[SR_DEPTH] (oldest in SR)\n    // and clear the V at [0]. But we also need to clear the V from output.\n    //\n    // Simpler: use the SR output (oldest) and look at newest for violation\n    // When violation appears at [0], the associated B is at [SR_DEPTH]\n    \n    logic data_s5;\n    logic error_s5;\n    logic zero_error_s5;\n    \n    // Zero counter for decoder (detect missing violations)\n    reg [3:0] dec_zero_cnt;\n    \n    // Track if the current output should be suppressed\n    // When violation at sr_viol[0], suppress:\n    //   - The V pulse itself (at [0]) -> will be output SR_DEPTH clocks later\n    //   - The B pulse (at [SR_DEPTH]) -> being output now\n    \n    // Let me use a different approach: \n    // Process from the SR output side.\n    // sr_*[SR_DEPTH] is the current output candidate.\n    // Check if it should be suppressed (it's a B pulse for a violation at [0])\n    \n    logic suppress_as_b;  // current output is a B pulse to suppress\n    logic suppress_as_v;  // current output is a V pulse to suppress\n    \n    // V suppression: use a separate shift register to mark V for suppression\n    logic [SR_DEPTH:0] sr_suppress_v;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_suppress_v <= '0;\n        end else if (clk_enable_in) begin\n            sr_suppress_v[0] <= is_violation_s2;  // mark V for future suppression\n            for (i = 1; i <= SR_DEPTH; i = i + 1)\n                sr_suppress_v[i] <= sr_suppress_v[i-1];\n        end\n    end\n    \n    // B suppression: when V is at [0], B is at [SR_DEPTH]\n    assign suppress_as_v = sr_suppress_v[SR_DEPTH];\n    assign suppress_as_b = sr_viol[0] && sr_pulse[SR_DEPTH];  // V detected, and oldest is a pulse (B)\n    \n    logic recovered_data;\n    assign recovered_data = sr_pulse[SR_DEPTH] && !suppress_as_v && !suppress_as_b;\n    \n    // Violation polarity error: consecutive violations should alternate polarity\n    logic last_viol_polarity;\n    logic had_violation;\n    logic viol_polarity_err;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            last_viol_polarity <= 1'b0;\n            had_violation      <= 1'b0;\n            viol_polarity_err  <= 1'b0;\n        end else if (clk_enable_in) begin\n            viol_polarity_err <= 1'b0;\n            if (sr_suppress_v[SR_DEPTH] && sr_viol[SR_DEPTH]) begin\n                // This is a confirmed violation at output\n                if (had_violation && (sr_pos[SR_DEPTH] == last_viol_polarity)) begin\n                    // Same polarity as last violation - could be error\n                    // Actually in HDBn, violations DO alternate, but consecutive\n                    // same-polarity violations are the normal pattern\n                    // V pulses should alternate polarity for DC balance\n                end\n                last_viol_polarity <= sr_pos[SR_DEPTH];\n                had_violation <= 1'b1;\n            end\n        end\n    end\n    \n    // Zero count error detection\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            dec_zero_cnt <= 4'd0;\n            zero_error_s5 <= 1'b0;\n            data_s5 <= 1'b0;\n            error_s5 <= 1'b0;\n        end else if (clk_enable_in) begin\n            data_s5 <= recovered_data;\n            \n            // Zero count tracking on the encoded stream (before stripping)\n            if (sr_pulse[SR_DEPTH]) begin\n                dec_zero_cnt <= 4'd0;\n            end else begin\n                if (dec_zero_cnt >= encoder_type[3:0]) begin\n                    zero_error_s5 <= 1'b1;\n                end else begin\n                    zero_error_s5 <= 1'b0;\n                end\n                dec_zero_cnt <= dec_zero_cnt + 4'd1;\n            end\n            \n            // Combine errors\n            error_s5 <= sr_perr[SR_DEPTH] | zero_error_s5;\n        end\n    end\n\n    // ---- Stage 6: Output Register ----\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_out       <= 1'b0;\n            code_error_out <= 1'b0;\n        end else if (clk_enable_in) begin\n            data_out       <= data_s5;\n            code_error_out <= error_s5;\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
