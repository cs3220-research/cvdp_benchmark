Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'EOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    //--------------------------------------------------------------------------\n    // Pipeline Architecture (total latency = encoder_type + 4 clocks)\n    //   For HDB3 (encoder_type=3): 7 clocks\n    //   For HDB2 (encoder_type=2): 6 clocks\n    //\n    //   Clk 1: Input sync register (data_s1)\n    //   Clk 2: Zero count + substitution decision (data_s2, viol_s2, bal_s2)\n    //   Clk 3..2+ET: Shift register delay (encoder_type stages)\n    //                 Balance pulse inserted retroactively at SR head\n    //   Clk 3+ET: AMI pulse generation (p_s, n_s)\n    //   Clk 4+ET: Output gating register (p_out, n_out)\n    //--------------------------------------------------------------------------\n\n    // ---- Stage 1: Input Synchronization ----\n    logic data_s1;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in)\n            data_s1 <= 1'b0;\n        else if (clk_enable_in)\n            data_s1 <= data_in;\n    end\n\n    // ---- Stage 2: Zero Counting & Substitution Decision ----\n    logic data_s2;\n    logic viol_s2;\n    logic bal_s2;  // balance pulse needed for this violation group\n\n    reg [3:0] zero_cnt;        // consecutive zero counter\n    reg [7:0] pulses_since_v;  // normal pulses since last violation\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_s2          <= 1'b0;\n            viol_s2          <= 1'b0;\n            bal_s2           <= 1'b0;\n            zero_cnt         <= 4'd0;\n            pulses_since_v   <= 8'd0;\n        end else if (clk_enable_in) begin\n            if (data_s1) begin\n                // Data bit = 1\n                zero_cnt       <= 4'd0;\n                pulses_since_v <= pulses_since_v + 8'd1;\n                data_s2        <= 1'b1;\n                viol_s2        <= 1'b0;\n                bal_s2         <= 1'b0;\n            end else if (zero_cnt == encoder_type[3:0] - 4'd1) begin\n                // encoder_type consecutive zeros reached -> insert V\n                zero_cnt       <= 4'd0;\n                // Balance needed when pulses_since_v is even (including 0)\n                bal_s2         <= ~pulses_since_v[0];\n                pulses_since_v <= 8'd0;\n                data_s2        <= 1'b1;  // V pulse\n                viol_s2        <= 1'b1;\n            end else begin\n                zero_cnt       <= zero_cnt + 4'd1;\n                data_s2        <= 1'b0;\n                viol_s2        <= 1'b0;\n                bal_s2         <= 1'b0;\n            end\n        end\n    end\n\n    // ---- Stages 3..2+encoder_type: Shift Register with Balance Insertion ----\n    // SR shifts data from [0] (newest) to [encoder_type-1] (oldest, output)\n    // When a violation enters at [0] with bal_s2=1, the first zero of the\n    // group is at sr_data[encoder_type-2]. We overwrite it with 1 (B pulse).\n\n    logic [encoder_type-1:0] sr_data;\n    logic [encoder_type-1:0] sr_viol;\n\n    integer idx;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_data <= '0;\n            sr_viol <= '0;\n        end else if (clk_enable_in) begin\n            // Normal shift\n            sr_data[0] <= data_s2;\n            sr_viol[0] <= viol_s2;\n            for (idx = 1; idx < encoder_type; idx = idx + 1) begin\n                sr_data[idx] <= sr_data[idx-1];\n                sr_viol[idx] <= sr_viol[idx-1];\n            end\n            // Retroactive balance insertion\n            // When violation with balance enters, first zero is at [encoder_type-2]\n            if (viol_s2 && bal_s2) begin\n                sr_data[encoder_type-2] <= 1'b1;\n            end\n        end\n    end\n\n    logic sr_out_data;\n    logic sr_out_viol;\n    assign sr_out_data = sr_data[encoder_type-1];\n    assign sr_out_viol = sr_viol[encoder_type-1];\n\n    // ---- Stage 3+encoder_type: AMI Pulse Generation ----\n    // ami_state: 0 -> next normal pulse is Positive, 1 -> next is Negative\n    // Normal pulse (1 or B): follows AMI alternation, toggles ami_state\n    // Violation pulse: SAME polarity as previous pulse, does NOT toggle\n    //   ami_state=0 means last pulse was Negative -> V is Negative\n    //   ami_state=1 means last pulse was Positive -> V is Positive\n\n    logic ami_state;\n    logic p_ami, n_ami;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami_state <= 1'b0;\n            p_ami     <= ~pulse_active_state;\n            n_ami     <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (sr_out_data) begin\n                if (sr_out_viol) begin\n                    // Violation: repeat last polarity\n                    if (ami_state) begin\n                        // Last was P -> V is P\n                        p_ami <= pulse_active_state;\n                        n_ami <= ~pulse_active_state;\n                    end else begin\n                        // Last was N -> V is N\n                        p_ami <= ~pulse_active_state;\n                        n_ami <= pulse_active_state;\n                    end\n                    // ami_state unchanged\n                end else begin\n                    // Normal pulse: alternate\n                    if (!ami_state) begin\n                        // Next is P\n                        p_ami <= pulse_active_state;\n                        n_ami <= ~pulse_active_state;\n                        ami_state <= 1'b1;\n                    end else begin\n                        // Next is N\n                    