al[k] - error_imag * data_imag[k];\n                update_imag = error_real * data_imag[k] + error_imag * data_real[k];\n                coeff_real[k] <= coeff_real[k] + (update_real >>> TOTAL_SHIFT);\n                coeff_imag[k] <= coeff_imag[k] + (update_imag >>> TOTAL_SHIFT);\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
