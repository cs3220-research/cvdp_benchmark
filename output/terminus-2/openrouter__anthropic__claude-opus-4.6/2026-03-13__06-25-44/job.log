 begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= '0;\n                shift_reg_imag[i] <= '0;\n            end\n        end else begin\n            shift_reg_real[0] <= data_in_real;\n            shift_reg_imag[0] <= data_in_imag;\n            for (i = 1; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= shift_reg_real[i-1];\n                shift_reg_imag[i] <= shift_reg_imag[i-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // Desired signal delay line (to align with FIR output)\n    // =========================================================================\n    integer d;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (d = 0; d <= TAP_NUM/2; d = d + 1) begin\n                desired_real_d[d] <= '0;\n                desired_imag_d[d] <= '0;\n            end\n        end else begin\n            desired_real_d[0] <= desired_real;\n            desired_imag_d[0] <= desired_imag;\n            for (d = 1; d <= TAP_NUM/2; d = d + 1) begin\n                desired_real_d[d] <= desired_real_d[d-1];\n                desired_imag_d[d] <= desired_imag_d[d-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // FIR Filter - Combinational multiply and accumulate\n    // y[n] = sum(w_k * x[n-k]) for k=0..TAP_NUM-1\n    // Complex multiply: (wr+j*wi)*(xr+j*xi) = (wr*xr - wi*xi) + j(wr*xi + wi*xr)\n    // =========================================================================\n    logic signed [DATA_WIDTH*2-1:0] acc_real;\n    logic signed [DATA_WIDTH*2-1:0] acc_imag;\n\n    integer j;\n    always_comb begin\n        acc_real = 0;\n        acc_imag = 0;\n        for (j = 0; j < TAP_NUM; j = j + 1) begin\n            acc_real = acc_real + (coeff_real[j] * shift_reg_real[j] - coeff_imag[j] * shift_reg_imag[j]);\n            acc_imag = acc_imag + (coeff_real[j] * shift_reg_imag[j] + coeff_imag[j] * shift_reg_real[j]);\n        end\n        // Truncate back to DATA_WIDTH after fixed-point shift (Q2.13 * Q2.13 = Q4.26, shift right by 13 to get Q4.13, then truncate to 16 bits)\n        fir_out_real = acc_real[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n        fir_out_imag = acc_imag[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n    end\n\n    // =========================================================================\n    // Output Register\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            out_real_reg <= '0;\n            out_imag_reg <= '0;\n        end else begin\n            out_real_reg <= fir_out_real;\n            out_imag_reg <= fir_out_imag;\n        end\n    end\n\n    assign data_out_real = out_real_reg;\n    assign data_out_imag = out_imag_reg;\n\n    // =========================================================================\n    // Error Calculation (combinational)\n    // =========================================================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (out_real_reg),\n        .data_imag    (out_imag_reg),\n        .desired_real (desired_real_d[TAP_NUM/2]),\n        .desired_imag (desired_imag_d[TAP_NUM/2]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================================================\n    // Coefficient Update\n    // =========================================================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_reg_real),\n        .data_imag  (shift_reg_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
