 port 1\n\n    assign cfg_ram_addr = cfg_addr_in[ADDR_W+1:2];\n    assign cfg_ram_wr = cfg_wr_in && (cfg_addr_in[15:0] < 16'h07F4);\n\n    ethernet_dp_ram #(\n        .WIDTH(WIDTH),\n        .ADDR_W(ADDR_W)\n    ) u_dp_ram (\n        .clk0_in   (clk_in),\n        .addr0_in  (cfg_ram_addr),\n        .data0_in  (cfg_data_wr_in),\n        .wr0_in    (cfg_ram_wr),\n        .data0_out (ram_data0_out),\n        .addr1_in  (ram_rd_addr),\n        .data1_in  (32'd0),\n        .wr1_in    (1'b0),\n        .data1_out (ram_data1_out)\n    );\n\n    // -------------------------------------------------------------------------\n    // Configuration Read Mux\n    // -------------------------------------------------------------------------\n    reg [31:0] cfg_data_rd_reg;\n    assign cfg_data_rd_out = cfg_data_rd_reg;\n\n    always @(*) begin\n        case (cfg_addr_in[15:0])\n            16'h07F4: cfg_data_rd_reg = {16'd0, tx_length};\n            16'h07F8: cfg_data_rd_reg = tx_irq_en;\n            16'h07FC: cfg_data_rd_reg = tx_ctrl;\n            default:  cfg_data_rd_reg = ram_data0_out;\n        endcase\n    end\n\n    // -------------------------------------------------------------------------\n    // AXI Output Assignments\n    // -------------------------------------------------------------------------\n    assign axis_tvalid_out = axis_tvalid_reg;\n    assign axis_tdata_out  = axis_tdata_reg;\n    assign axis_tstrb_out  = axis_tstrb_reg;\n    assign axis_tlast_out  = axis_tlast_reg;\n    assign interrupt_out   = interrupt_reg;\n\n    // -------------------------------------------------------------------------\n    // Effective length (minimum 64 bytes)\n    // -------------------------------------------------------------------------\n    wire [15:0] eff_length;\n    assign eff_length = (tx_length < 16'd64) ? 16'd64 : tx_length;\n\n    // -------------------------------------------------------------------------\n    // RAM read address - combinational\n    // Feed the address to RAM so data is available next cycle\n    // -------------------------------------------------------------------------\n    always @(*) begin\n        ram_rd_addr = tx_ptr;\n    end\n\n    // -------------------------------------------------------------------------\n    // Main FSM and Logic\n    // -------------------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state           <= ST_IDLE;\n            tx_length       <= 16'd0;\n            tx_irq_en       <= 32'd0;\n            tx_ctrl         <= 32'd0;\n            remaining       <= 16'd0;\n            tx_ptr          <= {ADDR_W{1'b0}};\n            interrupt_reg   <= 1'b0;\n            axis_tvalid_reg <= 1'b0;\n            axis_tdata_reg  <= 32'd0;\n            axis_tstrb_reg  <= 4'd0;\n            axis_tlast_reg  <= 1'b0;\n        end else begin\n            interrupt_reg <= 1'b0;\n\n            // Configuration Register Writes\n            if (cfg_wr_in) begin\n                case (cfg_addr_in[15:0])\n                    16'h07F4: tx_length <= cfg_data_wr_in[15:0];\n                    16'h07F8: tx_irq_en <= cfg_data_wr_in;\n                    16'h07FC: tx_ctrl   <= cfg_data_wr_in;\n                    default: ;\n                endcase\n            end\n\n            case (state)\n                ST_IDLE: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n                    axis_tstrb_reg  <= 4'd0;\n                    axis_tdata_reg  <= 32'd0;\n\n                    if (tx_ctrl[0]) begin\n                        if (tx_ctrl[1]) begin\n                            // PROGRAM mode: go directly to END\n                            state <= ST_END;\n                        end else begin\n                            // Normal mode: initialize and start\n                            remaining <= eff_length;\n                            tx_ptr    <= {ADDR_W{1'b0}};\n                            // tx_ptr=0 is now on RAM input combinationally\n                            // Data will be available next cycle (in ST_READ)\n                            state     <= ST_READ;\n                        end\n                    end\n                end\n\n                ST_READ: begin\n                    // RAM data for tx_ptr is now available on ram_data1_out\n                    // (address was presented last cycle)\n                    axis_tvalid_reg <= 1'b1;\n                    axis_tdata_reg  <= ram_data1_out;\n\n                    // Compute strobe\n                    if (remaining >= 16'd4) begin\n                        axis_tstrb_reg <= 4'hF;\n                    end else begin\n                        case (remaining[1:0])\n                            2'd3: axis_tstrb_reg <= 4'h7;\n                            2'd2: axis_tstrb_reg <= 4'h3;\n                            2'd1: axis_tstrb_reg <= 4'h1;\n                            default: axis_tstrb_reg <= 4'h0;\n                        endcase\n                    end\n\n                    // Check if last word\n                    if (remaining <= 16'd4) begin\n                        axis_tlast_reg <= 1'b1;\n                    end else begin\n                        axis_tlast_reg <= 1'b0;\n                    end\n\n                    // Always go to PAUSE\n                    state <= ST_PAUSE;\n                end\n\n                ST_PAUSE: begin\n                    // Deassert AXI valid\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n\n                    // Update counters\n                    if (remaining >= 16'd4) begin\n                        remaining <= remaining - 16'd4;\n                    end else begin\n                        remaining <= 16'd0;\n                    end\n                    tx_ptr <= tx_ptr + 1'b1;\n                    // New tx_ptr value feeds RAM combinationally\n                    // Data for new address will be ready next cycle\n\n                    if (remaining <= 16'd4) begin\n                        state <= ST_END;\n                    end else begin\n                        state <= ST_READ;\n                    end\n                end\n\n                ST_END: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n                    axis_tstrb_reg  <= 4'd0;\n\n                    // Clear BUSY and PROGRAM\n                    tx_ctrl[0] <= 1'b0;\n                    tx_ctrl[1] <= 1'b0;\n\n                    // Interrupt\n                    if (tx_irq_en[0]) begin\n                        interrupt_reg <= 1'b1;\n                    end\n\n                    state <= ST_IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
