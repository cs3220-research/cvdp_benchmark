Sending keys: ['cat > /code/rtl/hdbn_encoder.sv << \'VEOF\'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1\'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n    // =========================================================================\n    // HDBn Encoder\n    //\n    // HDB3 (encoder_type=3): replaces 4 consecutive zeros -> 000V or B00V\n    // HDB2 (encoder_type=2): replaces 3 consecutive zeros -> 00V or B0V  \n    //\n    // Pattern selection:\n    //   - 000V / 00V: when pulses since last substitution is ODD\n    //   - B00V / B0V: when pulses since last substitution is EVEN (incl. 0)\n    //\n    // V (Violation): same polarity as last pulse (violates AMI)\n    // B (Balance): follows normal AMI alternation\n    //\n    // Pipeline: S1(input) -> S2(zero count) -> SR[encoder_type] -> S_AMI -> S_OUT\n    // Latency = 1 + 1 + encoder_type + 1 + 1 = encoder_type + 4\n    // HDB3: 7 clocks, HDB2: 6 clocks\n    // =========================================================================\n\n    // ----- S1: Input Sync Register -----\n    logic s1;\n    always_ff @(posedge clk_in or posedge reset_in)\n        if (reset_in)           s1 <= 0;\n        else if (clk_enable_in) s1 <= data_in;\n\n    // ----- S2: Zero Counting & Substitution Decision -----\n    // zc: zero counter (0 to encoder_type)\n    // psv: pulse count since last violation/substitution\n    // When zc reaches encoder_type, the current zero is the\n    // (encoder_type+1)th consecutive zero -> replace with V\n    // The preceding encoder_type zeros are in the shift register\n\n    logic s2_d;       // data: 1=pulse (original or V), 0=zero\n    logic s2_v;       // violation flag\n    logic s2_b;       // balance needed flag\n\n    reg [3:0] zc;\n    reg [7:0] psv;    // pulses since last violation\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s2_d <= 0; s2_v <= 0; s2_b <= 0;\n            zc <= 0; psv <= 0;\n        end else if (clk_enable_in) begin\n            if (s1) begin\n                // Input is 1: normal pulse\n                zc  <= 0;\n                psv <= psv + 1;\n                s2_d <= 1; s2_v <= 0; s2_b <= 0;\n            end else if (zc == encoder_type[3:0]) begin\n                // (encoder_type+1)th consecutive zero: insert V\n                zc  <= 0;\n                s2_d <= 1;  // V is a pulse\n                s2_v <= 1;\n                s2_b <= ~psv[0]; // balance when even (0,2,4,...)\n                psv <= 0;\n            end else begin\n                // Input is 0: increment counter\n                zc <= zc + 1;\n                s2_d <= 0; s2_v <= 0; s2_b <= 0;\n            end\n        end\n    end\n\n    // ----- SR: Shift Register (encoder_type deep) -----\n    // Buffers data for encoder_type clocks.\n    // When V+B enters at [0], insert B at [encoder_type-1] (first zero of group)\n    //\n    // Shift direction: new data at [0], oldest at [encoder_type-1]\n    // Before shift (when V+B detected):\n    //   [0] = (encoder_type)th zero (most recent before V)\n    //   [1] = (encoder_type-1)th zero\n    //   ...\n    //   [encoder_type-1] = 1st zero (oldest)\n    //\n    // After shift:\n    //   [0] = V (new data)\n    //   [1] = (encoder_type)th zero\n    //   ...\n    //   [encoder_type-1] = 2nd zero\n    //   Output (was [encoder_type-1] before shift) = 1st zero\n    //\n    // Problem: the 1st zero exits the SR on the same clock V enters!\n    // So we can\'t retroactively insert B.\n    //\n    // Solution: Use SR of depth encoder_type+1. Then:\n    //   After shift: [encoder_type] = 1st zero (still in SR)\n    //   We can set [encoder_type] = 1 for B.\n    //   Output is from [encoder_type].\n    //   This adds 1 clock to pipeline.\n    //\n    // Revised latency: 1+1+(encoder_type+1)+1+1 = encoder_type+5\n    // HDB3: 8, HDB2: 7. Too much.\n    //\n    // Alternative: detect the need for B one clock EARLY.\n    // At zc == encoder_type - 1 AND s1 == 0, we know the NEXT zero\n    // (if it comes) will trigger V. But we don\'t know if next is 0 yet.\n    //\n    // Better alternative: use the SR output and a separate balance marker.\n    // When V is detected, also output a "balance marker" that travels\n    // through a separate SR. When the marker exits encoder_type clocks\n    // later, it coincides with the position where B should be.\n    // But that means B comes AFTER V in the output, which is wrong\n    // (B should come BEFORE V: B00V).\n    //\n    // Correct approach: The SR delays the data so that when V enters,\n    // the first zero is about to exit. We intercept it.\n    // SR depth = encoder_type. Output = sr[encoder_type-1].\n    // When V enters (s2_v & s2_b), the 1st zero is at sr[encoder_type-1]\n    // (it\'s about to be output). We can modify the OUTPUT instead of the SR.\n    // On the clock when V enters at [0], the output sr[encoder_type-1]\n    // is the 1st zero. If balance is needed, we force the output to 1.\n\n    logic [encoder_type-1:0] sr_d;\n    logic [encoder_type-1:0] sr_v;\n\n    integer k;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_d <= 0;\n            sr_v <= 0;\n        end else if (clk_enable_in) begin\n            sr_d[0] <= s2_d;\n            sr_v[0] <= s2_v;\n            for (k = 1; k < encoder_type; k++) begin\n                sr_d[k] <= sr_d[k-1];\n                sr_v[k] <= sr_v[k-1];\n            end\n        end\n    end\n\n    // SR output with balance override\n    // When s2_v & s2_b (V entering SR), force output to 1 (B pulse)\n    wire sr_out_d = (s2_v & s2_b) ? 1\'b1 : sr_d[encoder_type-1];\n    wire sr_out_v = sr_v[encoder_type-1]; // B is NOT a violation\n\n    // ----- AMI Pulse Generation -----\n    // ami: 0 = next normal pulse is P, 1 = next normal pulse is N\n    // Normal pulse (1 or B): follows AMI, toggles ami\n    // Violation pulse (V): same polarity as LAST pulse, no toggle\n    //   ami=0 -> last was N (or none) -> V is N\n    //   ami=1 -> last was P -> V is P\n\n    logic ami;\n    logic sp, sn; // pre-output\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami <= 0;\n            sp  <= ~pulse_active_state;\n            sn  <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (sr_out_d) begin\n                if (sr_out_v) begin\n                    // Violation: same as last pulse\n                    if (ami) begin\n                        sp <= pulse_active_state;\n                        sn <= ~pulse_active_state;\n                    end else begin\n                        sp <= ~pulse_active_state;\n                        sn <= pulse_active_state;\n                    end\n                    // Don\'t toggle ami\n                end else begin\n                    // Normal pulse: alternate\n                    if (!ami) begin\n                        sp <= pulse_active_state;\n                        sn <= ~pulse_active_state;\n                        ami <= 1;\n                    end else begin\n                        sp <= ~pulse_active_state;\n                        sn <= pulse_active_state;\n                        ami <= 0;\n                    end\n                end\n            end else begin\n                sp <= ~pulse_active_state;\n                sn <= ~pulse_active_state;\n            end\n        end\n    end\n\n    // ----- Output Gate Register -----\n    logic gp, gn;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            gp <= ~pulse_active_state;\n            gn <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (output_gate_in) begin\n                gp <= sp;\n                gn <= sn;\n            end else begin\n                gp <= ~pulse_active_state;\n                gn <= ~pulse_active_state;\n            end\n        end\n    end\n\n    assign p_out = gp;\n    assign n_out = gn;\n\nendmodule\nVEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > /code/rtl/hdbn_decoder.sv << 'VEOF'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n    // =========================================================================\n    // HDBn Decoder\n    //\n    // Decodes bipolar HDBn pulses back to binary data.\n    // Detects violations and strips V and B pulses.\n    // Reports errors: simultaneous pulses, wrong violations, excess zeros.\n    //\n    // Pipeline stages:\n    //   S1: Input sync + normalize (1 clk)\n    //   S2: Pulse detect + polarity + violation detect (1 clk)\n    //   SR: Shift register (encoder_type deep) for V/B pattern matching\n    //   S3: Data recovery + error detection (1 clk)\n    //   S4: Output register (1 clk)\n    //\n    // Total = 1 + 1 + encoder_type + 1 + 1 = encoder_type + 4\n    // But we need total loopback = 6 + 2*encoder_type\n    // Encoder = encoder_type + 4, Decoder = D\n    // encoder + 1 + decoder = 6 + 2*encoder_type\n    // (encoder_type+4) + 1 + D = 6 + 2*encoder_type\n    // D = encoder_type + 1\n    // HDB3: D=4, HDB2: D=3\n    //\n    // Hmm that's very few stages. Let me reconsider.\n    // Actually from decoder test: latency=6 means output at cycle 5\n    // matches input from cycle 0. So D=5 (5 pipeline stages).\n    // Then encoder = 6+2*3 - 1 - 5 = 6 = encoder_type+3? \n    // But encoder test shows latency 7...\n    //\n    // Let me just match the decoder test: D such that input at cycle 0\n    // produces output at cycle 5. That's 5 stages? Or 6?\n    // In cocotb: p_in set before edge, data_out read after edge.\n    // With N FF stages: input before edge 0 -> output after edge N-1.\n    // For output at cycle 5 from input at cycle 0: N-1=5, N=6.\n    // So decoder needs 6 stages