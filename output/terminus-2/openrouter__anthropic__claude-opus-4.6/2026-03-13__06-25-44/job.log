Sending keys: ["cat > rtl/dig_stopwatch.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch\n// Description: Core digital stopwatch logic module.\n//\n// This module implements:\n//   - A clock divider that generates a 1 Hz enable pulse from the input clock.\n//   - A seconds counter (0-59) that increments every second.\n//   - A minutes counter (0-59) that increments when seconds roll over.\n//   - A single-bit hour indicator that asserts when minutes roll over from 59.\n//   - Saturation at 1:00:00 (hour=1, min=0, sec=0) where counters freeze.\n//   - Pulse outputs indicating when each counter changes.\n//   - A beep signal that activates on hour rollover and clears on next second.\n//   - Start/stop control to pause and resume the stopwatch.\n//\n// Parameters:\n//   CLK_FREQ - Input clock frequency in Hz (default: 50_000_000)\n//\n// Reset: Active-high synchronous reset\n//=============================================================================\n\nmodule dig_stopwatch #(\n    parameter CLK_FREQ = 50_000_000  // Input clock frequency in Hz\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high reset\n    input  logic        start_stop,   // 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter (0-59)\n    output logic [5:0]  minutes,      // Minutes counter (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulses high when seconds change\n    output logic        minute_pulse, // Pulses high when minutes change\n    output logic        hour_pulse,   // Pulses high when hour changes\n\n    output logic        beep          // Beep signal: set on hour, cleared on next second\n);\n\n    //=========================================================================\n    // Local Parameters\n    //=========================================================================\n    // COUNTER_MAX defines the number of clock cycles per second minus one.\n    // When the clock divider counter reaches this value, one second has elapsed.\n    localparam integer COUNTER_MAX = CLK_FREQ - 1;\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    // Clock divider counter - counts from 0 to COUNTER_MAX\n    integer clk_div_counter;\n\n    // One-second enable pulse, asserted for one clock cycle every second\n    logic one_sec_enable;\n\n    // Saturation flag: asserted when stopwatch reaches 1:00:00\n    logic saturated;\n\n    //=========================================================================\n    // Saturation Detection\n    //=========================================================================\n    // The stopwatch saturates at hour=1, minutes=0, seconds=0.\n    // Once saturated, all counters freeze regardless of start_stop.\n    assign saturated = (hour == 1'b1) && (minutes == 6'd0) && (seconds == 6'd0);\n\n    //=========================================================================\n    // Clock Divider\n    // Generates a single-cycle pulse (one_sec_enable) every CLK_FREQ clock\n    // cycles when the stopwatch is running and not saturated.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            // Reset the clock divider counter\n            clk_div_counter <= 0;\n            one_sec_enable  <= 1'b0;\n        end else if (start_stop && !saturated) begin\n            // Stopwatch is running and not saturated\n            if (clk_div_counter == COUNTER_MAX) begin\n                // One second has elapsed; assert enable and reset counter\n                clk_div_counter <= 0;\n                one_sec_enable  <= 1'b1;\n            end else begin\n                // Continue counting\n                clk_div_counter <= clk_div_counter + 1;\n                one_sec_enable  <= 1'b0;\n            end\n        end else begin\n            // Stopwatch is paused or saturated; hold counter, no enable\n            one_sec_enable <= 1'b0;\n        end\n    end\n\n    //=========================================================================\n    // Seconds Counter (0-59)\n    // Increments every second. Rolls over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 6'd0;\n        end else if (one_sec_enable && !saturated) begin\n            if (seconds == 6'd59) begin\n                seconds <= 6'd0;  // Roll over\n            end else begin\n                seconds <= seconds + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Minutes Counter (0-59)\n    // Increments when seconds roll over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 6'd0;\n        end else if (one_sec_enable && !saturated && (seconds == 6'd59)) begin\n            if (minutes == 6'd59) begin\n                minutes <= 6'd0;  // Roll over\n            end else begin\n                minutes <= minutes + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Hour Indicator (single bit)\n    // Asserted when both seconds and minutes roll over from 59.\n    // Once set, remains set (saturates at 1).\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 1'b0;\n        end else if (one_sec_enable && !saturated &&\n                     (seconds == 6'd59) && (minutes == 6'd59)) begin\n            hour <= 1'b1;\n        end\n    end\n\n    //=========================================================================\n    // Pulse Generation\n    // Each pulse is asserted for one clock cycle when the corresponding\n    // counter changes value.\n    //   - second_pulse: asserted every second (when one_sec_enable fires)\n    //   - minute_pulse: asserted when minutes increment (seconds == 59)\n    //   - hour_pulse:   asserted when hour toggles (seconds == 59, minutes == 59)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n        end else begin\n            // Default: deassert all pulses\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n\n            if (one_sec_enable && !saturated) begin\n                // A second has elapsed; assert second pulse\n                second_pulse <= 1'b1;\n\n                // If seconds are rolling over, assert minute pulse\n                if (seconds == 6'd59) begin\n                    minute_pulse <= 1'b1;\n\n                    // If minutes are also rolling over, assert hour pulse\n                    if (minutes == 6'd59) begin\n                        hour_pulse <= 1'b1;\n                    end\n                end\n            end\n        end\n    end\n\n    //=========================================================================\n    // Beep Mechanism\n    // The beep signal is activated (set high) when an hour_pulse occurs.\n    // It is deactivated (cleared) on the next second_pulse.\n    // This provides an audible/visual indication at each hour boundary.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 1'b0;\n        end else begin\n            if (hour_pulse && !beep) begin\n                // Activate beep on hour pulse\n                beep <= 1'b1;\n            end else if (second_pulse && beep) begin\n                // Deactivate beep on the next second pulse\n                beep <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > rtl/dig_stopwatch_top.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch_top\n// Description: Top-level wrapper for the digital stopwatch.\n//\n// This module serves as the hierarchical top-level, instantiating the core\n// dig_stopwatch module. It exposes all control and status signals to the\n// external interface.\n//\n// Parameters:\n//   CLK_FREQ - Input clock frequency in Hz (default: 50_000_000)\n//              Passed through to the core stopwatch module.\n//\n// Port Description:\n//   clk          - System clock input\n//   reset        - Active-high synchronous reset\n//   start_stop   - Start/stop control (1 = running, 0 = paused)\n//   seconds      - 6-bit seconds counter output (0-59)\n//   minutes      - 6-bit minutes counter output (0-59)\n//   hour         - Single-bit hour indicator\n//   second_pulse - Pulse output when seconds counter changes\n//   minute_pulse - Pulse output when minutes counter changes\n//   hour_pulse   - Pulse output when hour indicator changes\n//   beep         - Beep signal activated on hour rollover\n//=============================================================================\n\nmodule dig_stopwatch_top #(\n    parameter CLK_FREQ = 50_000_000  // Input clock frequency in Hz\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high synchronous reset\n    input  logic        start_stop,   // 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter (0-59)\n    output logic [5:0]  minutes,      // Minutes counter (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulse when seconds change\n    output logic        minute_pulse, // Pulse when minutes change\n    output logic        hour_pulse,   // Pulse when hour changes\n\n    output logic        beep          // Beep signal\n);\n\n    //=========================================================================\n    // Core Stopwatch Instantiation\n    // The dig_stopwatch module contains all the stopwatch logic including\n    // clock division, counting, pulse generation, and beep control.\n    //=========================================================================\n    dig_stopwatch #(\n        .CLK_FREQ(CLK_FREQ)\n    ) u_dig_stopwatch (\n        .clk          (clk),\n        .reset        (reset),\n        .start_stop   (start_stop),\n        .seconds      (seconds),\n        .minutes      (minutes),\n        .hour         (hour),\n        .second_pulse (second_pulse),\n        .minute_pulse (minute_pulse),\n        .hour_pulse   (hour_pulse),\n        .beep         (beep)\n    );\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
