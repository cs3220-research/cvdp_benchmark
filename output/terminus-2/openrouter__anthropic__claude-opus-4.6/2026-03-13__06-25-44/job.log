Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'VEOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    // Pipeline stages:\n    // S1: input sync register\n    // S2: zero count + violation detect\n    // S3..S2+ET: shift register (ET = encoder_type deep) for balance insertion\n    // S3+ET: AMI pulse generation\n    // S4+ET: output gate register\n    // Total = ET + 4 stages\n    // HDB3: 3+4 = 7 stages\n    // HDB2: 2+4 = 6 stages\n\n    // ===== Stage 1: Input Sync =====\n    logic s1_data;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in)     s1_data <= 1'b0;\n        else if (clk_enable_in) s1_data <= data_in;\n    end\n\n    // ===== Stage 2: Zero Count + Violation Detection =====\n    logic s2_data;       // 1 = pulse (original 1 or V), 0 = zero\n    logic s2_is_viol;    // 1 = this pulse is a Violation\n    logic s2_need_bal;   // 1 = this violation group needs a Balance pulse\n\n    reg [3:0] zcount;          // consecutive zeros counter\n    reg [7:0] pulses_since_v;  // normal pulses since last violation\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s2_data        <= 1'b0;\n            s2_is_viol     <= 1'b0;\n            s2_need_bal    <= 1'b0;\n            zcount         <= 0;\n            pulses_since_v <= 0;\n        end else if (clk_enable_in) begin\n            if (s1_data) begin\n                // Input = 1: regular pulse\n                zcount         <= 0;\n                pulses_since_v <= pulses_since_v + 1;\n                s2_data        <= 1'b1;\n                s2_is_viol     <= 1'b0;\n                s2_need_bal    <= 1'b0;\n            end else if (zcount == encoder_type[3:0] - 1) begin\n                // Max consecutive zeros reached: insert Violation\n                zcount         <= 0;\n                s2_data        <= 1'b1;\n                s2_is_viol     <= 1'b1;\n                // Balance needed when pulses_since_v is even (0,2,4,...)\n                // Even count means V would have same polarity as previous V\n                // without B, causing DC imbalance\n                s2_need_bal    <= ~pulses_since_v[0];\n                pulses_since_v <= 0;\n            end else begin\n                // Input = 0: count it\n                zcount      <= zcount + 1;\n                s2_data     <= 1'b0;\n                s2_is_viol  <= 1'b0;\n                s2_need_bal <= 1'b0;\n            end\n        end\n    end\n\n    // ===== Stages 3..2+ET: Shift Register =====\n    // Delays data by encoder_type clocks.\n    // When a violation with balance enters, retroactively insert B\n    // at the first zero of the group (position encoder_type-2 in SR).\n    //\n    // SR layout: [0]=newest, [ET-1]=oldest (output)\n    // When V+bal enters at [0], the first zero of the ET-length group\n    // is at position [ET-2] (it entered ET-1 clocks ago).\n\n    logic [encoder_type-1:0] sr_d;  // data shift register\n    logic [encoder_type-1:0] sr_v;  // violation flag shift register\n\n    integer k;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_d <= '0;\n            sr_v <= '0;\n        end else if (clk_enable_in) begin\n            // Shift\n            sr_d[0] <= s2_data;\n            sr_v[0] <= s2_is_viol;\n            for (k = 1; k < encoder_type; k = k + 1) begin\n                sr_d[k] <= sr_d[k-1];\n                sr_v[k] <= sr_v[k-1];\n            end\n            // Balance insertion: overwrite first zero with B pulse\n            if (s2_is_viol && s2_need_bal) begin\n                sr_d[encoder_type-2] <= 1'b1;\n            end\n        end\n    end\n\n    wire sr_out_d = sr_d[encoder_type-1];\n    wire sr_out_v = sr_v[encoder_type-1];\n\n    // ===== Stage 3+ET: AMI Pulse Generation =====\n    // ami: 0 = next normal pulse is Positive, 1 = next is Negative\n    // Normal pulse (1 or B): follows AMI, toggles state\n    // Violation pulse: SAME polarity as previous pulse, no toggle\n    //   When ami=0: last pulse was N (or none), V should be N\n    //   When ami=1: last pulse was P, V should be P\n\n    logic ami;\n    logic s_p, s_n;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami <= 1'b0;\n            s_p <= ~pulse_active_state;\n            s_n <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (sr_out_d) begin\n                if (sr_out_v) begin\n                    // Violation: same as last pulse polarity\n                    if (ami) begin\n                        // Last was P -> V is P\n                        s_p <= pulse_active_state;\n                        s_n <= ~pulse_active_state;\n                    end else begin\n                        // Last was N (or initial) -> V is N\n                        s_p <= ~pulse_active_state;\n                        s_n <= pulse_active_state;\n                    end\n                    // Don't toggle ami\n                end else begin\n                    // Normal pulse: alternate\n                    if (!ami) begin\n                        s_p <= pulse_active_state;\n                        s_n <= ~pulse_active_state;\n                        ami <= 1'b1;\n                    end else begin\n                        s_p <= ~pulse_active_state;\n                        s_n <= pulse_active_state;\n                        ami <= 1'b0;\n                    end\n                end\n            end else begin\n                s_p <= ~pulse_active_state;\n                s_n <= ~pulse_active_state;\n            end\n        end\n    end\n\n    // ===== Stage 4+ET: Output Gate Register =====\n    logic g_p, g_n;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            g_p <= ~pulse_active_state;\n            g_n <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (output_gate_in) begin\n                g_p <= s_p;\n                g_n <= s_n;\n            end else begin\n                g_p <= ~pulse_active_state;\n                g_n <= ~pulse_active_state;\n            end\n        end\n    end\n\n    assign p_out = g_p;\n    assign n_out = g_n;\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > /code/rtl/hdbn_decoder.sv << 'VEOF'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    // Pipeline: 6 stages total (spec: input sync + 5-stage processing)\n    // But effective latency for the test is 5 cycles (input at edge N -> output at edge N+5)\n    // Actually we need: encoder(ET+4) + 1(loopback) + decoder(D) - 1 = 6 + 2*ET\n    // So D = 6 + 2*ET - ET - 4 = ET + 2\n    // For HDB3: D = 5, For HDB2: D = 4\n    // But decoder test uses latency=6 for both... Let me just use 5 stages for now.\n    //\n    // S1: Input sync + normalize\n    // S2: Pulse detect + polarity track + violation detect  \n    // S3: Shift register / pattern buffer (1 stage)\n    // S4: Data recovery (strip V and B) + error detect\n    // S5: Output register\n\n    // ===== Stage 1: Input Sync & Normalize =====\n    logic p1, n1;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p1 <= 1'b0;\n            n1 <= 1'b0;\n        end else if (clk_enable_in) begin\n            p1 <= pulse_active_state ? p_in : ~p_in;\n            n1 <= pulse_active_state ? n_in : ~n_in;\n        end\n    end\n\n    // ===== Stage 2: Pulse Analysis =====\n    logic s2_pulse;     // any pulse\n    logic s2_pos;       // 1=positive, 0=negative\n    logic s2_viol;      // violation detected (same polarity as previous)\n    logic s2_perr;      // simultaneous pulse error\n\n    logic last_pol;     // last pulse polarity\n    logic had_pulse;    // seen any pulse\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s2_pulse <= 0; s2_pos <= 0; s2_viol <= 0; s2_perr <= 0;\n            last_pol <= 0; had_pulse <= 0;\n        end else if (clk_enable_in) begin\n            s2_perr <= p1 & n1;\n            if (p1 & ~n1) begin\n                s2_pulse <= 1; s2_pos <= 1;\n                s2_viol  <= had_pulse & (last_pol == 1'b1);\n                last_pol <= 1; had_pulse <= 1;\n            end else if (n1 & ~p1) begin\n                s2_pulse <= 1; s2_pos <= 0;\n                s2_viol  <= had_pulse & (last_pol == 1'b0);\n                last_pol <= 0; had_pulse <= 1;\n            end else begin\n                s2_pulse <= 0; s2_pos <= 0; s2_viol <= 0;\n            end\n        end\n    end\n\n    // ===== Stages 3..3+ET-2: Shift Register for V/B Pattern =====\n    // Need encoder_type-1 delay stages so when V exits, B is at the entry.\n    // SR: [0]=newest, [ET-2]=oldest (output)\n    // When V is at [0], B (if present) is at [ET-2]\n    \n    localparam SR = encoder_type - 1; // number of SR stages\n    \n    logic [SR-1:0] sr_pulse;\n    logic [SR-1:0] sr_pos;\n    logic [SR-1:0] sr_viol;\n    logic [SR-1:0] sr_perr;\n\n    integer j;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_pulse <= '0; sr_pos <= '0; sr_viol <= '0; sr_perr <= '0;\n        end else if (clk_enable_in) begin\n            sr_pulse[0] <= s2_pulse;\n            sr_pos[0]   <= s2_pos;\n            sr_viol[0]  <= s2_viol;\n            sr_perr[0]  <= s2_perr;\n            for (j = 1; j < SR; j = j + 1) begin\n                sr_pulse[j] <= sr_pulse[j-1];\n                sr_pos[j]   <= sr_pos[j-1];\n                sr_viol[j]  <= sr_viol[j-1];\n                sr_perr[j]  <= sr_perr[j-1];\n            end\n        end\n    end\n\n    // Output of SR (oldest entry)\n    wire out_pulse = sr_pulse[SR-1];\n    wire out_pos   = sr_pos[SR-1];\n    wire out_viol  = sr_viol[SR-1];\n    wire out_perr  = sr_perr[SR-1];\n    \n    // Check if current newest entry is a violation -> oldest is its B pulse\n    wire newest_is_viol = s2_viol;\n    wire oldest_is_b    = newest_is_viol & out_pulse;\n\n    // ===== Stage 4+ET-2: Data Recovery + Error =====\n    // Strip violations (out_viol=1) and balance pulses (oldest_is_b=1)\n    // Remaining pulses are original data 1s\n    \n    logic s4_data;\n    logic s4_error;\n    \n    reg [3:0] dec_zcnt;  // zero counter for error detection\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s4_data  <= 0;\n            s4_error <= 0;\n            dec_zcnt <= 0;\n        end else if (clk_enable_in) begin\n            // Data recovery: pulse that is not V and not B\n            s4_data <= out_pulse & ~out_viol & ~oldest_is_b;\n            \n            // Zero count on encoded stream (before stripping)\n            if (out_pulse) begin\n                dec_zcnt <= 0;\n            end else begin\n                dec_zcnt <= dec_zcnt + 1;\n            end\n            \n            // Error: pulse error OR too many zeros\n            s4_error <= out_perr | ((!out_pulse) & (dec_zcnt >= encoder_type[3:0]));\n        end\n    end\n\n    // ===== Stage 5+ET-2: Output Register =====\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_out       <= 0;\n            code_error_out <= 0;\n        end else if (clk_enable_in) begin\n            data_out       <= s4_data;\n            code_error_out <= s4_error;\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
