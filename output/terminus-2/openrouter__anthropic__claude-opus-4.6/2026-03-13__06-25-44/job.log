Sending keys: ["cat > /code/rtl/jpeg_runlength_rzs.sv << 'ENDOFFILE'\nmodule jpeg_runlength_rzs (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire [3:0]  rlen_in,\n    input  wire [3:0]  size_in,\n    input  wire [11:0] amp_in,\n    input  wire        den_in,\n    input  wire        dc_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dc_out\n);\n\n    // FSM states\n    localparam S_IDLE = 2'd0;  // Normal pass-through\n    localparam S_HOLD = 2'd1;  // Holding a suppressed (15,0)\n    localparam S_EMIT = 2'd2;  // Emitting pending data after re-emitting held ZRL\n\n    reg [1:0] state;\n\n    // Held ZRL data\n    reg [3:0]  held_rlen;\n    reg [3:0]  held_size;\n    reg [11:0] held_amp;\n    reg        held_dc;\n\n    // Pending data (saved when we need to emit held ZRL first)\n    reg [3:0]  pend_rlen;\n    reg [3:0]  pend_size;\n    reg [11:0] pend_amp;\n    reg        pend_dc;\n\n    always @(posedge clk_in) begin\n        if (reset_in) begin\n            rlen_out  <= 4'd0;\n            size_out  <= 4'd0;\n            amp_out   <= 12'd0;\n            den_out   <= 1'b0;\n            dc_out    <= 1'b0;\n            state     <= S_IDLE;\n            held_rlen <= 4'd0;\n            held_size <= 4'd0;\n            held_amp  <= 12'd0;\n            held_dc   <= 1'b0;\n            pend_rlen <= 4'd0;\n            pend_size <= 4'd0;\n            pend_amp  <= 12'd0;\n            pend_dc   <= 1'b0;\n        end else if (enable_in) begin\n            case (state)\n                S_IDLE: begin\n                    if (den_in) begin\n                        if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                            // ZRL (15,0) detected - suppress it, go to HOLD\n                            state     <= S_HOLD;\n                            held_rlen <= rlen_in;\n                            held_size <= size_in;\n                            held_amp  <= amp_in;\n                            held_dc   <= dc_in;\n                            den_out   <= 1'b0;\n                        end else begin\n                            // Normal data - pass through\n                            rlen_out <= rlen_in;\n                            size_out <= size_in;\n                            amp_out  <= amp_in;\n                            den_out  <= 1'b1;\n                            dc_out   <= dc_in;\n                        end\n                    end else begin\n                        den_out <= 1'b0;\n                    end\n                end\n\n                S_HOLD: begin\n                    if (den_in) begin\n                        if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                            // Another ZRL - keep suppressing\n                            held_rlen <= rlen_in;\n                            held_size <= size_in;\n                            held_amp  <= amp_in;\n                            held_dc   <= dc_in;\n                            den_out   <= 1'b0;\n                        end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                            // EOB - discard held ZRL, pass EOB\n                            rlen_out <= rlen_in;\n                            size_out <= size_in;\n                            amp_out  <= amp_in;\n                            den_out  <= 1'b1;\n                            dc_out   <= dc_in;\n                            state    <= S_IDLE;\n                        end else begin\n                            // Non-ZRL, non-EOB: emit held ZRL now, save current for next cycle\n                            rlen_out  <= held_rlen;\n                            size_out  <= held_size;\n                            amp_out   <= held_amp;\n                            den_out   <= 1'b1;\n                            dc_out    <= held_dc;\n                            pend_rlen <= rlen_in;\n                            pend_size <= size_in;\n                            pend_amp  <= amp_in;\n                            pend_dc   <= dc_in;\n                            state     <= S_EMIT;\n                        end\n                    end else begin\n                        den_out <= 1'b0;\n                    end\n                end\n\n                S_EMIT: begin\n                    // Emit the pending data\n                    rlen_out <= pend_rlen;\n                    size_out <= pend_size;\n                    amp_out  <= pend_amp;\n                    den_out  <= 1'b1;\n                    dc_out   <= pend_dc;\n                    state    <= S_IDLE;\n                end\n\n                default: begin\n                    state   <= S_IDLE;\n                    den_out <= 1'b0;\n                end\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
