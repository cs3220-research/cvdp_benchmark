a0_in  (ram_data0_in),\n        .wr0_in    (ram_wr0),\n        .addr1_in  (ram_addr1),\n        .data1_in  (32'd0),\n        .wr1_in    (1'b0),\n        .data0_out (ram_data0_out),\n        .data1_out (ram_data1_out)\n    );\n\n    // -------------------------------------------------------\n    // Address decode\n    // -------------------------------------------------------\n    wire [15:0] cfg_addr_low = cfg_addr_in[15:0];\n    wire        cfg_is_tx_len  = (cfg_addr_low == 16'h07F4);\n    wire        cfg_is_irq_en  = (cfg_addr_low == 16'h07F8);\n    wire        cfg_is_tx_ctl  = (cfg_addr_low == 16'h07FC);\n    wire        cfg_is_ram     = !cfg_is_tx_len && !cfg_is_irq_en && !cfg_is_tx_ctl;\n\n    // -------------------------------------------------------\n    // Config register writes\n    // -------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            tx_length_reg  <= 32'd0;\n            irq_enable_reg <= 32'd0;\n        end else begin\n            if (cfg_wr_in && cfg_is_tx_len)\n                tx_length_reg <= cfg_data_wr_in;\n            if (cfg_wr_in && cfg_is_irq_en)\n                irq_enable_reg <= cfg_data_wr_in;\n        end\n    end\n\n    // -------------------------------------------------------\n    // RAM port 0 - config interface\n    // -------------------------------------------------------\n    always @(*) begin\n        ram_addr0    = cfg_addr_in[ADDR_W+1:2];\n        ram_data0_in = cfg_data_wr_in;\n        ram_wr0      = cfg_wr_in && cfg_is_ram;\n    end\n\n    // -------------------------------------------------------\n    // Config read\n    // -------------------------------------------------------\n    reg [31:0] cfg_rd_data;\n    always @(*) begin\n        case (cfg_addr_low)\n            16'h07F4: cfg_rd_data = tx_length_reg;\n            16'h07F8: cfg_rd_data = irq_enable_reg;\n            16'h07FC: cfg_rd_data = tx_control_reg;\n            default:  cfg_rd_data = ram_data0_out;\n        endcase\n    end\n    assign cfg_data_rd_out = cfg_rd_data;\n\n    // -------------------------------------------------------\n    // TX Control Register\n    // -------------------------------------------------------\n    reg fsm_clear_busy;\n    reg fsm_clear_program;\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            tx_control_reg <= 32'd0;\n        end else begin\n            if (cfg_wr_in && cfg_is_tx_ctl)\n                tx_control_reg <= cfg_data_wr_in;\n            else begin\n                if (fsm_clear_busy)\n                    tx_control_reg[0] <= 1'b0;\n                if (fsm_clear_program)\n                    tx_control_reg[1] <= 1'b0;\n            end\n        end\n    end\n\n    wire tx_busy    = tx_control_reg[0];\n    wire tx_program = tx_control_reg[1];\n\n    // -------------------------------------------------------\n    // Effective transmit length (min 64 bytes)\n    // -------------------------------------------------------\n    wire [15:0] effective_length = (tx_length_reg[15:0] < 16'd64) ? 16'd64 : tx_length_reg[15:0];\n\n    // -------------------------------------------------------\n    // Transmit FSM\n    // -------------------------------------------------------\n    reg [1:0]  state;\n    reg [15:0] bytes_remaining;\n    reg [ADDR_W-1:0] tx_word_addr;\n    reg        tx_valid_r;\n    reg [31:0] tx_data_r;\n    reg [3:0]  tx_strb_r;\n    reg        tx_last_r;\n    reg        irq_r;\n    reg        read_pending;  // RAM read in flight\n\n    assign axis_tvalid_out = tx_valid_r;\n    assign axis_tdata_out  = tx_data_r;\n    assign axis_tstrb_out  = tx_strb_r;\n    assign axis_tlast_out  = tx_last_r;\n    assign interrupt_out   = irq_r;\n\n    // Byte strobe computation\n    function [3:0] calc_strb;\n        input [15:0] rem;\n        begin\n            if (rem >= 16'd4)\n                calc_strb = 4'b1111;\n            else begin\n                case (rem[1:0])\n                    2'd0: calc_strb = 4'b1111;\n                    2'd1: calc_strb = 4'b0001;\n                    2'd2: calc_strb = 4'b0011;\n                    2'd3: calc_strb = 4'b0111;\n                endcase\n            end\n        end\n    endfunction\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state           <= S_IDLE;\n            tx_valid_r      <= 1'b0;\n            tx_data_r       <= 32'd0;\n            tx_strb_r       <= 4'd0;\n            tx_last_r       <= 1'b0;\n            irq_r           <= 1'b0;\n            bytes_remaining <= 16'd0;\n            tx_word_addr    <= {ADDR_W{1'b0}};\n            ram_addr1       <= {ADDR_W{1'b0}};\n            read_pending    <= 1'b0;\n            fsm_clear_busy    <= 1'b0;\n            fsm_clear_program <= 1'b0;\n        end else begin\n            // Defaults\n            irq_r            <= 1'b0;\n            fsm_clear_busy   <= 1'b0;\n            fsm_clear_program <= 1'b0;\n\n            case (state)\n                // =============================================\n                // IDLE: Wait for BUSY bit\n                // =============================================\n                S_IDLE: begin\n                    tx_valid_r <= 1'b0;\n                    tx_last_r  <= 1'b0;\n                    tx_data_r  <= 32'd0;\n                    tx_strb_r  <= 4'd0;\n                    read_pending <= 1'b0;\n\n                    if (tx_busy) begin\n                        if (tx_program) begin\n                            // MAC Program mode\n                            irq_r <= irq_enable_reg[0];\n                            fsm_clear_busy    <= 1'b1;\n                            fsm_clear_program <= 1'b1;\n                            state <= S_END;\n                        end else begin\n                            // Normal TX: setup first read\n                            bytes_remaining <= effective_length;\n                            tx_word_addr    <= {ADDR_W{1'b0}};\n                            ram_addr1       <= {ADDR_W{1'b0}};\n                            read_pending    <= 1'b1;\n                            state           <= S_TRANSMIT;\n                        end\n                    end\n                end\n\n                // =============================================\n                // TRANSMIT: Pipeline - read RAM, output data\n                // =============================================\n                S_TRANSMIT: begin\n                    if (read_pending) begin\n                        // Data will be available next cycle\n                        // Advance address for next word\n                        ram_addr1    <= ram_addr1 + 1'b1;\n                        tx_word_addr <= tx_word_addr + 1'b1;\n                        read_pending <= 1'b0;\n                    end else begin\n                        // RAM data is now valid for current word\n                        tx_valid_r <= 1'b1;\n                        \n                        if (bytes_remaining <= 16'd4) begin\n                            // Last word\n                            tx_data_r  <= ram_data1_out;\n                            tx_strb_r  <= calc_strb(bytes_remaining);\n                            tx_last_r  <= 1'b1;\n                            bytes_remaining <= 16'd0;\n                            state <= S_UPDATE;\n                        end else begin\n                            tx_data_r  <= ram_data1_out;\n                            tx_strb_r  <= 4'b1111;\n                            tx_last_r  <= 1'b0;\n                            bytes_remaining <= bytes_remaining - 16'd4;\n                            // Setup next read (pipeline: address now, data next cycle)\n                            ram_addr1    <= ram_addr1 + 1'b1;\n                            tx_word_addr <= tx_word_addr + 1'b1;\n                        end\n                    end\n                end\n\n                // =============================================\n                // UPDATE: Transition to END\n                // =============================================\n                S_UPDATE: begin\n                    tx_valid_r <= 1'b0;\n                    tx_last_r  <= 1'b0;\n                    tx_data_r  <= 32'd0;\n                    tx_strb_r  <= 4'd0;\n                    irq_r      <= irq_enable_reg[0];\n                    fsm_clear_busy    <= 1'b1;\n                    fsm_clear_program <= 1'b1;\n                    state      <= S_END;\n                end\n\n                // =============================================\n                // END: Return to IDLE\n                // =============================================\n                S_END: begin\n                    tx_valid_r <= 1'b0;\n                    tx_last_r  <= 1'b0;\n                    tx_data_r  <= 32'd0;\n                    tx_strb_r  <= 4'd0;\n                    state      <= S_IDLE;\n                end\n\n                default: state <= S_IDLE;\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
