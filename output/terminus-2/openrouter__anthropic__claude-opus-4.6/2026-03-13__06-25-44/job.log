Sending keys: ["cat > /code/rtl/jpeg_runlength_stage1.sv << 'ENDOFFILE'\nmodule jpeg_runlength_stage1 (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire        go_in,\n    input  wire [11:0] din_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dcterm_out\n);\n\n    // Internal state\n    reg [5:0] sample_cnt;\n    reg [3:0] zero_run;\n    reg       block_active;\n\n    // Size calculation function: ceil(log2(abs_val + 1))\n    function automatic [3:0] calc_size;\n        input [11:0] val;\n        reg [11:0] abs_val;\n        begin\n            if (val[11])\n                abs_val = (~val) + 1'b1;\n            else\n                abs_val = val;\n\n            if (abs_val == 0)          calc_size = 4'd0;\n            else if (abs_val <= 1)     calc_size = 4'd1;\n            else if (abs_val <= 3)     calc_size = 4'd2;\n            else if (abs_val <= 7)     calc_size = 4'd3;\n            else if (abs_val <= 15)    calc_size = 4'd4;\n            else if (abs_val <= 31)    calc_size = 4'd5;\n            else if (abs_val <= 63)    calc_size = 4'd6;\n            else if (abs_val <= 127)   calc_size = 4'd7;\n            else if (abs_val <= 255)   calc_size = 4'd8;\n            else if (abs_val <= 511)   calc_size = 4'd9;\n            else if (abs_val <= 1023)  calc_size = 4'd10;\n            else                       calc_size = 4'd11;\n        end\n    endfunction\n\n    // Next-state signals\n    reg [5:0] sample_cnt_nxt;\n    reg [3:0] zero_run_nxt;\n    reg       block_active_nxt;\n    reg [3:0] rlen_nxt;\n    reg [3:0] size_nxt;\n    reg [11:0] amp_nxt;\n    reg       den_nxt;\n    reg       dcterm_nxt;\n\n    // Combinational next-state and output logic\n    always @(*) begin\n        // Defaults: maintain state, no output\n        sample_cnt_nxt   = sample_cnt;\n        zero_run_nxt     = zero_run;\n        block_active_nxt = block_active;\n        rlen_nxt         = 4'd0;\n        size_nxt         = 4'd0;\n        amp_nxt          = 12'd0;\n        den_nxt          = 1'b0;\n        dcterm_nxt       = 1'b0;\n\n        if (go_in) begin\n            // DC coefficient\n            block_active_nxt = 1'b1;\n            sample_cnt_nxt   = 6'd1;\n            zero_run_nxt     = 4'd0;\n            rlen_nxt         = 4'd0;\n            size_nxt         = calc_size(din_in);\n            amp_nxt          = din_in;\n            den_nxt          = 1'b1;\n            dcterm_nxt       = 1'b1;\n        end else if (block_active) begin\n            if (din_in == 12'd0) begin\n                if (sample_cnt == 6'd63) begin\n                    // Last sample, zero - emit EOB\n                    rlen_nxt         = 4'd0;\n                    size_nxt         = 4'd0;\n                    amp_nxt          = 12'd0;\n                    den_nxt          = 1'b1;\n                    dcterm_nxt       = 1'b0;\n                    zero_run_nxt     = 4'd0;\n                    block_active_nxt = 1'b0;\n                end else if (zero_run == 4'd15) begin\n                    // ZRL marker\n                    rlen_nxt     = 4'd15;\n                    size_nxt     = 4'd0;\n                    amp_nxt      = 12'd0;\n                    den_nxt      = 1'b1;\n                    dcterm_nxt   = 1'b0;\n                    zero_run_nxt = 4'd0;\n                end else begin\n                    zero_run_nxt = zero_run + 4'd1;\n                end\n                sample_cnt_nxt = sample_cnt + 6'd1;\n            end else begin\n                // Non-zero\n                rlen_nxt     = zero_run;\n                size_nxt     = calc_size(din_in);\n                amp_nxt      = din_in;\n                den_nxt      = 1'b1;\n                dcterm_nxt   = 1'b0;\n                zero_run_nxt = 4'd0;\n                if (sample_cnt == 6'd63)\n                    block_active_nxt