============================================\n    localparam integer COUNTER_MAX = CLK_FREQ - 1;\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    reg [31:0] clk_div_counter;  // Clock divider counter (0 to COUNTER_MAX)\n    logic      one_sec_enable;   // Registered 1-cycle pulse every second\n    logic      saturated;        // High when stopwatch has reached 1:00:00\n\n    // Effective tick: gated by start_stop and saturation to ensure\n    // counters only update when the stopwatch is actively running.\n    logic      tick;\n    assign tick = one_sec_enable && start_stop && !saturated;\n\n    //=========================================================================\n    // Saturation Detection\n    //=========================================================================\n    assign saturated = (hour == 1'b1) && (minutes == 6'd0) && (seconds == 6'd0);\n\n    //=========================================================================\n    // Clock Divider & One-Second Enable Generation\n    //\n    // Counter counts from 0 to COUNTER_MAX. Enable is asserted one cycle\n    // early (at COUNTER_MAX-1) so it is visible to downstream FFs on the\n    // clock edge where the counter reaches COUNTER_MAX.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            clk_div_counter <= 32'd0;\n            one_sec_enable  <= 1'b0;\n        end else if (start_stop && !saturated) begin\n            if (clk_div_counter >= COUNTER_MAX) begin\n                clk_div_counter <= 32'd0;\n                one_sec_enable  <= 1'b0;\n            end else begin\n                clk_div_counter <= clk_div_counter + 32'd1;\n                if (clk_div_counter == (COUNTER_MAX - 1))\n                    one_sec_enable <= 1'b1;\n                else\n                    one_sec_enable <= 1'b0;\n            end\n        end else begin\n            one_sec_enable <= 1'b0;\n        end\n    end\n\n    //=========================================================================\n    // Seconds Counter (0-59)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 6'd0;\n        end else if (tick) begin\n            if (seconds == 6'd59)\n                seconds <= 6'd0;\n            else\n                seconds <= seconds + 6'd1;\n        end\n    end\n\n    //=========================================================================\n    // Minutes Counter (0-59)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 6'd0;\n        end else if (tick && (seconds == 6'd59)) begin\n            if (minutes == 6'd59)\n                minutes <= 6'd0;\n            else\n                minutes <= minutes + 6'd1;\n        end\n    end\n\n    //=========================================================================\n    // Hour Indicator (single bit, saturates at 1)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 1'b0;\n        end else if (tick && (seconds == 6'd59) && (minutes == 6'd59)) begin\n            hour <= 1'b1;\n        end\n    end\n\n    //=========================================================================\n    // Pulse Generation\n    // Pulses are asserted on the SAME clock edge as the counter updates.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n        end else begin\n            second_pulse <= tick;\n            minute_pulse <= tick && (seconds == 6'd59);\n            hour_pulse   <= tick && (seconds == 6'd59) && (minutes == 6'd59);\n        end\n    end\n\n    //=========================================================================\n    // Beep Mechanism\n    // Activated on hour_pulse, deactivated on the next second_pulse.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 1'b0;\n        end else begin\n            if (hour_pulse && !beep)\n                beep <= 1'b1;\n            else if (second_pulse && beep)\n                beep <= 1'b0;\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
