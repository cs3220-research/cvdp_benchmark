Sending keys: ["cat > /code/rtl/nmea_decoder.sv << 'VERILOG_EOF'\nmodule nmea_decoder (\n    input wire clk,\n    input wire reset,\n    input wire [7:0] serial_in,\n    input wire serial_valid,\n    input wire watchdog_timeout_en,\n    output reg [15:0] data_out,\n    output reg data_valid,\n    output reg [15:0] data_out_bin,\n    output reg data_bin_valid,\n    output reg error_overflow,\n    output reg valid_sentence,\n    output reg watchdog_timeout\n);\n\n    // FSM States\n    localparam STATE_IDLE   = 2'b00,\n               STATE_PARSE  = 2'b01,\n               STATE_OUTPUT = 2'b10;\n\n    // Configuration\n    localparam MAX_BUFFER_SIZE = 80;\n    localparam WATCHDOG_LIMIT  = 2048;\n\n    integer i;\n\n    // Internal registers\n    reg [7:0] buffer [0:MAX_BUFFER_SIZE-1];\n    reg [6:0] buffer_index;\n    reg [6:0] next_buffer_index;\n    reg [1:0] state, next_state;\n    reg [11:0] watchdog_counter;\n    reg [6:0] comma_count;\n    reg [6:0] field_index;\n\n    // Overflow detection signals\n    reg overflow_detected;\n    reg next_overflow;\n\n    // Character identifiers\n    wire is_start = (serial_in == 8'h24);  // '$'\n    wire is_comma = (serial_in == 8'h2C);  // ','\n    wire is_end   = (serial_in == 8'h0D);  // '\\r'\n\n    // Function to check if a character is a digit ('0'-'9')\n    function is_digit;\n        input [7:0] ch;\n        begin\n            is_digit = (ch >= 8'h30 && ch <= 8'h39);\n        end\n    endfunction\n\n    // Sequential logic for state, buffer_index, and registered outputs\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            data_out_bin <= 16'b0;\n            data_bin_valid <= 0;\n            error_overflow <= 0;\n            valid_sentence <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n        end else begin\n            state <= next_state;\n            buffer_index <= next_buffer_index;\n\n            //