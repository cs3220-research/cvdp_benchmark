Sending keys: ["cat > /code/rtl/dynamic_equalizer.sv << 'ENDOFFILE'\nmodule dynamic_equalizer #(\n    parameter TAP_NUM     = 7,\n    parameter DATA_WIDTH  = 16,\n    parameter COEFF_WIDTH = 16,\n    parameter MU          = 15\n) (\n    input  logic                              clk,\n    input  logic                              rst_n,\n    input  logic signed [DATA_WIDTH-1:0]      data_in_real,\n    input  logic signed [DATA_WIDTH-1:0]      data_in_imag,\n    input  logic signed [DATA_WIDTH-1:0]      desired_real,\n    input  logic signed [DATA_WIDTH-1:0]      desired_imag,\n    output logic signed [DATA_WIDTH-1:0]      data_out_real,\n    output logic signed [DATA_WIDTH-1:0]      data_out_imag\n);\n\n    localparam FRAC_BITS = DATA_WIDTH - 3;\n    localparam CENTER_TAP = TAP_NUM / 2;\n\n    // Shift register for input sample history\n    logic signed [DATA_WIDTH-1:0] shift_reg_real [0:TAP_NUM-1];\n    logic signed [DATA_WIDTH-1:0] shift_reg_imag [0:TAP_NUM-1];\n\n    // Coefficient arrays\n    logic signed [COEFF_WIDTH-1:0] coeff_real [0:TAP_NUM-1];\n    logic signed [COEFF_WIDTH-1:0] coeff_imag [0:TAP_NUM-1];\n\n    // Error signals\n    logic signed [DATA_WIDTH-1:0] error_real;\n    logic signed [DATA_WIDTH-1:0] error_imag;\n\n    // FIR output (combinational)\n    logic signed [DATA_WIDTH-1:0] fir_out_real;\n    logic signed [DATA_WIDTH-1:0] fir_out_imag;\n\n    // Desired signal delay line - match output latency\n    // Output latency = CENTER_TAP + 1 (shift reg) + 1 (output reg) = CENTER_TAP + 2\n    // Desired delay = same = CENTER_TAP + 2\n    localparam DESIRED_DELAY = CENTER_TAP + 2; // 5\n    logic signed [DATA_WIDTH-1:0] desired_real_pipe [0:DESIRED_DELAY-1];\n    logic signed [DATA_WIDTH-1:0] desired_imag_pipe [0:DESIRED_DELAY-1];\n\n    // =========================================================================\n    // Shift Register\n    // =========================================================================\n    integer i;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= '0;\n                shift_reg_imag[i] <= '0;\n            end\n        end else begin\n            shift_reg_real[0] <= data_in_real;\n            shift_reg_imag[0] <= data_in_imag;\n            for (i = 1; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= shift_reg_real[i-1];\n                shift_reg_imag[i] <= shift_reg_imag[i-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // Desired signal delay pipeline\n    // =========================================================================\n    integer d;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (d = 0; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= '0;\n                desired_imag_pipe[d] <= '0;\n            end\n        end else begin\n            desired_real_pipe[0] <= desired_real;\n            desired_imag_pipe[0] <= desired_imag;\n            for (d = 1; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= desired_real_pipe[d-1];\n                desired_imag_pipe[d] <= desired_imag_pipe[d-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // FIR Filter - Combinational\n    // =========================================================================\n    logic signed [2*DATA_WIDTH-1:0] acc_real;\n    logic signed [2*DATA_WIDTH-1:0] acc_imag;\n\n    integer j;\n    always_comb begin\n        acc_real = '0;\n        acc_imag = '0;\n        for (j = 0; j < TAP_NUM; j = j + 1) begin\n            acc_real = acc_real + coeff_real[j] * shift_reg_real[j] - coeff_imag[j] * shift_reg_imag[j];\n            acc_imag = acc_imag + coeff_real[j] * shift_reg_imag[j] + coeff_imag[j] * shift_reg_real[j];\n        end\n        fir_out_real = acc_real[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n        fir_out_imag = acc_imag[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n    end\n\n    // =========================================================================\n    // Output Register\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            data_out_real <= '0;\n            data_out_imag <= '0;\n        end else begin\n            data_out_real <= fir_out_real;\n            data_out_imag <= fir_out_imag;\n        end\n    end\n\n    // =========================================================================\n    // Error Calculation (combinational from registered output)\n    // =========================================================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (data_out_real),\n        .data_imag    (data_out_imag),\n        .desired_real (desired_real_pipe[DESIRED_DELAY-1]),\n        .desired_imag (desired_imag_pipe[DESIRED_DELAY-1]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================================================\n    // Coefficient Update\n    // =========================================================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_reg_real),\n        .data_imag  (shift_reg_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
