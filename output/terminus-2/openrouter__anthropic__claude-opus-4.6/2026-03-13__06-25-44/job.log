Sending keys: ["cat > rtl/poly_decimator.sv << 'ENDOFFILE'\nmodule poly_decimator #(\n  parameter M           = 4,\n  parameter TAPS        = 8,\n  parameter COEFF_WIDTH = 16,\n  parameter DATA_WIDTH  = 16,\n  localparam ACC_WIDTH   = DATA_WIDTH + COEFF_WIDTH + $clog2(TAPS),\n  localparam TOTAL_TAPS  = M * TAPS\n)\n(\n  input  logic                              clk,\n  input  logic                              arst_n,\n  input  logic [DATA_WIDTH-1:0]             in_sample,\n  input  logic                              in_valid,\n  output logic                              in_ready,\n  output logic [ACC_WIDTH+$clog2(M)-1:0]    out_sample,\n  output logic                              out_valid\n);\n\n  // -------------------------------------------------------\n  // FSM States\n  // -------------------------------------------------------\n  typedef enum logic [0:0] {\n    ACCUMULATE = 1'b0,\n    OUTPUT     = 1'b1\n  } state_t;\n\n  state_t state, next_state;\n\n  // -------------------------------------------------------\n  // Sample counter: counts M input samples\n  // -------------------------------------------------------\n  logic [$clog2(M):0] sample_cnt;\n\n  // -------------------------------------------------------\n  // Shift Register Instance\n  // -------------------------------------------------------\n  logic [DATA_WIDTH-1:0] shift_data [0:TOTAL_TAPS-1];\n  logic                  shift_data_val;\n\n  shift_register #(\n    .TAPS      (TOTAL_TAPS),\n    .DATA_WIDTH(DATA_WIDTH)\n  ) u_shift_reg_decim (\n    .clk        (clk),\n    .arst_n     (arst_n),\n    .load       (in_valid && in_ready),\n    .new_sample (in_sample),\n    .data_out   (shift_data),\n    .data_out_val(shift_data_val)\n  );\n\n  // -------------------------------------------------------\n  // Polyphase Branch Signals\n  // -------------------------------------------------------\n  logic [ACC_WIDTH-1:0] branch_out   [0:M-1];\n  logic                 branch_valid [0:M-1];\n\n  // -------------------------------------------------------\n  // Trigger filtering when M samples collected\n  // -------------------------------------------------------\n  logic filter_start;\n\n  // -------------------------------------------------------\n  // Generate M poly_filter branches\n  // -------------------------------------------------------\n  genvar gi;\n  generate\n    for (gi = 0; gi < M; gi = gi + 1) begin : poly_branch\n      // Extract TAPS samples with stride M starting at offset gi\n      logic [DATA_WIDTH-1:0] branch_samples [0:TAPS-1];\n      for (genvar t = 0; t < TAPS; t = t + 1) begin : sample_extract\n        assign branch_samples[t] = shift_data[gi + t * M];\n      end\n\n      poly_filter #(\n        .M          (M),\n        .TAPS       (TAPS),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .DATA_WIDTH (DATA_WIDTH)\n      ) u_poly_filter (\n        .clk           (clk),\n        .arst_n        (arst_n),\n        .sample_buffer (branch_samples),\n        .valid_in      (filter_start),\n        .phase         (gi[$clog2(M)-1:0]),\n        .filter_out    (branch_out[gi]),\n        .valid         (branch_valid[gi])\n      );\n    end\n  endgenerate\n\n  // -------------------------------------------------------\n  // Check all branches valid\n  // -------------------------------------------------------\n  logic all_branches_valid;\n  always_comb begin\n    all_branches_valid = 1'b1;\n    for (int b = 0; b < M; b = b + 1) begin\n      all_branches_valid = all_branches_valid & branch_valid[b];\n    end\n  end\n\n  // -------------------------------------------------------\n  // Adder Tree: Sum the M branch outputs\n  // -------------------------------------------------------\n  logic [ACC_WIDTH+$clog2(M)-1:0] tree_sum;\n  logic                           tree_valid;\n\n  adder_tree #(\n    .NUM_INPUTS(M),\n    .DATA_WIDTH(ACC_WIDTH)\n  ) u_adder_tree (\n    .clk      (clk),\n    .arst_n   (arst_n),\n    .valid_in (all_branches_valid),\n    .data_in  (branch_out),\n    .sum_out  (tree_sum),\n    .valid_out(tree_valid)\n  );\n\n  // -------------------------------------------------------\n  // FSM: State Register\n  // -------------------------------------------------------\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n)\n      state <= ACCUMULATE;\n    else\n      state <= next_state;\n  end\n\n  // -------------------------------------------------------\n  // FSM: Next State Logic\n  // -------------------------------------------------------\n  always_comb begin\n    next_state = state;\n    case (state)\n      ACCUMULATE: begin\n        if (in_valid && in_ready && (sample_cnt == M - 1))\n          next_state = OUTPUT;\n      end\n      OUTPUT: begin\n        if (tree_valid)\n          next_state = ACCUMULATE;\n      end\n    endcase\n  end\n\n  // -------------------------------------------------------\n  // Sample Counter\n  // -------------------------------------------------------\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n) begin\n      sample_cnt <= '0;\n    end\n    else begin\n      case (state)\n        ACCUMULATE: begin\n          if (in_valid && in_ready) begin\n            if (sample_cnt == M - 1)\n              sample_cnt <= '0;\n            else\n              sample_cnt <= sample_cnt + 1;\n          end\n        end\n        OUTPUT: begin\n          if (tree_valid)\n            sample_cnt <= '0;\n        end\n      endcase\n    end\n  end\n\n  // -------------------------------------------------------\n  // Filter Start Signal\n  // -------------------------------------------------------\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n)\n      filter_start <= 1'b0;\n    else if (state == ACCUMULATE && in_valid && in_ready && (sample_cnt == M - 1))\n      filter_start <= 1'b1;\n    else\n      filter_start <= 1'b0;\n  end\n\n  // -------------------------------------------------------\n  // in_ready: Accept samples only during ACCUMULATE\n  // -------------------------------------------------------\n  assign in_ready = (state == ACCUMULATE);\n\n  // -------------------------------------------------------\n  // Output Registration\n  // -------------------------------------------------------\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n) begin\n      out_sample <= '0;\n      out_valid  <= 1'b0;\n    end\n    else begin\n      if (tree_valid) begin\n        out_sample <= tree_sum;\n        out_valid  <= 1'b1;\n      end\n      else begin\n        out_valid <= 1'b0;\n      end\n    end\n  end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
