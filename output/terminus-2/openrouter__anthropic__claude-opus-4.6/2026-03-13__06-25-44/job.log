iolation <= 1'b0;\n        end else if (clk_enable_in) begin\n            if (data_reg == 1'b1) begin\n                // Normal '1' bit\n                zero_count <= 0;\n                violation_count <= violation_count + 1;\n                sub_data <= 1'b1;\n                sub_violation <= 1'b0;\n            end else begin\n                // Zero bit\n                if (zero_count == encoder_type - 1) begin\n                    // This is the Nth consecutive zero - insert violation\n                    zero_count <= 0;\n                    violation_count <= 0;\n                    sub_data <= 1'b1;      // V pulse (will be encoded as a pulse)\n                    sub_violation <= 1'b1;  // Mark as violation\n                end else begin\n                    zero_count <= zero_count + 1;\n                    sub_data <= 1'b0;\n                    sub_violation <= 1'b0;\n                end\n            end\n        end\n    end\n    \n    // Stage 3-4: Shift registers to create pipeline delay\n    // We need encoder_type stages of delay for the balance pulse insertion\n    // The balance pulse goes at position [encoder_type-1] in the shift register\n    // (i.e., encoder_type-1 positions before the violation)\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_sr <= '0;\n            viol_sr <= '0;\n        end else if (clk_enable_in) begin\n            data_sr <= {data_sr[encoder_type-1:0], sub_data};\n            viol_sr <= {viol_sr[encoder_type-1:0], sub_violation};\n        end\n    end\n    \n    // Balance pulse insertion logic\n    // When a violation comes out of the shift register (viol_sr[encoder_type]),\n    // we need to check if a balance pulse is needed\n    // For HDB3: B is at position [encoder_type] when violation is at [0]\n    // Actually, let me reconsider the pipeline architecture...\n    \n    // The output data from shift register\n    logic sr_data_out;\n    logic sr_viol_out;\n    \n    assign sr_data_out = data_sr[encoder_type];\n    assign sr_viol_out = viol_sr[encoder_type];\n    \n    // Balance pulse tracking\n    // When violation_count (at time of violation) is even, we need B00V (HDB3) or B0V (HDB2)\n    // The B pulse needs to be inserted at the beginning of the zero sequence\n    // We track this with a separate mechanism\n    \n    // Let me redesign with a cleaner approach using a FIFO-like pipeline\n    \n    // Stage 5: AMI encoding and output generation  \n    logic final_data;\n    logic final_viol;\n    logic need_balance;\n    \n    // Track balance need per violation\n    logic [encoder_type:0] balance_sr;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            balance_sr <= '0;\n        end else if (clk_enable_in) begin\n            // When we detect a violation is being inserted, check if balance is needed\n            if (sub_violation) begin\n                // violation_count was just set to 0, but we need the value BEFORE reset\n                // Even violation_count means we need balance\n                balance_sr <= {balance_sr[encoder_type-1:0], (violation_count[0] == 1'b0) ? 1'b1 : 1'b0};\n            end else begin\n                balance_sr <= {balance_sr[encoder_type-1:0], 1'b0};\n            end\n        end\n    end\n    \n    // The balance pulse should appear at the START of the zero sequence\n    // which is encoder_type positions before the violation\n    // Since the violation is at sr position [encoder_type], the balance\n    // info at balance_sr[encoder_type] tells us if the CURRENT violation needs balance\n    // But we need to insert B at the first zero, which was encoder_type-1 clocks ago\n    \n    // This approach is getting complex. Let me use a cleaner design.\n    \n    // REDESIGN: Use a simpler staged pipeline\n    \n    // Actually, let me think about this more carefully with proper pipeline stages\n    // and implement it cleanly.\n    \n    // For now, let me use a combined approach\n    logic out_data;  // final data to AMI encode\n    logic out_viol;  // final violation flag\n    \n    assign out_data = sr_data_out | (balance_sr[encoder_type] & (data_sr[encoder_type] == 1'b0));\n    assign out_viol = sr_viol_out;\n    \n    // AMI encoding with violation handling\n    // Normal pulse: alternate polarity\n    // Violation pulse: SAME polarity as last pulse (that's what makes it a violation)\n    \n    logic p_pre, n_pre;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami_state <= 1'b0;\n            p_pre <= ~pulse_active_state;\n            n_pre <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (out_data) begin\n                if (out_viol) begin\n                    // Violation: same polarity as last pulse\n                    if (ami_state == 1'b0) begin\n                        // Last was negative, violation = negative\n                        p_pre <= ~pulse_active_state;\n                        n_pre <= pulse_active_state;\n                    end else begin\n                        // Last was positive, violation = positive\n                        p_pre <= pulse_active_state;\n                        n_pre <= ~pulse_active_state;\n                    end\n                    // Don't toggle AMI state for violation\n                end else begin\n                    // Normal pulse: alternate\n                    ami_state <= ~ami_state;\n                    if (ami_state == 1'b0) begin\n                        p_pre <= pulse_active_state;\n                        n_pre <= ~pulse_active_state;\n                    end else begin\n                        p_pre <= ~pulse_active_state;\n                        n_pre <= pulse_active_state;\n                    end\n                end\n            end else begin\n                // Zero: no pulse\n                p_pre <= ~pulse_active_state;\n                n_pre <= ~pulse_active_state;\n            end\n        end\n    end\n    \n    // Output gating\n    assign p_out = output_gate_in ? p_pre : ~pulse_active_state;\n    assign n_out = output_gate_in ? n_pre : ~pulse_active_state;\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
