Sending keys: ['cat > /code/rtl/hdbn_encoder.sv << \'VEOF\'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1\'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    // =========================================================================\n    // HDBn Encoder Pipeline\n    //\n    // The encoder uses a shift register of depth encoder_type to buffer input\n    // data. This allows looking back to insert the Balance (B) pulse at the\n    // correct position when a Violation (V) is needed.\n    //\n    // Pipeline stages:\n    //   S1: Input sync register (1 clk)\n    //   S2: Zero counting + substitution decision (1 clk)  \n    //   S3: Shift register buffer (encoder_type clks)\n    //       When V is detected, B is retroactively inserted\n    //   S4: AMI pulse generation (1 clk)\n    //   S5: Output gating register (1 clk)\n    //\n    // Total latency = encoder_type + 4 clocks\n    //   HDB3: 7 clocks, HDB2: 6 clocks\n    // =========================================================================\n\n    // ----- Stage 1: Input Synchronization -----\n    logic s1_data;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in)\n            s1_data <= 1\'b0;\n        else if (clk_enable_in)\n            s1_data <= data_in;\n    end\n\n    // ----- Stage 2: Zero Counting & Substitution -----\n    // Counts consecutive zeros. When count reaches encoder_type,\n    // marks the current bit as Violation and determines if Balance is needed.\n    //\n    // Balance rule: B is needed when the number of normal pulses since\n    // the last violation is even (including 0). This ensures V always\n    // violates AMI rule.\n\n    logic s2_data;        // data bit (1 for original 1 or V pulse)\n    logic s2_viol;        // this bit is a