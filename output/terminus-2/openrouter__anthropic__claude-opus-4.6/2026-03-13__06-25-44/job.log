q <= 1'b1;\n                        end\n                    end\n                end\n\n                // --------------------------------------------------\n                S_SFD: begin\n                    // 1 byte of 0xD5: low nibble = 4'h5, high nibble = 4'hD\n                    mii_tx_en_q <= 1'b1;\n                    if (nibble_cnt_q == 5'd0) begin\n                        mii_txd_q    <= 4'h5;  // low nibble of 0xD5\n                        nibble_cnt_q <= 5'd1;\n                    end else begin\n                        mii_txd_q    <= 4'hD;  // high nibble of 0xD5\n                        nibble_cnt_q <= 5'd0;\n                        // Capture FIFO data (was popped at end of preamble)\n                        if (fifo_pop_pending_q) begin\n                            word_buf_q    <= fifo_data;\n                            word_strb_q   <= fifo_strb;\n                            word_last_q   <= fifo_last;\n                            byte_cnt_q    <= count_strb_bytes(fifo_strb);\n                            nibbles_in_word_q <= count_strb_bytes(fifo_strb) << 1;\n                            fifo_data_valid_q <= 1'b1;\n                            fifo_pop_pending_q <= 1'b0;\n                        end\n                        state_q <= S_PAYLOAD;\n                        payload_nibble_cnt_q <= 4'd0;\n                    end\n                end\n\n                // --------------------------------------------------\n                S_PAYLOAD: begin\n                    mii_tx_en_q <= 1'b1;\n\n                    if (fifo_data_valid_q) begin\n                        // Determine which byte we're on\n                        // payload_nibble_cnt_q counts 0..nibbles_in_word_q-1\n                        reg [3:0] current_byte_idx;\n                        reg [7:0] current_byte;\n                        reg [7:0] reversed_byte;\n\n                        current_byte_idx = payload_nibble_cnt_q >> 1;\n\n                        case (current_byte_idx)\n                            4'd0: current_byte = word_buf_q[7:0];\n                            4'd1: current_byte = word_buf_q[15:8];\n                            4'd2: current_byte = word_buf_q[23:16];\n                            4'd3: current_byte = word_buf_q[31:24];\n                            default: current_byte = 8'd0;\n                        endcase\n\n                        // Send low nibble first, then high nibble\n                        if (payload_nibble_cnt_q[0] == 1'b0) begin\n                            // Low nibble\n                            mii_txd_q <= current_byte[3:0];\n                        end else begin\n                            // High nibble\n                            mii_txd_q <= current_byte[7:4];\n                            // After high nibble, update CRC with this byte\n                            reversed_byte = reverse_byte(current_byte);\n                            crc_q <= crc32_byte(crc_q, reversed_byte);\n                        end\n\n                        payload_nibble_cnt_q <= payload_nibble_cnt_q + 1'b1;\n\n                        // Check if we've sent all nibbles for this word\n                        if (payload_nibble_cnt_q == nibbles_in_word_q - 1'b1) begin\n                            payload_nibble_cnt_q <= 4'd0;\n\n                            if (word_last_q) begin\n                                // Last word done, move to CRC\n                                state_q      <= S_CRC;\n                                nibble_cnt_q <= 5'd0;\n                                fifo_data_valid_q <= 1'b0;\n                            end else begin\n                                // Need next word from FIFO\n                                fifo_data_valid_q <= 1'b0;\n                                if (!fifo_rd_empty) begin\n                                    fifo_rd_pop_r <= 1'b1;\n                                    fifo_pop_pending_q <= 1'b1;\n                                end\n                            end\n                        end\n                    end else if (fifo_pop_pending_q) begin\n                        // Waiting for FIFO data to be available (1 cycle latency)\n                        word_buf_q    <= fifo_data;\n                        word_strb_q   <= fifo_strb;\n                        word_last_q   <= fifo_last;\n                        byte_cnt_q    <= count_strb_bytes(fifo_strb);\n                        nibbles_in_word_q <= count_strb_bytes(fifo_strb) << 1;\n                        fifo_data_valid_q <= 1'b1;\n                        fifo_pop_pending_q <= 1'b0;\n                        payload_nibble_cnt_q <= 4'd0;\n\n                        // While waiting, send first nibble of new word\n                        mii_txd_q <= fifo_data[3:0]; // low nibble of byte 0\n                        payload_nibble_cnt_q <= 4'd1;\n                    end else begin\n                        // Stall - FIFO was empty when we tried to pop, try again\n                        if (!fifo_rd_empty) begin\n                            fifo_rd_pop_r <= 1'b1;\n                            fifo_pop_pending_q <= 1'b1;\n                        end\n                    end\n                end\n\n                // --------------------------------------------------\n                S_CRC: begin\n                    mii_tx_en_q <= 1'b1;\n                    // CRC: 4 bytes = 8 nibbles\n                    // The CRC needs to be bit-reversed and inverted\n                    // Then sent as 4 bytes, each byte low nibble first\n                    reg [31:0] final_crc;\n                    final_crc = ~crc_q; // invert\n                    // Bit-reverse each byte of the CRC\n                    // final_crc bytes: [7:0], [15:8], [23:16], [31:24]\n                    // Each byte needs to be bit-reversed\n\n                    case (nibble_cnt_q)\n                        5'd0: mii_txd_q <= reverse_byte(final_crc[7:0])[3:0];\n                        5'd1: mii_txd_q <