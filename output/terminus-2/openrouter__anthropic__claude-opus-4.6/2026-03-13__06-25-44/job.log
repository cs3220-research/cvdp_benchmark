t_in) begin\n            s2_pulse <= 0; s2_pos <= 0; s2_viol <= 0; s2_perr <= 0;\n            last_pol <= 0; had_pulse <= 0;\n        end else if (clk_enable_in) begin\n            s2_perr <= p1 & n1;\n            if (p1 & ~n1) begin\n                s2_pulse <= 1; s2_pos <= 1;\n                s2_viol <= had_pulse & (last_pol == 1'b1);\n                last_pol <= 1; had_pulse <= 1;\n            end else if (n1 & ~p1) begin\n                s2_pulse <= 1; s2_pos <= 0;\n                s2_viol <= had_pulse & (last_pol == 1'b0);\n                last_pol <= 0; had_pulse <= 1;\n            end else begin\n                s2_pulse <= 0; s2_pos <= 0; s2_viol <= 0;\n            end\n        end\n    end\n\n    // SR: Shift register (encoder_type deep)\n    // Delays pulse/viol/perr by encoder_type clocks\n    // When V is at [0] (newest), B (if present) is at [encoder_type-1] (oldest)\n    // On the same clock, the output [encoder_type-1] can be checked\n\n    logic [encoder_type-1:0] sr_p, sr_v, sr_e, sr_pol;\n    integer j;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_p <= 0; sr_v <= 0; sr_e <= 0; sr_pol <= 0;\n        end else if (clk_enable_in) begin\n            sr_p[0]   <= s2_pulse;\n            sr_v[0]   <= s2_viol;\n            sr_e[0]   <= s2_perr;\n            sr_pol[0] <= s2_pos;\n            for (j = 1; j < encoder_type; j++) begin\n                sr_p[j]   <= sr_p[j-1];\n                sr_v[j]   <= sr_v[j-1];\n                sr_e[j]   <= sr_e[j-1];\n                sr_pol[j] <= sr_pol[j-1];\n            end\n        end\n    end\n\n    // Output from SR (oldest)\n    wire out_p = sr_p[encoder_type-1];\n    wire out_v = sr_v[encoder_type-1];\n    wire out_e = sr_e[encoder_type-1];\n\n    // Check for B pulse: when V enters at [0], B is at output [encoder_type-1]\n    // B is a pulse that's part of a violation group but not itself a violation\n    wire newest_v = s2_viol; // V just entered SR\n    wire out_is_b = newest_v & out_p & ~out_v; // oldest is pulse but not V\n\n    // Data recovery: strip V and B\n    wire recovered = out_p & ~out_v & ~out_is_b;\n\n    // S3: Error Detection + Data Output\n    logic s3_data, s3_err;\n    reg [3:0] dzc; // decoder zero counter\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s3_data <= 0; s3_err <= 0; dzc <= 0;\n        end else if (clk_enable_in) begin\n            s3_data <= recovered;\n            // Zero count on encoded line (before stripping)\n            if (out_p)\n                dzc <= 0;\n            else\n                dzc <= dzc + 1;\n            // Error conditions\n            s3_err <= out_e | (~out_p & (dzc >= encoder_type[3:0] + 1));\n        end\n    end\n\n    // S4: Output Register\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_out <= 0; code_error_out <= 0;\n        end else if (clk_enable_in) begin\n            data_out <= s3_data;\n            code_error_out <= s3_err;\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
