Sending keys: ["cat > rtl/ethernet_mac_tx.sv << 'VERILOG_EOF'\nmodule ethernet_mac_tx\n(\n    input            clk_in,\n    input            rst_in,\n\n    // Configuration Register Interface\n    input            cfg_wr_in,\n    input  [31:0]    cfg_addr_in,\n    input  [31:0]    cfg_data_wr_in,\n    output [31:0]    cfg_data_rd_out,\n\n    output           interrupt_out,\n\n    // AXI-stream TX Output Interface\n    output           axis_tvalid_out,\n    output [31:0]    axis_tdata_out,\n    output [3:0]     axis_tstrb_out,\n    output           axis_tlast_out,\n    input            axis_tready_in\n);\n\n    localparam ADDR_W = 10;\n    localparam WIDTH  = 32;\n\n    localparam ST_IDLE  = 2'd0;\n    localparam ST_READ  = 2'd1;\n    localparam ST_PAUSE = 2'd2;\n    localparam ST_END   = 2'd3;\n\n    reg [15:0]  tx_length;\n    reg [31:0]  tx_irq_en;\n    reg [31:0]  tx_ctrl;\n\n    reg [1:0]   state;\n    reg [15:0]  remaining;\n    reg [ADDR_W-1:0] rd_addr;   // Address being fed to RAM (registered)\n    reg         interrupt_reg;\n\n    reg [3:0]   axis_tstrb_reg;\n    reg         axis_tlast_reg;\n    reg         axis_tvalid_reg;\n\n    // DP-RAM\n    wire [ADDR_W-1:0] cfg_ram_addr;\n    wire              cfg_ram_wr;\n    wire [WIDTH-1:0]  ram_data0_out;\n    wire [WIDTH-1:0]  ram_data1_out;\n\n    assign cfg_ram_addr = cfg_addr_in[ADDR_W+1:2];\n    assign cfg_ram_wr = cfg_wr_in && (cfg_addr_in[15:0] < 16'h07F4);\n\n    ethernet_dp_ram #(\n        .WIDTH(WIDTH),\n        .ADDR_W(ADDR_W)\n    ) u_dp_ram (\n        .clk0_in   (clk_in),\n        .addr0_in  (cfg_ram_addr),\n        .data0_in  (cfg_data_wr_in),\n        .wr0_in    (cfg_ram_wr),\n        .data0_out (ram_data0_out),\n        .addr1_in  (rd_addr),\n        .data1_in  (32'd0),\n        .wr1_in    (1'b0),\n        .data1_out (ram_data1_out)\n    );\n\n    // Config Read Mux\n    reg [31:0] cfg_data_rd_reg;\n    assign cfg_data_rd_out = cfg_data_rd_reg;\n\n    always @(*) begin\n        case (cfg_addr_in[15:0])\n            16'h07F4: cfg_data_rd_reg = {16'd0, tx_length};\n            16'h07F8: cfg_data_rd_reg = tx_irq_en;\n            16'h07FC: cfg_data_rd_reg = tx_ctrl;\n            default:  cfg_data_rd_reg = ram_data0_out;\n        endcase\n    end\n\n    wire [15:0] eff_length;\n    assign eff_length = (tx_length < 16'd64) ? 16'd64 : tx_length;\n\n    assign axis_tvalid_out = axis_tvalid_reg;\n    assign axis_tdata_out  = ram_data1_out;\n    assign axis_tstrb_out  = axis_tstrb_reg;\n    assign axis_tlast_out  = axis_tlast_reg;\n    assign interrupt_out   = interrupt_reg;\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state           <= ST_IDLE;\n            tx_length       <= 16'd0;\n            tx_irq_en       <= 32'd0;\n            tx_ctrl         <= 32'd0;\n            remaining       <= 16'd0;\n            rd_addr         <= {ADDR_W{1'b0}};\n            interrupt_reg   <= 1'b0;\n            axis_tvalid_reg <= 1'b0;\n            axis_tstrb_reg  <= 4'd0;\n            axis_tlast_reg  <= 1'b0;\n        end else begin\n            interrupt_reg <= 1'b0;\n\n            // Config writes\n            if (cfg_wr_in) begin\n                case (cfg_addr_in[15:0])\n                    16'h07F4: tx_length <= cfg_data_wr_in[15:0];\n                    16'h07F8: tx_irq_en <= cfg_data_wr_in;\n                    16'h07FC: tx_ctrl   <= cfg_data_wr_in;\n                    default: ;\n                endcase\n            end\n\n            case (state)\n                ST_IDLE: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n                    axis_tstrb_reg  <= 4'd0;\n\n                    if (tx_ctrl[0]) begin\n                        if (tx_ctrl[1]) begin\n                            state <= ST_END;\n                        end else begin\n                            remaining <= eff_length;\n                            rd_addr   <= {ADDR_W{1'b0}}; // Present addr 0 to RAM\n                            state     <= ST_READ;\n                        end\n                    end\n                end\n\n                ST_READ: begin\n                    // RAM data for rd_addr is now available\n                    axis_tvalid_reg <= 1'b1;\n\n                    // Strobe\n                    if (remaining >= 16'd4) begin\n                        axis_tstrb_reg <= 4'hF;\n                    end else begin\n                        case (remaining[1:0])\n                            2'd3: axis_tstrb_reg <= 4'h7;\n                            2'd2: axis_tstrb_reg <= 4'h3;\n                            2'd1: axis_tstrb_reg <= 4'h1;\n                            default: axis_tstrb_reg <= 4'h0;\n                        endcase\n                    end\n\n                    // Last word?\n                    if (remaining <= 16'd4) begin\n                        axis_tlast_reg <= 1'b1;\n                    end else begin\n                        axis_tlast_reg <= 1'b0;\n                    end\n\n                    // Advance address for next read\n                    rd_addr <= rd_addr + 1'b1;\n\n                    state <= ST_PAUSE;\n                end\n\n                ST_PAUSE: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n\n                    // Decrement remaining\n                    if (remaining >= 16'd4) begin\n                        remaining <= remaining - 16'd4;\n                    end else begin\n                        remaining <= 16'd0;\n                    end\n\n                    // rd_addr already points to next word (incremented in READ)\n                    // RAM is registering rd_addr this cycle, data ready next cycle\n\n                    if (remaining <= 16'd4) begin\n                        state <= ST_END;\n                    end else begin\n                        state <= ST_READ;\n                    end\n                end\n\n                ST_END: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n                    axis_tstrb_reg  <= 4'd0;\n\n                    tx_ctrl[0] <= 1'b0;\n                    tx_ctrl[1] <= 1'b0;\n\n                    if (tx_irq_en[0]) begin\n                        interrupt_reg <= 1'b1;\n                    end\n\n                    state <= ST_IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
