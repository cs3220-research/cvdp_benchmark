Sending keys: ["cd /code && cat > rtl/dig_stopwatch.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch\n// Description: Core digital stopwatch logic module.\n//\n// This module implements:\n//   - A clock divider that generates a 1 Hz enable pulse from the input clock.\n//   - A seconds counter (0-59) that increments every second.\n//   - A minutes counter (0-59) that increments when seconds roll over.\n//   - A single-bit hour indicator that asserts when minutes roll over from 59.\n//   - Saturation at 1:00:00 (hour=1, min=0, sec=0) where counters freeze.\n//   - Pulse outputs indicating when each counter changes.\n//   - A beep signal that activates on hour rollover and clears on next second.\n//   - Start/stop control to pause and resume the stopwatch.\n//\n// Parameters:\n//   CLK_FREQ - Input clock frequency in Hz (default: 50_000_000)\n//\n// Reset: Active-high synchronous reset\n//=============================================================================\n\nmodule dig_stopwatch #(\n    parameter CLK_FREQ = 50_000_000  // Input clock frequency in Hz\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high reset\n    input  logic        start_stop,   // 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter (0-59)\n    output logic [5:0]  minutes,      // Minutes counter (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulses high when seconds change\n    output logic        minute_pulse, // Pulses high when minutes change\n    output logic        hour_pulse,   // Pulses high when hour changes\n\n    output logic        beep          // Beep signal: set on hour, cleared on next second\n);\n\n    //=========================================================================\n    // Local Parameters\n    //=========================================================================\n    localparam integer COUNTER_MAX = CLK_FREQ - 1;\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    reg [31:0] clk_div_counter;  // Clock divider counter\n    logic      one_sec_enable;   // Registered 1-cycle pulse every second\n    logic      saturated;        // High when stopwatch has reached 1:00:00\n\n    // Effective tick: gated by start_stop and saturation\n    logic      tick;\n    assign tick = one_sec_enable && start_stop && !saturated;\n\n    //=========================================================================\n    // Saturation Detection\n    //=========================================================================\n    assign saturated = (hour == 1'b1) && (minutes == 6'd0) && (seconds == 6'd0);\n\n    //=========================================================================\n    // Clock Divider & One-Second Enable Generation\n    //\n    // The counter counts from 0 to COUNTER_MAX. When the counter reaches\n    // COUNTER_MAX-1, one_sec_enable is asserted (registered), becoming\n    // visible on the next clock edge when the counter reaches COUNTER_MAX.\n    //\n    // On reset or when paused, the counter is set to 1 so that upon\n    // start/resume, the first second completes in exactly CLK_FREQ-1\n    // active clock edges. This compensates for the inherent 1-cycle\n    // latency in the start_stop signal path.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            clk_div_counter <= 32'd1;\n            one_sec_enable  <= 1'b0;\n        end else if (start_stop && !saturated) begin\n            if (clk_div_counter >= COUNTER_MAX) begin\n                clk_div_counter <= 32'd0;\n                one_sec_enable  <= 1'b0;\n            end else begin\n                clk_div_counter <= clk_div_counter + 32'd1;\n                if (clk_div_counter == (COUNTER_MAX - 1))\n                    one_sec_enable <= 1'b1;\n                else\n                    one_sec_enable <= 1'b0;\n            end\n        end else begin\n            // When paused or saturated, reset counter to 1\n            clk_div_counter <= 32'd1;\n            one_sec_enable  <= 1'b0;\n        end\n    end\n\n    //=========================================================================\n    // Seconds Counter (0-59)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 6'd0;\n        end else if (tick) begin\n            if (seconds == 6'd59)\n                seconds <= 6'd0;\n            else\n                seconds <= seconds + 6'd1;\n        end\n    end\n\n    //=========================================================================\n    // Minutes Counter (0-59)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 6'd0;\n        end else if (tick && (seconds == 6'd59)) begin\n            if (minutes == 6'd59)\n                minutes <= 6'd0;\n            else\n                minutes <= minutes + 6'd1;\n        end\n    end\n\n    //=========================================================================\n    // Hour Indicator (single bit, saturates at 1)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 1'b0;\n        end else if (tick && (seconds == 6'd59) && (minutes == 6'd59)) begin\n            hour <= 1'b1;\n        end\n    end\n\n    //=========================================================================\n    // Pulse Generation\n    // Pulses are asserted on the SAME clock edge as the counter updates.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n        end else begin\n            second_pulse <= tick;\n            minute_pulse <= tick && (seconds == 6'd59);\n            hour_pulse   <= tick && (seconds == 6'd59) && (minutes == 6'd59);\n        end\n    end\n\n    //=========================================================================\n    // Beep Mechanism\n    // Activated on hour_pulse, deactivated on the next second_pulse.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 1'b0;\n        end else begin\n            if (hour_pulse && !beep)\n                beep <= 1'b1;\n            else if (second_pulse && beep)\n                beep <= 1'b0;\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
