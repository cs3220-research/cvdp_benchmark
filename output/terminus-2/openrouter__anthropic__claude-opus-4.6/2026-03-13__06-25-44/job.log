Sending keys: ["cat > /code/rtl/dma_xfer_engine.sv << 'ENDOFFILE'\nmodule dma_xfer_engine (\n    input  logic        clk,\n    input  logic        rstn,\n\n    // Slave register interface\n    input  logic [3:0]  addr,\n    input  logic        we,\n    input  logic [31:0] wd,\n    output logic [31:0] rd,\n\n    // DMA control inputs\n    input  logic        dma_req,\n    input  logic        bus_grant,\n    input  logic [31:0] rd_m,\n\n    // DMA master outputs\n    output logic        bus_req,\n    output logic        bus_lock,\n    output logic [31:0] addr_m,\n    output logic        we_m,\n    output logic [31:0] wd_m,\n    output logic [1:0]  size_m\n);\n\n    // Transfer size encoding\n    localparam logic [1:0] DMA_B  = 2'b00;\n    localparam logic [1:0] DMA_HW = 2'b01;\n    localparam logic [1:0] DMA_W  = 2'b10;\n\n    // Register addresses\n    localparam logic [3:0] DMA_CR_ADDR      = 4'h0;\n    localparam logic [3:0] DMA_SRC_ADR_ADDR = 4'h4;\n    localparam logic [3:0] DMA_DST_ADR_ADDR = 4'h8;\n\n    // FSM states\n    typedef enum logic [1:0] {\n        IDLE = 2'b00,\n        WB   = 2'b01,\n        TR   = 2'b10\n    } state_t;\n\n    state_t state;\n\n    // Control register (10 bits)\n    logic [9:0]  dma_cr;\n    logic [31:0] dma_src_adr;\n    logic [31:0] dma_dst_adr;\n\n    // Extract control register fields\n    wire [2:0]  cnt      = dma_cr[9:7];\n    wire [1:0]  src_size = dma_cr[6:5];\n    wire [1:0]  dst_size = dma_cr[4:3];\n    wire        inc_src  = dma_cr[2];\n    wire        inc_dst  = dma_cr[1];\n    wire        line_en  = dma_cr[0];\n\n    // Internal working registers\n    logic [31:0] src_addr_reg;\n    logic [31:0] dst_addr_reg;\n    logic [2:0]  xfer_count;\n    logic [31:0] data_buf;\n    logic        rw_phase; // 0 = read phase, 1 = write phase\n\n    // Calculate address increment based on size\n    function automatic logic [31:0] calc_addr_inc(input logic [1:0] sz);\n        case (sz)\n            DMA_B:   calc_addr_inc = 32'd1;\n            DMA_HW:  calc_addr_inc = 32'd2;\n            DMA_W:   calc_addr_inc = 32'd4;\n            default: calc_addr_inc = 32'd4;\n        endcase\n    endfunction\n\n    // Data extraction from read bus\n    function automatic logic [31:0] extract_read_data(\n        input logic [31:0] raw_data,\n        input logic [1:0]  sz,\n        input logic [1:0]  byte_offset\n    );\n        case (sz)\n            DMA_B: begin\n                case (byte_offset)\n                    2'b00: extract_read_data = {24'b0, raw_data[7:0]};\n                    2'b01: extract_read_data = {24'b0, raw_data[15:8]};\n                    2'b10: extract_read_data = {24'b0, raw_data[23:16]};\n                    2'b11: extract_read_data = {24'b0, raw_data[31:24]};\n                endcase\n            end\n            DMA_HW: begin\n                case (byte_offset[1])\n                    1'b0: extract_read_data = {16'b0, raw_data[15:0]};\n                    1'b1: extract_read_data = {16'b0, raw_data[31:16]};\n                endcase\n            end\n            DMA_W: begin\n                extract_read_data = raw_data;\n            end\n            default: extract_read_data = raw_data;\n        endcase\n    endfunction\n\n    // Data packing for write bus\n    function automatic logic [31:0] pack_write_data(\n        input logic [31:0] buf_data,\n        input logic [1:0]  sz,\n        input logic [1:0]  byte_offset\n    );\n        case (sz)\n            DMA_B: begin\n                case (byte_offset)\n                    2'b00: pack_write_data = {24'b0, buf_data[7:0]};\n                    2'b01: pack_write_data = {16'b0, buf_data[7:0], 8'b0};\n                    2'b10: pack_write_data = {8'b0, buf_data[7:0], 16'b0};\n                    2'b11: pack_write_data = {buf_data[7:0], 24'b0};\n                endcase\n            end\n            DMA_HW: begin\n                case (byte_offset[1])\n                    1'b0: pack_write_data = {16'b0, buf_data[15:0]};\n                    1'b1: pack_write_data = {buf_data[15:0], 16'b0};\n                endcase\n            end\n            DMA_W: begin\n                pack_write_data = buf_data;\n            end\n            default: pack_write_data = buf_data;\n        endcase\n    endfunction\n\n    // Slave read logic (combinational)\n    always_comb begin\n        case (addr)\n            DMA_CR_ADDR:      rd = {22'b0, dma_cr};\n            DMA_SRC_ADR_ADDR: rd = dma_src_adr;\n            DMA_DST_ADR_ADDR: rd = dma_dst_adr;\n            default:          rd = 32'b0;\n        endcase\n    end\n\n    // Main sequential logic\n    always_ff @(posedge clk or negedge rstn) begin\n        if (!rstn) begin\n            state        <= IDLE;\n            dma_cr       <= 10'b0;\n            dma_src_adr  <= 32'b0;\n            dma_dst_adr  <= 32'b0;\n            src_addr_reg <= 32'b0;\n            dst_addr_reg <= 32'b0;\n            xfer_count   <= 3'b0;\n            data_buf     <= 32'b0;\n            rw_phase     <= 1'b0;\n            bus_req      <= 1'b0;\n            bus_lock     <= 1'b0;\n            addr_m       <= 32'b0;\n            we_m         <= 1'b0;\n            wd_m         <= 32'b0;\n            size_m       <= 2'b0;\n        end else begin\n            // Slave register writes\n            if (we) begin\n                case (addr)\n                    DMA_CR_ADDR:      dma_cr      <= wd[9:0];\n                    DMA_SRC_ADR_ADDR: dma_src_adr <= wd;\n                    DMA_DST_ADR_ADDR: dma_dst_adr <= wd;\n                    default: ;\n                endcase\n            end\n\n            case (state)\n                IDLE: begin\n                    bus_req  <= 1'b0;\n                    bus_lock <= 1'b0;\n                    we_m     <= 1'b0;\n                    addr_m   <= 32'b0;\n                    wd_m     <= 32'b0;\n                    size_m   <= 2'b0;\n\n                    if (dma_req) begin\n                        src_addr_reg <= dma_src_adr;\n                     