 0;\n        end else begin\n            // Default: deassert single-cycle pulses\n            data_bin_valid <= 0;\n            error_overflow <= 0;\n            valid_sentence <= 0;\n\n            case (state)\n                STATE_IDLE: begin\n                    watchdog_counter <= 0;\n                    watchdog_timeout <= 0;\n                end\n\n                STATE_PARSE: begin\n                    // Watchdog counter\n                    if (watchdog_timeout_en) begin\n                        if (watchdog_counter >= WATCHDOG_LIMIT - 1) begin\n                            watchdog_timeout <= 1;\n                            watchdog_counter <= 0;\n                        end else begin\n                            watchdog_counter <= watchdog_counter + 1;\n                        end\n                    end\n\n                    // Overflow detection\n                    if (serial_valid && !is_end && !(buffer_index < MAX_BUFFER_SIZE - 1)) begin\n                        error_overflow <= 1;\n                        watchdog_counter <= 0;\n                    end\n                end\n\n                STATE_OUTPUT: begin\n                    watchdog_counter <= 0;\n                    // Check for GPRMC\n                    if (buffer[0] == 8'h47 &&  // 'G'\n                        buffer[1] == 8'h50 &&  // 'P'\n                        buffer[2] == 8'h52 &&  // 'R'\n                        buffer[3] == 8'h4D &&  // 'M'\n                        buffer[4] == 8'h43)    // 'C'\n                    begin\n                        valid_sentence <= 1;\n                        // Binary conversion using the same field extraction\n                        // We need to find the field_index again for registered logic\n                        // Use data_out which is combinationally available\n                        if (data_valid) begin\n                            if (is_digit(data_out[15:8]) && is_digit(data_out[7:0])) begin\n                                data_out_bin <= ((data_out[15:8] - 8'h30) * 10) + (data_out[7:0] - 8'h30);\n                                data_bin_valid <= 1;\n                            end\n                        end\n                    end\n                end\n\n                default: begin\n                end\n            endcase\n        end\n    end\n\n    // Combinational logic (same as original for data_out and data_valid)\n    always @(*) begin\n        next_state = state;\n        next_buffer_index = buffer_index;\n        data_out = 16'b0;\n        data_valid = 0;\n        comma_count = 0;\n        field_index = 0;\n\n        case (state)\n            STATE_IDLE: begin\n                if (serial_valid && is_start) begin\n                    next_state = STATE_PARSE;\n                    next_buffer_index = 0;\n                end\n            end\n\n            STATE_PARSE: begin\n                if (watchdog_timeout_en && watchdog_counter >= WATCHDOG_LIMIT - 1) begin\n                    next_state = STATE_IDLE;\n                    next_buffer_index = 0;\n                end else if (serial_valid) begin\n                    if (is_end) begin\n                        next_state = STATE_OUTPUT;\n                    end else if (buffer_index < MAX_BUFFER_SIZE - 1) begin\n                        buffer[next_buffer_index] = serial_in;\n                        next_buffer_index = buffer_index + 1;\n                    end else begin\n                        next_state = STATE_IDLE;\n                        next_buffer_index = 0;\n                    end\n                end\n            end\n\n            STATE_OUTPUT: begin\n                if (buffer[0] == 8'h47 &&  // 'G'\n                    buffer[1] == 8'h50 &&  // 'P'\n                    buffer[2] == 8'h52 &&  // 'R'\n                    buffer[3] == 8'h4D &&  // 'M'\n                    buffer[4] == 8'h43)    // 'C'\n                begin\n                    for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1) begin\n                        if (i < buffer_index) begin\n                            if (buffer[i] == 8'h2C) begin\n                                comma_count = comma_count + 1;\n                                if (comma_count == 1) begin\n                                    field_index = i + 1;\n                                end\n                            end\n                        end\n                    end\n\n                    if (field_index + 1 < buffer_index) begin\n                        data_out = {buffer[field_index], buffer[field_index + 1]};\n                        data_valid = 1;\n                    end\n                end\n                next_state = STATE_IDLE;\n            end\n\n            default: next_state = STATE_IDLE;\n        endcase\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
