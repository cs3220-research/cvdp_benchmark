function\n\n    function automatic logic [31:0] extract_read_data(\n        input logic [31:0] raw_data, input logic [1:0] sz, input logic [1:0] byte_offset\n    );\n        case (sz)\n            DMA_B: case (byte_offset)\n                2'b00: extract_read_data = {24'b0, raw_data[7:0]};\n                2'b01: extract_read_data = {24'b0, raw_data[15:8]};\n                2'b10: extract_read_data = {24'b0, raw_data[23:16]};\n                2'b11: extract_read_data = {24'b0, raw_data[31:24]};\n            endcase\n            DMA_HW: case (byte_offset[1])\n                1'b0: extract_read_data = {16'b0, raw_data[15:0]};\n                1'b1: extract_read_data = {16'b0, raw_data[31:16]};\n            endcase\n            DMA_W:   extract_read_data = raw_data;\n            default: extract_read_data = raw_data;\n        endcase\n    endfunction\n\n    function automatic logic [31:0] pack_write_data(\n        input logic [31:0] buf_data, input logic [1:0] sz, input logic [1:0] byte_offset\n    );\n        case (sz)\n            DMA_B: case (byte_offset)\n                2'b00: pack_write_data = {24'b0, buf_data[7:0]};\n                2'b01: pack_write_data = {16'b0, buf_data[7:0], 8'b0};\n                2'b10: pack_write_data = {8'b0, buf_data[7:0], 16'b0};\n                2'b11: pack_write_data = {buf_data[7:0], 24'b0};\n            endcase\n            DMA_HW: case (byte_offset[1])\n                1'b0: pack_write_data = {16'b0, buf_data[15:0]};\n                1'b1: pack_write_data = {buf_data[15:0], 16'b0};\n            endcase\n            DMA_W:   pack_write_data = buf_data;\n            default: pack_write_data = buf_data;\n        endcase\n    endfunction\n\n    always_comb begin\n        case (addr)\n            4'h0:    rd = {22'b0, dma_cr};\n            4'h4:    rd = dma_src_adr;\n            4'h8:    rd = dma_dst_adr;\n            default: rd = 32'b0;\n        endcase\n    end\n\n    always_ff @(posedge clk or negedge rstn) begin\n        if (!rstn) begin\n            state        <= IDLE;\n            dma_cr       <= 10'b0;\n            dma_src_adr  <= 32'b0;\n            dma_dst_adr  <= 32'b0;\n            src_addr_reg <= 32'b0;\n            dst_addr_reg <= 32'b0;\n            xfer_count   <= 3'b0;\n            data_buf     <= 32'b0;\n            rw_phase     <= 1'b0;\n            bus_req_r    <= 1'b0;\n            bus_lock_r   <= 1'b0;\n            addr_m       <= 32'b0;\n            we_m         <= 1'b0;\n            wd_m         <= 32'b0;\n            size_m       <= 2'b0;\n        end else begin\n            if (we) begin\n                case (addr)\n                    4'h0:    dma_cr      <= wd[9:0];\n                    4'h4:    dma_src_adr <= wd;\n                    4'h8:    dma_dst_adr <= wd;\n                    default: ;\n                endcase\n            end\n\n            case (state)\n                IDLE: begin\n                    bus_req_r  <= 1'b0;\n                    bus_lock_r <= 1'b0;\n                    we_m       <= 1'b0;\n                    addr_m     <= 32'b0;\n                    wd_m       <= 32'b0;\n                    size_m     <= 2'b0;\n                    rw_phase   <= 1'b0;\n\n                    if (dma_req) begin\n                        if (cnt != 3'd0) begin\n                            src_addr_reg <= dma_src_adr;\n                            dst_addr_reg <= dma_dst_adr;\n                            xfer_count   <= cnt;\n                            bus_req_r    <= 1'b1;\n                            bus_lock_r   <= 1'b1;\n                            state        <= WB;\n                        end\n                    end\n                end\n\n                WB: begin\n                    if (bus_grant) begin\n                        addr_m   <= src_addr_reg;\n                        we_m     <= 1'b0;\n                        size_m   <= src_size;\n                        rw_phase <= 1'b0;\n                        state    <= TR;\n                    end\n                end\n\n                TR: begin\n                    if (rw_phase == 1'b0) begin\n                        data_buf <= extract_read_data(rd_m, src_size, src_addr_reg[1:0]);\n                        addr_m   <= dst_addr_reg;\n                        we_m     <= 1'b1;\n                        wd_m     <= pack_write_data(\n                                        extract_read_data(rd_m, src_size, src_addr_reg[1:0]),\n                                        dst_size, dst_addr_reg[1:0]);\n                        size_m   <= dst_size;\n                        rw_phase <= 1'b1;\n                        if (inc_src)\n                            src_addr_reg <= src_addr_reg + calc_addr_inc(src_size);\n                    end else begin\n                        if (inc_dst)\n                            dst_addr_reg <= dst_addr_reg + calc_addr_inc(dst_size);\n                        xfer_count <= xfer_count - 3'd1;\n                        if (xfer_count == 3'd1) begin\n                            bus_req_r  <= 1'b0;\n                            bus_lock_r <= 1'b0;\n                            we_m       <= 1'b0;\n                            addr_m     <= 32'b0;\n                            wd_m       <= 32'b0;\n                            size_m     <= 2'b0;\n                            state      <= IDLE;\n                        end else begin\n                            if (inc_src)\n                                addr_m <= src_addr_reg + calc_addr_inc(src_size);\n                            else\n                                addr_m <= src_addr_reg;\n                            we_m     <= 1'b0;\n                            size_m   <= src_size;\n                            rw_phase <= 1'b0;\n                        end\n                    end\n                end\n\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
