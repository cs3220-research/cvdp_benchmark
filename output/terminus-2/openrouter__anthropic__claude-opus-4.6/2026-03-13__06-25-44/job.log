Sending keys: ['cat > /code/rtl/hdbn_encoder.sv << \'VEOF\'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1\'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n    // HDBn Encoder\n    // HDB3 (encoder_type=3): replaces encoder_type+1 consecutive zeros\n    // HDB2 (encoder_type=2): replaces encoder_type+1 consecutive zeros\n    //\n    // Substitution patterns:\n    //   000V (HDB3) / 00V (HDB2): when pulse count since last V is odd\n    //   B00V (HDB3) / B0V (HDB2): when pulse count since last V is even\n    //\n    // V = violation pulse (same polarity as previous pulse)\n    // B = balance pulse (normal AMI alternating pulse)\n    //\n    // Pipeline: S1 -> S2 -> SR[encoder_type] -> AMI -> OUT\n    // Latency = encoder_type + 4\n\n    // ----- S1: Input Sync -----\n    logic s1;\n    always_ff @(posedge clk_in or posedge reset_in)\n        if (reset_in)           s1 <= 0;\n        else if (clk_enable_in) s1 <= data_in;\n\n    // ----- S2: Zero Count & Substitution -----\n    logic s2_d, s2_v, s2_b;\n    reg [3:0] zc;\n    reg [7:0] psv;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            s2_d <= 0; s2_v <= 0; s2_b <= 0;\n            zc <= 0; psv <= 0;\n        end else if (clk_enable_in) begin\n            if (s1) begin\n                zc  <= 0;\n                psv <= psv + 1;\n                s2_d <= 1; s2_v <= 0; s2_b <= 0;\n            end else if (zc == encoder_type[3:0]) begin\n                // (encoder_type+1)th zero: insert V\n                zc  <= 0;\n                s2_d <= 1; s2_v <= 1;\n                s2_b <= ~psv[0]; // B when even (0,2,4...)\n                psv  <= 0;\n            end else begin\n                zc <= zc + 1;\n                s2_d <= 0; s2_v <= 0; s2_b <= 0;\n            end\n        end\n    end\n\n    // ----- SR: Shift Register (encoder_type deep) -----\n    logic [encoder_type-1:0] sr_d, sr_v;\n    integer k;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_d <= 0; sr_v <= 0;\n        end else if (clk_enable_in) begin\n            sr_d[0] <= s2_d;\n            sr_v[0] <= s2_v;\n            for (k = 1; k < encoder_type; k++) begin\n                sr_d[k] <= sr_d[k-1];\n                sr_v[k] <= sr_v[k-1];\n            end\n        end\n    end\n\n    // SR output with balance override\n    // When V+B enters SR, the first zero of the group is at SR output\n    wire sr_out_d = (s2_v & s2_b) ? 1\'b1 : sr_d[encoder_type-1];\n    wire sr_out_v = sr_v[encoder_type-1];\n\n    // ----- AMI Pulse Generation -----\n    // ami=0: next normal pulse is P, ami=1: next is N\n    // Normal pulse: follows AMI, toggles\n    // V pulse: SAME polarity as PREVIOUS pulse (violation)\n    //   ami=0 means previous was N -> V=N\n    //   ami=1 means previous was P -> V=P  \n    // After V: AMI toggles (V counts as a pulse for AMI tracking)\n\n    logic ami;\n    logic sp, sn;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami <= 0;\n            sp  <= ~pulse_active_state;\n            sn  <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (sr_out_d) begin\n                if (sr_out_v) begin\n                    // Violation: same as PREVIOUS pulse\n                    // ami=0: prev was N -> V=N. After V, ami stays 0 (next normal=P)\n                    // ami=1: prev was P -> V=P. After V, ami stays 1 (next normal=N)\n                    // Actually if V has same polarity as prev, and we want AMI to\n                    // track as if V was a normal pulse, then:\n                    // V=prev_polarity. Normal would have been opposite. So AMI\n                    // should NOT toggle (V took the "wrong" slot).\n                    // But for DC balance, we need to think about this differently.\n                    //\n                    // Let me just try: V does NOT toggle AMI.\n                    if (ami) begin\n                        sp <= pulse_active_state;  // V=P (same as prev P)\n                        sn <= ~pulse_active_state;\n                    end else begin\n                        sp <= ~pulse_active_state; // V=N (same as prev N)\n                        sn <= pulse_active_state;\n                    end\n                    // Don\'t toggle ami\n                end else begin\n                    // Normal pulse\n                    if (!ami) begin\n                        sp <= pulse_active_state;\n                        sn <= ~pulse_active_state;\n                        ami <= 1;\n                    end else begin\n                        sp <= ~pulse_active_state;\n                        sn <= pulse_active_state;\n                        ami <= 0;\n                    end\n                end\n            end else begin\n                sp <= ~pulse_active_state;\n                sn <= ~pulse_active_state;\n            end\n        end\n    end\n\n    // ----- Output Gate -----\n    logic gp, gn;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            gp <= ~pulse_active_state;\n            gn <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (output_gate_in) begin gp <= sp; gn <= sn; end\n            else begin gp <= ~pulse_active_state; gn <= ~pulse_active_state; end\n        end\n    end\n\n    assign p_out = gp;\n    assign n_out = gn;\n\nendmodule\nVEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ['python3 << \'PYEOF\'\n# Simulate the encoder to verify DC balance\nimport sys\n\nencoder_type = 3\n\n# Generate PRBS15\nshiftreg = 0\ninput_bits = []\nfor i in range(100):\n    feedback = (not ((shiftreg >> 14) ^ (shiftreg >> 13)) & 1)\n    shiftreg = ((shiftreg << 1) | feedback) & 0x7FFF\n    input_bits.append((shiftreg >> 0) & 1)\n\n# Simulate encoder (without pipeline, just the algorithm)\nami = 0  # 0=next normal is P, 1=next normal is N\npsv = 0  # pulses since last violation\nzc = 0   # zero counter\nrunning_sum = 0\n\nfor i, bit in enumerate(input_bits):\n    if bit == 1:\n        zc = 0\n        psv += 1\n        # Normal pulse\n        if ami == 0:\n            p, n = 1, 0  # P\n            ami = 1\n        else:\n            p, n = 0, 1  # N\n            ami = 0\n    elif zc == encoder_type:\n        # V substitution\n        need_b = (psv % 2 == 0)\n        zc = 0\n        # V: same as previous pulse\n        if ami == 1:  # prev was P\n            p, n = 1, 0  # V=P\n        else:  # prev was N\n            p, n = 0, 1  # V=N\n        # Don\'t toggle ami for V\n        psv = 0\n        \n        if p == 1: running_sum += 1\n        elif n == 1: running_sum -= 1\n        \n        if need_b:\n            print(f"  Cycle {i}: B00V pattern, B would have been inserted earlier")\n        \n        if abs(running_sum) >= 2:\n            print(f"  Cycle {i}: RS={running_sum} VIOLATION! V={\'P\' if p else \'N\'}, ami={ami}, psv_was={psv}, need_b={need_b}")\n        else:\n            print(f"  Cycle {i}: V={\'P\' if p else \'N\'}, RS={running_sum}, ami={ami}")\n        continue\n    else:\n        zc += 1\n        p, n = 0, 0\n    \n    if p == 1: running_sum += 1\n    elif n == 1: running_sum -= 1\n    \n    if abs(running_sum) >= 2:\n        print(f"Cycle {i}: bit={bit} p={p} n={n} RS={running_sum} ERROR")\n\nprint(f"\\nFinal running sum: {running_sum}")\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
