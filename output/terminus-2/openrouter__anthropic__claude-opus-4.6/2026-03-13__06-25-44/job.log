Sending keys: ["cat > rtl/dig_stopwatch.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch\n// Description: Core digital stopwatch logic module.\n//\n// This module implements:\n//   - A clock divider that generates a 1 Hz enable pulse from the input clock.\n//   - A seconds counter (0-59) that increments every second.\n//   - A minutes counter (0-59) that increments when seconds roll over.\n//   - A single-bit hour indicator that asserts when minutes roll over from 59.\n//   - Saturation at 1:00:00 (hour=1, min=0, sec=0) where counters freeze.\n//   - Pulse outputs indicating when each counter changes.\n//   - A beep signal that activates on hour rollover and clears on next second.\n//   - Start/stop control to pause and resume the stopwatch.\n//\n// Parameters:\n//   CLK_FREQ - Input clock frequency in Hz (default: 50_000_000)\n//\n// Reset: Active-high synchronous reset\n//=============================================================================\n\nmodule dig_stopwatch #(\n    parameter CLK_FREQ = 50_000_000  // Input clock frequency in Hz\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high reset\n    input  logic        start_stop,   // 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter (0-59)\n    output logic [5:0]  minutes,      // Minutes counter (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulses high when seconds change\n    output logic        minute_pulse, // Pulses high when minutes change\n    output logic        hour_pulse,   // Pulses high when hour changes\n\n    output logic        beep          // Beep signal: set on hour, cleared on next second\n);\n\n    //=========================================================================\n    // Local Parameters\n    //=========================================================================\n    // COUNTER_MAX defines the terminal count for the clock divider.\n    // The divider counts from 0 to COUNTER_MAX (CLK_FREQ-1 values),\n    // producing a 1 Hz tick every CLK_FREQ clock cycles.\n    localparam integer COUNTER_MAX = CLK_FREQ - 1;\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    // Clock divider counter - counts from 0 to COUNTER_MAX\n    reg [31:0] clk_div_counter;\n\n    // Saturation flag: asserted when stopwatch reaches 1:00:00\n    logic saturated;\n\n    // One-second enable: combinational signal asserted when counter\n    // reaches COUNTER_MAX and stopwatch is running and not saturated.\n    // Using combinational logic ensures that the seconds counter and\n    // clock divider update on the same clock edge, maintaining exact\n    // CLK_FREQ cycle timing per second.\n    logic one_sec_enable;\n\n    //=========================================================================\n    // Saturation Detection\n    //=========================================================================\n    // The stopwatch saturates at hour=1, minutes=0, seconds=0.\n    // Once saturated, all counters freeze regardless of start_stop.\n    assign saturated = (hour == 1'b1) && (minutes == 6'd0) && (seconds == 6'd0);\n\n    //=========================================================================\n    // One-Second Enable (Combinational)\n    //=========================================================================\n    assign one_sec_enable = start_stop && !saturated &&\n                            (clk_div_counter == COUNTER_MAX[31:0]);\n\n    //=========================================================================\n    // Clock Divider\n    // Counts from 0 to COUNTER_MAX. When COUNTER_MAX is reached and the\n    // stopwatch is running, the counter resets to 0 on the next clock edge.\n    // When paused (start_stop=0) or saturated, the counter holds its value.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            clk_div_counter <= 32'd0;\n        end else if (start_stop && !saturated) begin\n            if (clk_div_counter == COUNTER_MAX) begin\n                clk_div_counter <= 32'd0;\n            end else begin\n                clk_div_counter <= clk_div_counter + 32'd1;\n            end\n        end\n        // When paused or saturated, counter holds its current value\n    end\n\n    //=========================================================================\n    // Seconds Counter (0-59)\n    // Increments on each one_sec_enable pulse. Rolls over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 6'd0;\n        end else if (one_sec_enable) begin\n            if (seconds == 6'd59) begin\n                seconds <= 6'd0;\n            end else begin\n                seconds <= seconds + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Minutes Counter (0-59)\n    // Increments when seconds roll over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 6'd0;\n        end else if (one_sec_enable && (seconds == 6'd59)) begin\n            if (minutes == 6'd59) begin\n                minutes <= 6'd0;\n            end else begin\n                minutes <= minutes + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Hour Indicator (single bit)\n    // Asserted when both seconds and minutes roll over from 59.\n    // Once set to 1, it remains set (design saturates at 1 hour).\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 1'b0;\n        end else if (one_sec_enable && (seconds == 6'd59) && (minutes == 6'd59)) begin\n            hour <= 1'b1;\n        end\n    end\n\n    //=========================================================================\n    // Pulse Generation\n    // Pulses are registered outputs asserted for one clock cycle when the\n    // corresponding time counter changes:\n    //   - second_pulse: every second tick\n    //   - minute_pulse: when minutes increment (at seconds rollover)\n    //   - hour_pulse:   when hour asserts (at minutes rollover)\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n        end else begin\n            // Default: deassert all pulses each cycle\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n\n            if (one_sec_enable) begin\n                second_pulse <= 1'b1;\n\n                if (seconds == 6'd59) begin\n                    minute_pulse <= 1'b1;\n\n                    if (minutes == 6'd59) begin\n                        hour_pulse <= 1'b1;\n                    end\n                end\n            end\n        end\n    end\n\n    //=========================================================================\n    // Beep Mechanism\n    // Activated (set high) when hour_pulse is asserted.\n    // Deactivated (cleared) on the next second_pulse.\n    // Provides an indication at each hour boundary.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 1'b0;\n        end else begin\n            if (hour_pulse && !beep) begin\n                beep <= 1'b1;\n            end else if (second_pulse && beep) begin\n                beep <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
