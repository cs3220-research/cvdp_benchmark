Sending keys: ["cat > /code/rtl/jpeg_runlength_stage1.sv << 'ENDOFFILE'\nmodule jpeg_runlength_stage1 (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire        go_in,\n    input  wire [11:0] din_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dcterm_out\n);\n\n    // Internal state\n    reg [5:0] sample_cnt;    // 0..63 position in block\n    reg [3:0] zero_run;      // count of consecutive zeros\n    reg       block_active;  // currently processing a block\n\n    // Size calculation function: ceil(log2(abs_val + 1))\n    function automatic [3:0] calc_size;\n        input [11:0] val;\n        reg [11:0] abs_val;\n        begin\n            // Get absolute value from signed 12-bit\n            if (val[11])\n                abs_val = (~val) + 1'b1;\n            else\n                abs_val = val;\n            \n            if (abs_val == 0)          calc_size = 4'd0;\n            else if (abs_val <= 1)     calc_size = 4'd1;\n            else if (abs_val <= 3)     calc_size = 4'd2;\n            else if (abs_val <= 7)     calc_size = 4'd3;\n            else if (abs_val <= 15)    calc_size = 4'd4;\n            else if (abs_val <= 31)    calc_size = 4'd5;\n            else if (abs_val <= 63)    calc_size = 4'd6;\n            else if (abs_val <= 127)   calc_size = 4'd7;\n            else if (abs_val <= 255)   calc_size = 4'd8;\n            else if (abs_val <= 511)   calc_size = 4'd9;\n            else if (abs_val <= 1023)  calc_size = 4'd10;\n            else                       calc_size = 4'd11;\n        end\n    endfunction\n\n    always @(posedge clk_in) begin\n        if (reset_in) begin\n            rlen_out   <= 4'd0;\n            size_out   <= 4'd0;\n            amp_out    <= 12'd0;\n            den_out    <= 1'b0;\n            dcterm_out <= 1'b0;\n            sample_cnt <= 6'd0;\n            zero_run   <= 4'd0;\n            block_active <= 1'b0;\n        end else if (enable_in) begin\n            // Default: no output\n            den_out    <= 1'b0;\n            dcterm_out <= 1'b0;\n\n            if (go_in) begin\n                // DC coefficient - first sample of new block\n                block_active <= 1'b1;\n                sample_cnt   <= 6'd1; // Next sample will be AC #1\n                zero_run     <= 4'd0;\n\n                // Output DC term\n                rlen_out   <= 4'd0;\n                size_out   <= calc_size(din_in);\n                amp_out    <= din_in;\n                den_out    <= 1'b1;\n                dcterm_out <= 1'b1;\n            end else if (block_active) begin\n                // AC coefficient processing\n                if (din_in == 12'd0) begin\n                    // Zero input\n                    if (sample_cnt == 6'd63) begin\n                        // Last sample in block and it's zero - emit EOB\n                        rlen_out   <= 4'd0;\n                        size_out   <= 4'd0;\n                        amp_out    <= 12'd0;\n                        den_out    <= 1'b1;\n                        dcterm_out <= 1'b0;\n                        zero_run   <= 4'd0;\n                        block_active <= 1'b0;\n                    end else if (zero_run == 4'd15) begin\n                        // 16th consecutive zero - emit ZRL marker (15, 0, 0)\n                        rlen_out   <= 4'd15;\n                        size_out   <= 4'd0;\n                        amp_out    <= 12'd0;\n                        den_out    <= 1'b1;\n                        dcterm_out <= 1'b0;\n                        zero_run   <= 4'd0;\n                    end else begin\n                        // Accumulate zero run\n                        zero_run <= zero_run + 4'd1;\n                    end\n                    sample_cnt <= sample_cnt + 6'd1;\n                end else begin\n                    // Non-zero input\n                    rlen_out   <= zero_run;\n                    size_out   <= calc_size(din_in);\n                    amp_out    <= din_in;\n                    den_out    <= 1'b1;\n                    dcterm_out <= 1'b0;\n                    zero_run   <= 4'd0;\n                    \n                    if (sample_cnt == 6'd63) begin\n                        block_active <= 1'b0;\n                    end\n                    sample_cnt <= sample_cnt + 6'd1;\n                end\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > /code/rtl/jpeg_runlength_rzs.sv << 'ENDOFFILE'\nmodule jpeg_runlength_rzs (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire [3:0]  rlen_in,\n    input  wire [3:0]  size_in,\n    input  wire [11:0] amp_in,\n    input  wire        den_in,\n    input  wire        dc_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dc_out\n);\n\n    // FSM states\n    localparam S_IDLE    = 2'd0;  // Normal pass-through\n    localparam S_HOLD    = 2'd1;  // Holding a (15,0) - suppressed for now\n    localparam S_EMIT    = 2'd2;  // Emit the held (15,0) then pass current\n\n    reg [1:0] state;\n    \n    // Saved data for re-emission\n    reg [3:0]  held_rlen;\n    reg [3:0]  held_size;\n    reg [11:0] held_amp;\n    reg        held_dc;\n    \n    // Pending data (the non-ZRL that triggered re-emission)\n    reg [3:0]  pend_rlen;\n    reg [3:0]  pend_size;\n    reg [11:0] pend_amp;\n    reg        pend_dc;\n\n    always @(posedge clk_in) begin\n        if (reset_in) begin\n            rlen_out <= 4'd0;\n            size_out <= 4'd0;\n            amp_out  <= 12'd0;\n            den_out  <= 1'b0;\n            dc_out   <= 1'b0;\n            state    <= S_IDLE;\n            held_rlen <= 4'd0;\n            held_size <= 4'd0;\n            held_amp  <= 12'd0;\n            held_dc   <= 1'b0;\n            pend_rlen <= 4'd0;\n            pend_size <= 4'd0;\n            pend_amp  <= 12'd0;\n            pend_dc   <= 1'b0;\n        end else if (enable_in) begin\n            case (state)\n                S_IDLE: begin\n                    if (den_in) begin\n                        if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                            // Suppress (15,0) - hold it\n                            state <= S_HOLD;\n                            held_rlen <= rlen_in;\n                            held_size <= size_in;\n                            held_amp  <= amp_in;\n                            held_dc   <= dc_in;\n                            den_out   <= 1'b0;\n                        end else begin\n                            // Pass through\n                            rlen_out <= rlen_in;\n                            size_out <= size_in;\n                            amp_out  <= amp_in;\n                            den_out  <= 1'b1;\n                            dc_out   <= dc_in;\n                        end\n                    end else begin\n                        den_out <= 1'b0;\n                    end\n                end\n\n                S_HOLD: begin\n                    if (den_in) begin\n                        if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                            // Another (15,0) - keep suppressing, update held\n                            held_rlen <= rlen_in;\n                            held_size <= size_in;\n                            held_amp  <= amp_in;\n                            held_dc   <= dc_in;\n                            den_out   <= 1'b0;\n                        end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                            // EOB - emit EOB, discard held (15,0)\n                            rlen_out <= rlen_in;\n                            size_out <= size_in;\n                            amp_out  <= amp_in;\n                            den_out  <= 1'b1;\n                            dc_out   <= dc_in;\n                            state    <= S_IDLE;\n                        end else begin\n                            // Non-ZRL, non-EOB: emit held (15,0) first\n                            rlen_out <= held_rlen;\n                            size_out <= held_size;\n                            amp_out  <= held_amp;\n                            den_out  <= 1'b1;\n                            dc_out   <= held_dc;\n                            // 