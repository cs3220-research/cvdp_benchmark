tion\n\n    // Clear the latch after consumption at posedge\n    always @(posedge clk) begin\n        if (!reset) begin\n            // Clear latch - will be re-set by negedge if new valid arrives\n            valid_latch <= 0;\n        end\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            data_out_bin <= 16'b0;\n            data_bin_valid <= 0;\n            error_overflow <= 0;\n            valid_sentence <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n        end else begin\n            state <= next_state;\n            buffer_index <= next_buffer_index;\n\n            // Default: deassert single-cycle pulses\n            data_bin_valid <= 0;\n            valid_sentence <= 0;\n\n            case (state)\n                STATE_IDLE: begin\n                    watchdog_counter <= 0;\n                    if (eff_valid && is_start) begin\n                        error_overflow <= 0;\n                        watchdog_timeout <= 0;\n                    end\n                end\n\n                STATE_PARSE: begin\n                    if (watchdog_timeout_en) begin\n                        if (watchdog_counter >= WATCHDOG_LIMIT - 1) begin\n                            watchdog_timeout <= 1;\n                            watchdog_counter <= 0;\n                        end else begin\n                            watchdog_counter <= watchdog_counter + 1;\n                        end\n                    end\n\n                    if (buffer_index >= MAX_BUFFER_SIZE - 1) begin\n                        error_overflow <= 1;\n                        watchdog_counter <= 0;\n                    end\n                end\n\n                STATE_OUTPUT: begin\n                    watchdog_counter <= 0;\n                    if (buffer[0] == 8'h47 &&\n                        buffer[1] == 8'h50 &&\n                        buffer[2] == 8'h52 &&\n                        buffer[3] == 8'h4D &&\n                        buffer[4] == 8'h43)\n                    begin\n                        valid_sentence <= 1;\n                        if (data_valid) begin\n                            if (is_digit(data_out[15:8]) && is_digit(data_out[7:0])) begin\n                                data_out_bin <= ((data_out[15:8] - 8'h30) * 10) + (data_out[7:0] - 8'h30);\n                                data_bin_valid <= 1;\n                            end\n                        end\n                    end\n                end\n\n                default: begin\n                end\n            endcase\n        end\n    end\n\n    // Combinational logic\n    always @(*) begin\n        next_state = state;\n        next_buffer_index = buffer_index;\n        data_out = 16'b0;\n        data_valid = 0;\n        comma_count = 0;\n        field_index = 0;\n\n        case (state)\n            STATE_IDLE: begin\n                if (eff_valid && is_start) begin\n                    next_state = STATE_PARSE;\n                    next_buffer_index = 0;\n                end\n            end\n\n            STATE_PARSE: begin\n                if (buffer_index >= MAX_BUFFER_SIZE - 1) begin\n                    next_state = STATE_IDLE;\n                    next_buffer_index = 0;\n                end else if (watchdog_timeout_en && watchdog_counter >= WATCHDOG_LIMIT - 1) begin\n                    next_state = STATE_IDLE;\n                    next_buffer_index = 0;\n                end else if (eff_valid) begin\n                    if (is_end) begin\n                        next_state = STATE_OUTPUT;\n                    end else begin\n                        buffer[buffer_index] = eff_data;\n                        next_buffer_index = buffer_index + 1;\n                    end\n                end\n            end\n\n            STATE_OUTPUT: begin\n                if (buffer[0] == 8'h47 &&\n                    buffer[1] == 8'h50 &