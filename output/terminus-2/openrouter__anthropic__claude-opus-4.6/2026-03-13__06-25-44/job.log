r update\n    integer k;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                if (k == CENTER_TAP)\n                    coeff_real[k] <= ONE;\n                else\n                    coeff_real[k] <= '0;\n                coeff_imag[k] <= '0;\n            end\n        end else begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                coeff_real[k] <= coeff_real[k] + delta_real[k];\n                coeff_imag[k] <= coeff_imag[k] + delta_imag[k];\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
