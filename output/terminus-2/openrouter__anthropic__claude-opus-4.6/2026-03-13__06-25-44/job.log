                  S_IFG      = 3'd5;\n\n    reg [2:0]   state_q;\n    reg [4:0]   cnt_q;\n    reg [3:0]   mii_txd_q;\n    reg         mii_tx_en_q;\n\n    // Current word being serialized\n    reg [31:0]  word_buf_q;\n    reg         word_last_q;\n    reg [3:0]   word_nib_total_q;\n    reg [3:0]   nib_idx_q;\n\n    // Next word (pre-fetched)\n    reg [31:0]  next_word_buf_q;\n    reg         next_word_last_q;\n    reg [3:0]   next_word_nib_total_q;\n    reg         next_word_valid_q;\n\n    // Track when we've issued a pop and are waiting for data\n    reg         pop_issued_q;    // pop was issued, waiting for FIFO to process\n    reg         pop_arriving_q;  // data arrives this cycle (1 cycle after FIFO processes)\n\n    // CRC\n    reg [31:0]  crc_q;\n    reg [31:0]  crc_out_q;\n    reg [4:0]   ifg_cnt_q;\n\n    assign mii_txd_out   = mii_txd_q;\n    assign mii_tx_en_out = mii_tx_en_q;\n\n    // ---------------------------------------------------------------\n    // CRC-32 reflected (0xEDB88320)\n    // ---------------------------------------------------------------\n    function [31:0] crc32_byte;\n        input [31:0] crc_in;\n        input [7:0]  data_byte;\n        reg [31:0] c;\n        integer i;\n        begin\n            c = crc_in ^ {24'h0, data_byte};\n            for (i = 0; i < 8; i = i + 1) begin\n                if (c[0])\n                    c = (c >> 1) ^ 32'hEDB88320;\n                else\n                    c = c >> 1;\n            end\n            crc32_byte = c;\n        end\n    endfunction\n\n    function [3:0] strb_to_nbytes;\n        input [3:0] strb;\n        begin\n            case (strb)\n                4'b0001: strb_to_nbytes = 4'd1;\n                4'b0011: strb_to_nbytes = 4'd2;\n                4'b0111: strb_to_nbytes = 4'd3;\n                4'b1111: strb_to_nbytes = 4'd4;\n                default: strb_to_nbytes = 4'd4;\n            endcase\n        end\n    endfunction\n\n    function [7:0] get_byte;\n        input [31:0] word;\n        input [1:0]  idx;\n        begin\n            case (idx)\n                2'd0: get_byte = word[7:0];\n                2'd1: get_byte = word[15:8];\n                2'd2: get_byte = word[23:16];\n                2'd3: get_byte = word[31:24];\n            endcase\n        end\n    endfunction\n\n    wire [1:0]  cur_byte_idx = nib_idx_q[3:1];\n    wire        cur_nib_half = nib_idx_q[0];\n    wire [7:0]  cur_byte     = get_byte(word_buf_q, cur_byte_idx);\n\n    // ---------------------------------------------------------------\n    // Pop pipeline tracking\n    // ---------------------------------------------------------------\n    // pop_issued_q: set when we assert fifo_rd_pop_r, cleared next cycle\n    // pop_arriving_q: set 1 cycle after pop_issued_q, means data is on fifo_rd_data\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            pop_issued_q  <= 1'b0;\n            pop_arriving_q <= 1'b0;\n        end else begin\n            pop_arriving_q <= pop_issued_q;\n            pop_issued_q   <= fifo_rd_pop_r;\n        end\n    end\n\n    // Capture pre-fetched data when it arrives\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            next_word_buf_q       <= 32'd0;\n            next_word_last_q      <= 1'b0;\n            next_word_nib_total_q <= 4'd0;\n            next_word_valid_q     <= 1'b0;\n        end else begin\n            if (pop_arriving_q && state_q != S_SFD) begin\n                // Capture FIFO data into next_word buffer\n                next_word_buf_q       <= fifo_data;\n                next_word_last_q      <= fifo_last;\n                next_word_nib_total_q <= strb_to_nbytes(fifo_strb) << 1;\n                next_word_valid_q     <= 1'b1;\n            end\n            // Clear when consumed by payload state\n            if (state_q == S_PAYLOAD && nib_idx_q == word_nib_total_q - 4'd1 && !word_last_q && next_word_valid_q) begin\n                next_word_valid_q <= 1'b0;\n            end\n        end\n    end\n\n    // ---------------------------------------------------------------\n    // Main FSM\n    // ---------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state_q          <= S_IDLE;\n            cnt_q            <= 5'd0;\n            mii_txd_q        <= 4'd0;\n            mii_tx_en_q      <= 1'b0;\n            word_buf_q       <= 32'd0;\n            word_last_q      <= 1'b0;\n            word_nib_total_q <= 4'd0;\n            nib_idx_q        <= 4'd0;\n            fifo_rd_pop_r    <= 1'b0;\n            crc_q            <= 32'hFFFFFFFF;\n            crc_out_q        <= 32'd0;\n            ifg_cnt_q        <= 5'd0;\n        end else begin\n            fifo_rd_pop_r <= 1'b0;\n\n            case (state_q)\n                S_IDLE: begin\n                    mii_txd_q   <= 4'd0;\n                    mii_tx_en_q <= 1'b0;\n                    crc_q       <= 32'hFFFFFFFF;\n                    nib_idx_q   <= 4'd0;\n                    if (!fifo_rd_empty) begin\n                        state_q <= S_PREAMBLE;\n                        cnt_q   <= 5'd0;\n                    end\n                end\n\n                S_PREAMBLE: begin\n                    mii_tx_en_q <= 1'b1;\n                    mii_txd_q   <= 4'h5;\n                    // Pop first word at nibble 11 so data is available at nibble 13\n                    // Then we capture at nibble 13 -> SFD transition\n                    if (cnt_q == 5'd11) begin\n                        if (!fifo_rd_empty)\n                            fifo_rd_pop_r <= 1'b1;\n                    end\n                    if (cnt_q == 5'd13) begin\n                        // pop_arriving_q should be set now\n                        // Capture first word directly from FIFO\n                        word_buf_q       <= fifo_data;\n                        word_last_q      <= fifo_last;\n                        word_nib_total_q <= strb_to_nbytes(fifo_strb) << 1;\n                        nib_idx_q        <= 4'd0;\n                        state_q          <= S_SFD;\n                        cnt_q            <= 5'd0;\n                    end else begin\n                        cnt_q <= cnt_q + 1'b1;\n                    end\n                end\n\n                S_SFD: begin\n                    mii_tx_en_q <= 1'b1;\n                    if (cnt_q == 5'd0) begin\n                        mii_txd_q <= 4'h5;\n                        cnt_q     <= 5'd1;\n                    end else begin\n                        mii_txd_q <= 4'hD;\n                        nib_idx_q <= 4'd0;\n                        state_q   <= S_PAYLOAD;\n                    end\n                end\n\n                S_PAYLOAD: begin\n                    mii_tx_en_q <= 1'b1;\n\n                    // Output current nibble\n                    if (!cur_nib_half)\n                        mii_txd_q <= cur_byte[3:0];\n                    else\n                        mii_txd_q <= cur_byte[7:4];\n\n                    // CRC on high nibble\n                    if (cur_nib_half)\n                        crc_q <= crc32_byte(crc_q, cur_byte);\n\n                    // Pre-fetch: issue pop 2 cycles before end of word\n                    // For 8-nibble word: pop at index 5 (8-3=5)\n                    // FIFO processes at index 6, data arrives at index 7\n                    // We capture it into next_word in the separate always block\n                    if (!word_last_q && nib_idx_q == word_nib_total_q - 4'd3) begin\n                        if (!fifo_rd_empty)\n                            fifo_rd_pop_r <= 1'b1;\n                    end\n\n                    // Last nibble of word\n                    if (nib_idx_q == word_nib_total_q - 4'd1) begin\n                        if (word_last_q) begin\n                            if (cur_nib_half)\n                                crc_out_q <= ~crc32_byte(crc_q, cur_byte);\n                            else\n                                crc_out_q <= ~crc_q;\n                            state_q <= S_CRC;\n                            cnt_q   <= 5'd0;\n                        end else if (next_word_valid_q) begin\n                            // Seamless transition to next word\n                            word_buf_q       <= next_word_buf_q;\n                            word_last_q      <= next_word_last_q;\n                            word_nib_total_q <= next_word_nib_total_q;\n                            nib_idx_q        <= 4'd0;\n                        end else if (pop_arriving_q) begin\n                            // Data just arriving this cycle\n                            word_buf_q       <= fifo_data;\n                            word_last_q      <= fifo_last;\n                            word_nib_total_q <= strb_to_nbytes(fifo_strb) << 1;\n                            nib_idx_q        <= 4'd0;\n                        end\n                        // else stall (shouldn't happen with proper pre-fetch)\n                    end else begin\n                        nib_idx_q <= nib_idx_q + 4'd1;\n                    end\n                end\n\n                S_CRC: begin\n                    mii_tx_en_q <= 1'b1;\n                    case (cnt_q[2:0])\n                        3'd0: mii_txd_q <= crc_out_q[3:0];\n                        3'd1: mii_txd_q <= crc_out_q[7:4];\n                        3'd2: mii_txd_q <= crc_out_q[11:8];\n                        3'd3: mii_txd_q <= crc_out_q[15:12];\n                        3'd4: mii_txd_q <= crc_out_q[19:16];\n                        3'd5: mii_txd_q <= crc_out_q[23:20];\n                        3'd6: mii_txd_q <= crc_out_q[27:24];\n                        3'd7: mii_txd_q <= crc_out_q[31:28];\n                    endcase\n                    cnt_q <= cnt_q + 1'b1;\n                    if (cnt_q == 5'd7) begin\n                        state_q   <= S_IFG;\n                       