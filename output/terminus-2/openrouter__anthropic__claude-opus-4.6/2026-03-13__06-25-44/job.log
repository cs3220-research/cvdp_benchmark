 localparam [2:0] S_IDLE     = 3'd0,\n                     S_PREAMBLE = 3'd1,\n                     S_SFD      = 3'd2,\n                     S_PAYLOAD  = 3'd3,\n                     S_CRC      = 3'd4,\n                     S_IFG      = 3'd5;\n\n    reg [2:0]   state_q;\n    reg [4:0]   cnt_q;          // general nibble/cycle counter\n    reg [3:0]   mii_txd_q;\n    reg         mii_tx_en_q;\n\n    // Payload word tracking\n    reg [31:0]  word_buf_q;\n    reg         word_last_q;\n    reg [3:0]   word_nbytes_q;  // number of valid bytes (1-4)\n    reg [3:0]   word_nib_total_q; // total nibbles = nbytes*2\n    reg [3:0]   nib_idx_q;      // nibble index within current word\n    reg         word_valid_q;   // current word_buf is valid\n    reg         pop_pending_q;  // pop issued, data arriving next cycle\n\n    // CRC\n    reg [31:0]  crc_q;\n    reg [31:0]  crc_out_q;      // latched final CRC for transmission\n    reg [4:0]   ifg_cnt_q;\n\n    // FIFO pop\n    reg         fifo_rd_pop_r;\n    assign fifo_rd_pop = fifo_rd_pop_r;\n\n    assign mii_txd_out   = mii_txd_q;\n    assign mii_tx_en_out = mii_tx_en_q;\n\n    // ---------------------------------------------------------------\n    // CRC-32 function: reflected algorithm (polynomial 0xEDB88320)\n    // Feed raw bytes (no bit reversal needed)\n    // ---------------------------------------------------------------\n    function [31:0] crc32_byte;\n        input [31:0] crc_in;\n        input [7:0]  data_byte;\n        reg [31:0] c;\n        integer i;\n        begin\n            c = crc_in ^ {24'h0, data_byte};\n            for (i = 0; i < 8; i = i + 1) begin\n                if (c[0])\n                    c = (c >> 1) ^ 32'hEDB88320;\n                else\n                    c = c >> 1;\n            end\n            crc32_byte = c;\n        end\n    endfunction\n\n    // Count valid bytes from strobe\n    function [3:0] strb_to_nbytes;\n        input [3:0] strb;\n        begin\n            case (strb)\n                4'b0001: strb_to_nbytes = 4'd1;\n                4'b0011: strb_to_nbytes = 4'd2;\n                4'b0111: strb_to_nbytes = 4'd3;\n                4'b1111: strb_to_nbytes = 4'd4;\n                default: strb_to_nbytes = 4'd4;\n            endcase\n        end\n    endfunction\n\n    // Get byte from 32-bit word by index\n    function [7:0] get_byte;\n        input [31:0] word;\n        input [1:0]  idx;\n        begin\n            case (idx)\n                2'd0: get_byte = word[7:0];\n                2'd1: get_byte = word[15:8];\n                2'd2: get_byte = word[23:16];\n                2'd3: get_byte = word[31:24];\n            endcase\n        end\n    endfunction\n\n    // Intermediates for payload\n    wire [1:0]  cur_byte_idx  = nib_idx_q[3:1];\n    wire        cur_nib_half  = nib_idx_q[0]; // 0=low, 1=high\n    wire [7:0]  cur_byte      = get_byte(word_buf_q, cur_byte_idx);\n\n    // ---------------------------------------------------------------\n    // Main FSM\n    // ---------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state_q         <= S_IDLE;\n            cnt_q           <= 5'd0;\n            mii_txd_q       <= 4'd0;\n            mii_tx_en_q     <= 1'b0;\n            word_buf_q      <= 32'd0;\n            word_last_q     <= 1'b0;\n            word_nbytes_q   <= 4'd0;\n            word_nib_total_q <= 4'd0;\n            nib_idx_q       <= 4'd0;\n            word_valid_q    <= 1'b0;\n            pop_pending_q   <= 1'b0;\n            fifo_rd_pop_r   <= 1'b0;\n            crc_q           <= 32'hFFFFFFFF;\n            crc_out_q       <= 32'd0;\n            ifg_cnt_q       <= 5'd0;\n        end else begin\n            fifo_rd_pop_r <= 1'b0;\n\n            case (state_q)\n                // ==================================================\n                S_IDLE: begin\n                    mii_txd_q   <= 4'd0;\n                    mii_tx_en_q <= 1'b0;\n                    crc_q       <= 32'hFFFFFFFF;\n                    word_valid_q <= 1'b0;\n                    pop_pending_q <= 1'b0;\n                    nib_idx_q   <= 4'd0;\n                    if (!fifo_rd_empty) begin\n                        state_q <= S_PREAMBLE;\n                        cnt_q   <= 5'd0;\n                    end\n                end\n\n                // ==================================================\n                S_PREAMBLE: begin\n                    mii_tx_en_q <= 1'b1;\n                    mii_txd_q   <= 4'h5; // 0x55 nibbles\n                    cnt_q       <= cnt_q + 1'b1;\n                    if (cnt_q == 5'd13) begin\n                        // 14 nibbles of preamble done (nibbles 0-13)\n                        state_q <= S_SFD;\n                        cnt_q   <= 5'd0;\n                        // Issue first FIFO pop\n                        if (!fifo_rd_empty) begin\n                            fifo_rd_pop_r <= 1'b1;\n                            pop_pending_q <= 1'b1;\n                        end\n                    end\n                end\n\n                // ==================================================\n                S_SFD: begin\n                    mii_tx_en_q <= 1'b1;\n                    if (cnt_q == 5'd0) begin\n                        mii_txd_q <= 4'h5; // low nibble of 0xD5\n                        cnt_q     <= 5'd1;\n                    end else begin\n                        mii_txd_q <= 4'hD; // high nibble of 0xD5\n                        // Capture popped FIFO data\n                        if (pop_pending_q) begin\n                            word_buf_q       <= fifo_data;\n                            word_last_q      <= fifo_last;\n                            word_nbytes_q    <= strb_to_nbytes(fifo_strb);\n                            word_nib_total_q <= strb_to_nbytes(fifo_strb) << 1;\n                            word_valid_q     <= 1'b1;\n                            pop_pending_q    <= 1'b0;\n                        end\n                        state_q  <= S_PAYLOAD;\n                        nib_idx_q <= 4'd0;\n                        cnt_q    <= 5'd0;\n                    end\n                end\n\n                // ==================================================\n                S_PAYLOAD: begin\n                    mii_tx_en_q <= 1'b1;\n\n                    if (word_valid_q) begin\n                        // Output current nibble\n                        if (!cur_nib_half)\n                            mii_txd_q <= cur_byte[3:0];\n                        else\n                            mii_txd_q <= cur_byte[7:4];\n\n                        // Update CRC on high nibble (complete byte)\n                        if (cur_nib_half) begin\n                            crc_q <= crc32_byte(crc_q, cur_byte);\n                        end\n\n                        // Advance nibble index\n                        if (nib_idx_q == word_nib_total_q - 4'd1) begin\n                            // Finished this word\n                            nib_idx_q <= 4'd0;\n                            if (word_last_q) begin\n                                // Frame payload done -> CRC\n                                // Latch the final CRC (will be updated by last byte's CRC on this cycle if cur_nib_half)\n                                if (cur_nib_half) begin\n                                    crc_out_q <= ~crc32_byte(crc_q, cur_byte);\n                                end else begin\n                                    crc_out_q <= ~crc_q;\n                                end\n                                state_q      <= S_CRC;\n                                cnt_q        <= 5'd0;\n                                word_valid_q <= 1'b0;\n                            end else begin\n                                // Need next word\n                                word_valid_q <= 1'b0;\n                                if (!fifo_rd_empty) begin\n                                    fifo_rd_pop_r <= 1'b1;\n                                    pop_pending_q <= 1'b1;\n                                end\n                            end\n                        end else begin\n                            nib_idx_q <= nib_idx_q + 4'd1;\n                        end\n\n                    end else if (pop_pending_q) begin\n                        // FIFO data arriving this cycle (1 cycle after pop)\n                        word_buf_q       <= fifo_data;\n                        word_last_q      <= fifo_last;\n                        word_nbytes_q    <= strb_to_nbytes(fifo_strb);\n                        word_nib_total_q <= strb_to_nbytes(fifo_strb) << 1;\n                        word_valid_q     <= 1'b1;\n                        pop_pending_q    <= 1'b0;\n                        nib_idx_q        <= 4'd0;\n                        // Send first nibble of new word immediately\n                        mii_txd_q <= fifo_data[3:0];\n                        nib_idx_q <= 4'd1;\n                    end else begin\n                        // Stall: wait for FIFO\n                        if (!fifo_rd_empty) begin\n                            fifo_rd_pop_r <= 1'b1;\n                            pop_pending_q <= 1'b1;\n                        end\n                    end\n                end\n\n                // ==================================================\n                S_CRC: begin\n                    mii_tx_en_q <= 1'b1;\n                    // Send 4 CRC bytes (8 nibbles), low nibble first per byte\n                    // crc_out_q = ~crc_q (already computed)\n                    // Byte order: crc_out_q[7:0], [15:8], [23:16], [31:24]\n                    case (cnt_q[2:0])\n                        3'd0: mii_txd_q <= crc_out_q[3:0];\n                        3'd1: mii_txd_q <= crc_out_q[7:4];\n                        3'd2: mii_txd_q <= crc_out_q[11:8];\n                        3'd3: mii_txd_q <= crc_out_q[15:12];\n                        3'd4: mii_txd_q <= crc_out_q[19:16];\n                        3'd5: mii_txd_q <= crc_out_q[23:20];\n                        3'd6: mii_txd_q <= crc_out_q[27:24];\n                        3'd7: mii_txd_q <= crc_out_q[31:28];\n                    endcase\n\n                    cnt_q <= cnt_q + 1'b1;\n                    if (cnt_q == 5'd7) begin\n                        state_q     <= S_IFG;\n                        ifg_cnt_q   <= 5'd0;\n                    end\n                end\n\n                // ==================================================\n                S_IFG: begin\n                    mii_tx_en_q <= 1'b0;\n                    mii_txd_q   <= 4'd0;\n                    ifg_cnt_q   <= ifg_cnt_q + 1'b1;\n                    if (ifg_cnt_q == 5'd23) begin\n                        state_q <= S_IDLE;\n                    end\n                end\n\n                default: state_q <= S_IDLE;\n            endcase\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
