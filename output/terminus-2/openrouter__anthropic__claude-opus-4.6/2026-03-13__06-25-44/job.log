Sending keys: ["cat > /code/rtl/coeff_update.sv << 'ENDOFFILE'\nmodule coeff_update #(\n    parameter TAP_NUM     = 7,\n    parameter DATA_WIDTH  = 16,\n    parameter COEFF_WIDTH = 16,\n    parameter MU          = 15\n) (\n    input  logic                              clk,\n    input  logic                              rst_n,\n    input  logic signed [DATA_WIDTH-1:0]      data_real  [0:TAP_NUM-1],\n    input  logic signed [DATA_WIDTH-1:0]      data_imag  [0:TAP_NUM-1],\n    input  logic signed [DATA_WIDTH-1:0]      error_real,\n    input  logic signed [DATA_WIDTH-1:0]      error_imag,\n    output logic signed [COEFF_WIDTH-1:0]     coeff_real [0:TAP_NUM-1],\n    output logic signed [COEFF_WIDTH-1:0]     coeff_imag [0:TAP_NUM-1]\n);\n\n    // Internal signals for coefficient update computation\n    // LMS update: w(n+1) = w(n) + mu * e(n) * x(n)\n    // For complex: mu * e * x* (conjugate of x for complex LMS)\n    // But since LMS spec says w(n+1) = w(n) + mu * e(n) * x(n)\n    // Complex multiplication: e * x = (er + j*ei)(xr + j*xi) = (er*xr - ei*xi) + j(er*xi + ei*xr)\n    // mu is implemented as right shift by MU bits\n\n    localparam signed [COEFF_WIDTH-1:0] ONE = (1 <<< (COEFF_WIDTH - 3)); // Q2.13: 1.0 = 8192\n    localparam integer CENTER_TAP = TAP_NUM / 2;\n\n    integer k;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                if (k == CENTER_TAP) begin\n                    coeff_real[k] <= ONE;\n                end else begin\n                    coeff_real[k] <= '0;\n                end\n                coeff_imag[k] <= '0;\n            end\n        end else begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                // Complex multiplication: e(n) * x(n)\n                // (er + j*ei) * (xr + j*xi) = (er*xr - ei*xi) + j(er*xi + ei*xr)\n                // Then scale by mu (right shift by MU)\n                coeff_real[k] <= coeff_real[k] + ((error_real * data_real[k] - error_imag * data_imag[k]) >>> MU);\n                coeff_imag[k] <= coeff_imag[k] + ((error_real * data_imag[k] + error_imag * data_real[k]) >>> MU);\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
