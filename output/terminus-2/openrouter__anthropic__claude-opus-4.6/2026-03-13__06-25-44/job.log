AP+1 edges ago\n    //   desired_pipe[D-1] (from previous edge) corresponds to desired from D edges ago\n    //   For match: D = CENTER_TAP + 1\n    localparam DESIRED_DELAY = CENTER_TAP + 1; // 4\n    logic signed [DATA_WIDTH-1:0] desired_real_pipe [0:DESIRED_DELAY-1];\n    logic signed [DATA_WIDTH-1:0] desired_imag_pipe [0:DESIRED_DELAY-1];\n\n    // =========================================================================\n    // Shift Register\n    // =========================================================================\n    integer i;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= '0;\n                shift_reg_imag[i] <= '0;\n            end\n        end else begin\n            shift_reg_real[0] <= data_in_real;\n            shift_reg_imag[0] <= data_in_imag;\n            for (i = 1; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= shift_reg_real[i-1];\n                shift_reg_imag[i] <= shift_reg_imag[i-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // Desired signal delay pipeline\n    // =========================================================================\n    integer d;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (d = 0; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= '0;\n                desired_imag_pipe[d] <= '0;\n            end\n        end else begin\n            desired_real_pipe[0] <= desired_real;\n            desired_imag_pipe[0] <= desired_imag;\n            for (d = 1; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= desired_real_pipe[d-1];\n                desired_imag_pipe[d] <= desired_imag_pipe[d-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // FIR Filter - Combinational\n    // =========================================================================\n    logic signed [2*DATA_WIDTH-1:0] acc_real;\n    logic signed [2*DATA_WIDTH-1:0] acc_imag;\n\n    integer j;\n    always_comb begin\n        acc_real = '0;\n        acc_imag = '0;\n        for (j = 0; j < TAP_NUM; j = j + 1) begin\n            acc_real = acc_real + coeff_real[j] * shift_reg_real[j] - coeff_imag[j] * shift_reg_imag[j];\n            acc_imag = acc_imag + coeff_real[j] * shift_reg_imag[j] + coeff_imag[j] * shift_reg_real[j];\n        end\n        fir_out_real = acc_real[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n        fir_out_imag = acc_imag[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n    end\n\n    // =========================================================================\n    // Output Register\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            out_real_reg <= '0;\n            out_imag_reg <= '0;\n        end else begin\n            out_real_reg <= fir_out_real;\n            out_imag_reg <= fir_out_imag;\n        end\n    end\n\n    assign data_out_real = out_real_reg;\n    assign data_out_imag = out_imag_reg;\n\n    // =========================================================================\n    // Error Calculation (combinational)\n    // =========================================================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (out_real_reg),\n        .data_imag    (out_imag_reg),\n        .desired_real (desired_real_pipe[DESIRED_DELAY-1]),\n        .desired_imag (desired_imag_pipe[DESIRED_DELAY-1]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================================================\n    // Coefficient Update\n    // =========================================================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_reg_real),\n        .data_imag  (shift_reg_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
