ength;\n                            rd_addr   <= {ADDR_W{1'b0}};\n                            state     <= ST_READ;\n                        end\n                    end\n                end\n\n                ST_READ: begin\n                    // Capture RAM data into register\n                    axis_tdata_reg  <= ram_data1_out;\n                    axis_tvalid_reg <= 1'b1;\n\n                    // Strobe\n                    if (remaining >= 16'd4) begin\n                        axis_tstrb_reg <= 4'hF;\n                    end else begin\n                        case (remaining[1:0])\n                            2'd3: axis_tstrb_reg <= 4'h7;\n                            2'd2: axis_tstrb_reg <= 4'h3;\n                            2'd1: axis_tstrb_reg <= 4'h1;\n                            default: axis_tstrb_reg <= 4'h0;\n                        endcase\n                    end\n\n                    // Last word?\n                    if (remaining <= 16'd4) begin\n                        axis_tlast_reg <= 1'b1;\n                    end else begin\n                        axis_tlast_reg <= 1'b0;\n                    end\n\n                    // Advance address for next word\n                    rd_addr <= rd_addr + 1'b1;\n\n                    state <= ST_PAUSE;\n                end\n\n                ST_PAUSE: begin\n                    axis_tvalid_reg <= 1'b0;\n                    axis_tlast_reg  <= 1'b0;\n\n                    // Decrement remaining\n                    if (remaining >= 16'd4) begin\n                        remaining <= remaining - 16'd4;\n                    end else begin\n                        remaining <= 16'd0;\n                    end\n\n                    if (remaining <= 16'd4) begin\n                        state <= ST_END;\n                    end else begin\n                        state <= ST_READ;\n                    end\n                end\n\n                ST_END: begin\n                    axis_tvalid_reg <= 1'b0;\n     