Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'ENDOFFILE'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    // =========================================================================\n    // Pipeline: 7 clock cycles total latency for HDB3 (encoder_type=3)\n    //   Stage 1: Input synchronization register\n    //   Stage 2: Zero counting + violation/balance detection\n    //   Stage 3 to 3+encoder_type-1: Shift register (encoder_type deep)\n    //            Balance pulse is retroactively inserted at SR head\n    //   Stage 3+encoder_type: AMI pulse encoding + output register\n    //\n    // Total = 1 + 1 + encoder_type + 1 + 1 = encoder_type + 4\n    // For HDB3: 3 + 4 = 7 cycles\n    // For HDB2: 2 + 4 = 6 cycles\n    // =========================================================================\n\n    // Stage 1: Input sync register\n    logic data_s1;\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in)\n            data_s1 <= 1'b0;\n        else if (clk_enable_in)\n            data_s1 <= data_in;\n    end\n\n    // Stage 2: Zero counting and violation marking\n    // zero_count: counts consecutive zeros seen\n    // violation_type: counts normal pulses since last violation (for balance decision)\n    // When zero_count reaches encoder_type, mark as violation\n    // Also determine if balance pulse is needed\n    \n    logic data_s2;          // data going into shift register\n    logic viol_s2;          // violation flag\n    logic need_balance_s2;  // balance pulse needed for this violation\n    \n    reg [3:0] zero_count;\n    reg [7:0] pulse_since_viol; // counts pulses since last violation\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            zero_count <= 0;\n            pulse_since_viol <= 0;\n            data_s2 <= 1'b0;\n            viol_s2 <= 1'b0;\n            need_balance_s2 <= 1'b0;\n        end else if (clk_enable_in) begin\n            if (data_s1 == 1'b1) begin\n                // Input is 1: normal pulse\n                zero_count <= 0;\n                pulse_since_viol <= pulse_since_viol + 1;\n                data_s2 <= 1'b1;\n                viol_s2 <= 1'b0;\n                need_balance_s2 <= 1'b0;\n            end else begin\n                // Input is 0\n                if (zero_count == encoder_type - 1) begin\n                    // Reached max zeros, insert violation\n                    zero_count <= 0;\n                    // Check if balance is needed:\n                    // For HDB3: need balance when pulse_since_viol is even (0,2,4...)\n                    //   even -> B00V pattern, odd -> 000V pattern\n                    // For HDB2: need balance when pulse_since_viol is even\n                    //   even -> B0V, odd -> 00V\n                    need_balance_s2 <= (pulse_since_viol[0] == 1'b0) ? 1'b1 : 1'b0;\n                    pulse_since_viol <= 0;\n                    data_s2 <= 1'b1;  // Violation pulse\n                    viol_s2 <= 1'b1;\n                end else begin\n                    zero_count <= zero_count + 1;\n                    data_s2 <= 1'b0;\n                    viol_s2 <= 1'b0;\n                    need_balance_s2 <= 1'b0;\n                end\n            end\n        end\n    end\n\n    // Stage 3 to 3+encoder_type-1: Shift registers\n    // Data and violation flags shift through encoder_type stages\n    // When a violation exits the SR, if it needs balance, we retroactively\n    // set the first bit of the zero sequence (which is at SR[encoder_type-1])\n    \n    logic [encoder_type-1:0] sr_data;\n    logic [encoder_type-1:0] sr_viol;\n    logic [encoder_type-1:0] sr_balance;\n    \n    // The data entering the shift register and the balance info\n    // When violation+balance enters SR at position [0], we need to mark\n    // that position [encoder_type-1] (the oldest/first zero) should become B\n    // But the B pulse was encoder_type-1 clocks ago...\n    // \n    // Solution: Use the shift register to delay the violation by encoder_type clocks.\n    // When the violation reaches the output of SR, at that same time,\n    // the balance flag also reaches the output. We then look back into the SR\n    // at position [encoder_type-1] to insert B. But that position already shifted out.\n    //\n    // Better approach: When we detect a violation needs balance at stage 2,\n    // we immediately mark the FIRST zero in the sequence. Since the first zero\n    // entered the SR encoder_type-1 clocks ago, it's now at SR[encoder_type-1].\n    // So we can set it directly!\n    \n    // Actually, let's think about this differently.\n    // At the moment we detect the violation (stage 2 output), the first zero\n    // of the sequence entered the SR encoder_type-1 clocks ago.\n    // So it's currently at sr_data[encoder_type-2] (0-indexed, shifting left)\n    // Wait, let me think about shift direction.\n    //\n    // sr_data shifts: new data enters at [0], oldest at [encoder_type-1]\n    // At time T: violation detected, data_s2=1(V), need_balance_s2=1\n    // At time T: sr_data contains the previous encoder_type bits\n    //   sr_data[0] = bit from T-1 (the (encoder_type-1)th zero)\n    //   sr_data[1] = bit from T-2 (the (encoder_type-2)th zero)  \n    //   ...\n    //   sr_data[encoder_type-2] = bit from T-(encoder_type-1) (the 1st zero)\n    //   sr_data[encoder_type-1] = bit from T-encoder_type (bit before zeros)\n    //\n    // So the first zero is at sr_data[encoder_type-2]\n    // We need to change that to a 1 (B pulse)\n    \n    // Let's use a different approach: use a separate balance marker shift register\n    // When need_balance is set, mark the position in the SR\n    \n    // Simplest: when need_balance_s2 is asserted, directly modify sr_data[encoder_type-2]\n    \n    integer i;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            sr_data <= '0;\n            sr_viol <= '0;\n        end else if (clk_enable_in) begin\n            // Shift in new data\n            sr_data[0] <= data_s2;\n            sr_viol[0] <= viol_s2;\n            for (i = 1; i < encoder_type; i = i + 1) begin\n                sr_data[i] <= sr_data[i-1];\n                sr_viol[i] <= sr_viol[i-1];\n            end\n            \n            // If balance is needed, insert B pulse at the first zero position\n            if (need_balance_s2 && viol_s2) begin\n                sr_data[encoder_type-2] <= 1'b1;\n            end\n        end\n    end\n    \n    // Output of shift register\n    logic sr_out_data;\n    logic sr_out_viol;\n    \n    assign sr_out_data = sr_data[encoder_type-1];\n    assign sr_out_viol = sr_viol[encoder_type-1];\n\n    // Stage: AMI encoding\n    // ami_flip: tracks polarity. 0 = next normal pulse is positive, 1 = next is negative\n    // Normal pulse (including B): follows AMI alternation\n    // Violation pulse: SAME polarity as the LAST pulse (violates AMI)\n    //   This means V doesn't toggle ami_flip\n    \n    logic ami_flip;\n    logic p_pre, n_pre;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            ami_flip <= 1'b0;\n            p_pre <= ~pulse_active_state;\n            n_pre <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (sr_out_data) begin\n                if (sr_out_viol) begin\n                    // Violation: same polarity as last pulse\n                    // ami_flip after last pulse: 0 means last was positive, 1 means last was negative\n                    // Wait, ami_flip=0 means NEXT normal is positive, meaning last was negative\n                    // ami_flip=1 means NEXT normal is negative, meaning last was positive\n                    if (ami_flip) begin\n                        // Last normal was positive, so violation = positive\n                        p_pre <= pulse_active_state;\n                        n_pre <= ~pulse_active_state;\n                    end else begin\n                        // Last normal was negative, so violation = negative  \n                        p_pre <= ~pulse_active_state;\n                        n_pre <= pulse_active_state;\n                    end\n                    // Don't toggle ami_flip for violation\n                end else begin\n                    // Normal pulse (data 1 or Balance): alternate polarity\n                    if (ami_flip == 1'b0) begin\n                        p_pre <= pulse_active_state;\n                        n_pre <= ~pulse_active_state;\n                    end else begin\n                        p_pre <= ~pulse_active_state;\n                        n_pre <= pulse_active_state;\n                    end\n                    ami_flip <= ~ami_flip;\n                end\n            end else begin\n                // Zero: no pulse\n                p_pre <= ~pulse_active_state;\n                n_pre <= ~pulse_active_state;\n            end\n        end\n    end\n    \n    // Output gating (adds 1 more register stage)\n    logic p_gated, n_gated;\n    \n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p_gated <= ~pulse_active_state;\n            n_gated <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            if (output_gate_in) begin\n                p_gated <= p_pre;\n                n_gated <= n_pre;\n            end else begin\n                p_gated <= ~pulse_active_state;\n                n_gated <= ~pulse_active_state;\n            end\n        end\n    end\n    \n    assign p_out = p_gated;\n    assign n_out = n_gated;\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
