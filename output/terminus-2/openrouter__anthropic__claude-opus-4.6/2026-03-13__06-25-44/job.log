_clk_i   (clk_in),\n        .rd_rst_i   (rst_in),\n        .rd_pop_i   (fifo_rd_pop),\n        .rd_data_o  (fifo_rd_data),\n        .rd_empty_o (fifo_rd_empty)\n    );\n\n    // ---------------------------------------------------------------\n    // Unpack FIFO read data\n    // ---------------------------------------------------------------\n    wire [31:0] fifo_data  = fifo_rd_data[31:0];\n    wire [3:0]  fifo_strb  = fifo_rd_data[35:32];\n    wire        fifo_last  = fifo_rd_data[36];\n\n    // ---------------------------------------------------------------\n    // TX FSM\n    // ---------------------------------------------------------------\n    localparam [2:0] S_IDLE     = 3'd0,\n                     S_PREAMBLE = 3'd1,\n                     S_SFD      = 3'd2,\n                     S_PAYLOAD  = 3'd3,\n                     S_CRC      = 3'd4,\n                     S_IFG      = 3'd5;\n\n    reg [2:0]   state_q;\n    reg [4:0]   nibble_cnt_q;   // counts nibbles within current phase\n    reg [3:0]   mii_txd_q;\n    reg         mii_tx_en_q;\n\n    // Payload tracking\n    reg [31:0]  word_buf_q;     // current word being serialized\n    reg [3:0]   word_strb_q;    // byte strobes for current word\n    reg         word_last_q;    // last flag for current word\n    reg [3:0]   byte_cnt_q;     // number of valid bytes in current word (1-4)\n    reg [3:0]   nibbles_in_word_q; // total nibbles to send for current word\n    reg [3:0]   payload_nibble_cnt_q; // nibble counter within current word\n    reg         fifo_data_valid_q;    // indicates word_buf has valid data from FIFO\n    reg         fifo_pop_pending_q;   // FIFO pop was issued, waiting for data\n\n    // CRC\n    reg [31:0]  crc_q;\n    reg [4:0]   ifg_cnt_q;\n\n    assign mii_txd_out  = mii_txd_q;\n    assign mii_tx_en_out = mii_tx_en_q;\n\n    // ---------------------------------------------------------------\n    // CRC-32 function (one byte at a time)\n    // Uses Ethernet polynomial 0x04C11DB7 (reflected: 0xEDB88320)\n    // Input byte must be bit-reversed before calling\n    // ---------------------------------------------------------------\n    function [31:0] crc32_byte;\n        input [31:0] crc_in;\n        input [7:0]  data_byte;\n        reg [31:0] crc_tmp;\n        integer i;\n        begin\n            crc_tmp = crc_in ^ {24'h0, data_byte};\n            for (i = 0; i < 8; i = i + 1) begin\n                if (crc_tmp[0])\n                    crc_tmp = (crc_tmp >> 1) ^ 32'hEDB88320;\n                else\n                    crc_tmp = crc_tmp >> 1;\n            end\n            crc32_byte = crc_tmp;\n        end\n    endfunction\n\n    // Bit-reverse a byte\n    function [7:0] reverse_byte;\n        input [7:0] b;\n        begin\n            reverse_byte = {b[0], b[1], b[2], b[3], b[4], b[5], b[6], b[7]};\n        end\n    endfunction\n\n    // Count valid bytes from strobe\n    function [3:0] count_strb_bytes;\n        input [3:0] strb;\n        begin\n            case (strb)\n                4'b0001: count_strb_bytes = 4'd1;\n                4'b0011: count_strb_bytes = 4'd2;\n                4'b0111: count_strb_bytes = 4'd3;\n                4'b1111: count_strb_bytes = 4'd4;\n                default: count_strb_bytes = 4'd4;\n            endcase\n        end\n    endfunction\n\n    // ---------------------------------------------------------------\n    // FIFO pop control\n    // ---------------------------------------------------------------\n    reg fifo_rd_pop_r;\n    assign fifo_rd_pop = fifo_rd_pop_r;\n\n    // ---------------------------------------------------------------\n    // Main TX FSM\n    // ---------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state_q             <= S_IDLE;\n            nibble_cnt_q        <= 5'd0;\n            mii_txd_q           <= 4'd0;\n            mii_tx_en_q         <= 1'b0;\n            word_buf_q          <= 32'