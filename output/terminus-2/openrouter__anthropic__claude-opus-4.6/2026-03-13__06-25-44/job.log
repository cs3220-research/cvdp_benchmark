ipe [0:DESIRED_DELAY-1];\n\n    // =========================================================================\n    // Shift Register\n    // =========================================================================\n    integer i;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= '0;\n                shift_reg_imag[i] <= '0;\n            end\n        end else begin\n            shift_reg_real[0] <= data_in_real;\n            shift_reg_imag[0] <= data_in_imag;\n            for (i = 1; i < TAP_NUM; i = i + 1) begin\n                shift_reg_real[i] <= shift_reg_real[i-1];\n                shift_reg_imag[i] <= shift_reg_imag[i-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // Desired signal delay pipeline\n    // =========================================================================\n    integer d;\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (d = 0; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= '0;\n                desired_imag_pipe[d] <= '0;\n            end\n        end else begin\n            desired_real_pipe[0] <= desired_real;\n            desired_imag_pipe[0] <= desired_imag;\n            for (d = 1; d < DESIRED_DELAY; d = d + 1) begin\n                desired_real_pipe[d] <= desired_real_pipe[d-1];\n                desired_imag_pipe[d] <= desired_imag_pipe[d-1];\n            end\n        end\n    end\n\n    // =========================================================================\n    // FIR Filter - Combinational multiply and accumulate\n    // Complex: y = sum(w_k * x_k)\n    // (wr+j*wi)*(xr+j*xi) = (wr*xr - wi*xi) + j(wr*xi + wi*xr)\n    // =========================================================================\n    logic signed [2*DATA_WIDTH-1:0] acc_real;\n    logic signed [2*DATA_WIDTH-1:0] acc_imag;\n\n    integer j;\n    always_comb begin\n        acc_real = '0;\n        acc_imag = '0;\n        for (j = 0; j < TAP_NUM; j = j + 1) begin\n            acc_real = acc_real + coeff_real[j] * shift_reg_real[j] - coeff_imag[j] * shift_reg_imag[j];\n            acc_imag = acc_imag + coeff_real[j] * shift_reg_imag[j] + coeff_imag[j] * shift_reg_real[j];\n        end\n        // Q2.13 * Q2.13 = Q4.26. Extract Q2.13 by taking bits [28:13]\n        fir_out_real = acc_real[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n        fir_out_imag = acc_imag[FRAC_BITS + DATA_WIDTH - 1 : FRAC_BITS];\n    end\n\n    // =========================================================================\n    // Output Register\n    // =========================================================================\n    logic signed [DATA_WIDTH-1:0] out_real_reg;\n    logic signed [DATA_WIDTH-1:0] out_imag_reg;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            out_real_reg <= '0;\n            out_imag_reg <= '0;\n        end else begin\n            out_real_reg <= fir_out_real;\n            out_imag_reg <= fir_out_imag;\n        end\n    end\n\n    assign data_out_real = out_real_reg;\n    assign data_out_imag = out_imag_reg;\n\n    // =========================================================================\n    // Error Calculation (combinational)\n    // Uses registered output aligned with delayed desired signal\n    // =========================================================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (out_real_reg),\n        .data_imag    (out_imag_reg),\n        .desired_real (desired_real_pipe[DESIRED_DELAY-1]),\n        .desired_imag (desired_imag_pipe[DESIRED_DELAY-1]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================================================\n    // Coefficient Update\n    // =========================================================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_reg_real),\n        .data_imag  (shift_reg_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > /code/rtl/coeff_update.sv << 'ENDOFFILE'\nmodule coeff_update #(\n    parameter TAP_NUM     = 7,\n    parameter DATA_WIDTH  = 16,\n    parameter COEFF_WIDTH = 16,\n    parameter MU          = 15\n) (\n    input  logic                              clk,\n    input  logic                              rst_n,\n    input  logic signed [DATA_WIDTH-1:0]      data_real  [0:TAP_NUM-1],\n    input  logic signed [DATA_WIDTH-1:0]      data_imag  [0:TAP_NUM-1],\n    input  logic signed [DATA_WIDTH-1:0]      error_real,\n    input  logic signed [DATA_WIDTH-1:0]      error_imag,\n    output logic signed [COEFF_WIDTH-1:0]     coeff_real [0:TAP_NUM-1],\n    output logic signed [COEFF_WIDTH-1:0]     coeff_imag [0:TAP_NUM-1]\n);\n\n    localparam FRAC_BITS = DATA_WIDTH - 3; // 13 for Q2.13\n    localparam signed [COEFF_WIDTH-1:0] ONE = (1 <<< FRAC_BITS); // 8192\n    localparam integer CENTER_TAP = TAP_NUM / 2;\n    // mu * e * x: mu divides by 2^MU, e*x is Q2.13*Q2.13=Q4.26\n    // To convert back to Q2.13: shift right by FRAC_BITS (13)\n    // Then apply mu: shift right by MU (15)\n    // Total shift from Q4.26 to Q2.13 with mu: FRAC_BITS + MU = 28\n    localparam integer TOTAL_SHIFT = FRAC_BITS + MU;\n\n    // Use wider intermediate to avoid overflow\n    // 16-bit * 16-bit = 32-bit, two products subtracted/added = 33-bit max\n    localparam WIDE = DATA_WIDTH * 2 + 2; // 34 bits\n\n    logic signed [WIDE-1:0] prod_real;\n    logic signed [WIDE-1:0] prod_imag;\n\n    integer k;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                if (k == CENTER_TAP) begin\n                    coeff_real[k] <= ONE;\n                end else begin\n                    coeff_real[k] <= '0;\n                end\n                coeff_imag[k] <= '0;\n            end\n        end else begin\n            for (k = 0; k < TAP_NUM; k = k + 1) begin\n                // Complex: mu * e(n) * x(n)\n                // (er+j*ei)*(xr+j*xi) = (er*xr - ei*xi) + j(er*xi + ei*xr)\n                prod_real = $signed(error_real) * $signed(data_real[k]) - $signed(error_imag) * $signed(data_imag[k]);\n                prod_imag = $signed(error_real) * $signed(data_imag[k]) + $signed(error_imag) * $signed(data_real[k]);\n                coeff_real[k] <= coeff_real[k] + $signed(prod_real >>> TOTAL_SHIFT);\n                coeff_imag[k] <= coeff_imag[k] + $signed(prod_imag >>> TOTAL_SHIFT);\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
