IZE)+1)] <= INVALID_PTR;\n                        temp_out[i*DATA_WIDTH +: DATA_WIDTH] <= INVALID_KEY;\n                        sorted_out[i*DATA_WIDTH +: DATA_WIDTH] <= INVALID_KEY;\n                    end\n                    if (start) begin\n                        sort_state <= S_INIT;\n                    end\n                end\n\n                S_INIT: begin\n                    if (root != INVALID_PTR) begin\n                        current_node <= root;\n                        sp <= 0;\n                        sort_state <= S_TRAVERSE_LEFT;\n                    end else begin\n                        done <= 1;\n                        sort_state <= S_IDLE;\n                    end\n                end\n\n                S_TRAVERSE_LEFT: begin\n                    if (!traverse_right) begin\n                        if (current_node != INVALID_PTR) begin\n                            stack[sp*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] <= current_node;\n                            sp <= sp + 1;\n                            current_node <= left_child[current_node*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\n                        end else begin\n                            sort_state <= S_PROCESS_NODE;\n                        end\n                    end else begin\n                        // After traverse right, go back to traverse left\n                        traverse_right <= 0;\n                        if (current_node != INVALID_PTR) begin\n                            stack[sp*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] <= current_node;\n                            sp <= sp + 1;\n                            current_node <= left_child[current_node*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\n                        end else begin\n                            sort_state <= S_PROCESS_NODE;\n                        end\n                    end\n                end\n\n                S_PROCESS_NODE: begin\n                    if (sp > 0) begin\n                        sp <= sp - 1;\n                        current_node <= stack[(sp-1)*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\n                        output_index <= output_index + 1;\n                        temp_out[output_index*DATA_WIDTH +: DATA_WIDTH] <= keys[stack[($unsigned(sp)-1)*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)]*DATA_WIDTH +: DATA_WIDTH];\n                        // Go to traverse right\n                        traverse_right <= 1;\n                        sort_state <= S_TRAVERSE_LEFT; // Will handle traverse_right in S_TRAVERSE_LEFT\n                    end else begin\n                        done <= 1;\n                        sort_state <= S_IDLE;\n                        sorted_out <= temp_out;\n                    end\n                end\n\n                default: begin\n                    sort_state <= S_IDLE;\n                end\n            endcase\n        end\n    end\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
