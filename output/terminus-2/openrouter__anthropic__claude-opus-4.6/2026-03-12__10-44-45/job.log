Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'VEOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n    // Latency = encoder_type + 3 clocks\n    // 1(input reg) + (encoder_type+1)(shift reg) + 1(output reg)\n    // AMI logic is combinational on SR output\n\n    localparam SR_DEPTH = encoder_type + 1;\n\n    // Stage 1: Input register\n    logic data_r1;\n\n    // Shift register: [SR_DEPTH-1]=newest, [0]=oldest (read end)\n    logic [SR_DEPTH-1:0] sr_d;  // data bits\n    logic [SR_DEPTH-1:0] sr_v;  // violation markers\n    logic [SR_DEPTH-1:0] sr_b;  // balance markers\n\n    // Zero counter\n    logic [2:0] zero_cnt;\n\n    // Pulse parity since last substitution\n    logic pulse_parity;\n\n    // AMI state: 0=next normal pulse positive, 1=next normal pulse negative\n    logic ami;\n\n    // Combinational AMI outputs\n    logic p_comb, n_comb;\n\n    // Combinational logic for AMI assignment based on sr[0]\n    always_comb begin\n        p_comb = 1'b0;\n        n_comb = 1'b0;\n        if (sr_d[0]) begin\n            if (sr_v[0]) begin\n                // Violation: same polarity as last pulse\n                if (ami) begin\n                    p_comb = 1'b1;  // last was +, V is +\n                end else begin\n                    n_comb = 1'b1;  // last was -, V is -\n                end\n            end else begin\n                // Normal or B pulse: follows AMI\n                if (!ami) begin\n                    p_comb = 1'b1;  // next is +\n                end else begin\n                    n_comb = 1'b1;  // next is -\n                end\n            end\n        end\n    end\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n          