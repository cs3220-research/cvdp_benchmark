begin\n                    if (axis_tready_in) begin\n                        if (!data_valid_pipe) begin\n                            // First cycle: RAM read was issued, wait for data\n                            data_valid_pipe <= 1'b1;\n                            // Advance address for next read\n                            ram_addr1 <= ram_addr1 + 1;\n                        end else begin\n                            // Data from RAM is available\n                            state <= S_UPDATE;\n                            tx_valid <= 1'b1;\n\n                            // Determine remaining bytes\n                            if (bytes_sent < tx_length_reg) begin\n                                // Real data from RAM\n                                tx_data <= ram_data1_out;\n                            end else begin\n                                // Padding region\n                                tx_data <= 32'd0;\n                            end\n\n                            // Compute how many bytes remain after this word\n                            if ((tx_byte_count - bytes_sent) <= 4) begin\n                                tx_strb <= compute_strb(tx_byte_count - bytes_sent);\n                                tx_last <= 1'b1;\n                            end else begin\n                                tx_strb <= 4'b1111;\n                                tx_last <= 1'b0;\n                            end\n                        end\n                    end\n                end\n\n                // ------------------------------------------------\n                // UPDATE: Update counters, check if done\n                // ------------------------------------------------\n                S_UPDATE: begin\n                    tx_valid <= 1'b0;\n                    tx_last  <= 1'b0;\n\n                    // Update byte counter\n                    if ((tx_byte_count - bytes_sent) >= 4)\n                        bytes_sent <= bytes_sent + 32'd4;\n      