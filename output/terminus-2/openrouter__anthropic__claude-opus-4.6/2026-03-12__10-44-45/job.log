Sending keys: ["cat > /code/rtl/hdbn_decoder.sv << 'VEOF'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n    // Latency = encoder_type + 3 clocks\n    // 1(input reg) + (encoder_type+1)(shift reg) + 1(output reg)\n\n    localparam SR_DEPTH = encoder_type + 1;\n\n    // Stage 1: Input register (normalize to active-high)\n    logic p_r1, n_r1;\n\n    // Shift registers for P and N pulses\n    logic [SR_DEPTH-1:0] sr_p;\n    logic [SR_DEPTH-1:0] sr_n;\n\n    // Polarity tracking for violation detection\n    // last_polarity: 0=last pulse was negative, 1=last pulse was positive\n    logic last_polarity;\n    logic last_polarity_valid;  // have we seen any pulse yet?\n\n    // Zero counter for error detection\n    logic [2:0] dec_zero_cnt;\n\n    // Violation detection at SR output\n    logic is_pulse;      // any pulse at sr[0]\n    logic is_positive;   // positive pulse at sr[0]\n    logic is_negative;   // negative pulse at sr[0]\n    logic is_violation;  // violation detected at sr[0]\n\n    // Error signals\n    logic pulse_error;   // simultaneous P and N\n    logic violation_error;\n    logic zero_error;    // too many consecutive zeros\n\n    // Data reconstruction\n    logic data_comb;\n    logic error_comb;\n\n    // Combinational violation detection and data reconstruction\n    always_comb begin\n        is_positive = sr_p[0];\n        is_negative = sr_n[0];\n        is_pulse    = is_positive || is_negative;\n\n        // Violation: same polarity as last pulse\n        is_violation = 1'b0;\n        if (is_pulse && last_polarity_valid) begin\n            if (is_positive && last_polarity)  // both positive\n                is_violation = 1'b1;\n            if (is_negative && !last_polarity)  // both negative\n                is_violation = 1'b1;\n        end\n\n        // Pulse error: both P and N active simultaneously\n        pulse_error = is_positive && is_negative;\n\n        // Data output: pulse = 1, no pulse = 0\n        // But V pulses should be stripped (output 0)\n        // And B pulses preceding V should also be stripped\n        // For now, output 1 for any pulse, 0 for no pulse\n        // Violation stripping is handled by checking if this is V\n        data_comb = is_pulse && !is_violation;\n\n        // For B pulse stripping in B00V/B0V:\n        // B is at SR[SR_DEPTH-1] when V is at SR[0]\n        // We need to retroactively clear B when V is detected\n        // This is handled by checking SR[SR_DEPTH-1] when V detected\n\n        // Error: zero count exceeded\n        zero_error = (dec_zero_cnt > encoder_type[2:0]);\n\n        // Combined error\n        error_comb = pulse_error || violation_error || zero_error;\n    end\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p_r1              <= 1'b0;\n            n_r1              <= 1'b0;\n            sr_p              <= '0;\n            sr_n              <= '0;\n            last_polarity     <= 1'b0;\n            last_polarity_valid <= 1'b0;\n            dec_zero_cnt      <= '0;\n            violation_error   <= 1'b0;\n            data_out          <= 1'b0;\n            code_error_out    <= 1'b0;\n        end else if (clk_enable_in) begin\n\n            // === Stage 1: Input register with normalization ===\n            p_r1 <= (p_in == pulse_active_state) ? 1'b1 : 1'b0;\n            n_r1 <= (n_in == pulse_active_state) ? 1'b1 : 1'b0;\n\n            // === Stage 2: Shift register ===\n            for (int i = 0; i < SR_DEPTH - 1; i++) begin\n                sr_p[i] <= sr_p[i+1];\n                sr_n[i] <= sr_n[i+1];\n            end\n            sr_p[SR_DEPTH-1] <= p_r1;\n            sr_n[SR_DEPTH-1] <= n_r1;\n\n            // === Polarity tracking ===\n            if (is_pulse && !pulse_error) begin\n                last_polarity <= is_positive;\n                last_polarity_valid <= 1'b1;\n            end\n\n            // === Zero counting ===\n            if (is_pulse) begin\n                dec_zero_cnt <= '0;\n            end else begin\n                if (dec_zero_cnt <= encoder_type[2:0] + 1)\n                    dec_zero_cnt <= dec_zero_cnt + 1'b1;\n            end\n\n            // === Violation error tracking ===\n            violation_error <= 1'b0;  // default\n            // A violation that doesn't match expected pattern is an error\n            // For proper HDBn, violations should come at regular intervals\n            // For simplicity, we flag violation_error if violation polarity\n            // doesn't alternate (consecutive violations of same polarity)\n\n            // === Output: data and error ===\n            // When V detected at sr[0], output 0 for V position\n            // Also need to suppress B pulse that was already output\n            // Since B was output SR_DEPTH-1 clocks ago, we can't undo it.\n            // Instead, use the SR to detect the full pattern.\n\n            if (is_violation) begin\n                // V detected: output 0 (strip violation)\n                data_out <= 1'b0;\n                // Check if there's a B pulse at SR_DEPTH-1 positions back\n                // If so, we need to signal that B was also a substitution\n                // But B was already output... we need a different approach.\n                // Use a delayed correction: flag that B was part of substitution\n            end else begin\n                data_out <= data_comb;\n            end\n\n            code_error_out <= pulse_error || zero_error;\n\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
