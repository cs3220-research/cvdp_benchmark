============================================================\ntop_phase_rotation #(\n   .NBW_ANG     (NBW_PHASE_SAT),\n   .NBW_COS     (NBW_COS),\n   .NBW_IN_DATA (NBW_IN),\n   .NS_IN       (1)\n) u_top_phase_rotation (\n   .clk       (clk),\n   .i_data_re (data_i_delayed),\n   .i_data_im (data_q_delayed),\n   .i_angle   (phase_div4_sat),\n   .o_data_re (rot_data_i),\n   .o_data_im (rot_data_q)\n);\n\n// ============================================================\n// Output assignment\n// ============================================================\nassign o_data_i = rot_data_i;\nassign o_data_q = rot_data_q;\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
