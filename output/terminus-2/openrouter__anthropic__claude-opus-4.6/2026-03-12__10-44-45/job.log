  wire [ADDR_W-1:0] ram_addr0;\n    wire [WIDTH-1:0]  ram_data0_in;\n    wire              ram_wr0;\n    wire [WIDTH-1:0]  ram_data0_out;\n\n    // Port 1: Transmit side\n    reg  [ADDR_W-1:0] ram_addr1;\n    wire [WIDTH-1:0]  ram_data1_out;\n\n    assign ram_addr0    = cfg_addr_in[ADDR_W+1:2]; // word-aligned: addr >> 2\n    assign ram_data0_in = cfg_data_wr_in;\n    assign ram_wr0      = cfg_wr_in && cfg_is_ram;\n\n    ethernet_dp_ram #(\n        .WIDTH  (WIDTH),\n        .ADDR_W (ADDR_W)\n    ) u_dp_ram (\n        .clk0_in   (clk_in),\n        .addr0_in  (ram_addr0),\n        .data0_in  (ram_data0_in),\n        .wr0_in    (ram_wr0),\n        .addr1_in  (ram_addr1),\n        .data1_in  (32'd0),\n        .wr1_in    (1'b0),\n        .data0_out (ram_data0_out),\n        .data1_out (ram_data1_out)\n    );\n\n    // ---------------------------------------------------------------\n    // Configuration Read Mux\n    // ---------------------------------------------------------------\n    reg [31:0] cfg_data_rd_reg;\n    assign cfg_data_rd_out = cfg_data_rd_reg;\n\n    always @(*) begin\n        case (cfg_addr_in[15:0])\n            16'h07F4: cfg_data_rd_reg = tx_length_reg;\n            16'h07F8: cfg_data_rd_reg = irq_enable_reg;\n            16'h07FC: cfg_data_rd_reg = tx_control_reg;\n            default:  cfg_data_rd_reg = ram_data0_out;\n        endcase\n    end\n\n    // ---------------------------------------------------------------\n    // Transmit FSM\n    // ---------------------------------------------------------------\n    reg [1:0]  state;\n    reg [31:0] tx_byte_count;     // total bytes to transmit (with padding)\n    reg [31:0] bytes_sent;        // bytes sent so far\n    reg [ADDR_W-1:0] tx_addr;    // current word address in RAM\n    reg        tx_valid;\n    reg [31:0] tx_data;\n    reg [3:0]  tx_strb;\n    reg        tx_last;\n    reg        interrupt_reg;\n    reg        data_valid_pipe;   // pipeline stage for RAM read latency\n\n    assign axis_tvalid_out = tx_valid;\n    assign axis_tdata_out  = tx_data;\n    assign axis_tstrb_out  = tx_strb;\n    assign axis_tlast_out  = tx_last;\n    assign interrupt_out   = interrupt_reg;\n\n    // Effective length: max(tx_length_reg, 64)\n    wire [31:0] effective_length = (tx_length_reg < 32'd64) ? 32'd64 : tx_length_reg;\n\n    // Compute strobe for a given remaining byte count\n    function [3:0] compute_strb;\n        input [31:0] remaining;\n        begin\n            if (remaining >= 4)\n                compute_strb = 4'b1111;\n            else begin\n                case (remaining[1:0])\n                    2'd1: compute_strb = 4'b0001;\n                    2'd2: compute_strb = 4'b0011;\n                    2'd3: compute_strb = 4'b0111;\n                    default: compute_strb = 4'b1111;\n                endcase\n            end\n        end\n    endfunction\n\n    // ---------------------------------------------------------------\n    // Main FSM\n    // ---------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state           <= S_IDLE;\n            tx_length_reg   <= 32'd0;\n            irq_enable_reg  <= 32'd0;\n            tx_control_reg  <= 32'd0;\n            tx_byte_count   <= 32'd0;\n            bytes_sent      <= 32'd0;\n            tx_addr         <= {ADDR_W{1'b0}};\n            ram_addr1       <= {ADDR_W{1'b0}};\n            tx_valid        <= 1'b0;\n            tx_data         <= 32'd0;\n            tx_strb         <= 4'b0000;\n            tx_last         <= 1'b0;\n            interrupt_reg   <= 1'b0;\n            data_valid_pipe <= 1'b0;\n        end else begin\n            // Default: clear interrupt after one cycle\n            if (interrupt_reg)\n                interrupt_reg <= 1'b0;\n\n            // Configuration register writes (active in IDLE or when not transmitting)\n            if (cfg_wr_in) begin\n                if (cfg_is_length)\n    