Sending keys: ["cat > /code/rtl/event_scheduler.sv << 'RTLEOF'\n`timescale 1ns/1ps\n\nmodule event_scheduler #(\n    parameter MAX_EVENTS      = 16,\n    parameter TIMESTAMP_WIDTH  = 16,\n    parameter PRIORITY_WIDTH   = 4,\n    parameter TIME_INCREMENT   = 10\n) (\n    input  wire                          clk,\n    input  wire                          reset,\n    input  wire                          add_event,\n    input  wire                          cancel_event,\n    input  wire [3:0]                    event_id,\n    input  wire [TIMESTAMP_WIDTH-1:0]    timestamp,\n    input  wire [PRIORITY_WIDTH-1:0]     priority_in,\n    output reg                           event_triggered,\n    output reg  [3:0]                    triggered_event_id,\n    output reg                           error,\n    output reg  [TIMESTAMP_WIDTH-1:0]    current_time\n);\n\n    // Event storage arrays\n    reg [TIMESTAMP_WIDTH-1:0] event_timestamps [0:MAX_EVENTS-1];\n    reg [PRIORITY_WIDTH-1:0]  event_priorities [0:MAX_EVENTS-1];\n    reg                       event_valid      [0:MAX_EVENTS-1];\n\n    // Temporary arrays for atomic state updates\n    reg [TIMESTAMP_WIDTH-1:0] tmp_event_timestamps [0:MAX_EVENTS-1];\n    reg [PRIORITY_WIDTH-1:0]  tmp_event_priorities [0:MAX_EVENTS-1];\n    reg                       tmp_event_valid      [0:MAX_EVENTS-1];\n    reg [TIMESTAMP_WIDTH-1:0] tmp_current_time;\n\n    // Internal variables for event selection\n    integer i;\n    reg                       found;\n    reg [3:0]                 best_id;\n    reg [PRIORITY_WIDTH-1:0]  best_priority;\n\n    always @(posedge clk) begin\n        if (reset) begin\n            // Reset all state\n            current_time       <= {TIMESTAMP_WIDTH{1'b0}};\n            event_triggered    <= 1'b0;\n            triggered_event_id <= 4'b0;\n            error              <= 1'b0;\n            for (i = 0; i < MAX_EVENTS; i = i + 1) begin\n                event_timestamps[i] <= {TIMESTAMP_WIDTH{1'b0}};\n                event_priorities[i] <= {PRIORITY_WIDTH{1'b0}};\n                event_valid[i]      <= 1'b0;\n            end\n        end else begin\n            // Step 1: Create temporary copies of all arrays\n            for (i = 0; i < MAX_EVENTS; i = i + 1) begin\n                tmp_event_timestamps[i] = event_timestamps[i];\n                tmp_event_priorities[i] = event_priorities[i];\n                tmp_event_valid[i]      = event_valid[i];\n            end\n\n            // Step 2: Increment time\n            tmp_current_time = current_time + TIME_INCREMENT;\n\n            // Step 3: Default outputs\n            error              = 1'b0;\n            event_triggered    <= 1'b0;\n            triggered_event_id <= 4'b0;\n\n            // Step 4: Handle event addition\n            if (add_event) begin\n                if (tmp_event_valid[event_id]) begin\n                    // Slot already occupied - signal error\n                    error = 1'b1;\n                end else begin\n                    // Add the event\n                    tmp_event_timestamps[event_id] = timestamp;\n                    tmp_event_priorities[event_id] = priority_in;\n                    tmp_event_valid[event_id]      = 1'b1;\n                end\n            end\n\n            // Step 5: Handle event cancellation\n            if (cancel_event) begin\n                if (!tmp_event_valid[event_id]) begin\n                    // Event not active - signal error\n                    error = 1'b1;\n                end else begin\n                    // Cancel the event\n                    tmp_event_valid[event_id] = 1'b0;\n                end\n            end\n\n            // Step 6: Event selection - find eligible event with highest priority\n            found         = 1'b0;\n            best_id       = 4'b0;\n            best_priority = {PRIORITY_WIDTH{1'b0}};\n\n            for (i = 0; i < MAX_EVENTS; i = i + 1) begin\n                if (tmp_event_valid[i] && (tmp_event_timestamps[i] <= tmp_current_time)) begin\n                    if (!found || (tmp_event_priorities[i] > best_priority)) begin\n                        found         = 1'b1;\n                        best_id       = i[3:0];\n                        best_priority = tmp_event_priorities[i];\n                    end\n                end\n            end\n\n            // Step 7: Trigger the selected event\n            if (found) begin\n                event_triggered    <= 1'b1;\n                triggered_event_id <= best_id;\n                tmp_event_valid[best_id] = 1'b0;\n            end\n\n            // Step 8: Commit temporary state back to main registers\n            current_time <= tmp_current_time;\n            for (i = 0; i < MAX_EVENTS; i = i + 1) begin\n                event_timestamps[i] <= tmp_event_timestamps[i];\n                event_priorities[i] <= tmp_event_priorities[i];\n                event_valid[i]      <= tmp_event_valid[i];\n            end\n\n            // Commit error (use non-blocking for registered output)\n            error <= error;\n        end\n    end\n\nendmodule\nRTLEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
