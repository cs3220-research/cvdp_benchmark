dge clk or posedge rst) begin\n        if (rst) begin\n            cycle_counter     <= 0;\n            running           <= 0;\n            match_valid       <= 0;\n            matched_price     <= 0;\n            done              <= 0;\n            latency_error     <= 0;\n            best_bid          <= 0;\n            best_ask          <= 0;\n            sort_results_valid <= 0;\n        end else begin\n            // Default: deassert done and match_valid each cycle\n            done        <= 0;\n            match_valid <= 0;\n            matched_price <= 0;\n            latency_error <= 0;\n            sort_results_valid <= 0;\n\n            if (start && !running) begin\n                // Start the latency counter\n                running       <= 1;\n                cycle_counter <= 1;\n            end else if (running) begin\n                cycle_counter <= cycle_counter + 1;\n\n                // When both sorters are done, capture the best bid and best ask\n                if (bid_sort_done && ask_sort_done) begin\n                    best_bid <= sorted_bids[7*PRICE_WIDTH +: PRICE_WIDTH]; // highest bid (index 7)\n                    best_ask <= sorted_asks[0 +: PRICE_WIDTH];             // lowest ask (index 0)\n                    sort_results_valid <= 1;\n                end\n\n                // At exactly cycle 21, produce output\n                if (cycle_counter == 21) begin\n                    done    <= 1;\n                    running <= 0;\n                    cycle_counter <= 0;\n\n                    // Check latency\n                    if (cycle_counter != 21) begin\n                        latency_error <= 1;\n                    end else begin\n                        latency_error <= 0;\n                    end\n\n                    // Perform matching using registered values\n                    if (best_bid >= best_ask) begin\n                        match_valid   <= 1;\n                        matched_price <= best_ask;\n                    end else begin\n                        match_valid   <= 0;\n                        matched_price <= 0;\n                    end\n                end\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
