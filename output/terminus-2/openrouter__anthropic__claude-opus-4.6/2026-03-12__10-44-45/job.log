Sending keys: ["cat > /code/rtl/csr_apb_interface.sv << 'ENDOFFILE'\nmodule csr_apb_interface (\n    input  logic        pclk,\n    input  logic        presetn,\n    input  logic        pselx,\n    input  logic        penable,\n    input  logic        pwrite,\n    input  logic [31:0] pwdata,\n    input  logic [31:0] paddr,\n    output logic [31:0] prdata,\n    output logic        pslverr,\n    output logic [1:0]  state_out\n);\n\n    // Register addresses\n    localparam DATA_REG_ADDR      = 32'h10;\n    localparam CONTROL_REG_ADDR   = 32'h14;\n    localparam INTERRUPT_REG_ADDR = 32'h18;\n    localparam ISR_REG_ADDR       = 32'h1C;\n\n    // FSM states\n    typedef enum logic [1:0] {\n        IDLE        = 2'b00,\n        SETUP       = 2'b01,\n        READ_STATE  = 2'b10,\n        WRITE_STATE = 2'b11\n    } state_t;\n\n    state_t current_state, next_state;\n\n    // Internal registers\n    logic [31:0] data_reg;\n    logic [31:0] control_reg;\n    logic [31:0] interrupt_reg;\n    logic [31:0] isr_reg;\n\n    // Latched transaction info\n    logic [31:0] addr_latched;\n    logic [31:0] wdata_latched;\n    logic        pwrite_latched;\n\n    // Debug output\n    assign state_out = current_state;\n\n    // FSM: State register\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn)\n            current_state <= IDLE;\n        else\n            current_state <= next_state;\n    end\n\n    // FSM: Next state logic\n    always_comb begin\n        next_state = current_state;\n        case (current_state)\n            IDLE: begin\n                if (pselx && !penable)\n                    next_state = SETUP;\n                else\n                    next_state = IDLE;\n            end\n            SETUP: begin\n                if (pselx && penable) begin\n                    if (pwrite_latched)\n                        next_state = WRITE_STATE;\n                    else\n                        next_state = READ_STATE;\n                end else\n                    next_state = SETUP;\n            end\n            READ_STATE: begin\n                next_state = IDLE;\n            end\n            WRITE_STATE: begin\n                next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    // Latch address and write data during SETUP phase entry\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            addr_latched   <= 32'b0;\n            wdata_latched  <= 32'b0;\n            pwrite_latched <= 1'b0;\n        end else if (current_state == IDLE && pselx && !penable) begin\n            addr_latched   <= paddr;\n            wdata_latched  <= pwdata;\n            pwrite_latched <= pwrite;\n        end\n    end\n\n    // Register write logic\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            data_reg      <= 32'b0;\n            control_reg   <= 32'b0;\n            interrupt_reg <= 32'b0;\n            isr_reg       <= 32'b0;\n        end else if (current_state == SETUP && pselx && penable && pwrite_latched) begin\n            case (addr_latched)\n                DATA_REG_ADDR:      data_reg      <= wdata_latched;\n                CONTROL_REG_ADDR:   control_reg   <= wdata_latched;\n                INTERRUPT_REG_ADDR: begin\n                    interrupt_reg <= wdata_latched;\n                    // Clear ISR bits where interrupt enable bits are written as 1\n                    isr_reg <= isr_reg & ~wdata_latched;\n                end\n                ISR_REG_ADDR: begin\n                    // Write protected - do nothing\n                end\n                default: ;\n            endcase\n        end\n    end\n\n    // Read data output\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            prdata <= 32'b0;\n        end else if (current_state == SETUP && pselx && penable && !pwrite_latched) begin\n            case (addr_latched)\n                DATA_REG_ADDR:      prdata <= data_reg;\n                CONTROL_REG_ADDR:   prdata <= control_reg;\n                INTERRUPT_REG_ADDR: prdata <= interrupt_reg;\n                ISR_REG_ADDR:       prdata <= isr_reg;\n                default:            prdata <= 32'b0;\n            endcase\n        end\n    end\n\n    // Slave error for write-protected ISR_REG\n    // Set when attempting to write to ISR_REG, hold value otherwise\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            pslverr <= 1'b0;\n        end else if (current_state == SETUP && pselx && penable && pwrite_latched && addr_latched == ISR_REG_ADDR) begin\n            pslverr <= 1'b1;\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
