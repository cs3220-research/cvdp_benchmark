size_in;\n                            held_amp  <= amp_in;\n                            held_dc   <= dc_in;\n                            state     <= RELEASE;\n                        end\n                    end\n                end\n                RELEASE: begin\n                    state <= IDLE;\n                end\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\n    // Combinational output logic\n    always @(*) begin\n        // Defaults\n        rlen_out = rlen_in;\n        size_out = size_in;\n        amp_out  = amp_in;\n        den_out  = den_in;\n        dc_out   = dc_in;\n\n        case (state)\n            IDLE: begin\n                if (den_in && rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                    // Suppress (15,0)\n                    den_out = 1'b0;\n                    dc_out  = 1'b0;\n                end else begin\n                    // Pass through\n                    rlen_out = rlen_in;\n                    size_out = size_in;\n                    amp_out  = amp_in;\n                    den_out  = den_in;\n                    dc_out   = dc_in;\n                end\n            end\n            HOLD: begin\n                if (den_in) begin\n                    if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                        // Another ZRL - suppress\n                        den_out = 1'b0;\n                        dc_out  = 1'b0;\n                    end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                        // EOB - pass through\n                        rlen_out = 4'd0;\n                        size_out = 4'd0;\n                        amp_out  = 12'd0;\n                        den_out  = 1'b1;\n                        dc_out   = 1'b0;\n                    end else begin\n                        // Non-ZRL follows suppressed ZRL - emit (15,0)\n                        rlen_out = 4'd15;\n                        size_out = 4'd0;\n                        amp_out  = 12'd0;\n                        den_out  = 1'b1;\n                        dc_out   = 1'b0;\n                    end\n                end else begin\n                    // No valid input\n                    den_out = 1'b0;\n                    dc_out  = 1'b0;\n                end\n            end\n            RELEASE: begin\n                // Emit saved data\n                rlen_out = held_rlen;\n                size_out = held_size;\n                amp_out  = held_amp;\n                den_out  = 1'b1;\n                dc_out   = held_dc;\n            end\n            default: begin\n                den_out = 1'b0;\n                dc_out  = 1'b0;\n            end\n        endcase\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
