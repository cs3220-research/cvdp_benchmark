 if (digit_count == PASSWORD_LENGTH) begin\n            next_state = CHECK_PASS;\n          end else begin\n            next_state = PASSWORD_FAIL;\n          end\n        end\n      end\n\n      CHECK_PASS: begin\n        if (entered_password == stored_password) begin\n          next_state = PASSWORD_OK;\n        end else begin\n          next_state = PASSWORD_FAIL;\n        end\n      end\n\n      PASSWORD_OK: begin\n        next_state = IDLE;\n      end\n\n      PASSWORD_FAIL: begin\n        if (fail_count >= (MAX_TRIALS - 1)) begin\n          next_state = LOCKED_OUT;\n        end else begin\n          next_state = IDLE;\n        end\n      end\n\n      LOCKED_OUT: begin\n        if (admin_override) begin\n          next_state = PASSWORD_OK;\n        end\n      end\n\n      ADMIN_MODE: begin\n        if (new_password_valid) begin\n          next_state = IDLE;\n        end\n      end\n\n      default: next_state = IDLE;\n    endcase\n  end\n\n  // Datapath: entered_password and digit_count\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      entered_password <= '0;\n      digit_count <= 0;\n    end else begin\n      case (state)\n        IDLE: begin\n          entered_password <= '0;\n          digit_count <= 0;\n          if (key_valid && key_input <= 4'd9) begin\n            entered_password[3:0] <= key_input;\n            digit_count <= 1;\n          end\n        end\n\n        ENTER_PASS: begin\n          if (key_valid && key_input <= 4'd9 && !confirm) begin\n            entered_password <= {entered_password[(PASSWORD_LENGTH*4-5):0], key_input};\n            digit_count <= digit_count + 1;\n          end\n        end\n\n        PASSWORD_OK: begin\n          entered_password <= '0;\n          digit_count <= 0;\n        end\n\n        PASSWORD_FAIL: begin\n          entered_password <= '0;\n          digit_count <= 0;\n        end\n\n        default: ;\n      endcase\n    end\n  end\n\n  // Datapath: stored_password\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      stored_password <= DEFAULT_PASSWORD;\n    end else begin\n      if (state == ADMIN_MODE && new_password_valid) begin\n        stored_password <= new_password;\n      end\n    end\n  end\n\n  // Datapath: fail_count\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      fail_count <= 0;\n    end else begin\n      if (state == PASSWORD_FAIL) begin\n        fail_count <= fail_count + 1;\n      end else if (admin_override) begin\n        fail_count <= 0;\n      end else if (state == PASSWORD_OK) begin\n        fail_count <= 0;\n      end\n    end\n  end\n\n  // Output: door_unlock\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      door_unlock <= 1'b0;\n    end else begin\n      if (state == PASSWORD_OK) begin\n        door_unlock <= 1'b1;\n      end else begin\n        door_unlock <= 1'b0;\n      end\n    end\n  end\n\n  // Output: lockout\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      lockout <= 1'b0;\n    end else begin\n      if (state == PASSWORD_FAIL && (fail_count >= (MAX_TRIALS - 1))) begin\n        lockout <= 1'b1;\n      end else if (admin_override) begin\n        lockout <= 1'b0;\n      end\n    end\n  end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
