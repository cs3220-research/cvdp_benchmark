Sending keys: ["cat > /code/rtl/nbit_swizzling.sv << 'ENDOFFILE'\n//=============================================================================\n// Module: nbit_swizzling\n// Description: Parameterizable bit-swizzling (reversal) and Gray code\n//              conversion module. Performs various bit reversal operations\n//              on an n-bit input data vector based on a 2-bit selection\n//              signal, then generates a Gray-coded version of the result.\n//\n// Parameters:\n//   DATA_WIDTH - Width of input/output data buses (default: 64)\n//\n// Ports:\n//   data_in  [DATA_WIDTH-1:0] - Input data bus\n//   sel      [1:0]            - Reversal mode selection\n//   data_out [DATA_WIDTH-1:0] - Swizzled (reversed) output\n//   gray_out [DATA_WIDTH-1:0] - Gray code of data_out\n//\n// Selection Modes:\n//   sel = 2'b00 : Reverse entire input (full bit reversal)\n//   sel = 2'b01 : Split into 2 halves, reverse each half\n//   sel = 2'b10 : Split into 4 quarters, reverse each quarter\n//   sel = 2'b11 : Split into 8 eighths, reverse each eighth\n//   default     : Pass-through (data_out = data_in)\n//=============================================================================\n\nmodule nbit_swizzling #(\n    parameter DATA_WIDTH = 64\n) (\n    input  logic [DATA_WIDTH-1:0] data_in,\n    input  logic [1:0]            sel,\n    output logic [DATA_WIDTH-1:0] data_out,\n    output logic [DATA_WIDTH-1:0] gray_out\n);\n\n    //=========================================================================\n    // Internal signals for each swizzling mode\n    //=========================================================================\n    logic [DATA_WIDTH-1:0] reversed_full;     // sel=00: full reversal\n    logic [DATA_WIDTH-1:0] reversed_half;     // sel=01: half reversal\n    logic [DATA_WIDTH-1:0] reversed_quarter;  // sel=10: quarter reversal\n    logic [DATA_WIDTH-1:0] reversed_eighth;   // sel=11: eighth reversal\n\n    //=========================================================================\n    // Segment width calculations\n    //=========================================================================\n    localparam HALF_WIDTH    = DATA_WIDTH / 2;\n    localparam QUARTER_WIDTH = DATA_WIDTH / 4;\n    localparam EIGHTH_WIDTH  = DATA_WIDTH / 8;\n\n    //=========================================================================\n    // sel = 2'b00: Full Bit Reversal\n    // Reverse the entire input vector. Bit 0 of data_out gets bit\n    // DATA_WIDTH-1 of data_in, bit 1 gets DATA_WIDTH-2, etc.\n    //=========================================================================\n    genvar i;\n    generate\n        for (i = 0; i < DATA_WIDTH; i = i + 1) begin : gen_full_reverse\n            assign reversed_full[i] = data_in[DATA_WIDTH - 1 - i];\n        end\n    endgenerate\n\n    //=========================================================================\n    // sel = 2'b01: Half-Swizzle\n    // Split input into two halves and reverse bits within each half.\n    // Lower half [HALF_WIDTH-1:0] is reversed independently.\n    // Upper half [DATA_WIDTH-1:HALF_WIDTH] is reversed independently.\n    //=========================================================================\n    genvar h;\n    generate\n        for (h = 0; h < 2; h = h + 1) begin : gen_half_reverse\n            genvar hj;\n            for (hj = 0; hj < HALF_WIDTH; hj = hj + 1) begin : gen_half_bits\n                assign reversed_half[h * HALF_WIDTH + hj] = data_in[h * HALF_WIDTH + (HALF_WIDTH - 1 - hj)];\n            end\n        end\n    endgenerate\n\n    //=========================================================================\n    // sel = 2'b10: Quarter-Swizzle\n    // Split input into four quarters and reverse bits within each quarter.\n    //=========================================================================\n    genvar q;\n    generate\n        for (q = 0; q < 4; q = q + 1) begin : gen_quarter_reverse\n            genvar qj;\n            for (qj = 0; qj < QUARTER_WIDTH; qj = qj + 1) begin : gen_quarter_bits\n                assign reversed_quarter[q * QUARTER_WIDTH + qj] = data_in[q * QUARTER_WIDTH + (QUARTER_WIDTH - 1 - qj)];\n            end\n        end\n    endgenerate\n\n    //=========================================================================\n    // sel = 2'b11: Eighth-Swizzle\n    // Split input into eight segments and reverse bits within each segment.\n    //=========================================================================\n    genvar e;\n    generate\n        for (e = 0; e < 8; e = e + 1) begin : gen_eighth_reverse\n            genvar ej;\n            for (ej = 0; ej < EIGHTH_WIDTH; ej = ej + 1) begin : gen_eighth_bits\n                assign reversed_eighth[e * EIGHTH_WIDTH + ej] = data_in[e * EIGHTH_WIDTH + (EIGHTH_WIDTH - 1 - ej)];\n            end\n        end\n    endgenerate\n\n    //=========================================================================\n    // Output Multiplexer\n    // Select the appropriate swizzled output based on the sel signal.\n    // Default case passes data_in through unchanged.\n    //=========================================================================\n    always_comb begin\n        case (sel)\n            2'b00:   data_out = reversed_full;\n            2'b01:   data_out = reversed_half;\n            2'b10:   data_out = reversed_quarter;\n            2'b11:   data_out = reversed_eighth;\n            default: data_out = data_in;  // Pass-through for invalid sel\n        endcase\n    end\n\n    //=========================================================================\n    // Gray Code Conversion\n    // Standard binary-to-Gray code transformation:\n    //   gray_out[MSB] = data_out[MSB]\n    //   gray_out[j]   = data_out[j+1] XOR data_out[j]  for j < MSB\n    // This is equivalent to: gray_out = data_out ^ (data_out >> 1)\n    //=========================================================================\n    assign gray_out = data_out ^ (data_out >> 1);\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
