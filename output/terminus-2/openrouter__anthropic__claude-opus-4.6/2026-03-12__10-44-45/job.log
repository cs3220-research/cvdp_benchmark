Sending keys: ["cat > /code/rtl/cache_controller.sv << 'VERILOG_EOF'\nmodule cache_controller (\n    input  wire        clk,\n    input  wire        reset,\n    input  wire [ 4:0] address,\n    input  wire [31:0] write_data,\n    input  wire        read,\n    input  wire        write,\n    output reg  [31:0] read_data,\n    output reg         hit,\n    output reg         miss,\n    output reg         mem_write,\n    output reg  [31:0] mem_address,\n    output reg  [31:0] mem_write_data,\n    input  wire [31:0] mem_read_data,\n    input  wire        mem_ready\n);\n\n    // Cache storage: 32 entries, each with valid bit, 5-bit tag, 32-bit data\n    reg        valid_bits [0:31];\n    reg  [4:0] tags       [0:31];\n    reg [31:0] data_store [0:31];\n\n    // Internal signals for combinational hit detection\n    wire [4:0] index;\n    wire [4:0] tag;\n    wire       tag_match;\n    wire       cache_hit;\n\n    assign index     = address;\n    assign tag       = address;\n    assign tag_match = (tags[index] == tag);\n    assign cache_hit = valid_bits[index] && tag_match;\n\n    integer i;\n\n    // Sequential logic: update cache and registered outputs\n    always @(posedge clk or posedge reset) begin\n        if (reset) begin\n            for (i = 0; i < 32; i = i + 1) begin\n                valid_bits[i] <= 1'b0;\n                tags[i]       <= 5'b0;\n                data_store[i] <= 32'b0;\n            end\n            read_data      <= 32'b0;\n            hit            <= 1'b0;\n            miss           <= 1'b0;\n            mem_write      <= 1'b0;\n            mem_address    <= 32'b0;\n            mem_write_data <= 32'b0;\n        end else begin\n            // Default: clear control signals\n            mem_write <= 1'b0;\n            hit       <= 1'b0;\n            miss      <= 1'b0;\n\n            if (read) begin\n                mem_address <= {27'b0, address};\n                if (cache_hit) begin\n                    // Read hit: return cached data\n                    read_data <= data_store[index];\n                    hit       <= 1'b1;\n                    miss      <= 1'b0;\n                end else begin\n                    // Read miss: fetch from memory\n                    miss <= 1'b1;\n                    hit  <= 1'b0;\n                    if (mem_ready) begin\n                        read_data         <= mem_read_data;\n                        valid_bits[index] <= 1'b1;\n                        tags[index]       <= tag;\n                        data_store[index] <= mem_read_data;\n                    end\n                end\n            end\n\n            if (write) begin\n                // Write-through: always write to memory\n                mem_write      <= 1'b1;\n                mem_address    <= {27'b0, address};\n                mem_write_data <= write_data;\n                if (cache_hit) begin\n                    // Write hit: update cache too\n                    data_store[index] <= write_data;\n                    hit  <= 1'b1;\n                    miss <= 1'b0;\n                end else begin\n                    hit  <= 1'b0;\n                    miss <= 1'b1;\n                end\n            end\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
