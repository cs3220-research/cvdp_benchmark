Sending keys: ["cat > /code/rtl/des3_dec.sv << 'ENDOFFILE'\nmodule des3_dec #(\n    parameter NBW_DATA = 'd64,\n    parameter NBW_KEY  = 'd192\n) (\n    input  logic              clk,\n    input  logic              rst_async_n,\n    input  logic              i_start,\n    input  logic [1:NBW_DATA] i_data,\n    input  logic [1:NBW_KEY]  i_key,\n    output logic              o_done,\n    output logic [1:NBW_DATA] o_data\n);\n\nlocalparam NBW_SUBKEY = 'd64;\n\n// Internal signals\nlogic [1:NBW_SUBKEY] key1_reg;\nlogic [1:NBW_SUBKEY] key2_reg;\nlogic [5:0]          counter;\nlogic                busy;\nlogic                done_ff;\nlogic [1:NBW_DATA]   data_out_ff;\n\n// Sub-module interface signals\nlogic              stage1_start;\nlogic [1:NBW_DATA] stage1_out;\n\nlogic              stage2_start;\nlogic [1:NBW_DATA] stage2_out;\n\nlogic              stage3_start;\nlogic [1:NBW_DATA] stage3_out;\n\n// Start signal for stage 1\nassign stage1_start = i_start && !busy;\n\n// Stage 1: Decrypt with K3\ndes_dec #(\n    .NBW_DATA(NBW_DATA),\n    .NBW_KEY(NBW_SUBKEY)\n) uu_des_dec_k3 (\n    .clk        (clk),\n    .rst_async_n(rst_async_n),\n    .i_start    (stage1_start),\n    .i_data     (i_data),\n    .i_key      (i_key[129:192]),\n    .o_data     (stage1_out)\n);\n\n// Stage 2: Encrypt with K2\ndes_enc #(\n    .NBW_DATA(NBW_DATA),\n    .NBW_KEY(NBW_SUBKEY)\n) uu_des_enc_k2 (\n    .clk        (clk),\n    .rst_async_n(rst_async_n),\n    .i_start    (stage2_start),\n    .i_data     (stage1_out),\n    .i_key      (key2_reg),\n    .o_data     (stage2_out)\n);\n\n// Stage 3: Decrypt with K1\ndes_dec #(\n    .NBW_DATA(NBW_DATA),\n    .NBW_KEY(NBW_SUBKEY)\n) uu_des_dec_k1 (\n    .clk        (clk),\n    .rst_async_n(rst_async_n),\n    .i_start    (stage3_start),\n    .i_data     (stage2_out),\n    .i_key      (key1_reg),\n    .o_data     (stage3_out)\n);\n\n// Stage start signals\n// counter increments from 1 to 48\n// stage1 captures at cycle N (via stage1_start = i_start && !busy)\n// counter set to 1 at posedge N\n// stage2 needs to capture at posedge N+16, counter=17... no\n// Let me think differently:\n// At posedge N: i_start captured. stage1_start=1. des_dec captures. busy<=1, counter<=0.\n// At posedge N+1: counter=0, increments to 1. \n// ...\n// At posedge N+16: counter=15, stage2_start fires. des_enc captures stage1_out.\n// At posedge N+32: counter=31, stage3_start fires. des_dec captures stage2_out.\n// At posedge N+48: counter=47, done fires. stage3_out valid.\n// \n// cocotb counts from FE(N) with latency=1, then while loop.\n// For latency=48, o_done must be 1 at FE(N+46).\n// done_reg set at PE(N+48) -> visible at FE(N+48) -> latency=49. Too late.\n// \n// Need done at PE(N+47) -> visible at FE(N+47) -> latency=48.\n// But stage3_out valid after PE(N+47) (16 cycles from PE(N+32)).\n// stage3_out is combinational from stage3's round 16 FFs.\n// Round 16 FFs update at PE(N+47). stage3_out is valid AFTER PE(N+47).\n// So at FE(N+47), stage3_out IS valid (it updated at PE(N+47)).\n// \n// So if I set done_reg at PE(N+47) when counter==46:\n// stage3_out is being computed from FFs that update at PE(N+47).\n// But done_reg <= 1 also happens at PE(N+47).\n// data_out_ff <= stage3_out at PE(N+47) reads the OLD stage3_out (before PE update).\n// That's wrong - stage3_out from round 15, not round 16.\n//\n// Solution: Don't register stage3_out. Use stage3_out directly for o_data\n// when done, and register it one cycle later for persistence.\nassign stage2_start = busy && (counter == 6'd15);\nassign stage3_start = busy && (counter == 6'd31);\n\n// Main control logic\nalways_ff @(posedge clk or negedge rst_async_n) begin\n    if (!rst_async_n) begin\n        key1_reg     <= '0;\n        key2_reg     <= '0;\n        counter      <= '0;\n        busy         <= 1'b0;\n        done_ff      <= 1'b0;\n        data_out_ff  <= '0;\n    end else begin\n        if (i_start && !busy) begin\n            key1_reg <= i_key[1:64];\n            key2_reg <= i_key[65:128];\n            counter  <= 6'd0;\n            busy     <= 1'b1;\n            done_ff  <= 1'b0;\n        end else if (busy) begin\n            if (counter == 6'd47) begin\n                busy        <= 1'b0;\n                done_ff     <= 1'b1;\n                data_out_ff <= stage3_out;\n            end else begin\n                counter <= counter + 6'd1;\n            end\n        end\n    end\nend\n\nassign o_done = done_ff;\nassign o_data = data_out_ff;\n\nendmodule : des3_dec\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
