    if (i_read_write_enable) begin\n                    // Expect address 1, data = unlock_code_1\n                    if (i_addr == {{(p_address_width-1){1'b0}}, 1'b1} && i_data_in == p_unlock_code_1[p_data_width-1:0])\n                        next_state = UNLOCKED;\n                    else\n                        next_state = LOCKED; // Wrong sequence, reset\n                end\n            end\n\n            UNLOCKED: begin\n                next_unlocked = 1'b1;\n                next_state    = UNLOCKED;\n            end\n\n            default: begin\n                next_state    = LOCKED;\n                next_unlocked = 1'b0;\n            end\n        endcase\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
