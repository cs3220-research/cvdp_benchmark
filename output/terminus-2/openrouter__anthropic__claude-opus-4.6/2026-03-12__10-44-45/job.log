ft_real[j];\n        end\n    end\n\n    // Truncate back to Q2.13\n    assign fir_out_real = (acc_real >>> FRAC_BITS);\n    assign fir_out_imag = (acc_imag >>> FRAC_BITS);\n\n    // =========================================\n    // Register output\n    // =========================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            out_real_reg <= 0;\n            out_imag_reg <= 0;\n        end else begin\n            out_real_reg <= fir_out_real;\n            out_imag_reg <= fir_out_imag;\n        end\n    end\n\n    // =========================================\n    // Error Calculation (combinational)\n    // Uses registered output and delayed desired\n    // =========================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (out_real_reg),\n        .data_imag    (out_imag_reg),\n        .desired_real (desired_real_dly[DESIRED_DELAY-1]),\n        .desired_imag (desired_imag_dly[DESIRED_DELAY-1]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================\n    // Coefficient Update (registered)\n    // =========================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_real),\n        .data_imag  (shift_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\n    // =========================================\n    // Output Assignment\n    // =========================================\n    assign data_out_real = out_real_reg;\n    assign data_out_imag = out_imag_reg;\n\nendmodule\n""")\nprint(\'File written successfully\')\nPYEOF\n'] min_ti