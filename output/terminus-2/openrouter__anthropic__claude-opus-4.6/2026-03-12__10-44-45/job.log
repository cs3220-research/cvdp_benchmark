Sending keys: ["cat > rtl/signed_comparator.sv << 'ENDOFFILE'\nmodule signed_comparator #(\n  parameter integer DATA_WIDTH = 16,\n  parameter integer REGISTER_OUTPUT = 0,\n  parameter integer ENABLE_TOLERANCE = 0,\n  parameter integer TOLERANCE = 0,\n  parameter integer SHIFT_LEFT = 0\n)(\n  input  wire clk,\n  input  wire rst_n,\n  input  wire enable,\n  input  wire bypass,\n  input  wire signed [DATA_WIDTH-1:0] a,\n  input  wire signed [DATA_WIDTH-1:0] b,\n  output reg gt,\n  output reg lt,\n  output reg eq\n);\n\n  // Internal width after shifting\n  localparam integer SHIFTED_WIDTH = DATA_WIDTH + SHIFT_LEFT;\n\n  // Shifted values (signed)\n  wire signed [SHIFTED_WIDTH-1:0] a_shifted;\n  wire signed [SHIFTED_WIDTH-1:0] b_shifted;\n\n  assign a_shifted = a <<< SHIFT_LEFT;\n  assign b_shifted = b <<< SHIFT_LEFT;\n\n  // Signed difference\n  wire signed [SHIFTED_WIDTH:0] diff;\n  assign diff = a_shifted - b_shifted;\n\n  // Absolute difference\n  wire [SHIFTED_WIDTH:0] abs_diff;\n  assign abs_diff = (diff < 0) ? -diff : diff;\n\n  // Tolerance-based equality\n  wire eq_tolerance;\n  generate\n    if (ENABLE_TOLERANCE) begin : gen_tol\n      assign eq_tolerance = (abs_diff <= TOLERANCE);\n    end else begin : gen_no_tol\n      assign eq_tolerance = (a_shifted == b_shifted);\n    end\n  endgenerate\n\n  // Combinational comparison results\n  reg gt_comb;\n  reg lt_comb;\n  reg eq_comb;\n\n  always @(*) begin\n    if (bypass) begin\n      gt_comb = 1'b0;\n      lt_comb = 1'b0;\n      eq_comb = 1'b1;\n    end else if (enable) begin\n      if (eq_tolerance) begin\n        gt_comb = 1'b0;\n        lt_comb = 1'b0;\n        eq_comb = 1'b1;\n      end else begin\n        if (a_shifted > b_shifted) begin\n          gt_comb = 1'b1;\n          lt_comb = 1'b0;\n          eq_comb = 1'b0;\n        end else if (a_shifted < b_shifted) begin\n          gt_comb = 1'b0;\n          lt_comb = 1'b1;\n          eq_comb = 1'b0;\n        end else begin\n          gt_comb = 1'b0;\n          lt_comb = 1'b0;\n          eq_comb = 1'b1;\n        end\n      end\n    end else begin\n      gt_comb = 1'b0;\n      lt_comb = 1'b0;\n      eq_comb = 1'b0;\n    end\n  end\n\n  // Output assignment: registered or combinational\n  generate\n    if (REGISTER_OUTPUT) begin : gen_reg\n      always @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n          gt <= 1'b0;\n          lt <= 1'b0;\n          eq <= 1'b0;\n        end else begin\n          gt <= gt_comb;\n          lt <= lt_comb;\n          eq <= eq_comb;\n        end\n      end\n    end else begin : gen_comb\n      always @(*) begin\n        gt = gt_comb;\n        lt = lt_comb;\n        eq = eq_comb;\n      end\n    end\n  endgenerate\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
