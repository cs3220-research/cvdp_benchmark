                        state    <= GEN_SBOX;\n                        sbox_cnt <= 3'd0;\n                        ca_reset <= 1'b0;\n                    end\n                end\n\n                GEN_SBOX: begin\n                    // Collect 4 S-box values from CA over 4 clock cycles\n                    s_box[sbox_cnt[1:0]] <= ca_out;\n                    sbox_cnt <= sbox_cnt + 1;\n                    if (sbox_cnt == 3'd3) begin\n                        state <= INIT_ADD;\n                        A <= (p[15:8]);\n                        B <= (p[7:0]);\n                    end\n                end\n\n                INIT_ADD: begin\n                    // A = A + S[0]; B = B + S[1]\n                    A <= A + s_box[0];\n                    B <= B + s_box[1];\n                    state <= COMP_MSB;\n                end\n\n                COMP_MSB: begin\n                    // A = ((A XOR B) <<< B) + S[2]\n                    A <= left_rotate(A ^ B, B) + s_box[2];\n                    state <= COMP_LSB;\n                end\n\n                COMP_LSB: begin\n                    // B = ((B XOR A) <<< A) + S[3]\n                    B <= left_rotate(B ^ A, A) + s_box[3];\n                    state <= DONE;\n                end\n\n                DONE: begin\n                    c <= {A, B};\n                    enc_done <= 1'b1;\n                    state <= IDLE;\n                end\n\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\nendmodule\nRTLEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
