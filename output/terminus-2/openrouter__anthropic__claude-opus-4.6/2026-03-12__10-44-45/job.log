Sending keys: ["cat > /code/rtl/Min_Hamming_Distance_Finder.sv << 'EOF'\n//=============================================================================\n// Module: Min_Hamming_Distance_Finder\n// Description: Computes the minimum Hamming distance between an input query\n//              vector and a set of reference vectors. Outputs the index of\n//              the reference vector with the smallest Hamming distance and\n//              the corresponding minimum distance value.\n//\n// Parameters:\n//   BIT_WIDTH       - Width of each vector (query and reference)\n//   REFERENCE_COUNT - Number of reference vectors to compare against\n//\n// Hierarchy:\n//   Min_Hamming_Distance_Finder\n//     └── Bit_Difference_Counter (one per reference vector)\n//           └── Data_Reduction (XOR-based bitwise comparison)\n//                 └── Bitwise_Reduction (core reduction logic)\n//=============================================================================\n\nmodule Min_Hamming_Distance_Finder\n#(\n    parameter BIT_WIDTH       = 8,   // Width of query and each reference vector\n    parameter REFERENCE_COUNT = 4    // Number of reference vectors\n)\n(\n    // Input query vector to be compared against all reference vectors\n    input  wire [BIT_WIDTH-1:0]                   input_query,\n\n    // Concatenated reference vectors: ref[0] occupies bits [BIT_WIDTH-1:0],\n    // ref[1] occupies bits [2*BIT_WIDTH-1:BIT_WIDTH], and so on.\n    input  wire [REFERENCE_COUNT*BIT_WIDTH-1:0]   references,\n\n    // Index of the reference vector with the smallest Hamming distance.\n    // In case of ties, the lowest index is selected.\n    output reg  [$clog2(REFERENCE_COUNT)-1:0]     best_match_index,\n\n    // The minimum Hamming distance found among all reference vectors.\n    output reg  [$clog2(BIT_WIDTH+1)-1:0]         min_distance\n);\n\n    //=========================================================================\n    // Local Parameters\n    //=========================================================================\n    localparam COUNT_WIDTH = $clog2(BIT_WIDTH + 1);  // Width for distance values\n    localparam INDEX_WIDTH = $clog2(REFERENCE_COUNT); // Width for index values\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    // Array to hold the computed Hamming distance for each reference vector\n    wire [COUNT_WIDTH-1:0] distances [0:REFERENCE_COUNT-1];\n\n    //=========================================================================\n    // Distance Calculation\n    // Instantiate one Bit_Difference_Counter per reference vector.\n    // Each instance computes the Hamming distance between the input_query\n    // and the corresponding reference vector extracted from the concatenated\n    // references input.\n    //=========================================================================\n    generate\n        genvar i;\n        for (i = 0; i < REFERENCE_COUNT; i = i + 1) begin : hamming_distance_calc\n            Bit_Difference_Counter\n            #(\n                .BIT_WIDTH(BIT_WIDTH)\n            )\n            bdc_inst\n            (\n                // Connect input_query as one operand\n                .input_A(input_query),\n                // Extract the i-th reference vector from the concatenated bus\n                .input_B(references[i*BIT_WIDTH +: BIT_WIDTH]),\n                // Output: Hamming distance for this reference\n                .bit_difference_count(distances[i])\n            );\n        end\n    endgenerate\n\n    //=========================================================================\n    // Minimum Distance Determination\n    // Iteratively compare all computed distances to find the smallest one.\n    // The loop starts from index 0 and updates the best match only when a\n    // strictly smaller distance is found, ensuring that the lowest index\n    // wins in case of ties.\n    //=========================================================================\n    integer j;\n\n    always @(*) begin\n        // Initialize with the first reference vector's distance\n        min_distance     = distances[0];\n        best_match_index = {INDEX_WIDTH{1'b0}};\n\n        // Compare remaining reference distances\n        for (j = 1; j < REFERENCE_COUNT; j = j + 1) begin\n            if (distances[j] < min_distance) begin\n                min_distance     = distances[j];\n                best_match_index = j[INDEX_WIDTH-1:0];\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
