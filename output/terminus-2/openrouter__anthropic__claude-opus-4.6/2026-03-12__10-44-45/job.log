Sending keys: ["cat > /code/rtl/systolic_array.sv << 'ENDOFFILE'\n`timescale 1ns/1ns\n\nmodule systolic_array #(\n  parameter DATA_WIDTH = 8\n)(\n  input  wire                  clk,\n  input  wire                  reset,\n  input  wire                  load_weights,\n  input  wire                  start,\n  input  wire [DATA_WIDTH-1:0] w00, w01, w10, w11,\n  input  wire [DATA_WIDTH-1:0] x0,  x1,\n  output reg  [DATA_WIDTH-1:0] y0,  y1,\n  output reg                   done\n);\n\n  // Internal wires for PE interconnections\n  wire [DATA_WIDTH-1:0] pe00_input_out, pe00_psum_out;\n  wire [DATA_WIDTH-1:0] pe01_input_out, pe01_psum_out;\n  wire [DATA_WIDTH-1:0] pe10_input_out, pe10_psum_out;\n  wire [DATA_WIDTH-1:0] pe11_input_out, pe11_psum_out;\n\n  // Valid signals for each PE (staggered for wavefront)\n  reg valid_pe00, valid_pe01, valid_pe10, valid_pe11;\n\n  // Pipeline cycle counter\n  reg [2:0] cycle_count;\n\n  // -------------------------------------------------------\n  // Wavefront valid signal generation\n  // -------------------------------------------------------\n  // PE(0,0): valid at cycle 1 (first cycle after start)\n  // PE(0,1): valid at cycle 2 (input_out from PE(0,0) ready)\n  // PE(1,0): valid at cycle 2 (psum_out from PE(0,0) ready)\n  // PE(1,1): valid at cycle 3 (needs both PE(0,1).psum_out and PE(1,0).input_out)\n  //\n  // After cycle 3, y0 is available from PE(1,0) (computed at cycle 2)\n  // and y1 is available from PE(1,1) (computed at cycle 3)\n\n  always @(posedge clk or posedge reset) begin\n    if (reset) begin\n      cycle_count <= 3'd0;\n      valid_pe00  <= 1'b0;\n      valid_pe01  <= 1'b0;\n      valid_pe10  <= 1'b0;\n      valid_pe11  <= 1'b0;\n      done        <= 1'b0;\n      y0          <= {DATA_WIDTH{1'b0}};\n      y1          <= {DATA_WIDTH{1'b0}};\n    end else begin\n      if (start && cycle_count == 3'd0) begin\n        // First cycle of computation\n        cycle_count <= 3'd1;\n        valid_pe00  <= 1'b1;\n        valid_pe01  <= 1'b0;\n        valid_pe10  <= 1'b0;\n        valid_pe11  <= 1'b0;\n        done        <= 1'b0;\n      end else if (cycle_count == 3'd1) begin\n        // Second cycle\n        cycle_count <= 3'd2;\n        valid_pe00  <= 1'b0;\n        valid_pe01  <= 1'b1;\n        valid_pe10  <= 1'b1;\n        valid_pe11  <= 1'b0;\n      end else if (cycle_count == 3'd2) begin\n        // Third cycle\n        cycle_count <= 3'd3;\n        valid_pe00  <= 1'b0;\n        valid_pe01  <= 1'b0;\n        valid_pe10  <= 1'b0;\n        valid_pe11  <= 1'b1;\n      end else if (cycle_count == 3'd3) begin\n        // Computation complete - register outputs and assert done\n        cycle_count <= 3'd4;\n        valid_pe00  <= 1'b0;\n        valid_pe01  <= 1'b0;\n        valid_pe10  <= 1'b0;\n        valid_pe11  <= 1'b0;\n        y0          <= pe10_psum_out;\n        y1          <= pe11_psum_out;\n        done        <= 1'b1;\n      end else if (cycle_count >= 3'd4 && !start) begin\n        // Reset for next computation when start is deasserted\n        cycle_count <= 3'd0;\n        done        <= 1'b0;\n      end\n    end\n  end\n\n  // -------------------------------------------------------\n  // PE Instantiations\n  // -------------------------------------------------------\n\n  // PE(0,0): Top-left\n  //   - input_in = x0\n  //   - weight = w00\n  //   - psum_in = 0 (top of column)\n  //   - input_out -> PE(0,1)\n  //   - psum_out -> PE(1,0)\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe00 (\n    .clk        (clk),\n    .reset      (reset),\n    .load_weight(load_weights),\n    .valid      (valid_pe00),\n    .input_in   (x0),\n    .weight     (w00),\n    .psum_in    ({DATA_WIDTH{1'b0}}),\n    .input_out  (pe00_input_out),\n    .psum_out   (pe00_psum_out)\n  );\n\n  // PE(0,1): Top-right\n  //   - input_in = PE(0,0).input_out (x0 delayed)\n  //   - weight = w01\n  //   - psum_in = 0 (top of column)\n  //   - psum_out -> PE(1,1)\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe01 (\n    .clk        (clk),\n    .reset      (reset),\n    .load_weight(load_weights),\n    .valid      (valid_pe01),\n    .input_in   (pe00_input_out),\n    .weight     (w01),\n    .psum_in    ({DATA_WIDTH{1'b0}}),\n    .input_out  (pe01_input_out),\n    .psum_out   (pe01_psum_out)\n  );\n\n  // PE(1,0): Bottom-left\n  //   - input_in = x1\n  //   - weight = w10\n  //   - psum_in = PE(0,0).psum_out (x0*w00)\n  //   - psum_out = y0 = x0*w00 + x1*w10\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe10 (\n    .clk        (clk),\n    .reset      (reset),\n    .load_weight(load_weights),\n    .valid      (valid_pe10),\n    .input_in   (x1),\n    .weight     (w10),\n    .psum_in    (pe00_psum_out),\n    .input_out  (pe10_input_out),\n    .psum_out   (pe10_psum_out)\n  );\n\n  // PE(1,1): Bottom-right\n  //   - input_in = PE(1,0).input_out (x1 delayed)\n  //   - weight = w11\n  //   - psum_in = PE(0,1).psum_out (x0*w01)\n  //   - psum_out = y1 = x0*w01 + x1*w11\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe11 (\n    .clk        (clk),\n    .reset      (reset),\n    .load_weight(load_weights),\n    .valid      (valid_pe11),\n    .input_in   (pe10_input_out),\n    .weight     (w11),\n    .psum_in    (pe01_psum_out),\n    .input_out  (pe11_input_out),\n    .psum_out   (pe11_psum_out)\n  );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
