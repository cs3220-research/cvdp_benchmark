Sending keys: ["cat > /code/rtl/dynamic_equalizer.sv << 'ENDOFFILE'\nmodule dynamic_equalizer #(\n    parameter TAP_NUM     = 7,\n    parameter DATA_WIDTH  = 16,\n    parameter COEFF_WIDTH = 16,\n    parameter MU          = 15\n) (\n    input  logic                              clk,\n    input  logic                              rst_n,\n    input  logic signed [DATA_WIDTH-1:0]      data_in_real,\n    input  logic signed [DATA_WIDTH-1:0]      data_in_imag,\n    input  logic signed [DATA_WIDTH-1:0]      desired_real,\n    input  logic signed [DATA_WIDTH-1:0]      desired_imag,\n    output logic signed [DATA_WIDTH-1:0]      data_out_real,\n    output logic signed [DATA_WIDTH-1:0]      data_out_imag\n);\n\n    localparam FRAC_BITS = DATA_WIDTH - 3; // Q2.13 -> 13 fractional bits\n\n    // Shift register for input samples\n    logic signed [DATA_WIDTH-1:0] shift_real [0:TAP_NUM-1];\n    logic signed [DATA_WIDTH-1:0] shift_imag [0:TAP_NUM-1];\n\n    // Snapshot of shift register used for coeff update (aligned with error)\n    logic signed [DATA_WIDTH-1:0] shift_snap_real [0:TAP_NUM-1];\n    logic signed [DATA_WIDTH-1:0] shift_snap_imag [0:TAP_NUM-1];\n\n    // Coefficients from coeff_update\n    logic signed [COEFF_WIDTH-1:0] coeff_real [0:TAP_NUM-1];\n    logic signed [COEFF_WIDTH-1:0] coeff_imag [0:TAP_NUM-1];\n\n    // FIR accumulator (wide)\n    logic signed [2*DATA_WIDTH-1:0] acc_real;\n    logic signed [2*DATA_WIDTH-1:0] acc_imag;\n\n    // FIR output truncated\n    logic signed [DATA_WIDTH-1:0] fir_out_real;\n    logic signed [DATA_WIDTH-1:0] fir_out_imag;\n\n    // Registered FIR output\n    logic signed [DATA_WIDTH-1:0] fir_out_real_reg;\n    logic signed [DATA_WIDTH-1:0] fir_out_imag_reg;\n\n    // Error signals\n    logic signed [DATA_WIDTH-1:0] error_real;\n    logic signed [DATA_WIDTH-1:0] error_imag;\n\n    // Delayed desired signals\n    localparam DESIRED_DELAY = TAP_NUM - 1; // 6 stages\n    logic signed [DATA_WIDTH-1:0] desired_real_dly [0:DESIRED_DELAY-1];\n    logic signed [DATA_WIDTH-1:0] desired_imag_dly [0:DESIRED_DELAY-1];\n\n    integer i;\n\n    // =========================================\n    // Shift Register\n    // =========================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_real[i] <= '0;\n                shift_imag[i] <= '0;\n            end\n        end else begin\n            shift_real[0] <= data_in_real;\n            shift_imag[0] <= data_in_imag;\n            for (i = 1; i < TAP_NUM; i = i + 1) begin\n                shift_real[i] <= shift_real[i-1];\n                shift_imag[i] <= shift_imag[i-1];\n            end\n        end\n    end\n\n    // =========================================\n    // Desired Signal Delay Line\n    // =========================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < DESIRED_DELAY; i = i + 1) begin\n                desired_real_dly[i] <= '0;\n                desired_imag_dly[i] <= '0;\n            end\n        end else begin\n            desired_real_dly[0] <= desired_real;\n            desired_imag_dly[0] <= desired_imag;\n            for (i = 1; i < DESIRED_DELAY; i = i + 1) begin\n                desired_real_dly[i] <= desired_real_dly[i-1];\n                desired_imag_dly[i] <= desired_imag_dly[i-1];\n            end\n        end\n    end\n\n    // =========================================\n    // FIR Filter - Combinational accumulation\n    // =========================================\n    always_comb begin\n        acc_real = 0;\n        acc_imag = 0;\n        for (int j = 0; j < TAP_NUM; j = j + 1) begin\n            acc_real = acc_real + coeff_real[j] * shift_real[j] - coeff_imag[j] * shift_imag[j];\n            acc_imag = acc_imag + coeff_real[j] * shift_imag[j] + coeff_imag[j] * shift_real[j];\n        end\n    end\n\n    // Truncate: extract Q2.13 from the 32-bit accumulator\n    // After multiplying two Q2.13 numbers, result is Q4.26 in 32 bits\n    // We need to shift right by 13 to get back to Q2.13\n    assign fir_out_real = acc_real[2*FRAC_BITS +: DATA_WIDTH];\n    assign fir_out_imag = acc_imag[2*FRAC_BITS +: DATA_WIDTH];\n\n    // =========================================\n    // Register FIR output\n    // =========================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            fir_out_real_reg <= '0;\n            fir_out_imag_reg <= '0;\n        end else begin\n            fir_out_real_reg <= fir_out_real;\n            fir_out_imag_reg <= fir_out_imag;\n        end\n    end\n\n    // =========================================\n    // Snapshot shift register for coeff update alignment\n    // =========================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_snap_real[i] <= '0;\n                shift_snap_imag[i] <= '0;\n            end\n        end else begin\n            for (i = 0; i < TAP_NUM; i = i + 1) begin\n                shift_snap_real[i] <= shift_real[i];\n                shift_snap_imag[i] <= shift_imag[i];\n            end\n        end\n    end\n\n    // =========================================\n    // Error Calculation (combinational)\n    // =========================================\n    error_calc #(\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_error_calc (\n        .data_real    (fir_out_real_reg),\n        .data_imag    (fir_out_imag_reg),\n        .desired_real (desired_real_dly[DESIRED_DELAY-1]),\n        .desired_imag (desired_imag_dly[DESIRED_DELAY-1]),\n        .error_real   (error_real),\n        .error_imag   (error_imag)\n    );\n\n    // =========================================\n    // Coefficient Update (registered)\n    // =========================================\n    coeff_update #(\n        .TAP_NUM    (TAP_NUM),\n        .DATA_WIDTH (DATA_WIDTH),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .MU         (MU)\n    ) u_coeff_update (\n        .clk        (clk),\n        .rst_n      (rst_n),\n        .data_real  (shift_snap_real),\n        .data_imag  (shift_snap_imag),\n        .error_real (error_real),\n        .error_imag (error_imag),\n        .coeff_real (coeff_real),\n        .coeff_imag (coeff_imag)\n    );\n\n    // =========================================\n    // Output Assignment\n    // =========================================\n    assign data_out_real = fir_out_real_reg;\n    assign data_out_imag = fir_out_imag_reg;\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
