                  sr_b[0] <= 1'b1;\n                        sr_d[0] <= 1'b1;\n                    end\n\n                    pulse_parity <= 1'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end else begin\n                // Data is 1\n                zero_cnt <= '0;\n                pulse_parity <= ~pulse_parity;\n            end\n\n            // === AMI state update ===\n            // Based on what's exiting sr[0] this clock\n            if (sr_d[0]) begin\n                if (sr_v[0]) begin\n                    // Violation: don't toggle AMI\n                end else begin\n                    // Normal/B pulse: toggle AMI\n                    ami <= ~ami;\n                end\n            end\n\n            // === Output register with gating ===\n            if (output_gate_in) begin\n                p_out <= p_comb ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_comb ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
