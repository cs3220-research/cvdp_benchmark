Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'VEOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n    // Latency: encoder_type + 3 clocks\n    //   1 (input reg) + encoder_type (FIFO) + 1 (AMI) + 1 (output)\n\n    logic data_r1;  // input register\n\n    // FIFO: depth = encoder_type, [encoder_type-1]=newest, [0]=oldest\n    logic [encoder_type-1:0] fifo_d;\n    logic [encoder_type-1:0] fifo_b;  // balance marker\n\n    // Zero counter: counts consecutive zeros entering FIFO\n    logic [2:0] zero_cnt;\n\n    // Pending violation: when set, the NEXT pulse exiting FIFO that is a zero\n    // gets converted to V. Actually, V is applied to the bit exiting FIFO\n    // on the clock AFTER the substitution is triggered.\n    logic pending_v;\n    logic [2:0] v_delay_cnt;  // countdown for V placement\n\n    // Pulse parity since last substitution\n    logic pulse_parity;\n\n    // AMI state\n    logic ami;\n\n    // AMI output\n    logic p_ami, n_ami;\n\n    // Bit exiting FIFO and its markers\n    logic exit_data;\n    logic exit_v;\n    logic exit_b;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_r1      <= 1'b0;\n            fifo_d       <= '0;\n            fifo_b       <= '0;\n            zero_cnt     <= '0;\n            pending_v    <= 1'b0;\n            v_delay_cnt  <= '0;\n            pulse_parity <= 1'b0;\n            ami          <= 1'b0;\n            p_ami        <= 1'b0;\n            n_ami        <= 1'b0;\n            p_out        <= ~pulse_active_state;\n            n_out        <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n\n            // === Stage 1: Input register ===\n            data_r1 <= data_in;\n\n            // === Stage 2: FIFO + substitution ===\n            // Capture exiting bit before shift\n            exit_data = fifo_d[0];\n            exit_b    = fifo_b[0];\n            exit_v    = pending_v;\n\n            // Handle pending V\n            if (pending_v) begin\n                pending_v <= 1'b0;\n                exit_data = 1'b1;  // V is a pulse\n                exit_v    = 1'b1;\n            end\n\n            // Shift FIFO\n            for (int i = 0; i < encoder_type - 1; i++) begin\n                fifo_d[i] <= fifo_d[i+1];\n                fifo_b[i] <= fifo_b[i+1];\n            end\n            fifo_d[encoder_type-1] <= data_r1;\n            fifo_b[encoder_type-1] <= 1'b0;\n\n            // Zero counting\n            if (data_r1 == 1'b0) begin\n                if (zero_cnt == encoder_type[2:0]) begin\n                    // encoder_type+1 consecutive zeros detected\n                    // (encoder_type in FIFO + current data_r1)\n                    // Trigger substitution\n                    zero_cnt <= '0;\n\n                    // V will be applied to the NEXT bit exiting FIFO\n                    // Actually no - we need V at the end of the pattern.\n                    // The pattern is: (B)00...0V where V is the last zero.\n                    // The last zero is data_r1 which just entered FIFO at [encoder_type-1].\n                    // It will exit FIFO in encoder_type clocks.\n                    // We need to mark it somehow.\n                    //\n                    // Alternative: mark V directly in the FIFO\n                    // But we need a fifo_v array for that.\n                    // Let me add it back.\n\n                    // For now, set pending_v with a delay counter\n                    // V exits encoder_type clocks from now\n                    v_delay_cnt <= encoder_type[2:0] - 1;\n\n                    // B placement: B is at the FIRST zero of the sequence\n                    // The first zero entered FIFO encoder_type clocks ago\n                    // It's currently at fifo_d[0] (about to exit)\n                    // Actually it already exited this clock (exit_data above)!\n                    // Hmm, this is getting complicated.\n\n                    // Let me rethink...\n                    pulse_parity <= 1'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end else begin\n                zero_cnt <= '0;\n                pulse_parity <= ~pulse_parity;\n            end\n\n            // V delay counter\n            if (v_delay_cnt > 0) begin\n                v_delay_cnt <= v_delay_cnt - 1'b1;\n                if (v_delay_cnt == 1) begin\n                    pending_v <= 1'b1;\n                end\n            end\n\n            // === Stage 3: AMI ===\n            if (exit_data || exit_v) begin\n                if (exit_v) begin\n                    // Violation: same polarity as last\n                    if (ami) begin\n                        p_ami <= 1'b1;\n                        n_ami <= 1'b0;\n                    end else begin\n                        p_ami <= 1'b0;\n                        n_ami <= 1'b1;\n                    end\n                end else begin\n                    // Normal or B: alternate\n                    if (ami == 1'b0) begin\n                        p_ami <= 1'b1;\n                        n_ami <= 1'b0;\n                        ami   <= 1'b1;\n                    end else begin\n                        p_ami <= 1'b0;\n                        n_ami <= 1'b1;\n                        ami   <= 1'b0;\n                    end\n                end\n            end else begin\n                p_ami <= 1'b0;\n                n_ami <= 1'b0;\n            end\n\n            // === Stage 4: Output ===\n            if (output_gate_in) begin\n                p_out <= p_ami ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_ami ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
