Sending keys: ["cat > /code/rtl/pseudoRandGenerator_ca.sv << 'EOF'\nmodule pseudoRandGenerator_ca (\n    input  logic         clock,\n    input  logic         reset,\n    input  logic [15:0]  CA_seed,\n    input  logic [1:0]   rule_sel,\n    output logic [15:0]  CA_out\n);\n\n    logic [15:0] next_CA_out;\n\n    // Function to compute the next bit for cell index 'i'\n    function automatic logic compute_next_bit(\n        input int          i,\n        input logic [15:0] state,\n        input logic [1:0]  rule\n    );\n        logic left, center, right;\n        logic [2:0] neighborhood;\n        logic next_bit;\n\n        // Wrap-around indexing\n        left   = state[(i + 1) % 16];\n        center = state[i];\n        right  = state[(i - 1 + 16) % 16];\n\n        neighborhood = {left, center, right};\n\n        case (rule)\n            2'b00: begin // Rule 30\n                case (neighborhood)\n                    3'b111: next_bit = 1'b0;\n                    3'b110: next_bit = 1'b0;\n                    3'b101: next_bit = 1'b0;\n                    3'b100: next_bit = 1'b1;\n                    3'b011: next_bit = 1'b1;\n                    3'b010: next_bit = 1'b1;\n                    3'b001: next_bit = 1'b1;\n                    3'b000: next_bit = 1'b0;\n                    default: next_bit = 1'b0;\n                endcase\n            end\n            2'b01: begin // Rule 110\n                case (neighborhood)\n                    3'b111: next_bit = 1'b0;\n                    3'b110: next_bit = 1'b1;\n                    3'b101: next_bit = 1'b1;\n                    3'b100: next_bit = 1'b0;\n                    3'b011: next_bit = 1'b1;\n                    3'b010: next_bit = 1'b1;\n                    3'b001: next_bit = 1'b1;\n                    3'b000: next_bit = 1'b0;\n                    default: next_bit = 1'b0;\n                endcase\n            end\n            default: begin // Default to Rule 30\n                case (neighborhood)\n                    3'b111: next_bit = 1'b0;\n                    3'b110: next_bit = 1'b0;\n                    3'b101: next_bit = 1'b0;\n                    3'b100: next_bit = 1'b1;\n                    3'b011: next_bit = 1'b1;\n                    3'b010: next_bit = 1'b1;\n                    3'b001: next_bit = 1'b1;\n                    3'b000: next_bit = 1'b0;\n                    default: next_bit = 1'b0;\n                endcase\n            end\n        endcase\n\n        return next_bit;\n    endfunction\n\n    // Combinational next-state computation\n    always_comb begin\n        for (int i = 0; i < 16; i++) begin\n            next_CA_out[i] = compute_next_bit(i, CA_out, rule_sel);\n        end\n    end\n\n    // Synchronous state update\n    always_ff @(posedge clock) begin\n        if (reset) begin\n            CA_out <= CA_seed;\n        end else begin\n            CA_out <= next_CA_out;\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
