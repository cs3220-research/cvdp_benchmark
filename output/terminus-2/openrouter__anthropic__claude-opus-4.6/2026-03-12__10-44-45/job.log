Sending keys: ["cat > /code/rtl/order_matching_engine.sv << 'ENDOFFILE'\nmodule order_matching_engine #(\n    parameter PRICE_WIDTH = 16  // width of the price field\n)(\n    input                      clk,\n    input                      rst,\n    input                      start,         // start matching operation\n    input  [8*PRICE_WIDTH-1:0] bid_orders,    // 8 bid orders (flat vector)\n    input  [8*PRICE_WIDTH-1:0] ask_orders,    // 8 ask orders (flat vector)\n    output reg                 match_valid,   // high if a match occurs\n    output reg [PRICE_WIDTH-1:0] matched_price, // matched price (best ask)\n    output reg                 done,          // matching engine done\n    output reg                 latency_error  // asserted if latency != 20 cycles\n);\n\n    // Wires for sorting engine outputs\n    wire [8*PRICE_WIDTH-1:0] sorted_bids;\n    wire [8*PRICE_WIDTH-1:0] sorted_asks;\n    wire                     bid_sort_done;\n    wire                     ask_sort_done;\n\n    // Instantiate sorting engine for bid orders (ascending: highest bid at index 7)\n    sorting_engine #(.WIDTH(PRICE_WIDTH)) bid_sorter (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(bid_orders),\n        .done(bid_sort_done),\n        .out_data(sorted_bids)\n    );\n\n    // Instantiate sorting engine for ask orders (ascending: lowest ask at index 0)\n    sorting_engine #(.WIDTH(PRICE_WIDTH)) ask_sorter (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(ask_orders),\n        .done(ask_sort_done),\n        .out_data(sorted_asks)\n    );\n\n    // Extract best bid (highest = index 7) and best ask (lowest = index 0)\n    wire [PRICE_WIDTH-1:0] best_bid = sorted_bids[7*PRICE_WIDTH +: PRICE_WIDTH];\n    wire [PRICE_WIDTH-1:0] best_ask = sorted_asks[0 +: PRICE_WIDTH];\n\n    // Latency counter\n    reg [5:0] cycle_counter;\n    reg       running;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cycle_counter <= 0;\n            running       <= 0;\n            match_valid   <= 0;\n            matched_price <= 0;\n            done          <= 0;\n            latency_error <= 0;\n        end else begin\n            // Default: deassert single-cycle outputs\n            done          <= 0;\n            match_valid   <= 0;\n            matched_price <= 0;\n            latency_error <= 0;\n\n            if (start && !running) begin\n                running       <= 1;\n                cycle_counter <= 1;\n            end else if (running) begin\n                cycle_counter <= cycle_counter + 1;\n\n                // At cycle_counter == 20, produce output\n                // Both sorters should be done by now (they take 20 cycles = counter 20)\n                // sorted_bids and sorted_asks are wire outputs updated by the sorters\n                if (cycle_counter == 20) begin\n                    done    <= 1;\n                    running <= 0;\n                    cycle_counter <= 0;\n                    latency_error <= 0;\n\n                    if (best_bid >= best_ask) begin\n                        match_valid   <= 1;\n                        matched_price <= best_ask;\n                    end else begin\n                        match_valid   <= 0;\n                        matched_price <= 0;\n                    end\n                end\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
