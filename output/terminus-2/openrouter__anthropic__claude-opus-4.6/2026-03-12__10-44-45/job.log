_count_bin_next = r_count_bin - 1;\n    wire [PTR_WIDTH-1:0] r_ptr_next = bin2gray(r_count_bin_next);\n\n    always @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= {PTR_WIDTH{1'b0}};\n            r_ptr       <= {PTR_WIDTH{1'b0}};\n            r_empty     <= 1'b1;\n        end else begin\n            // Update read binary counter to track write pointer when not popping\n            // The read domain needs to know the current stack level\n            if (pop && !r_empty) begin\n                r_count_bin <= r_count_bin_next;\n                r_ptr       <= r_ptr_next;\n            end else if (!pop) begin\n                // When not popping, update read pointer to follow write pointer\n                // This is key for FILO: the read side needs to know the top of stack\n                r_count_bin <= gray2bin(rq2_wptr);\n                r_ptr       <= rq2_wptr;\n            end\n            // Empty flag: compare read pointer with synchronized write pointer\n            if (pop && !r_empty)\n                r_empty <= (r_ptr_next == {PTR_WIDTH{1'b0}}) ? 1'b1 :\n                           (r_ptr_next == rq2_wptr) ? 1'b1 : 1'b0;\n            else\n                r_empty <= (r_ptr == rq2_wptr) ? 1'b1 : 1'b0;\n        end\n    end\n\n    // Read data - continuously driven from top of stack\n    // In FILO, we read from the position just below the current read pointer\n    assign r_data = mem[r_count_bin[ADDR_WIDTH-1:0] - 1];\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
