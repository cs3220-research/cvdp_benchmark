Sending keys: ["cat > rtl/rgb_color_space_hsv.sv << 'ENDOFFILE'\nmodule rgb_color_space_hsv (\n    input               clk,\n    input               rst,\n\n    // Memory ports to initialize (1/delta) values\n    input               we,\n    input       [7:0]   waddr,\n    input      [24:0]   wdata,\n\n    // Input data with valid.\n    input               valid_in,\n    input       [7:0]   r_component,\n    input       [7:0]   g_component,\n    input       [7:0]   b_component,\n\n    // Output values\n    output reg [11:0]   h_component,  // Output in fx10.2 format\n    output reg [12:0]   s_component,  // Output in fx1.12 format\n    output reg [11:0]   v_component,  // For actual % value = (v_component/255) * 100\n    output reg          valid_out\n);\n\n    // =========================================================================\n    // Dual-Port RAM for inverse lookup\n    // =========================================================================\n    reg [24:0] ram [0:255];\n\n    // RAM write port\n    always @(posedge clk) begin\n        if (we) begin\n            ram[waddr] <= wdata;\n        end\n    end\n\n    // RAM read port A (for 1/i_max)\n    reg        ren_a;\n    reg  [7:0] raddr_a;\n    reg [24:0] rdata_a;\n\n    always @(posedge clk) begin\n        if (ren_a)\n            rdata_a <= ram[raddr_a];\n    end\n\n    // RAM read port B (for 1/delta)\n    reg        ren_b;\n    reg  [7:0] raddr_b;\n    reg [24:0] rdata_b;\n\n    always @(posedge clk) begin\n        if (ren_b)\n            rdata_b <= ram[raddr_b];\n    end\n\n    // =========================================================================\n    // Valid pipeline (8 cycles)\n    // =========================================================================\n    reg [7:0] valid_sr;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst)\n            valid_sr <= 8'd0;\n        else\n            valid_sr <= {valid_sr[6:0], valid_in};\n    end\n\n    // =========================================================================\n    // Pipeline Stage 1: Compute differences and register inputs\n    // =========================================================================\n    reg signed [8:0] diff_gb_s1;  // G - B\n    reg signed [8:0] diff_br_s1;  // B - R\n    reg signed [8:0] diff_rg_s1;  // R - G\n    reg [7:0] r_s1, g_s1, b_s1;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            diff_gb_s1 <= 0;\n            diff_br_s1 <= 0;\n            diff_rg_s1 <= 0;\n            r_s1 <= 0;\n            g_s1 <= 0;\n            b_s1 <= 0;\n        end else begin\n            diff_gb_s1 <= $signed({1'b0, g_component}) - $signed({1'b0, b_component});\n            diff_br_s1 <= $signed({1'b0, b_component}) - $signed({1'b0, r_component});\n            diff_rg_s1 <= $signed({1'b0, r_component}) - $signed({1'b0, g_component});\n            r_s1 <= r_component;\n            g_s1 <= g_component;\n            b_s1 <= b_component;\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 2: Max/Min calculation\n    // =========================================================================\n    reg [7:0] i_max_s2, i_min_s2;\n    reg [1:0] max_sel_s2;  // 0=R, 1=G, 2=B\n    reg signed [8:0] diff_gb_s2, diff_br_s2, diff_rg_s2;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            i_max_s2 <= 0;\n            i_min_s2 <= 0;\n            max_sel_s2 <= 0;\n            diff_gb_s2 <= 0;\n            diff_br_s2 <= 0;\n            diff_rg_s2 <= 0;\n        end else begin\n            diff_gb_s2 <= diff_gb_s1;\n            diff_br_s2 <= diff_br_s1;\n            diff_rg_s2 <= diff_rg_s1;\n\n            if (r_s1 >= g_s1 && r_s1 >= b_s1) begin\n                i_max_s2 <= r_s1;\n                max_sel_s2 <= 2'd0;\n                i_min_s2 <= (g_s1 <= b_s1) ? g_s1 : b_s1;\n            end else if (g_s1 >= r_s1 && g_s1 >= b_s1) begin\n                i_max_s2 <= g_s1;\n                max_sel_s2 <= 2'd1;\n                i_min_s2 <= (r_s1 <= b_s1) ? r_s1 : b_s1;\n            end else begin\n                i_max_s2 <= b_s1;\n                max_sel_s2 <= 2'd2;\n                i_min_s2 <= (r_s1 <= g_s1) ? r_s1 : g_s1;\n            end\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 3: Compute delta, initiate RAM reads\n    // Also: read RAM for 1/i_max (available at end of cycle 3)\n    // and 1/delta (available at end of cycle 4 since delta computed here)\n    // =========================================================================\n    reg [7:0] delta_s3;\n    reg [7:0] i_max_s3;\n    reg [1:0] max_sel_s3;\n    reg signed [8:0] diff_gb_s3, diff_br_s3, diff_rg_s3;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            delta_s3 <= 0;\n            i_max_s3 <= 0;\n            max_sel_s3 <= 0;\n            diff_gb_s3 <= 0;\n            diff_br_s3 <= 0;\n            diff_rg_s3 <= 0;\n        end else begin\n            delta_s3 <= i_max_s2 - i_min_s2;\n            i_max_s3 <= i_max_s2;\n            max_sel_s3 <= max_sel_s2;\n            diff_gb_s3 <= diff_gb_s2;\n            diff_br_s3 <= diff_br_s2;\n            diff_rg_s3 <= diff_rg_s2;\n        end\n    end\n\n    // RAM read for 1/i_max: address with i_max_s2, read in cycle 2->3\n    // So rdata_a available at end of cycle 3\n    always @(*) begin\n        ren_a = valid_sr[1]; // enable during cycle 2\n        raddr_a = i_max_s2;\n    end\n\n    // RAM read for 1/delta: address with delta_s3, read in cycle 3->4\n    // So rdata_b available at end of cycle 4\n    always @(*) begin\n        ren_b = valid_sr[2]; // enable during cycle 3\n        raddr_b = delta_s3;\n    end\n\n    // =========================================================================\n    // Pipeline Stage 4: Select appropriate diff based on max_sel,\n    //                    capture RAM outputs\n    // =========================================================================\n    reg signed [8:0] selected_diff_s4;\n    reg [1:0] max_sel_s4;\n    reg [24:0] inv_imax_s4;  // 1/i_max from RAM (available now)\n    reg [7:0] delta_s4;\n    reg [7:0] i_max_s4;\n    reg delta_zero_s4;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            selected_diff_s4 <= 0;\n            max_sel_s4 <= 0;\n            inv_imax_s4 <= 0;\n            delta_s4 <= 0;\n            i_max_s4 <= 0;\n            delta_zero_s4 <= 0;\n        end else begin\n            max_sel_s4 <= max_sel_s3;\n            inv_imax_s4 <= rdata_a;  // 1/i_max available at end of cycle 3\n            delta_s4 <= delta_s3;\n            i_max_s4 <= i_max_s3;\n            delta_zero_s4 <= (delta_s3 == 0);\n\n            case (max_sel_s3)\n                2'd0: selected_diff_s4 <= diff_gb_s3;  // R is max: G-B\n                2'd1: selected_diff_s4 <= diff_br_s3;  // G is max: B-R\n                2'd2: selected_diff_s4 <= diff_rg_s3;  // B is max: R-G\n                default: selected_diff_s4 <= 0;\n            endcase\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 5: Multiply selected_diff by 60, capture 1/delta from RAM\n    //                    Start saturation computation: delta * inv_imax\n    // =========================================================================\n    reg signed [17:0] hue_pre_s5;  // selected_diff * 60 (9-bit * 6-bit + sign = ~16 bits)\n    reg [24:0] inv_delta_s5;       // 1/delta from RAM (available at end of cycle 4)\n    reg [1:0] max_sel_s5;\n    reg delta_zero_s5;\n    reg [7:0] delta_s5;\n    reg [24:0] inv_imax_s5;\n    reg [7:0] i_max_s5;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            hue_pre_s5 <= 0;\n            inv_delta_s5 <= 0;\n            max_sel_s5 <= 0;\n            delta_zero_s5 <= 0;\n            delta_s5 <= 0;\n            inv_imax_s5 <= 0;\n            i_max_s5 <= 0;\n        end else begin\n            hue_pre_s5 <= $signed(selected_diff_s4) * $signed(10'd60);\n            inv_delta_s5 <= rdata_b;  // 1/delta available at end of cycle 4\n            max_sel_s5 <= max_sel_s4;\n            delta_zero_s5 <= delta_zero_s4;\n            delta_s5 <= delta_s4;\n            inv_imax_s5 <= inv_imax_s4;\n            i_max_s5 <= i_max_s4;\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 6: Hue multiplication (hue_pre * inv_delta)\n    //                    Saturation multiplication (delta * inv_imax)\n    // =========================================================================\n    reg signed [42:0] hue_mult_s6;  // hue_pre * inv_delta\n    reg [32:0] sat_mult_s6;          // delta * inv_imax\n    reg [1:0] max_sel_s6;\n    reg delta_zero_s6;\n    reg [7:0] i_max_s6;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            hue_mult_s6 <= 0;\n            sat_mult_s6 <= 0;\n            max_sel_s6 <= 0;\n            delta_zero_s6 <= 0;\n            i_max_s6 <= 0;\n        end else begin\n            // Hue: (diff * 60) * (1/delta) in fx0.24\n            hue_mult_s6 <= $signed(hue_pre_s5) * $signed({1'b0, inv_delta_s5});\n            // Saturation: delta * (1/i_max) in fx0.24\n            sat_mult_s6 <= {1'b0, delta_s5} * {1'b0, inv_imax_s5};\n            max_sel_s6 <= max_sel_s5;\n            delta_zero_s6 <= delta_zero_s5;\n            i_max_s6 <= i_max_s5;\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 7: Round/extract hue and saturation, add hue offset\n    // =========================================================================\n    reg signed [42:0] hue_mult_s7;\n    reg [32:0] sat_mult_s7;\n    reg [1:0] max_sel_s7;\n    reg delta_zero_s7;\n    reg [7:0] i_max_s7;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            hue_mult_s7 <= 0;\n            sat_mult_s7 <= 0;\n            max_sel_s7 <= 0;\n            delta_zero_s7 <= 0;\n            i_max_s7 <= 0;\n        end else begin\n            hue_mult_s7 <= hue_mult_s6;\n            sat_mult_s7 <= sat_mult_s6;\n            max_sel_s7 <= max_sel_s6;\n            delta_zero_s7 <= delta_zero_s6;\n            i_max_s7 <= i_max_s6;\n        end\n    end\n\n    // =========================================================================\n    // Pipeline Stage 8: Final output computation\n    // =========================================================================\n    // Hue: hue_mult is (diff*60) * (1/delta) where 1/delta is in fx0.24\n    // So hue_mult is in units of degrees * 2^24\n    // We need fx10.2 output (degrees * 4)\n    // So we extract: hue_mult >> 22 (shift right by 24-2=22)\n    // Then add offset based on max_sel\n\n    wire signed [42:0] hue_shifted = hue_mult_s7;\n    // hue_mult_s7 = diff*60/delta * 2^24\n    // We want degrees * 4 = (diff*60/delta) * 4\n    // So divide by 2^22: hue_mult_s7 >> 22\n    // But we need rounding: add 2^21 before shifting\n\n    wire signed [42:0] hue_rounded = hue_mult_s7 + $signed(43'd2097152); // + 2^21 for rounding\n    wire signed [20:0] hue_raw = hue_rounded[42:22]; // degrees * 4 (signed)\n\n    // Hue offset: R->0, G->480(120*4), B->960(240*4)\n    wire signed [20:0] hue_offset = (max_sel_s7 == 2'd0) ? 21'sd0 :\n                                    (max_sel_s7 == 2'd1) ? 21'sd480 :\n                                                           21'sd960;\n\n    wire signed [20:0] hue_with_offset = hue_raw + hue_offset;\n\n    // Handle wrap-around for negative values (mod 1440, since 360*4=1440)\n    wire signed [20:0] hue_mod = (hue_with_offset < 0) ? (hue_with_offset + 21'sd1440) :\n                                 (hue_with_offset >= 21'sd1440) ? (hue_with_offset - 21'sd1440) :\n                                  hue_with_offset;\n\n    // Saturation: sat_mult is delta * (1/i_max) where 1/i_max is fx0.24\n    // sat_mult = delta/i_max * 2^24\n    // We need fx1.12 output = (delta/i_max) * 2^12\n    // So divide by 2^12: sat_mult >> 12\n    // Rounding: add 2^11 before shifting\n    wire [32:0] sat_rounded = sat_mult_s7 + 33'd2048; // + 2^11\n    wire [12:0] sat_raw = sat_rounded[24:12];\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            h_component <= 12'd0;\n            s_component <= 13'd0;\n            v_component <= 12'd0;\n            valid_out   <= 1'b0;\n        end else begin\n            valid_out <= valid_sr[7];\n\n            if (valid_sr[7]) begin\n                // Value is simply i_max\n                v_component <= {4'd0, i_max_s7};\n\n                // Saturation\n                if (delta_zero_s7)\n                    s_component <= 13'd0;\n                else\n                    s_component <= sat_raw;\n\n                // Hue\n                if (delta_zero_s7)\n                    h_component <= 12'd0;\n                else\n                    h_component <= hue_mod[11:0];\n            end else begin\n                h_component <= 12'd0;\n                s_component <= 13'd0;\n                v_component <= 12'd0;\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
