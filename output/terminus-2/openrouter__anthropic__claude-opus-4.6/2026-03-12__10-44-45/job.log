osedge clk) begin\n    if (srst) begin\n      stored_password <= DEFAULT_PASSWORD;\n    end else begin\n      if (state == ADMIN_MODE && new_password_valid) begin\n        stored_password <= new_password;\n      end\n    end\n  end\n\n  // Datapath: fail_count\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      fail_count <= 0;\n    end else begin\n      if (state == PASSWORD_FAIL) begin\n        fail_count <= fail_count + 1;\n      end else if (admin_override) begin\n        fail_count <= 0;\n      end else if (state == PASSWORD_OK) begin\n        fail_count <= 0;\n      end\n    end\n  end\n\n  // Output: door_unlock\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      door_unlock <= 1'b0;\n    end else begin\n      if (state == PASSWORD_OK) begin\n        door_unlock <= 1'b1;\n      end else begin\n        door_unlock <= 1'b0;\n      end\n    end\n  end\n\n  // Output: lockout\n  always_ff @(posedge clk) begin\n    if (srst) begin\n      lockout <= 1'b0;\n    end else begin\n      if (state == PASSWORD_FAIL && (fail_count >= (MAX_TRIALS - 1))) begin\n        lockout <= 1'b1;\n      end else if (admin_override) begin\n        lockout <= 1'b0;\n      end\n    end\n  end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
