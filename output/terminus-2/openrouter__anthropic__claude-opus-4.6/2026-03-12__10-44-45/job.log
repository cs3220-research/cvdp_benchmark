n    always @(posedge clk or posedge reset) begin\n        if (reset) begin\n            search_state <= S_IDLE;\n            found <= 0;\n            position <= {INV};\n            complete_deletion <= 0;\n            key_position <= {INV};\n            left_output_index <= 0;\n            right_output_index <= 0;\n            sp_left <= 0;\n            sp_right <= 0;\n            left_done <= 0;\n            right_done <= 0;\n            delete_invalid <= 0;\n            node_to_delete <= {INV};\n            parent_of_delete <= {INV};\n            delete_left_idx <= {INV};\n            delete_right_idx <= {INV};\n            inorder_current <= {INV};\n            inorder_parent <= {INV};\n            for (i = 0; i < ARRAY_SIZE; i = i + 1) begin\n                modified_keys[i*DATA_WIDTH +: DATA_WIDTH] <= {KINV};\n                modified_left_child[i*{P} +: {P}] <= {INV};\n                modified_right_child[i*{P} +: {P}] <= {INV};\n                left_stack[i*{P} +: {P}] <= {INV};\n                right_stack[i*{P} +: {P}] <= {INV};\n            end\n        end else begin\n            case (search_state)\n                S_IDLE: begin\n                    for (i = 0; i < ARRAY_SIZE; i = i + 1) begin\n                        left_stack[i*{P} +: {P}] <= {INV};\n                        right_stack[i*{P} +: {P}] <= {INV};\n                        modified_keys[i*DATA_WIDTH +: DATA_WIDTH] <= {KINV};\n                        modified_left_child[i*{P} +: {P}] <= {INV};\n                        modified_right_child[i*{P} +: {P}] <= {INV};\n                    end\n                    complete_deletion <= 0;\n                    delete_invalid <= 0;\n                    found <= 0;\n                    position <= {INV};\n                    key_position <= {INV};\n                    left_output_index <= 0;\n                    right_output_index <= 0;\n                    sp_left <= 0;\n                    sp_right <= 0;\n                    left_done <= 0;\n      