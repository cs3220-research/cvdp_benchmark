Sending keys: ['python3 << \'PYEOF\'\ndecoder_sv = \'\'\'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1\'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    // Latency = encoder_type + 3 clocks (same as encoder)\n    // 1(input reg) + (encoder_type+1)(SR) + 1(output reg)\n\n    localparam integer SR_DEPTH = encoder_type + 1;\n\n    // Stage 1: Input register (normalize to active-high internal)\n    logic p_r1, n_r1;\n\n    // Shift register for P and N\n    logic [SR_DEPTH-1:0] sr_p;\n    logic [SR_DEPTH-1:0] sr_n;\n    logic [SR_DEPTH-1:0] sr_v;  // violation markers (set at write end, shift with data)\n\n    // Polarity tracking for violation detection\n    logic last_pol;       // 1=last pulse positive, 0=last pulse negative\n    logic last_pol_valid; // have we seen any pulse?\n\n    // Violation detection at write end (newest position)\n    logic new_pulse;\n    logic new_is_pos;\n    logic new_is_neg;\n    logic new_is_violation;\n    logic suppress_b;  // suppress B at read end when V detected\n\n    // Zero counter for error detection (counts zeros at output)\n    logic [2:0] out_zero_cnt;\n\n    // Error flags\n    logic pulse_err_r;   // simultaneous P and N\n    logic zero_err_r;    // too many zeros\n\n    // Output data computation\n    logic data_comb;\n    logic has_pulse_at_read;\n\n    always_comb begin\n        // Detect new pulse at write end\n        new_is_pos = p_r1;\n        new_is_neg = n_r1;\n        new_pulse  = new_is_pos || new_is_neg;\n\n        // Violation: same polarity as last pulse\n        new_is_violation = 1\'b0;\n        if (new_pulse && last_pol_valid && !(new_is_pos && new_is_neg)) begin\n            if (new_is_pos && last_pol)       // both positive\n                new_is_violation = 1\'b1;\n            else if (new_is_neg && !last_pol) // both negative\n                new_is_violation = 1\'b1;\n        end\n\n        // Data at read end (oldest position)\n        has_pulse_at_read = sr_p[0] || sr_n[0];\n\n        // Output: pulse=1, no pulse=0, but suppress V and B\n        if (sr_v[0])\n            data_comb = 1\'b0;  // V pulse: suppress\n        else if (suppress_b && has_pulse_at_read)\n            data_comb = 1\'b0;  // B pulse: suppress\n        else\n            data_comb = has_pulse_at_read;\n    end\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p_r1           <= 1\'b0;\n            n_r1           <= 1\'b0;\n            sr_p           <= \\\'0;\n            sr_n           <= \\\'0;\n            sr_v           <= \\\'0;\n            last_pol       <= 1\'b0;\n            last_pol_valid <= 1\'b0;\n            suppress_b     <= 1\'b0;\n            out_zero_cnt   <= \\\'0;\n            pulse_err_r    <= 1\'b0;\n            zero_err_r     <= 1\'b0;\n            data_out       <= 1\'b0;\n            code_error_out <= 1\'b0;\n        end else if (clk_enable_in) begin\n\n            // === Stage 1: Input register ===\n            p_r1 <= (p_in == pulse_active_state) ? 1\'b1 : 1\'b0;\n            n_r1 <= (n_in == pulse_active_state) ? 1\'b1 : 1\'b0;\n\n            // === Stage 2: Shift register ===\n            for (int i = 0; i < SR_DEPTH - 1; i++) begin\n                sr_p[i] <= sr_p[i+1];\n                sr_n[i] <= sr_n[i+1];\n                sr_v[i] <= sr_v[i+1];\n            end\n            sr_p[SR_DEPTH-1] <= p_r1;\n            sr_n[SR_DEPTH-1] <= n_r1;\n            sr_v[SR_DEPTH-1] <= new_is_violation;\n\n            // === Polarity tracking ===\n            if (new_pulse && !(new_is_pos && new_is_neg)) begin\n                last_pol <= new_is_pos;\n                last_pol_valid <= 1\'b1;\n            end\n\n            // === B suppression ===\n            // When V detected at write end, B i