Sending keys: ["cat > /code/rtl/jpeg_runlength_rzs.sv << 'ENDOFFILE'\nmodule jpeg_runlength_rzs (\n    input  wire        clk_in,\n    input  wire        reset_in,\n    input  wire        enable_in,\n    input  wire [3:0]  rlen_in,\n    input  wire [3:0]  size_in,\n    input  wire [11:0] amp_in,\n    input  wire        den_in,\n    input  wire        dc_in,\n    output reg  [3:0]  rlen_out,\n    output reg  [3:0]  size_out,\n    output reg  [11:0] amp_out,\n    output reg         den_out,\n    output reg         dc_out\n);\n\n    // FSM states for zero-run suppression\n    localparam IDLE    = 2'd0;\n    localparam HOLD    = 2'd1;  // Suppressed a (15,0), waiting to see what follows\n    localparam RELEASE = 2'd2;  // Need to emit held data on next cycle\n\n    reg [1:0] state;\n    \n    // Saved data for RELEASE state\n    reg [3:0]  held_rlen;\n    reg [3:0]  held_size;\n    reg [11:0] held_amp;\n    reg        held_den;\n    reg        held_dc;\n\n    always @(posedge clk_in) begin\n        if (reset_in) begin\n            rlen_out  <= 4'd0;\n            size_out  <= 4'd0;\n            amp_out   <= 12'd0;\n            den_out   <= 1'b0;\n            dc_out    <= 1'b0;\n            state     <= IDLE;\n            held_rlen <= 4'd0;\n            held_size <= 4'd0;\n            held_amp  <= 12'd0;\n            held_den  <= 1'b0;\n            held_dc   <= 1'b0;\n        end else if (enable_in) begin\n            case (state)\n                IDLE: begin\n                    if (den_in && rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                        // (15,0) ZRL detected - suppress it\n                        den_out  <= 1'b0;\n                        dc_out   <= 1'b0;\n                        state    <= HOLD;\n                    end else begin\n                        // Pass through (including when den_in=0)\n                        rlen_out <= rlen_in;\n                        size_out <= size_in;\n                        amp_out  <= amp_in;\n                        den_out  <= den_in;\n                        dc_out   <= dc_in;\n                    end\n                end\n\n                HOLD: begin\n                    if (den_in) begin\n                        if (rlen_in == 4'd15 && size_in == 4'd0 && !dc_in) begin\n                            // Another (15,0) - keep suppressing\n                            den_out <= 1'b0;\n                            dc_out  <= 1'b0;\n                            state   <= HOLD;\n                        end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                            // EOB (0,0) - emit EOB, discard suppressed ZRL\n                            rlen_out <= 4'd0;\n                            size_out <= 4'd0;\n                            amp_out  <= 12'd0;\n                            den_out  <= 1'b1;\n                            dc_out   <= 1'b0;\n                            state    <= IDLE;\n                        end else begin\n                            // Non-ZRL data follows - re-emit (15,0) now, hold this data for next cycle\n                            rlen_out  <= 4'd15;\n                            size_out  <= 4'd0;\n                            amp_out   <= 12'd0;\n                            den_out   <= 1'b1;\n                            dc_out    <= 1'b0;\n                            // Save the current data for next cycle\n                            held_rlen <= rlen_in;\n                            held_size <= size_in;\n                            held_amp  <= amp_in;\n                            held_den  <= den_in;\n                            held_dc   <= dc_in;\n                            state     <= RELEASE;\n                        end\n                    end else begin\n                        // No valid input while holding - keep waiting\n                        den_out <= 1'b0;\n                        dc_out  <= 1'b0;\n                    end\n                end\n\n                RELEASE: begin\n                    // Emit the saved data\n                    rlen_out <= held_rlen;\n                    size_out <= held_size;\n                    amp_out  <= held_amp;\n                    den_out  <= held_den;\n                    dc_out   <= held_dc;\n                    state    <= IDLE;\n                end\n\n                default: begin\n                    state   <= IDLE;\n                    den_out <= 1'b0;\n                    dc_out  <= 1'b0;\n                end\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
