gic                 branch_valid [0:M-1];\n\n  // -------------------------------------------------------\n  // Trigger filtering when M samples have been collected\n  // -------------------------------------------------------\n  logic filter_start;\n\n  // -------------------------------------------------------\n  // Generate M polyphase filter branches\n  // -------------------------------------------------------\n  genvar p, t;\n  generate\n    for (p = 0; p < M; p = p + 1) begin : poly_branches\n      // Extract TAPS samples for this branch with stride M\n      logic [DATA_WIDTH-1:0] branch_samples [0:TAPS-1];\n      for (t = 0; t < TAPS; t = t + 1) begin : sample_extract\n        assign branch_samples[t] = shift_data[p + t * M];\n      end\n\n      poly_filter #(\n        .M          (M),\n        .TAPS       (TAPS),\n        .COEFF_WIDTH(COEFF_WIDTH),\n        .DATA_WIDTH (DATA_WIDTH)\n      ) u_poly_filter (\n        .clk          (clk),\n        .arst_n       (arst_n),\n        .sample_buffer(branch_samples),\n        .valid_in     (filter_start),\n        .phase        (p[$clog2(M)-1:0]),\n        .filter_out   (branch_out[p]),\n        .valid        (branch_valid[p])\n      );\n    end\n  endgenerate\n\n  // -------------------------------------------------------\n  // Check all branches valid\n  // -------------------------------------------------------\n  logic all_branches_valid;\n  always_comb begin\n    all_branches_valid = 1'b1;\n    for (int i = 0; i < M; i = i + 1) begin\n      all_branches_valid = all_branches_valid & branch_valid[i];\n    end\n  end\n\n  // -------------------------------------------------------\n  // Adder Tree to sum branch outputs\n  // -------------------------------------------------------\n  logic [ACC_WIDTH+$clog2(M)-1:0] tree_sum;\n  logic                           tree_valid;\n\n  adder_tree #(\n    .NUM_INPUTS(M),\n    .DATA_WIDTH(ACC_WIDTH)\n  ) u_adder_tree (\n    .clk      (clk),\n    .arst_n   (arst_n),\n    .valid_in (all_branches_valid),\n    .data_in  (branch_out),\n    .sum_out  (tree_sum),\n    .valid_out(tree_valid)\n  );\n\n  // -------------------------------------------------------\n  // FSM and Control Logic\n  // -------------------------------------------------------\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n) begin\n      state        <= ACCUMULATE;\n      sample_cnt   <= '0;\n      filter_start <= 1'b0;\n      out_sample   <= '0;\n      out_valid    <= 1'b0;\n    end\n    else begin\n      // Default: clear the one-cycle pulse\n      filter_start <= 1'b0;\n\n      case (state)\n        ACCUMULATE: begin\n          // Clear out_valid when we start accepting new samples\n          if (shift_load) begin\n            out_valid <= 1'b0;\n          end\n          if (shift_load) begin\n            if (sample_cnt == M - 1) begin\n              // M samples collected, trigger filtering\n              sample_cnt   <= '0;\n              filter_start <= 1'b1;\n              state        <= OUTPUT;\n            end\n            else begin\n              sample_cnt <= sample_cnt + 1;\n            end\n          end\n        end\n\n        OUTPUT: begin\n          if (tree_valid) begin\n            out_sample <= tree_sum;\n            out_valid  <= 1'b1;\n            state      <= ACCUMULATE;\n          end\n        end\n\n        default: state <= ACCUMULATE;\n      endcase\n    end\n  end\n\n  // -------------------------------------------------------\n  // Ready signal: accept samples only in ACCUMULATE state\n  // -------------------------------------------------------\n  assign in_ready = (state == ACCUMULATE);\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
