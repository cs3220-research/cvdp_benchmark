        16'h07F4: cfg_rd = tx_length_reg;\n            16'h07F8: cfg_rd = irq_enable_reg;\n            16'h07FC: cfg_rd = tx_control_reg;\n            default:  cfg_rd = ram_data0_out;\n        endcase\n    end\n\n    // TX FSM\n    reg [1:0]  state;\n    reg [31:0] total_bytes;    // effective length with padding\n    reg [31:0] bytes_remaining;\n    reg [ADDR_W-1:0] word_ptr;  // current word being output\n    reg        interrupt_reg;\n    reg        started;  // indicates we've issued the first RAM read\n\n    // AXI outputs - directly from RAM or zero\n    reg        o_valid;\n    reg [31:0] o_data;\n    reg [3:0]  o_strb;\n    reg        o_last;\n\n    assign axis_tvalid_out = o_valid;\n    assign axis_tdata_out  = o_data;\n    assign axis_tstrb_out  = o_strb;\n    assign axis_tlast_out  = o_last;\n    assign interrupt_out   = interrupt_reg;\n\n    wire [31:0] eff_len = (tx_length_reg < 32'd64) ? 32'd64 : tx_length_reg;\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state          <= S_IDLE;\n            tx_length_reg  <= 0;\n            irq_enable_reg <= 0;\n            tx_control_reg <= 0;\n            total_bytes    <= 0;\n            bytes_remaining <= 0;\n            word_ptr       <= 0;\n            ram_addr1      <= 0;\n            interrupt_reg  <= 0;\n            started        <= 0;\n            o_valid        <= 0;\n            o_data         <= 0;\n            o_strb         <= 0;\n            o_last         <= 0;\n        end else begin\n            // Clear interrupt pulse\n            if (interrupt_reg)\n                interrupt_reg <= 0;\n\n            // Config writes (always active)\n            if (cfg_wr_in) begin\n                if (cfg_is_length)  tx_length_reg  <= cfg_data_wr_in;\n                if (cfg_is_irq_en)  irq_enable_reg <= cfg_data_wr_in;\n                if (cfg_is_control) tx_control_reg <= cfg_data_wr_in;\n            end\n\n            case (state)\n                S_IDLE: