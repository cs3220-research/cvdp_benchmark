rate < RMAX[$clog2(RMAX+1)-1:0]) ? rate : RMAX[$clog2(RMAX+1)-1:0];\n\n    always @(posedge clk) begin\n        if (rst) begin\n            cycle_reg <= {($clog2(RMAX+1)){1'b0}};\n        end else if (input_handshake) begin\n            if (cycle_reg >= (cycle_limit - 1))\n                cycle_reg <= {($clog2(RMAX+1)){1'b0}};\n            else\n                cycle_reg <= cycle_reg + 1;\n        end\n    end\n\n    // Output valid: input is valid and we're at the decimation point\n    assign output_tvalid = input_tvalid & (cycle_reg == 0);\n\n    // Input ready: downstream ready OR we're not at the decimation point (keep accumulating)\n    assign input_tready = output_tready | (cycle_reg != 0);\n\n    // =========================================================================\n    // Comb Section\n    // =========================================================================\n    reg [REG_WIDTH-1:0] comb_delay [0:N-1][0:M-1];\n    reg [REG_WIDTH-1:0] comb_out   [0:N-1];\n\n    wire output_handshake = output_tready & output_tvalid;\n\n    generate\n        for (k = 0; k < N; k = k + 1) begin : gen_comb\n            // Determine the input to this comb stage\n            wire [REG_WIDTH-1:0] comb_input;\n            if (k == 0)\n                assign comb_input = integrator[N-1];\n            else\n                assign comb_input = comb_out[k-1];\n\n            // Comb stage logic\n            integer m_idx;\n            always @(posedge clk) begin\n                if (rst) begin\n                    for (m_idx = 0; m_idx < M; m_idx = m_idx + 1)\n                        comb_delay[k][m_idx] <= {REG_WIDTH{1'b0}};\n                    comb_out[k] <= {REG_WIDTH{1'b0}};\n                end else if (output_handshake) begin\n                    // Compute comb output: difference between current input and delayed version\n                    comb_out[k] <= comb_input - comb_delay[k][M-1];\n\n                    // Shift delay line\n                    comb_delay[k][0] <= comb_input;\n                    for (m_idx = 1; m_idx < M; m_idx = m_idx + 1)\n                        comb_delay[k][m_idx] <= comb_delay[k][m_idx-1];\n                end\n            end\n        end\n    endgenerate\n\n    // =========================================================================\n    // Output Assignment\n    // =========================================================================\n    assign output_tdata = comb_out[N-1];\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
