ters done\n    wire sort_done = bid_sort_done & ask_sort_done;\n\n    // Add exactly 1 clock cycle of latency on top of sorting engine\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            match_valid   <= 1'b0;\n            matched_price <= {PRICE_WIDTH{1'b0}};\n            done          <= 1'b0;\n        end else begin\n            if (sort_done) begin\n                done <= 1'b1;\n                if (!circuit_breaker && (best_bid >= best_ask)) begin\n                    match_valid   <= 1'b1;\n                    matched_price <= best_bid;\n                end else begin\n                    match_valid   <= 1'b0;\n                    matched_price <= {PRICE_WIDTH{1'b0}};\n                end\n            end else begin\n                done          <= 1'b0;\n                match_valid   <= 1'b0;\n                matched_price <= {PRICE_WIDTH{1'b0}};\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
