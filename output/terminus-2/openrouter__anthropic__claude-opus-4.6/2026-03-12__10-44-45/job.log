Sending keys: ["cat > /tmp/gen_lut.py << 'PYEOF'\nimport math\n\nNBW_IN = 6\nNBI_IN = 1\nNBF_IN = NBW_IN - NBI_IN  # 5\nNBW_PHASE = 9\nNBI_PHASE = 1\nNBF_PHASE = NBW_PHASE - NBI_PHASE  # 8\n\n# Number of possible absolute values: 0 to 2^NBF_IN = 0 to 32 => 33 values\nNUM_ABS = (1 << NBF_IN) + 1  # 33\nLUT_SIZE = NUM_ABS * NUM_ABS  # 1089\n\n# Generate LUT entries for first quadrant\n# abs_i ranges from 0 to 32, abs_q ranges from 0 to 32\n# These represent unsigned fixed-point values with NBF_IN fractional bits\n# So actual value = abs_val / 2^NBF_IN\n\nlut_entries = []\nfor abs_i in range(NUM_ABS):\n    for abs_q in range(NUM_ABS):\n        fi = abs_i / (1 << NBF_IN)  # float value of abs(i_data_i)\n        fq = abs_q / (1 << NBF_IN)  # float value of abs(i_data_q)\n        \n        # atan2 for first quadrant: both positive\n        angle_deg = math.atan2(fq, fi) * 180.0 / math.pi  # 0 to 90 degrees\n        # Normalize: already in [-180, 180] since it's [0, 90]\n        # Convert to output format: multiply by 256/180\n        phase_float = angle_deg * (1 << NBF_PHASE) / 180.0\n        # Round to nearest integer\n        phase_int = round(phase_float)\n        lut_entries.append(phase_int)\n\n# Now generate the SystemVerilog module\nlines = []\nlines.append('module phase_lut #(')\nlines.append('   parameter NBW_IN    = 6,')\nlines.append('   parameter NBI_IN    = 1,')\nlines.append('   parameter NBW_PHASE = 9,')\nlines.append('   parameter NBI_PHASE = 1')\nlines.append(')')\nlines.append('(')\nlines.append('   input  logic                          clk,')\nlines.append('   input  logic                          rst_async_n,')\nlines.append('   input  logic signed [NBW_IN-1:0]      i_data_i,')\nlines.append('   input  logic signed [NBW_IN-1:0]      i_data_q,')\nlines.append('   output logic signed [NBW_PHASE-1:0]   o_phase')\nlines.append(');')\nlines.append('')\nlines.append('// Derived parameters')\nlines.append('localparam NBF_IN    = NBW_IN - NBI_IN;       // 5')\nlines.append('localparam NBF_PHASE = NBW_PHASE - NBI_PHASE; // 8')\nlines.append('localparam NUM_ABS   = (1 << NBF_IN) + 1;     // 33')\nlines.append('localparam LUT_SIZE  = NUM_ABS * NUM_ABS;      // 1089')\nlines.append('localparam FULL_SCALE = (1 << NBF_PHASE);      // 256')\nlines.append('')\nlines.append('// Combinational: sign detection and absolute values')\nlines.append('logic sign_i, sign_q;')\nlines.append('logic [NBF_IN:0] abs_i, abs_q;')\nlines.append('')\nlines.append('assign sign_i = i_data_i[NBW_IN-1];')\nlines.append('assign sign_q = i_data_q[NBW_IN-1];')\nlines.append('')\nlines.append('assign abs_i = sign_i ? -i_data_i : i_data_i;')\nlines.append('assign abs_q = sign_q ? -i_data_q : i_data_q;')\nlines.append('')\nlines.append('// Combinational: LUT index computation')\nlines.append('logic [$clog2(LUT_SIZE)-1:0] lut_index_comb;')\nlines.append('assign lut_index_comb = abs_i * NUM_ABS + abs_q;')\nlines.append('')\nlines.append('// Registered signals')\nlines.append('logic [$clog2(LUT_SIZE)-1:0] lut_index_r;')\nlines.append('logic sign_i_r, sign_q_r;')\nlines.append('')\nlines.append('always_ff @(posedge clk or negedge rst_async_n) begin')\nlines.append('    if (!rst_async_n) begin')\nlines.append('        lut_index_r <= \\'0;')\nlines.append('        sign_i_r    <= \\'0;')\nlines.append('        sign_q_r    <= \\'0;')\nlines.append('    end else begin')\nlines.append('        lut_index_r <= lut_index_comb;')\nlines.append('        sign_i_r    <= sign_i;')\nlines.append('        sign_q_r    <= sign_q;')\nlines.append('    end')\nlines.append('end')\nlines.append('')\nlines.append('// LUT: first quadrant phase values')\nlines.append('logic [NBW_PHASE-2:0] lut_value;  // unsigned, first quadrant only')\nlines.append('')\nlines.append('always_comb begin')\nlines.append('    case (lut_index_r)')\n\nfor idx, val in enumerate(lut_entries):\n    lines.append(f'        {idx}: lut_value = {NBW_PHASE-1}\\'d{val};')\n\nlines.append(f'        default: lut_value = \\'0;')\nlines.append('    endcase')\nlines.append('end')\nlines.append('')\nlines.append('// Quadrant adjustment')\nlines.append('always_comb begin')\nlines.append('    case ({sign_i_r, sign_q_r})')\nlines.append('        2\\'b00: o_phase = $signed({1\\'b0, lut_value});                              // Q1: +lut')\nlines.append('        2\\'b01: o_phase = -$signed({1\\'b0, lut_value});                             // Q4: -lut')\nlines.append('        2\\'b10: o_phase = $signed(FULL_SCALE[NBW_PHASE-1:0]) - $signed({1\\'b0, lut_value}); // Q2: full_scale - lut')\nlines.append('        2\\'b11: o_phase = $signed({1\\'b0, lut_value}) - $signed(FULL_SCALE[NBW_PHASE-1:0]); // Q3: lut - full_scale')\nlines.append('        default: o_phase = \\'0;')\nlines.append('    endcase')\nlines.append('end')\nlines.append('')\nlines.append('endmodule')\n\nwith open('/code/rtl/phase_lut.sv', 'w') as f:\n    f.write('\\n'.join(lines) + '\\n')\n\nprint(f'Generated LUT with {LUT_SIZE} entries')\nprint(f'Sample entries:')\nfor i in range(min(10, len(lut_entries))):\n    print(f'  [{i}] = {lut_entries[i]}')\nPYEOF\npython3 /tmp/gen_lut.py\n"] min_timeout_sec: 5.0 max_timeout_sec: 180.0
