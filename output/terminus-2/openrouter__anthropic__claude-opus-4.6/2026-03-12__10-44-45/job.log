und_ff <= 5'd0;\n        for(int i = 0; i < 4; i++) begin\n            for(int j = 0; j < 4; j++) begin\n                current_data_ff[i][j] <= 8'd0;\n            end\n        end\n    end else begin\n        if(i_start & o_done || (round_ff > 5'd0 && round_ff < 5'd15)) begin\n            round_ff <= round_ff + 1'b1;\n        end else begin\n            round_ff <= 5'd0;\n        end\n\n        for(int i = 0; i < 4; i++) begin\n            for(int j = 0; j < 4; j++) begin\n                current_data_ff[i][j] <= current_data_nx[i][j];\n            end\n        end\n    end\nend\n\nalways_comb begin : next_data\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(i_start & o_done) begin\n                if(i_update_key) begin\n                    current_data_nx[i][j] = i_data[NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE] ^ i_key[NBW_KEY-1-(4*j+i)*NBW_BYTE-:NBW_BYTE];\n                end else begin\n                    current_data_nx[i][j] = i_data[NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE] ^ expanded_key_ff[NBW_EX_KEY-(4*j+i)*NBW_BYTE-1-:NBW_BYTE];\n                end\n            end else begin\n                if(round_ff > 5'd1) begin\n                    if(round_ff != 5'd15) begin\n                        current_data_nx[i][j] = MixColumns[i][j] ^ expanded_key_ff[NBW_EX_KEY-(round_ff-1)*NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE];\n                    end else begin\n                        current_data_nx[i][j] = ShiftRows[i][j] ^ expanded_key_ff[NBW_EX_KEY-(round_ff-1)*NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE];\n                    end\n                end else begin\n                    current_data_nx[i][j] = current_data_ff[i][j];\n                end\n            end\n        end\n    end\nend\n\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : row\n        for(genvar j = 0; j < 4; j++) begin : col\n            sbox uu_sbox0 (\n                .i_data(current_data_ff[i][j]),\n                .o_data(SubBytes[i][j])\n            );\n        end\n    end\nendgenerate\n\nalways_comb begin : cypher_logic\n    // Shift Rows logic\n    // Line 0: No shift\n    ShiftRows[0][0] = SubBytes[0][0];\n    ShiftRows[0][1] = SubBytes[0][1];\n    ShiftRows[0][2] = SubBytes[0][2];\n    ShiftRows[0][3] = SubBytes[0][3];\n\n    // Line 1: Shift 1 left\n    ShiftRows[1][0] = SubBytes[1][1];\n    ShiftRows[1][1] = SubBytes[1][2];\n    ShiftRows[1][2] = SubBytes[1][3];\n    ShiftRows[1][3] = SubBytes[1][0];\n\n    // Line 2: Shift 2 left\n    ShiftRows[2][0] = SubBytes[2][2];\n    ShiftRows[2][1] = SubBytes[2][3];\n    ShiftRows[2][2] = SubBytes[2][0];\n    ShiftRows[2][3] = SubBytes[2][1];\n\n    // Line 3: Shift 3 left\n    ShiftRows[3][0] = SubBytes[3][3];\n    ShiftRows[3][1] = SubBytes[3][0];\n    ShiftRows[3][2] = SubBytes[3][1];\n    ShiftRows[3][3] = SubBytes[3][2];\n\n    // Mix Columns logic\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(ShiftRows[i][j][NBW_BYTE-1]) begin\n                xtimes02[i][j] = {ShiftRows[i][j][NBW_BYTE-2:0], 1'b0} ^ 8'h1B;\n                xtimes03[i][j] = {ShiftRows[i][j][NBW_BYTE-2:0], 1'b0} ^ 8'h1B ^ ShiftRows[i][j];\n            end else begin\n                xtimes02[i][j] = {ShiftRows[i][j][NBW_BYTE-2:0], 1'b0};\n                xtimes03[i][j] = {ShiftRows[i][j][NBW_BYTE-2:0], 1'b0} ^ ShiftRows[i][j];\n            end\n        end\n    end\n\n    for(int i = 0; i < 4; i++) begin\n        MixColumns[0][i] = xtimes02[0][i] ^ xtimes03[1][i] ^ ShiftRows[2][i] ^ ShiftRows[3][i];\n        MixColumns[1][i] = xtimes02[1][i] ^ xtimes03[2][i] ^ ShiftRows[3][i] ^ ShiftRows[0][i];\n        MixColumns[2][i] = xtimes02[2][i] ^ xtimes03[3][i] ^ ShiftRows[0][i] ^ ShiftRows[1][i];\n        MixColumns[3][i] = xtimes02[3][i] ^ xtimes03[0][i] ^ ShiftRows[1][i] ^ ShiftRows[2][i];\n    end\nend\n\n// ****************************************\n// - Key Expansion logic\n// ****************************************\n\n// ----------------------------------------\n// - Registers\n// ----------------------------------------\nalways_ff @(posedge clk or negedge rst_async_n) begin : reset_regs\n    if(~rst_async_n) begin\n        expanded_key_ff <= {NBW_EX_KEY{1'b0}};\n    end else begin\n        expanded_key_ff <= expanded_key_nx;\n    end\nend\n\n// ----------------------------------------\n// - Rcon values (only 7 needed for AES-256)\n// ----------------------------------------\nassign Rcon[0] = 8'h01;\nassign Rcon[1] = 8'h02;\nassign Rcon[2] = 8'h04;\nassign Rcon[3] = 8'h08;\nassign Rcon[4] = 8'h10;\nassign Rcon[5] = 8'h20;\nassign Rcon[6] = 8'h40;\n\n// ----------------------------------------\n// - Key Expansion: compute w[0]..w[59]\n// ----------------------------------------\n\n// w[0]..w[7] come from valid_key\ngenerate\n    for (genvar k = 0; k < 8; k++) begin : init_words\n        assign w[k] = valid_key[NBW_KEY - k*NBW_WORD - 1 -: NBW_WORD];\n    end\nendgenerate\n\n// w[8]..w[59]: AES-256 key schedule\ngenerate\n    for (genvar idx = 8; idx < NUM_WORDS; idx++) begin : key_exp\n        logic [NBW_WORD-1:0] RotWord;\n        logic [NBW_WORD-1:0] SubWord;\n        logic [NBW_WORD-1:0] Temp;\n\n        // SubWord uses sbox on w[idx-1] (or RotWord for i%8==0)\n        if (idx % 8 == 0) begin : rot_sub_rcon\n            // RotWord of w[idx-1]\n            assign RotWord = {w[idx-1][NBW_WORD-NBW_BYTE-1:0], w[idx-1][NBW_WORD-1-:NBW_BYTE]};\n\n            sbox uu_sbox0 (.i_data(RotWord[NBW_WORD-1-:NBW_BYTE]),            .o_data(SubWord[NBW_WORD-1-:NBW_BYTE]));\n            sbox uu_sbox1 (.i_data(RotWord[NBW_WORD-NBW_BYTE-1-:NBW_BYTE]),   .o_data(SubWord[NBW_WORD-NBW_BYTE-1-:NBW_BYTE]));\n            sbox uu_sbox2 (.i_data(RotWord[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]), .o_data(SubWord[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]));\n            sbox uu_sbox3 (.i_data(RotWord[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]), .o_data(SubWord[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]));\n\n            assign Temp = {SubWord[NBW_WORD-1-:NBW_BYTE] ^ Rcon[idx/8 - 1], SubWord[NBW_WORD-NBW_BYTE-1:0]};\n        end else if (idx % 8 == 4) begin : sub_only\n            // SubWord of w[idx-1], no rotation, no Rcon\n            sbox uu_sbox0 (.i_data(w[idx-1][NBW_WORD-1-:NBW_BYTE]),            .o_data(SubWord[NBW_WORD-1-:NBW_BYTE]));\n            sbox uu_sbox1 (.i_data(w[idx-1][NBW_WORD-NBW_BYTE-1-:NBW_BYTE]),   .o_data(SubWord[NBW_WORD-NBW_BYTE-1-:NBW_BYTE]));\n            sbox uu_sbox2 (.i_data(w[idx-1][NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]), .o_data(SubWord[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]));\n            sbox uu_sbox3 (.i_data(w[idx-1][NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]), .o_data(SubWord[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]));\n\n            assign Temp = SubWord;\n        end else begin : pass_through\n            assign Temp = w[idx-1];\n        end\n\n        assign w[idx] = w[idx-8] ^ Temp;\n    end\nendgenerate\n\n// Build expanded_key_nx from w[] and valid_key\nalways_comb begin : build_expanded_key\n    for (int i = 0; i < NUM_WORDS; i++) begin\n        expanded_key_nx[NBW_EX_KEY - i*NBW_WORD - 1 -: NBW_WORD] = w[i];\n    end\nend\n\nalways_comb begin : input_data\n    if (i_update_key & o_done) begin\n        valid_key = i_key;\n    end else begin\n        valid_key = expanded_key_ff[NBW_EX_KEY-1-:NBW_KEY];\n    end\nend\n\nendmodule : aes_encrypt\nENDOFFILE\n"] min_timeout_sec: 2.0 max_timeout_sec: 180.0
