Sending keys: ['cat > /code/rtl/nmea_decoder.sv << \'VERILOG_EOF\'\nmodule nmea_decoder (\n    input wire clk,\n    input wire reset,\n    input wire [7:0] serial_in,         // ASCII character input\n    input wire serial_valid,            // Valid signal for character\n    input wire watchdog_timeout_en,     // Enable watchdog timeout detection\n    output reg [15:0] data_out,         // Decoded 16-bit output (ASCII)\n    output reg data_valid,              // Valid signal for output\n    output reg [15:0] data_out_bin,     // Binary converted output\n    output reg data_bin_valid,          // Valid signal for binary output\n    output reg error_overflow,          // Buffer overflow error flag\n    output reg valid_sentence,          // Indicates a valid GPRMC sentence was processed\n    output reg watchdog_timeout         // Watchdog timeout flag\n);\n\n    // FSM States\n    localparam\n        STATE_IDLE   = 2\'b00,\n        STATE_PARSE  = 2\'b01,\n        STATE_OUTPUT = 2\'b10;\n\n    // Configuration\n    localparam MAX_BUFFER_SIZE = 80;\n    localparam WATCHDOG_LIMIT  = 1024;\n\n    integer i;\n\n    // Internal registers\n    reg [7:0] buffer [0:MAX_BUFFER_SIZE-1];\n    reg [6:0] buffer_index;\n    reg [6:0] next_buffer_index;\n    reg [1:0] state, next_state;\n    reg overflow_detected;\n    reg store_char;\n    reg [6:0] store_index;\n\n    // Watchdog counter\n    reg [15:0] watchdog_counter;\n\n    // Character identifiers\n    wire is_start = (serial_in == 8\'h24);  // \'$\'\n    wire is_comma = (serial_in == 8\'h2C);  // \',\'\n    wire is_end   = (serial_in == 8\'h0D);  // \'\\r\'\n\n    // Combinational logic\n    always @(*) begin\n        next_state = state;\n        next_buffer_index = buffer_index;\n        overflow_detected = 0;\n        data_out = 16\'b0;\n        data_valid = 0;\n        store_char = 0;\n        store_index = 0;\n\n        case (state)\n            STATE_IDLE: begin\n                if (serial_valid && is_start) begin\n                    next_state = STATE_PARSE;\n                    next_buffer_index = 0;\n                end\n            end\n\n            STATE_PARSE: begin\n                if (serial_valid) begin\n                    if (is_end) begin\n                        next_state = STATE_OUTPUT;\n                    end else if (buffer_index < MAX_BUFFER_SIZE - 2) begin\n                        store_char = 1;\n                        store_index = buffer_index;\n                        next_buffer_index = buffer_index + 1;\n                    end else begin\n                        overflow_detected = 1;\n                        next_state = STATE_IDLE;\n                        next_buffer_index = 0;\n                    end\n                end\n            end\n\n            STATE_OUTPUT: begin\n                if (buffer[0] == 8\'h47 &&  // \'G\'\n                    buffer[1] == 8\'h50 &&  // \'P\'\n                    buffer[2] == 8\'h52 &&  // \'R\'\n                    buffer[3] == 8\'h4D &&  // \'M\'\n                    buffer[4] == 8\'h43)    // \'C\'\n                begin : gprmc_extract\n                    reg [6:0] comma_count;\n                    reg [6:0] field_index;\n                    comma_count = 0;\n                    field_index = 0;\n\n                    for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1) begin\n                        if (i[6:0] < buffer_index) begin\n                            if (buffer[i] == 8\'h2C) begin\n                                comma_count = comma_count + 1;\n                                if (comma_count == 1) begin\n                                    field_index = i[6:0] + 1;\n                                end\n                            end\n                        end\n                    end\n\n                    if (field_index + 1 < buffer_index) begin\n                        data_out = {buffer[field_index], buffer[field_index + 1]};\n                        data_valid = 1;\n                    end\n                end\n                next_state = STATE_IDLE;\n            end\n\n            default: next_state = STATE_IDLE;\n        endcase\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            error_overflow <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n            data_out_bin <= 16\'b0;\n            data_bin_valid <= 0;\n            valid_sentence <= 0;\n            for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1)\n                buffer[i] <= 8\'h00;\n        end else begin\n            state <= next_state;\n            buffer_index <= next_buffer_index;\n\n            // Store character into buffer during PARSE\n            if (store_char) begin\n                buffer[store_index] <= serial_in;\n            end\n\n            // Error overflow - sticky until next $ start\n            if (overflow_detected) begin\n                error_overflow <= 1;\n            end else if (state == STATE_IDLE && serial_valid && is_start) begin\n                error_overflow <= 0;\n            end\n\n            // Debug - print every 500 cycles after time 1800\n            if (watchdog_counter == 0 || watchdog_counter == 500 || watchdog_counter == 1024 || watchdog_counter == 1025) begin\n                $display("DBG t=%0t st=%0d sv=%0d is_s=%0d wdt_en=%0d cnt=%0d to=%0d nst=%0d",\n                    $time, state, serial_valid, is_start, watchdog_timeout_en, watchdog_counter, watchdog_timeout, next_state);\n            end\n\n            // Watchdog logic\n            if (state == STATE_IDLE && serial_valid && is_start) begin\n                watchdog_counter <= 0;\n                watchdog_timeout <= 0;\n            end else if (state == STATE_PARSE) begin\n                if (watchdog_timeout_en) begin\n                    watchdog_counter <= watchdog_counter + 1;\n                    if (watchdog_counter >= WATCHDOG_LIMIT) begin\n                        watchdog_timeout <= 1;\n                    end\n                end\n            end\n\n            // Binary conversion - registered\n            if (state == STATE_OUTPUT && data_valid) begin\n                valid_sentence <= 1;\n                if (data_out[15:8] >= 8\'h30 && data_out[15:8] <= 8\'h39 &&\n                    data_out[7:0] >= 8\'h30 && data_out[7:0] <= 8\'h39) begin\n                    data_out_bin <= (data_out[15:8] - 8\'h30) * 10 + (data_out[7:0] - 8\'h30);\n                    data_bin_valid <= 1;\n                end else begin\n                    data_out_bin <= 16\'b0;\n                    data_bin_valid <= 0;\n                end\n            end else begin\n                data_bin_valid <= 0;\n                valid_sentence <= 0;\n            end\n        end\n    end\n\nendmodule\nVERILOG_EOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
