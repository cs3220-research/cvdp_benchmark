Sending keys: ['cat > /tmp/gen2.py << \'SCRIPTEOF\'\nimport os\n\ndecoder = """module hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1\'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    localparam integer SR_DEPTH = encoder_type + 1;\n\n    logic p_r1, n_r1;\n    logic [SR_DEPTH-1:0] sr_p;\n    logic [SR_DEPTH-1:0] sr_n;\n    logic [SR_DEPTH-1:0] sr_v;\n    logic last_pol;\n    logic last_pol_valid;\n    logic suppress_b;\n    logic [2:0] out_zero_cnt;\n    logic pulse_err_r;\n    logic zero_err_r;\n\n    // Combinational signals\n    logic new_is_pos, new_is_neg, new_pulse, new_is_violation;\n    logic has_pulse_rd, is_v_rd, data_c;\n\n    always_comb begin\n        new_is_pos = p_r1;\n        new_is_neg = n_r1;\n        new_pulse  = new_is_pos | new_is_neg;\n\n        new_is_violation = 1\'b0;\n        if (new_pulse & last_pol_valid & ~(new_is_pos & new_is_neg)) begin\n            if (new_is_pos & last_pol)\n                new_is_violation = 1\'b1;\n            else if (new_is_neg & ~last_pol)\n                new_is_violation = 1\'b1;\n        end\n\n        has_pulse_rd = sr_p[0] | sr_n[0];\n        is_v_rd = sr_v[0];\n\n        if (is_v_rd)\n            data_c = 1\'b0;\n        else if (suppress_b & has_pulse_rd)\n            data_c = 1\'b0;\n        else\n            data_c = has_pulse_rd;\n    end\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            p_r1           <= 1\'b0;\n            n_r1           <= 1\'b0;\n            sr_p           <= \'0;\n            sr_n           <= \'0;\n            sr_v           <= \'0;\n            last_pol       <= 1\'b0;\n            last_pol_valid <= 1\'b0;\n            suppress_b     <= 1\'b0;\n            out_zero_cnt   <= \'0;\n            pulse_err_r    <= 1\'b0;\n            zero_err_r     <= 1\'b0;\n            data_out       <= 1\'b0;\n            code_error_out <= 1\'b0;\n        end else if (clk_enable_in) begin\n\n            // Input register\n            p_r1 <= (p_in == pulse_active_state) ? 1\'b1 : 1\'b0;\n            n_r1 <= (n_in == pulse_active_state) ? 1\'b1 : 1\'b0;\n\n            // Shift register\n            for (int i = 0; i < SR_DEPTH - 1; i++) begin\n                sr_p[i] <= sr_p[i+1];\n                sr_n[i] <= sr_n[i+1];\n                sr_v[i] <= sr_v[i+1];\n            end\n            sr_p[SR_DEPTH-1] <= p_r1;\n            sr_n[SR_DEPTH-1] <= n_r1;\n            sr_v[SR_DEPTH-1] <= new_is_violation;\n\n            // Polarity tracking\n            if (new_pulse & ~(new_is_pos & new_is_neg)) begin\n                last_pol <= new_is_pos;\n                last_pol_valid <= 1\'b1;\n            end\n\n            // B suppression\n            suppress_b <= new_is_violation;\n\n            // Error detection\n            pulse_err_r <= (p_r1 & n_r1);\n\n            if (data_c)\n                out_zero_cnt <= \'0;\n            else if (out_zero_cnt <= encoder_type[2:0] + 3\'d2)\n                out_zero_cnt <= out_zero_cnt + 1\'b1;\n\n            zero_err_r <= (out_zero_cnt > encoder_type[2:0] + 3\'d1);\n\n            // Output register\n            data_out <= data_c;\n            code_error_out <= pulse_err_r | zero_err_r;\n        end\n    end\n\nendmodule\n"""\n\nwith open(\'/code/rtl/hdbn_decoder.sv\', \'w\') as f:\n    f.write(decoder)\nprint(\'Decoder rewritten\')\nSCRIPTEOF\npython3 /tmp/gen2.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
