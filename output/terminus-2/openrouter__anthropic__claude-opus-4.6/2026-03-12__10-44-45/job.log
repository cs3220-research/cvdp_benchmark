tion [encoder_type]\n            data_sr[0] <= data_sr[1];\n            is_v_sr[0] <= is_v_sr[1];\n            is_b_sr[0] <= is_b_sr[1];\n\n            for (int i = 1; i < encoder_type; i++) begin\n                data_sr[i] <= data_sr[i+1];\n                is_v_sr[i] <= is_v_sr[i+1];\n                is_b_sr[i] <= is_b_sr[i+1];\n            end\n\n            // New input enters at top of shift register\n            data_sr[encoder_type] <= data_in;\n            is_v_sr[encoder_type] <= 1'b0;\n            is_b_sr[encoder_type] <= 1'b0;\n\n            // ---- Zero counting and substitution ----\n            if (data_in == 1'b0) begin\n                if (zero_count == encoder_type[2:0]) begin\n                    // We've accumulated encoder_type zeros - substitute!\n                    zero_count <= '0;\n\n                    // Mark violation at current position (V pulse)\n                    is_v_sr[encoder_type] <= 1'b1;\n                    data_sr[encoder_type] <= 1'b1; // V is a pulse\n\n                    // For HDB3: need_balance when violation_parity is even (0)\n                    // For HDB2: always need balance (B0V pattern)\n                    if (encoder_type == 3) begin\n                        if (violation_parity == 1'b0) begin\n                            // Even: use B00V pattern\n                            // B is at position [encoder_type] in the shift register\n                            // which is encoder_type-1 positions before V\n                            // Since V is at [encoder_type] now, B was encoder_type-1 ago\n                            // B is at shift register position [1] (3 positions before current)\n                            is_b_sr[1] <= 1'b1;\n                            data_sr[1] <= 1'b1; // B is a pulse\n                        end\n                    end else begin\n                        // HDB2: B0V pattern, B is 2 positions before V\n                        is_b_sr[encoder_type-1] <= 1'b1;\n                        data_sr[encoder_type-1] <= 1'b1; // B is a pulse  \n                    end\n\n                    // Toggle violation parity\n                    violation_parity <= ~violation_parity;\n                end else begin\n                    zero_count <= zero_count + 1'b1;\n                end\n            end else begin\n                // Data is 1\n                zero_count <= '0;\n                violation_parity <= ~violation_parity; // count pulses\n            end\n\n            // ---- AMI polarity and output generation ----\n            // Process the oldest bit exiting the shift register (data_sr[0])\n            if (data_sr[0] || is_v_sr[0] || is_b_sr[0]) begin\n                if (is_v_sr[0]) begin\n                    // Violation pulse: SAME polarity as last pulse (intentional violation)\n                    // Don't toggle AMI\n                    if (ami_ff == 1'b0) begin\n                        // Last pulse was negative, violation = negative\n                        p_pipe <= 1'b0;\n                        n_pipe <= 1'b1;\n                    end else begin\n                        // Last pulse was positive, violation = positive\n                        p_pipe <= 1'b1;\n                        n_pipe <= 1'b0;\n                    end\n                end else if (is_b_sr[0]) begin\n                    // Balance pulse: follows AMI rule (alternates)\n                    ami_ff <= ~ami_ff;\n                    if (ami_ff == 1'b0) begin\n                        p_pipe <= 1'b1;\n                        n_pipe <= 1'b0;\n                    end else begin\n                        p_pipe <= 1'b0;\n                        n_pipe <= 1'b1;\n                    end\n                end else begin\n                    // Normal data pulse: follows AMI rule\n                    ami_ff <= ~ami_ff;\n                    if (ami_ff == 1'b0) begin\n                        p_pipe <= 1'b1;\n                        n_pipe <= 1'b0;\n                    end els