ag_reg[k] <= coeff_imag_reg[k] + ((error_imag * data_real[k] - error_real * data_imag[k]) >>> MU);\n            end\n        end\n    end\n\n    // Output assignments\n    genvar g;\n    generate\n        for (g = 0; g < TAP_NUM; g = g + 1) begin : coeff_out\n            assign coeff_real[g] = coeff_real_reg[g];\n            assign coeff_imag[g] = coeff_imag_reg[g];\n        end\n    endgenerate\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
