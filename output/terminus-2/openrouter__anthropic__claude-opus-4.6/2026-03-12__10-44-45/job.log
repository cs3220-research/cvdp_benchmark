Sending keys: ["cat > /code/rtl/axi4lite_to_pcie_cfg_bridge.sv << 'ENDOFFILE'\n`timescale 1ns/1ps\n\n//=============================================================================\n// Module: axi4lite_to_pcie_cfg_bridge\n//\n// Description:\n//   This module implements an AXI4-Lite to PCIe Configuration Space bridge.\n//   It translates AXI4-Lite write and read transactions into PCIe Configuration\n//   Space write and read transactions. The module uses two independent FSMs:\n//   one for handling write transactions and one for handling read transactions.\n//\n// Parameters:\n//   ADDR_WIDTH - Width of the address bus (default: 8 bits)\n//   DATA_WIDTH - Width of the data bus (default: 32 bits)\n//\n// Features:\n//   - Supports AXI4-Lite write transactions with byte-level strobe\n//   - Supports AXI4-Lite read transactions\n//   - Independent write and read FSMs for concurrent operation\n//   - Proper AXI4-Lite handshaking on all channels\n//   - Shared PCIe configuration address bus between read and write paths\n//=============================================================================\n\nmodule axi4lite_to_pcie_cfg_bridge #(\n    parameter ADDR_WIDTH = 8,\n    parameter DATA_WIDTH = 32\n)(\n    //=========================================================================\n    // Clock and Reset\n    //=========================================================================\n    input  logic                    aclk,       // AXI4-Lite clock signal\n    input  logic                    aresetn,    // AXI4-Lite active-low reset\n\n    //=========================================================================\n    // AXI4-Lite Write Address Channel\n    //=========================================================================\n    input  logic [ADDR_WIDTH-1:0]   awaddr,     // Write address from AXI4-Lite master\n    input  logic                    awvalid,    // Write address valid signal\n    output logic                    awready,    // Write address ready signal\n\n    //=========================================================================\n    // AXI4-Lite Write Data Channel\n    //=========================================================================\n    input  logic [DATA_WIDTH-1:0]   wdata,      // Write data from AXI4-Lite master\n    input  logic [DATA_WIDTH/8-1:0] wstrb,      // Write strobe for byte-level writes\n    input  logic                    wvalid,     // Write data valid signal\n    output logic                    wready,     // Write data ready signal\n\n    //=========================================================================\n    // AXI4-Lite Write Response Channel\n    //=========================================================================\n    output logic [1:0]              bresp,      // Write response (OKAY, SLVERR, etc.)\n    output logic                    bvalid,     // Write response valid signal\n    input  logic                    bready,     // Write response ready signal\n\n    //=========================================================================\n    // AXI4-Lite Read Address Channel\n    //=========================================================================\n    input  logic [ADDR_WIDTH-1:0]   araddr,     // Read address from AXI4-Lite master\n    input  logic                    arvalid,    // Read address valid signal\n    output logic                    arready,    // Read address ready signal\n\n    //=========================================================================\n    // AXI4-Lite Read Data Channel\n    //=========================================================================\n    output logic [DATA_WIDTH-1:0]   rdata,      // Read data output\n    output logic                    rvalid,     // Read data valid signal\n    input  logic                    rready,     // Read data ready signal\n    output logic [1:0]              rresp,      // Read response signal\n\n    //=========================================================================\n    // PCIe Configuration Space Interface\n    //=========================================================================\n    output logic [ADDR_WIDTH-1:0]   pcie_cfg_addr,  // PCIe configuration address\n    output logic [DATA_WIDTH-1:0]   pcie_cfg_wdata, // Data to write to PCIe config space\n    output logic                    pcie_cfg_wr_en, // Write enable for PCIe config space\n    input  logic [DATA_WIDTH-1:0]   pcie_cfg_rdata, // Data read from PCIe config space\n    output logic                    pcie_cfg_rd_en  // Read enable for PCIe config space\n);\n\n    //=========================================================================\n    // Write FSM States\n    //=========================================================================\n    typedef enum logic [2:0] {\n        W_IDLE,           // Wait for valid write transaction\n        W_ADDR_CAPTURE,   // Capture write address\n        W_DATA_CAPTURE,   // Capture write data and strobe\n        W_PCIE_WRITE,     // Perform PCIe configuration write\n        W_SEND_RESPONSE   // Send write response to master\n    } wr_state_t;\n\n    //=========================================================================\n    // Read FSM States\n    //=========================================================================\n    typedef enum logic [1:0] {\n        R_IDLE,           // Wait for valid read transaction\n        R_ADDR_CAPTURE,   // Capture read address\n        R_PCIE_READ,      // Perform PCIe configuration read\n        R_SEND_RESPONSE   // Send read response to master\n    } rd_state_t;\n\n    // FSM state registers\n    wr_state_t wr_current_state, wr_next_state;\n    rd_state_t rd_current_state, rd_next_state;\n\n    //=========================================================================\n    // Internal Registers for Write Path\n    //=========================================================================\n    logic [ADDR_WIDTH-1:0]   awaddr_reg;   // Captured write address\n    logic [DATA_WIDTH-1:0]   wdata_reg;    // Captured write data\n    logic [DATA_WIDTH/8-1:0] wstrb_reg;    // Captured write strobe\n\n    //=========================================================================\n    // Internal Registers for Read Path\n    //=========================================================================\n    logic [ADDR_WIDTH-1:0]   araddr_reg;   // Captured read address\n    logic [DATA_WIDTH-1:0]   rdata_reg;    // Captured read data from PCIe\n\n    //=========================================================================\n    // Write FSM State Transition (Sequential)\n    //=========================================================================\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            wr_current_state <= W_IDLE;\n        end else begin\n            wr_current_state <= wr_next_state;\n        end\n    end\n\n    //=========================================================================\n    // Write FSM Next State Logic (Combinational)\n    //=========================================================================\n    always_comb begin\n        wr_next_state = wr_current_state;\n        case (wr_current_state)\n            W_IDLE: begin\n                // Wait for both address and data valid signals\n                if (awvalid && wvalid) begin\n                    wr_next_state = W_ADDR_CAPTURE;\n                end\n            end\n\n            W_ADDR_CAPTURE: begin\n                // Address captured, move to data capture\n                wr_next_state = W_DATA_CAPTURE;\n            end\n\n            W_DATA_CAPTURE: begin\n                // Data captured, move to PCIe write\n                wr_next_state = W_PCIE_WRITE;\n            end\n\n            W_PCIE_WRITE: begin\n                // PCIe write done, move to send response\n                wr_next_state = W_SEND_RESPONSE;\n            end\n\n            W_SEND_RESPONSE: begin\n                // Wait for master to acknowledge response\n                if (bready) begin\n                    wr_next_state = W_IDLE;\n                end\n            end\n\n            default: begin\n                wr_next_state = W_IDLE;\n            end\n        endcase\n    end\n\n    //=========================================================================\n    // Write FSM Output Logic (Sequential)\n    //=========================================================================\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            // Reset all write-related outputs and registers\n            awready        <= 1'b0;\n            wready         <= 1'b0;\n            bvalid         <= 1'b0;\n            bresp          <= 2'b00;\n            pcie_cfg_wr_en <= 1'b0;\n            pcie_cfg_wdata <= {DATA_WIDTH{1'b0}};\n            awaddr_reg     <= {ADDR_WIDTH{1'b0}};\n            wdata_reg      <= {DATA_WIDTH{1'b0}};\n            wstrb_reg      <= {(DATA_WIDTH/8){1'b0}};\n        end else begin\n            case (wr_current_state)\n                W_IDLE: begin\n                    // De-assert all write handshake signals\n                    awready        <= 1'b0;\n                    wready         <= 1'b0;\n                    bvalid         <= 1'b0;\n                    pcie_cfg_wr_en <= 1'b0;\n                end\n\n                W_ADDR_CAPTURE: begin\n                    // Accept the write address\n                    awready    <= 1'b1;\n                    awaddr_reg <= awaddr;\n                end\n\n                W_DATA_CAPTURE: begin\n                    // Accept the write data and strobe\n                    awready   <= 1'b0;\n                    wready    <= 1'b1;\n                    wdata_reg <= wdata;\n                    wstrb_reg <= wstrb;\n                end\n\n                W_PCIE_WRITE: begin\n                    // Drive PCIe write signals\n                    wready         <= 1'b0;\n                    pcie_cfg_wr_en <= 1'b1;\n\n                    // Apply write strobe to selectively update bytes\n                    // Bytes not selected by wstrb are preserved from pcie_cfg_rdata\n                    for (int i = 0; i < (DATA_WIDTH/8); i++) begin\n                        pcie_cfg_wdata[(i*8)+:8] <= (wstrb_reg[i]) ?\n                            wdata_reg[(i*8)+:8] : pcie_cfg_rdata[(i*8)+:8];\n                    end\n                end\n\n                W_SEND_RESPONSE: begin\n                    // Send OKAY response and de-assert write enable\n                    pcie_cfg_wr_en <= 1'b0;\n                    bvalid         <= 1'b1;\n                    bresp          <= 2'b00; // OKAY response\n                end\n\n                default: begin\n                    // Default: de-assert all outputs\n                end\n            endcase\n        end\n    end\n\n    //=========================================================================\n    // Read FSM State Transition (Sequential)\n    //=========================================================================\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            rd_current_state <= R_IDLE;\n        end else begin\n            rd_current_state <= rd_next_state;\n        end\n    end\n\n    //=========================================================================\n    // Read FSM Next State Logic (Combinational)\n    //=========================================================================\n    always_comb begin\n        rd_next_state = rd_current_state;\n        case (rd_current_state)\n            R_IDLE: begin\n                // Wait for read address valid signal\n                if (arvalid) begin\n                    rd_next_state = R_ADDR_CAPTURE;\n                end\n            end\n\n            R_ADDR_CAPTURE: begin\n                // Address captured, move to PCIe read\n                rd_next_state = R_PCIE_READ;\n            end\n\n            R_PCIE_READ: begin\n                // PCIe read done, move to send response\n                rd_next_state = R_SEND_RESPONSE;\n            end\n\n            R_SEND_RESPONSE: begin\n                // Wait for master to accept read data\n                if (rready) begin\n                    rd_next_state = R_IDLE;\n                end\n            end\n\n            default: begin\n                rd_next_state = R_IDLE;\n            end\n        endcase\n    end\n\n    //=========================================================================\n    // Read FSM Output Logic (Sequential)\n    //=========================================================================\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            // Reset all read-related outputs and registers\n            arready        <= 1'b0;\n            rdata          <= {DATA_WIDTH{1'b0}};\n            rvalid         <= 1'b0;\n            rresp          <= 2'b00;\n            pcie_cfg_rd_en <= 1'b0;\n            araddr_reg     <= {ADDR_WIDTH{1'b0}};\n            rdata_reg      <= {DATA_WIDTH{1'b0}};\n        end else begin\n            case (rd_current_state)\n                R_IDLE: begin\n                    // De-assert all read handshake signals\n                    arready        <= 1'b0;\n                    rvalid         <= 1'b0;\n                    pcie_cfg_rd_en <= 1'b0;\n                end\n\n                R_ADDR_CAPTURE: begin\n                    // Accept the read address\n                    arready    <= 1'b1;\n                    araddr_reg <= araddr;\n                end\n\n                R_PCIE_READ: begin\n                    // Initiate PCIe configuration read\n                    arready        <= 1'b0;\n                    pcie_cfg_rd_en <= 1'b1;\n                    // Capture read data from PCIe configuration space\n                    rdata_reg      <= pcie_cfg_rdata;\n                end\n\n                R_SEND_RESPONSE: begin\n                    // Send read data and OKAY response to master\n                    pcie_cfg_rd_en <= 1'b0;\n                    rvalid         <= 1'b1;\n                    rdata          <= rdata_reg;\n                    rresp          <= 2'b00; // OKAY response\n                end\n\n                default: begin\n                    // Default: de-assert all outputs\n                end\n            endcase\n        end\n    end\n\n    //=========================================================================\n    // PCIe Configuration Address Multiplexing\n    // The pcie_cfg_addr is shared between write and read paths.\n    // During a write transaction, it carries the write address.\n    // During a read transaction, it carries the read address.\n    //=========================================================================\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            pcie_cfg_addr <= {ADDR_WIDTH{1'b0}};\n        end else begin\n            if (wr_current_state == W_PCIE_WRITE) begin\n                // Drive write address to PCIe during write transaction\n                pcie_cfg_addr <= awaddr_reg[ADDR_WIDTH-1:0];\n            end else if (rd_current_state == R_PCIE_READ) begin\n                // Drive read address to PCIe during read transaction\n                pcie_cfg_addr <= araddr_reg[ADDR_WIDTH-1:0];\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 2.0 max_timeout_sec: 180.0
