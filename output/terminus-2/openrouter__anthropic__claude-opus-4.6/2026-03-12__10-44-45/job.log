valid_reg <= valid_in;\n\n         // CHECK_MODE=1 extra pipeline stage\n         check_data_reg  <= prbs_data_out;\n         check_valid_reg <= scrambled_valid_reg;\n      end\n   end\n\n   // Output mux\n   generate\n      if (CHECK_MODE == 0) begin : gen_scrambler_mode\n         // 1 clock latency for both bypass and scramble\n         always_comb begin\n            if (bypass_scrambling) begin\n               data_out  = bypass_data_reg;\n               valid_out = bypass_valid_reg;\n            end else begin\n               data_out  = prbs_data_out;\n               valid_out = scrambled_valid_reg;\n            end\n         end\n      end else begin : gen_checker_mode\n         // bypass: 1 clock latency, check: 2 clock latency\n         always_comb begin\n            if (bypass_scrambling) begin\n               data_out  = bypass_data_reg;\n               valid_out = bypass_valid_reg;\n            end else begin\n               data_out  = check_data_reg;\n               valid_out = check_valid_reg;\n            end\n         end\n      end\n   endgenerate\n\n   // Bit counter: increments by WIDTH every time valid_out is asserted\n   always_ff @(posedge clk) begin\n      if (rst) begin\n         bit_count <= 32'd0;\n      end else if (valid_out) begin\n         bit_count <= bit_count + WIDTH;\n      end\n   end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
