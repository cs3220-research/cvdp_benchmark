= STATE_LOCKED;\n                end\n            end\n            STATE_STEP1_DONE: begin\n                if (write_valid && (paddr == ADDR_UNLOCK_1) && (pwdata == p_unlock_code_1)) begin\n                    next_state = STATE_UNLOCKED;\n                end else if (write_valid) begin\n                    // Wrong second step, reset to locked\n                    next_state = STATE_LOCKED;\n                end\n            end\n            STATE_UNLOCKED: begin\n                next_state = STATE_UNLOCKED;\n            end\n            default: begin\n                next_state = STATE_LOCKED;\n            end\n        endcase\n    end\n\n    //---------------------------------------------\n    // Output Logic\n    //---------------------------------------------\n    always @(posedge i_capture_pulse or negedge presetn) begin\n        if (!presetn) begin\n            secure <= 1'b0;\n        end else begin\n            if (next_state == STATE_UNLOCKED) begin\n                secure <= 1'b1;\n            end else begin\n                secure <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
