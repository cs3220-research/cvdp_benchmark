Sending keys: ["cat > /code/rtl/nmea_decoder.sv << 'VERILOG_EOF'\nmodule nmea_decoder (\n    input wire clk,\n    input wire reset,\n    input wire [7:0] serial_in,\n    input wire serial_valid,\n    input wire watchdog_timeout_en,\n    output reg [15:0] data_out,\n    output reg data_valid,\n    output reg [15:0] data_out_bin,\n    output reg data_bin_valid,\n    output reg error_overflow,\n    output reg valid_sentence,\n    output reg watchdog_timeout\n);\n\n    localparam STATE_IDLE   = 2'b00;\n    localparam STATE_PARSE  = 2'b01;\n    localparam STATE_OUTPUT = 2'b10;\n    localparam MAX_BUFFER_SIZE = 80;\n    localparam WATCHDOG_LIMIT  = 1024;\n\n    integer i;\n\n    reg [7:0] buffer [0:MAX_BUFFER_SIZE-1];\n    reg [6:0] buffer_index;\n    reg [6:0] next_buffer_index;\n    reg [1:0] state, next_state;\n    reg overflow_detected;\n    reg [15:0] watchdog_counter;\n\n    // Input registration for edge detection\n    reg serial_valid_d;\n    reg [7:0] serial_in_d;\n    wire sv_pulse = serial_valid & ~serial_valid_d;  // Rising edge detect\n    // Use either direct or delayed valid (whichever fires)\n    wire sv_eff = serial_valid | sv_pulse;\n    \n    always @(posedge clk or posedge reset) begin\n        if (reset) begin\n            serial_valid_d <= 0;\n            serial_in_d <= 8'h00;\n        end else begin\n            serial_valid_d <= serial_valid;\n            serial_in_d <= serial_in;\n        end\n    end\n\n    // Use direct serial_in for combinational logic (works for non-aligned case)\n    // For the aligned case, serial_in_d has the correct value one cycle later\n    wire is_start = (serial_in == 8'h24);\n    wire is_comma = (serial_in == 8'h2C);\n    wire is_end   = (serial_in == 8'h0D);\n\n    // Combinational logic\n    always @(*) begin\n        next_state = state;\n        next_buffer_index = buffer_index;\n        overflow_detected = 0;\n        data_out = 16'b0;\n        data_valid = 0;\n\n        case (state)\n            STATE_IDLE: begin