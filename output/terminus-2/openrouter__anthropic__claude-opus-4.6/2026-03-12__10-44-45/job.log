_CONTROL_CAPTURE_ST;\n                else if (i_calc_valid)\n                    next_state = PROC_WAIT_ST;\n                else\n                    next_state = PROC_CALC_ST;\n            end\n            PROC_WAIT_ST: begin\n                if (!i_enable || timecnt_ff == 0)\n                    next_state = PROC_CONTROL_CAPTURE_ST;\n                else\n                    next_state = PROC_WAIT_ST;\n            end\n            default: next_state = PROC_CONTROL_CAPTURE_ST;\n        endcase\n    end\n\n    // Output/control signal logic (combinational)\n    always_comb begin\n        case (state_ff)\n            PROC_CONTROL_CAPTURE_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = i_enable;\n                cnt_rstctrl  = 1'b1;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n            PROC_DATA_CAPTURE_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = i_valid;\n                timecnt_en   = 1'b0;\n            end\n            PROC_CALC_START_ST: begin\n                o_start_calc = 1'b1;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b1;\n                timecnt_en   = 1'b0;\n            end\n            PROC_CALC_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n            PROC_WAIT_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b1;\n            end\n            default: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n        endcase\n    end\n\n    // o_valid combinational output\n    assign o_valid = cnt_en & (state_ff == PROC_DATA_CAPTURE_ST) & (cnt_ff > 0);\n\n    // o_subsampling output\n    assign o_subsampling = subsampling_ff;\n\n    // Sequential logic - state register\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            state_ff <= PROC_CONTROL_CAPTURE_ST;\n        end else begin\n            state_ff <= next_state;\n        end\n    end\n\n    // Sequential logic - general purpose counter\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            cnt_ff <= '0;\n        end else begin\n            if (cnt_rstctrl) begin\n                cnt_ff <= i_subsampling ? (1 << (NBW_CNT - 1)) : 8;\n            end else if ((state_ff == PROC_DATA_CAPTURE_ST) && (cnt_ff == 0)) begin\n                cnt_ff <= (1 << NBW_CALCSTART) - 1;\n            end else if (cnt_en) begin\n                cnt_ff <= (cnt_ff > 0) ? cnt_ff - 1 : '0;\n            end\n        end\n    end\n\n    // Sequential logic - timeout counter and capture\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            timecnt_ff  <= '0;\n            timecnt_ff0 <= '0;\n        end else begin\n            if (i_calc_valid && (state_ff == PROC_CALC_ST)) begin\n                timecnt_ff <= timecnt_ff0;\n            end else if (timecnt_en) begin\n                timecnt_ff <= (timecnt_ff > 0) ? timecnt_ff - 1 : '0;\n            end\n        end\n    end\n\n    // Sequential logic - control capture (subsampling and wait)\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            subsampling_ff <= 1'b0;\n            timecnt_ff0    <= '0;\n        end else begin\n            if (ctrl_en) begin\n                timecnt_ff0    <= i_wait;\n                subsampling_ff <= i_subsampling;\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
