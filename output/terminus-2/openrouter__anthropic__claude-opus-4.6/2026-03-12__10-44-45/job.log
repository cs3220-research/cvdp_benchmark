pe2, cmyk_m_pipe2, cmyk_y_pipe2;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cmyk_c_pipe1 <= 16\'d0; cmyk_m_pipe1 <= 16\'d0; cmyk_y_pipe1 <= 16\'d0;\n            cmyk_c_pipe2 <= 16\'d0; cmyk_m_pipe2 <= 16\'d0; cmyk_y_pipe2 <= 16\'d0;\n        end else begin\n            cmyk_c_pipe1 <= cmyk_c_result;\n            cmyk_m_pipe1 <= cmyk_m_result;\n            cmyk_y_pipe1 <= cmyk_y_result;\n            cmyk_c_pipe2 <= cmyk_c_pipe1;\n            cmyk_m_pipe2 <= cmyk_m_pipe1;\n            cmyk_y_pipe2 <= cmyk_y_pipe1;\n        end\n    end\n\n    assign cmyk_channel_c = cmyk_c_pipe2;\n    assign cmyk_channel_m = cmyk_m_pipe2;\n    assign cmyk_channel_y = cmyk_y_pipe2;\n    assign cmyk_channel_k = cmyk_k_pipe[5];\n\nendmodule\n\nmodule multi_port_ram (\n    input               clk,\n    input               we,\n    input       [7:0]   waddr,\n    input      [24:0]   wdata,\n    input       [7:0]   raddr_a,\n    output reg [24:0]   rdata_a,\n    input       [7:0]   raddr_b,\n    output reg [24:0]   rdata_b,\n    input       [7:0]   raddr_c,\n    output reg [24:0]   rdata_c\n);\n\n    reg [24:0] ram [0:255];\n\n    always @(posedge clk) begin\n        if (we) ram[waddr] <= wdata;\n    end\n\n    always @(posedge clk) begin\n        rdata_a <= ram[raddr_a];\n    end\n\n    always @(posedge clk) begin\n        rdata_b <= ram[raddr_b];\n    end\n\n    always @(posedge clk) begin\n        rdata_c <= ram[raddr_c];\n    end\nendmodule\n\nmodule saturation_mult (\n    input  wire         clk,\n    input  wire         rst,\n    input  wire [24:0]  a,\n    input  wire [7:0]   b,\n    output [12:0]       result\n);\n\n    reg [24:0] A_reg;\n    reg [7:0] B_reg;\n    reg [30:0] mult_result;\n    reg [18:0] rounded_result;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            A_reg <= 25\'d0;\n            B_reg <= 8\'d0;\n        end else begin\n            A_reg <= a;\n            B_reg <= b;\n        end\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) mult_result <= \'d0;\n        else mult_result <= A_reg * B_reg;\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) rounded_result <= \'d0;\n        else rounded_result <= mult_result[30:12] + mult_result[11];\n    end\n\n    assign result = rounded_result[12:0];\nendmodule\n\nmodule hue_mult (\n    input               clk,\n    input               rst,\n    input signed [18:0] dataa,\n    input      [24:0]   datab,\n    output reg signed [11:0] result\n);\n\n    reg signed [43:0] mult_stage1;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) mult_stage1 <= 44\'d0;\n        else mult_stage1 <= $signed(dataa) * $signed({1\'b0, datab});\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) result <= 12\'d0;\n        else result <= mult_stage1[33:22];\n    end\nendmodule\n\nmodule cmyk_mult (\n    input  wire         clk,\n    input  wire         rst,\n    input  wire [24:0]  a,\n    input  wire [15:0]  b,\n    output [15:0]       result\n);\n\n    reg [24:0] A_reg;\n    reg [15:0] B_reg;\n    reg [40:0] mult_result;\n    reg [15:0] rounded_result;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            A_reg <= 25\'d0;\n            B_reg <= 16\'d0;\n        end else begin\n            A_reg <= a;\n            B_reg <= b;\n        end\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) mult_result <= 41\'d0;\n        else mult_result <= A_reg * B_reg;\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) rounded_result <= 16\'d0;\n        else rounded_result <= mult_result[39:16] + mult_result[15];\n    end\n\n    assign result = rounded_result;\nendmodule\n""")\nprint(\'Done\')\nENDPY\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
