_out;\n\n    assign ram_addr0    = cfg_addr_in[ADDR_W+1:2];\n    assign ram_data0_in = cfg_data_wr_in;\n    assign ram_wr0      = cfg_wr_in && cfg_is_ram;\n\n    ethernet_dp_ram #(\n        .WIDTH  (WIDTH),\n        .ADDR_W (ADDR_W)\n    ) u_dp_ram (\n        .clk0_in   (clk_in),\n        .addr0_in  (ram_addr0),\n        .data0_in  (ram_data0_in),\n        .wr0_in    (ram_wr0),\n        .addr1_in  (ram_addr1),\n        .data1_in  (32'd0),\n        .wr1_in    (1'b0),\n        .data0_out (ram_data0_out),\n        .data1_out (ram_data1_out)\n    );\n\n    // ---------------------------------------------------------------\n    // Configuration Read\n    // ---------------------------------------------------------------\n    reg [31:0] cfg_data_rd_reg;\n    assign cfg_data_rd_out = cfg_data_rd_reg;\n\n    always @(*) begin\n        case (cfg_addr_in[15:0])\n            16'h07F4: cfg_data_rd_reg = tx_length_reg;\n            16'h07F8: cfg_data_rd_reg = irq_enable_reg;\n            16'h07FC: cfg_data_rd_reg = tx_control_reg;\n            default:  cfg_data_rd_reg = ram_data0_out;\n        endcase\n    end\n\n    // ---------------------------------------------------------------\n    // Transmit FSM registers\n    // ---------------------------------------------------------------\n    reg [2:0]  state;\n    reg [31:0] tx_total_bytes;    // effective length (with padding)\n    reg [31:0] bytes_sent;        // bytes output so far\n    reg [ADDR_W-1:0] word_addr;  // current word index for RAM reads\n    reg        tx_valid;\n    reg [31:0] tx_data;\n    reg [3:0]  tx_strb;\n    reg        tx_last;\n    reg        interrupt_reg;\n\n    assign axis_tvalid_out = tx_valid;\n    assign axis_tdata_out  = tx_data;\n    assign axis_tstrb_out  = tx_strb;\n    assign axis_tlast_out  = tx_last;\n    assign interrupt_out   = interrupt_reg;\n\n    // Effective length: max(tx_length_reg, 64)\n    wire [31:0] eff_len = (tx_length_reg < 32'd64) ? 32'd64 : tx_length_reg;\n\n    // Compute strobe for remaining bytes\n    function [3:0] calc_strb;\n        input [31:0] remaining;\n        begin\n            if (remaining >= 4)\n                calc_strb = 4'b1111;\n            else begin\n                case (remaining[1:0])\n                    2'd1: calc_strb = 4'b0001;\n                    2'd2: calc_strb = 4'b0011;\n                    2'd3: calc_strb = 4'b0111;\n                    default: calc_strb = 4'b1111;\n                endcase\n            end\n        end\n    endfunction\n\n    // ---------------------------------------------------------------\n    // Main FSM\n    // ---------------------------------------------------------------\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state          <= S_IDLE;\n            tx_length_reg  <= 32'd0;\n            irq_enable_reg <= 32'd0;\n            tx_control_reg <= 32'd0;\n            tx_total_bytes <= 32'd0;\n            bytes_sent     <= 32'd0;\n            word_addr      <= {ADDR_W{1'b0}};\n            ram_addr1      <= {ADDR_W{1'b0}};\n            tx_valid       <= 1'b0;\n            tx_data        <= 32'd0;\n            tx_strb        <= 4'b0000;\n            tx_last        <= 1'b0;\n            interrupt_reg  <= 1'b0;\n        end else begin\n            // Clear single-cycle interrupt\n            if (interrupt_reg)\n                interrupt_reg <= 1'b0;\n\n            // Config register writes\n            if (cfg_wr_in) begin\n                if (cfg_is_length)\n                    tx_length_reg <= cfg_data_wr_in;\n                else if (cfg_is_irq_en)\n                    irq_enable_reg <= cfg_data_wr_in;\n                else if (cfg_is_control)\n                    tx_control_reg <= cfg_data_wr_in;\n            end\n\n            case (state)\n                // ====================================================\n                S_IDLE: begin\n                    tx_valid <= 1'b0;\n                    tx_last  <= 1'b0;\n                    tx_strb  <= 4'b0000;\n\n                    if (cfg_wr_in && cfg_is_control && cfg_data_wr_in[0]) begin\n                        if (cfg_data_wr_in[1]) begin\n                            // MAC PROGRAM mode\n                            state         <= S_END;\n                            interrupt_reg <= irq_enable_reg[0];\n                        end else begin\n                            // Normal TX: start prefetch\n                            tx_total_bytes <= eff_len;\n                            bytes_sent     <= 32'd0;\n                            word_addr      <= {ADDR_W{1'b0}};\n                            ram_addr1      <= {ADDR_W{1'b0}}; // present addr 0 to RAM\n                            state          <= S_PREFETCH;\n                        end\n                    end\n                end\n\n                // ====================================================\n                // PREFETCH: Wait one cycle for RAM read latency\n                // After this cycle, ram_data1_out has data for word_addr=0\n                // ====================================================\n                S_PREFETCH: begin\n                    // Advance address for the NEXT word\n                    word_addr <= word_addr + 1;\n                    ram_addr1 <= word_addr + 1;\n                    state     <= S_TRANSMIT;\n                end\n\n                // ====================================================\n                // TRANSMIT: RAM data is ready, output it\n                // ====================================================\n                S_TRANSMIT: begin\n                    if (axis_tready_in) begin\n                        tx_valid <= 1'b1;\n\n                        // Output data: real data or padding\n                        if (bytes_sent < tx_length_reg)\n                            tx_data <= ram_data1_out;\n                        else\n                            tx_data <= 32'd0;\n\n                        // Remaining bytes\n                        if ((tx_total_bytes - bytes_sent) <= 32'd4) begin\n                            tx_strb <= calc_strb(tx_total_bytes - bytes_sent);\n                            tx_last <= 1'b1;\n                        end else begin\n                            tx_strb <= 4'b1111;\n                            tx_last <= 1'b0;\n                        end\n\n                        state <= S_UPDATE;\n                    end\n                end\n\n                // ====================================================\n                // UPDATE: Advance counters, decide next state\n                // ====================================================\n                S_UPDATE: begin\n                    tx_valid <= 1'b0;\n                    tx_last  <= 1'b0;\n\n                    if ((tx_total_bytes - bytes_sent) >= 32'd4)\n                        bytes_sent <= bytes_sent + 32'd4;\n                    else\n                        bytes_sent <= tx_total_bytes;\n\n                    if ((tx_total_bytes - bytes_sent) <= 32'd4) begin\n                        // Done\n                        state <= S_END;\n                        if (irq_enable_reg[0])\n                            interrupt_reg <= 1'b1;\n                    end else begin\n                        // More data: advance RAM address for next-next word\n                        // Current read (word_addr) data will be ready next cycle\n                        if ((bytes_sent + 32'd4) < tx_length_reg) begin\n                            word_addr <= word_addr + 1;\n                            ram_addr1 <= word_addr + 1;\n                        end\n                        state <= S_TRANSMIT;\n                    end\n                end\n\n                // ====================================================\n                S_END: begin\n                    tx_valid       <= 1'b0;\n                    tx_last        <= 1'b0;\n                    tx_strb        <= 4'b0000;\n                    tx_control_reg <= 32'd0;\n                    state          <= S_IDLE;\n                end\n\n                default: state <= S_IDLE;\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
