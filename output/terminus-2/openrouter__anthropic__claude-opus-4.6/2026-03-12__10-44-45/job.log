Sending keys: ["python3 << 'PYEOF'\nencoder_sv = r'''\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    // Pipeline latency = encoder_type + 3 clocks\n    // Stage 1: input register\n    // Stage 2 to encoder_type+2: shift register of depth encoder_type+1\n    // Stage encoder_type+3: output register with gating\n    // AMI polarity is applied combinationally at SR output\n\n    localparam integer SR_DEPTH = encoder_type + 1;\n\n    // Input register\n    logic data_r1;\n\n    // Shift register: [SR_DEPTH-1] = write end, [0] = read end\n    logic [SR_DEPTH-1:0] sr_data;\n    logic [SR_DEPTH-1:0] sr_v;  // violation marker\n    logic [SR_DEPTH-1:0] sr_b;  // balance marker\n\n    // Zero counter (counts consecutive zeros entering SR)\n    logic [2:0] zero_cnt;\n\n    // Pulse parity: number of data-1 pulses since last substitution (mod 2)\n    logic pulse_parity;\n\n    // AMI state: 0 = next normal pulse is positive, 1 = next normal pulse is negative\n    logic ami;\n\n    // Combinational AMI output from SR[0]\n    logic p_comb, n_comb;\n\n    always_comb begin\n        p_comb = 1'b0;\n        n_comb = 1'b0;\n        if (sr_data[0]) begin\n            if (sr_v[0]) begin\n                // Violation: same polarity as last pulse (don't follow AMI)\n                if (ami)\n                    p_comb = 1'b1;  // last was positive, V = positive\n                else\n                    n_comb = 1'b1;  // last was negative, V = negative\n            end else begin\n                // Normal or B pulse: follow AMI alternation\n                if (!ami)\n                    p_comb = 1'b1;  // next is positive\n                else\n                    n_comb = 1'b1;  // next is negative\n            end\n        end\n    end\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_r1      <= 1'b0;\n            sr_data      <= '0;\n            sr_v         <= '0;\n            sr_b         <= '0;\n            zero_cnt     <= '0;\n            pulse_parity <= 1'b0;\n            ami          <= 1'b0;\n            p_out        <= ~pulse_active_state;\n            n_out        <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n\n            // Stage 1: Input register\n            data_r1 <= data_in;\n\n            // Stage 2: Shift register management\n            // Shift toward [0]\n            for (int i = 0; i < SR_DEPTH - 1; i++) begin\n                sr_data[i] <= sr_data[i+1];\n                sr_v[i]    <= sr_v[i+1];\n                sr_b[i]    <= sr_b[i+1];\n            end\n\n            // Write new data at top\n            sr_data[SR_DEPTH-1] <= data_r1;\n            sr_v[SR_DEPTH-1]    <= 1'b0;\n            sr_b[SR_DEPTH-1]    <= 1'b0;\n\n            // Zero counting and substitution\n            if (data_r1 == 1'b0) begin\n                if (zero_cnt == encoder_type[2:0]) begin\n                    // encoder_type+1 consecutive zeros detected\n                    // SR[0] = 1st zero, SR[SR_DEPTH-1] = last zero\n                    zero_cnt <= '0;\n\n                    // V at write position (last zero)\n                    sr_v[SR_DEPTH-1] <= 1'b1;\n                    sr_data[SR_DEPTH-1] <= 1'b1;\n\n                    // B placement\n                    if (encoder_type == 3) begin\n                        if (pulse_parity == 1'b0) begin\n                            // HDB3 even: B00V\n                            sr_b[0] <= 1'b1;\n                            sr_data[0] <= 1'b1;\n                        end\n                        // HDB3 odd: 000V (no B)\n                    end else begin\n                        // HDB2: always B0V\n                        sr_b[0] <= 1'b1;\n                        sr_data[0] <= 1'b1;\n                    end\n\n                    pulse_parity <= 1'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end else begin\n                zero_cnt <= '0;\n                pulse_parity <= ~pulse_parity;\n            end\n\n            // AMI state update (based on current SR[0] before shift)\n            if (sr_data[0] && !sr_v[0]) begin\n                ami <= ~ami;\n            end\n            // V doesn't toggle AMI\n\n            // Output register with gating\n            if (output_gate_in) begin\n                p_out <= p_comb ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_comb ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n        end\n    end\n\nendmodule\n'''\n\nwith open('/code/rtl/hdbn_encoder.sv', 'w') as f:\n    f.write(encoder_sv.strip() + '\\n')\nprint('Encoder written')\nPYEOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
