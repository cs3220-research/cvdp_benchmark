Sending keys: ["cat > /code/rtl/uart_rx_to_axis.sv << 'ENDOFFILE'\n`timescale 1ns / 1ps\n\nmodule uart_rx_to_axis #(\n    parameter CLK_FREQ      = 100,       // Clock frequency in MHz\n    parameter BIT_RATE       = 115200,    // UART bit rate in bps\n    parameter BIT_PER_WORD   = 8,         // Number of data bits per word\n    parameter PARITY_BIT     = 0,         // 0: none, 1: odd, 2: even\n    parameter STOP_BITS_NUM  = 1          // Number of stop bits (1 or 2)\n) (\n    input  wire                    aclk,\n    input  wire                    aresetn,\n    input  wire                    RX,\n    output reg  [BIT_PER_WORD-1:0] tdata,\n    output reg                     tuser,\n    output reg                     tvalid\n);\n\n    // -----------------------------------------------------------------------\n    // Timing calculation\n    // -----------------------------------------------------------------------\n    localparam integer CYCLE_PER_PERIOD = (CLK_FREQ * 1_000_000) / BIT_RATE;\n    localparam integer HALF_PERIOD      = CYCLE_PER_PERIOD / 2;\n\n    // -----------------------------------------------------------------------\n    // FSM State Encoding\n    // -----------------------------------------------------------------------\n    typedef enum logic [2:0] {\n        IDLE    = 3'd0,\n        START   = 3'd1,\n        DATA    = 3'd2,\n        PARITY  = 3'd3,\n        STOP1   = 3'd4,\n        STOP2   = 3'd5,\n        OUT_RDY = 3'd6\n    } state_t;\n\n    state_t state, next_state;\n\n    // -----------------------------------------------------------------------\n    // Internal Signals\n    // -----------------------------------------------------------------------\n    reg [$clog2(CYCLE_PER_PERIOD):0] Clk_Count;\n    reg [$clog2(BIT_PER_WORD):0]     Bit_Count;\n    reg [BIT_PER_WORD-1:0]           Data_Shift_Reg;\n    reg                              parity_calc;\n    reg                              parity_sampled;\n    reg                              rx_d;  // Delayed RX for edge detection\n    wire                             rx_falling_edge;\n    wire                             clk_count_done;\n    wire                             half_count_done;\n\n    // Falling edge detection on RX\n    assign rx_falling_edge = rx_d & ~RX;\n\n    // Counter comparisons\n    assign clk_count_done = (Clk_Count == (CYCLE_PER_PERIOD - 1));\n    assign half_count_done = (Clk_Count == (HALF_PERIOD - 1));\n\n    // -----------------------------------------------------------------------\n    // RX delayed register (for edge detection)\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn)\n            rx_d <= 1'b1;\n        else\n            rx_d <= RX;\n    end\n\n    // -----------------------------------------------------------------------\n    // FSM State Register\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn)\n            state <= IDLE;\n        else\n            state <= next_state;\n    end\n\n    // -----------------------------------------------------------------------\n    // FSM Next State Logic\n    // -----------------------------------------------------------------------\n    always @(*) begin\n        next_state = state;\n        case (state)\n            IDLE: begin\n                if (rx_falling_edge)\n                    next_state = START;\n            end\n            START: begin\n                // Sample at half bit period to center-align\n                if (half_count_done)\n                    next_state = DATA;\n            end\n            DATA: begin\n                if (clk_count_done && (Bit_Count == BIT_PER_WORD - 1)) begin\n                    if (PARITY_BIT != 0)\n                        next_state = PARITY;\n                    else\n                        next_state = STOP1;\n                end\n            end\n            PARITY: begin\n                if (clk_count_done)\n                    next_state = STOP1;\n            end\n            STOP1: begin\n                if (clk_count_done) begin\n                    if (STOP_BITS_NUM == 2)\n                        next_state = STOP2;\n                    else\n                        next_state = OUT_RDY;\n                end\n            end\n            STOP2: begin\n                if (clk_count_done)\n                    next_state = OUT_RDY;\n            end\n            OUT_RDY: begin\n                next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    // -----------------------------------------------------------------------\n    // Clock Counter\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Clk_Count <= 0;\n        end else begin\n            case (state)\n                IDLE: begin\n                    Clk_Count <= 0;\n                end\n                START: begin\n                    if (half_count_done)\n                        Clk_Count <= 0;\n                    else\n                        Clk_Count <= Clk_Count + 1;\n                end\n                DATA, PARITY, STOP1, STOP2: begin\n                    if (clk_count_done)\n                        Clk_Count <= 0;\n                    else\n                        Clk_Count <= Clk_Count + 1;\n                end\n                OUT_RDY: begin\n                    Clk_Count <= 0;\n                end\n                default: Clk_Count <= 0;\n            endcase\n        end\n    end\n\n    // -----------------------------------------------------------------------\n    // Bit Counter\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Bit_Count <= 0;\n        end else begin\n            if (state == DATA) begin\n                if (clk_count_done)\n                    Bit_Count <= Bit_Count + 1;\n            end else begin\n                Bit_Count <= 0;\n            end\n        end\n    end\n\n    // -----------------------------------------------------------------------\n    // Data Shift Register (right-shift: LSB first received ends at LSB)\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Data_Shift_Reg <= 0;\n        end else begin\n            if (state == DATA && clk_count_done) begin\n                Data_Shift_Reg <= {RX, Data_Shift_Reg[BIT_PER_WORD-1:1]};\n            end\n        end\n    end\n\n    // -----------------------------------------------------------------------\n    // Parity Sampling\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            parity_sampled <= 1'b0;\n        end else begin\n            if (state == PARITY && clk_count_done) begin\n                parity_sampled <= RX;\n            end\n        end\n    end\n\n    // -----------------------------------------------------------------------\n    // Parity Calculation\n    // -----------------------------------------------------------------------\n    always @(*) begin\n        parity_calc = ^Data_Shift_Reg;  // Even parity (XOR of all data bits)\n        if (PARITY_BIT == 1)\n            parity_calc = ~parity_calc;  // Odd parity: invert even parity\n    end\n\n    // -----------------------------------------------------------------------\n    // AXI-Stream Output Generation\n    // -----------------------------------------------------------------------\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            tdata  <= 0;\n            tuser  <= 1'b0;\n            tvalid <= 1'b0;\n        end else begin\n            if (state == OUT_RDY) begin\n                tdata  <= Data_Shift_Reg;\n                tvalid <= 1'b1;\n                if (PARITY_BIT != 0)\n                    tuser <= (parity_calc != parity_sampled);\n                else\n                    tuser <= 1'b0;\n            end else begin\n                tvalid <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
