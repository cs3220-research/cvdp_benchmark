r_key = round_keys_ff[5];\n        4'd7:  cur_key = round_keys_ff[6];\n        4'd8:  cur_key = round_keys_ff[7];\n        4'd9:  cur_key = round_keys_ff[8];\n        4'd10: cur_key = round_keys_ff[9];\n        default: cur_key = round_keys_ff[0];\n    endcase\n\n    // Split current key into 4 words\n    w0 = cur_key[NBW_KEY-1 -: NBW_WORD];\n    w1 = cur_key[NBW_KEY-NBW_WORD-1 -: NBW_WORD];\n    w2 = cur_key[NBW_KEY-2*NBW_WORD-1 -: NBW_WORD];\n    w3 = cur_key[NBW_KEY-3*NBW_WORD-1 -: NBW_WORD];\n\n    // RotWord: rotate last word (w3) left by one byte\n    RotWord = {w3[NBW_WORD-NBW_BYTE-1:0], w3[NBW_WORD-1 -: NBW_BYTE]};\n\n    // Rcon value\n    rcon_val = 8'h00;\n    case(step_cnt_ff)\n        4'd1:  rcon_val = Rcon[0];\n        4'd2:  rcon_val = Rcon[1];\n        4'd3:  rcon_val = Rcon[2];\n        4'd4:  rcon_val = Rcon[3];\n        4'd5:  rcon_val = Rcon[4];\n        4'd6:  rcon_val = Rcon[5];\n        4'd7:  rcon_val = Rcon[6];\n        4'd8:  rcon_val = Rcon[7];\n        4'd9:  rcon_val = Rcon[8];\n        4'd10: rcon_val = Rcon[9];\n        default: rcon_val = 8'h00;\n    endcase\n\n    // RconXor: XOR Rcon with MSB of SubWord\n    RconXor = {SubWord[NBW_WORD-1 -: NBW_BYTE] ^ rcon_val, SubWord[NBW_WORD-NBW_BYTE-1 -: (NBW_WORD-NBW_BYTE)]};\n\n    // New words\n    nw0 = w0 ^ RconXor;\n    nw1 = w1 ^ nw0;\n    nw2 = w2 ^ nw1;\n    nw3 = w3 ^ nw2;\nend\n\n// S-box instances for SubWord\nsbox uu_sbox0 (.i_data(RotWord[31:24]), .o_data(SubWord[31:24]));\nsbox uu_sbox1 (.i_data(RotWord[23:16]), .o_data(SubWord[23:16]));\nsbox uu_sbox2 (.i_data(RotWord[15:8]),  .o_data(SubWord[15:8]));\nsbox uu_sbox3 (.i_data(RotWord[7:0]),   .o_data(SubWord[7:0]));\n\nalways_ff @(posedge clk or negedge rst_async_n) begin\n    if(!rst_async_n) begin\n        step_cnt_ff <= 4'd0;\n        done_ff <= 1'b0;\n        for(int k = 0; k < 11; k++)\n            round_keys_ff[k] <= {NBW_KEY{1'b0}};\n    end else begin\n        if(i_start) begin\n            step_cnt_ff <= 4'd1;\n         