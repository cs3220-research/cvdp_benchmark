    r_unlock_sync_0 <= 1'b0;\n            r_unlock_sync_1 <= 1'b0;\n        end else begin\n            r_unlock_sync_0 <= w_unlocked_cap_domain;\n            r_unlock_sync_1 <= r_unlock_sync_0;\n        end\n    end\n\n    wire w_enable = r_unlock_sync_1;\n\n    // -------------------------------------------------------\n    // Thermostat instance (operates in i_clk domain)\n    // -------------------------------------------------------\n    wire w_heater_full;\n    wire w_heater_medium;\n    wire w_heater_low;\n    wire w_aircon_full;\n    wire w_aircon_medium;\n    wire w_aircon_low;\n    wire w_fan;\n    wire [2:0] w_state;\n\n    thermostat u_thermostat (\n        .i_temp_feedback (i_temp_feedback),\n        .i_fan_on        (i_fan_on),\n        .i_enable        (w_enable),\n        .i_fault         (i_fault),\n        .i_clr           (i_clr),\n        .i_clk           (i_clk),\n        .i_rst           (i_rst),\n        .o_heater_full   (w_heater_full),\n        .o_heater_medium (w_heater_medium),\n        .o_heater_low    (w_heater_low),\n        .o_aircon_full   (w_aircon_full),\n        .o_aircon_medium (w_aircon_medium),\n        .o_aircon_low    (w_aircon_low),\n        .o_fan           (w_fan),\n        .o_state         (w_state)\n    );\n\n    // -------------------------------------------------------\n    // Register top-level outputs from thermostat\n    // -------------------------------------------------------\n    always @(posedge i_clk or negedge i_rst) begin\n        if (!i_rst) begin\n            o_heater_full   <= 1'b0;\n            o_heater_medium <= 1'b0;\n            o_heater_low    <= 1'b0;\n            o_aircon_full   <= 1'b0;\n            o_aircon_medium <= 1'b0;\n            o_aircon_low    <= 1'b0;\n            o_fan           <= 1'b0;\n            o_state         <= 3'b011;\n        end else begin\n            o_heater_full   <= w_heater_full;\n            o_heater_medium <= w_heater_medium;\n            o_heater_low    <= w_heater_low;\n            o_aircon_full   <= w_aircon_full;\n            o_aircon_medium <= w_aircon_medium;\n            o_aircon_low    <= w_aircon_low;\n            o_fan           <= w_fan;\n            o_state         <= w_state;\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
