Sending keys: ['cat > /code/verif/barrel_shifter_tb.sv << \'TBEOF\'\n`timescale 1ns / 1ps\n\nmodule barrel_shifter_tb;\n\n    // Testbench Signals\n    reg [7:0] data_in;           // Input data\n    reg [2:0] shift_bits;        // Number of bits to shift\n    reg left_right;              // Direction of shift: 1 for left, 0 for right\n    reg shift_mode;              // Shift mode: 0 for logical, 1 for arithmetic\n    wire [7:0] data_out;         // Output data\n\n    // Instantiate the DUT (Device Under Test)\n    barrel_shifter uut (\n        .data_in(data_in),\n        .shift_bits(shift_bits),\n        .left_right(left_right),\n        .shift_mode(shift_mode),\n        .data_out(data_out)\n    );\n\n    // Task to calculate expected output for comparison\n    function [7:0] expected_output(input [7:0] data_in, input [2:0] shift_bits, input left_right, input shift_mode);\n        begin\n            if (left_right) begin\n                // Left shift (both logical and arithmetic)\n                expected_output = (data_in << shift_bits) & 8\'hFF;\n            end else begin\n                if (shift_mode) begin\n                    // Arithmetic right shift: sign-extend\n                    expected_output = ($signed(data_in) >>> shift_bits) & 8\'hFF;\n                end else begin\n                    // Logical right shift\n                    expected_output = (data_in >> shift_bits) & 8\'hFF;\n                end\n            end\n        end\n    endfunction\n\n    // Test procedure\n    initial begin\n        integer i;  // Loop variable\n        reg [7:0] expected; // Holds the expected output\n\n        // Display header\n        $display("Starting Testbench for barrel_shifter...");\n        $display("--------------------------------------------------");\n        $display("|  Data_in  |  Shift | Left/Right | Mode |  Output  | Expected |");\n        $display("--------------------------------------------------");\n\n        // Test logical shifts\n        for (i = 0; i < 50; i = i + 1) begin\n            data_in = $random % 256;\n            shift_bits = $random % 8;\n            left_right = $random % 2;\n            shift_mode = 0;\n\n            expected = expected_output(data_in, shift_bits, left_right, shift_mode);\n            #5;\n\n            $display("| %b |   %0d   |     %0d     |   %0d  | %b | %b |",\n                data_in, shift_bits, left_right, shift_mode, data_out, expected);\n\n            if (data_out !== expected) begin\n                $display("Test failed for data_in=%b, shift_bits=%0d, left_right=%0d, shift_mode=%0d. Expected=%b, Got=%b",\n                    data_in, shift_bits, left_right, shift_mode, expected, data_out);\n                $fatal;\n            end\n        end\n\n        // Test arithmetic shifts\n        for (i = 0; i < 50; i = i + 1) begin\n            data_in = $random % 256;\n            shift_bits = $random % 8;\n            left_right = $random % 2;\n            shift_mode = 1;\n\n            expected = expected_output(data_in, shift_bits, left_right, shift_mode);\n            #5;\n\n            $display("| %b |   %0d   |     %0d     |   %0d  | %b | %b |",\n                data_in, shift_bits, left_right, shift_mode, data_out, expected);\n\n            if (data_out !== expected) begin\n                $display("Test failed for data_in=%b, shift_bits=%0d, left_right=%0d, shift_mode=%0d. Expected=%b, Got=%b",\n                    data_in, shift_bits, left_right, shift_mode, expected, data_out);\n                $fatal;\n            end\n        end\n\n        $display("All tests passed!");\n        $finish;\n    end\nendmodule\nTBEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
