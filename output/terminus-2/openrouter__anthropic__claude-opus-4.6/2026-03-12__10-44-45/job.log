       // Complex: w_real += mu * (e_real * x_real + e_imag * x_imag)\n                //          w_imag += mu * (e_imag * x_real - e_real * x_imag)\n                // mu applied as arithmetic right shift by MU bits\n                coeff_real_reg[k] <= coeff_real_reg[k] +\n                    COEFF_WIDTH\'(({{2{error_real[DATA_WIDTH-1]}}, error_real} * {{2{data_real[k][DATA_WIDTH-1]}}, data_real[k]} +\n                                  {{2{error_imag[DATA_WIDTH-1]}}, error_imag} * {{2{data_imag[k][DATA_WIDTH-1]}}, data_imag[k]}) >>> MU);\n                coeff_imag_reg[k] <= coeff_imag_reg[k] +\n                    COEFF_WIDTH\'(({{2{error_imag[DATA_WIDTH-1]}}, error_imag} * {{2{data_real[k][DATA_WIDTH-1]}}, data_real[k]} -\n                                  {{2{error_real[DATA_WIDTH-1]}}, error_real} * {{2{data_imag[k][DATA_WIDTH-1]}}, data_imag[k]}) >>> MU);\n            end\n        end\n    end\n\n    // Output assignments\n    genvar g;\n    generate\n        for (g = 0; g < TAP_NUM; g = g + 1) begin : coeff_out\n            assign coeff_real[g] = coeff_real_reg[g];\n            assign coeff_imag[g] = coeff_imag_reg[g];\n        end\n    endgenerate\n\nendmodule\n""")\nprint(\'File written successfully\')\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
