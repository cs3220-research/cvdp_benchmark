                        done       <= 1'b0;\n                        serial_out <= data_in[0];\n                    end\n                    3'b010: begin  // 16-bit\n                        data_reg   <= {48'd0, data_in[15:0]};\n                        bit_count  <= 7'd16;\n                        done       <= 1'b0;\n                        serial_out <= data_in[0];\n                    end\n                    3'b011: begin  // 32-bit\n                        data_reg   <= {32'd0, data_in[31:0]};\n                        bit_count  <= 7'd32;\n                        done       <= 1'b0;\n                        serial_out <= data_in[0];\n                    end\n                    3'b100: begin  // 64-bit\n                        data_reg   <= data_in;\n                        bit_count  <= 7'd64;\n                        done       <= 1'b0;\n                        serial_out <= data_in[0];\n                    end\n                    default: begin\n                        done       <= 1'b1;\n                        serial_out <= 1'b0;\n                    end\n                endcase\n            end else begin\n                // Shifting: send next bit\n                if (bit_count > 7'd1) begin\n                    data_reg   <= {1'b0, data_reg[63:1]};\n                    serial_out <= data_reg[1];\n                    bit_count  <= bit_count - 7'd1;\n                end else begin\n                    // Transmission complete\n                    bit_count  <= 7'd0;\n                    done       <= 1'b1;\n                    serial_out <= 1'b0;\n                end\n            end\n        end\n    end\n\nendmodule\n\n\n//=============================================================================\n// Module: rx_block\n// Description: Deserializes serial data and reconstructs parallel data_out.\n//   Captures bits on rising edge of serial_clk.\n//   Asserts done when all expected bits have been received.\n//=============================================================================\nmodule rx_block (\n    input  logic        clk,\n    input  logic        reset_n,\n    input  logic        data_in,\n    input  logic        serial_clk,\n    input  logic [2:0]  sel,\n    output logic        done,\n    output logic [63:0] data_out\n);\n\n    // Internal registers\n    logic [63:0] shift_reg;     // Shift register for deserialization\n    logic [6:0]  bit_count;     // Counter for received bits\n    logic [6:0]  expected_bits; // Expected number of bits\n    logic        serial_clk_d;  // Delayed serial_clk for edge detection\n    logic        serial_clk_rise; // Rising edge detect\n\n    // Edge detection: detect rising edge of serial_clk\n    always_ff @(posedge clk or negedge reset_n) begin\n        if (!reset_n)\n            serial_clk_d <= 1'b0;\n        else\n            serial_clk_d <= serial_clk;\n    end\n\n    assign serial_clk_rise = serial_clk & ~serial_clk_d;\n\n    // Expected bits based on sel\n    always_comb begin\n        case (sel)\n            3'b001:  expected_bits = 7'd8;\n            3'b010:  expected_bits = 7'd16;\n            3'b011:  expected_bits = 7'd32;\n            3'b100:  expected_bits = 7'd64;\n            default: expected_bits = 7'd0;\n        endcase\n    end\n\n    // Main RX logic\n    always_ff @(posedge clk or negedge reset_n) begin\n        if (!reset_n) begin\n            shift_reg <= 64'd0;\n            bit_count <= 7'd0;\n            done      <= 1'b0;\n            data_out  <= 64'd0;\n        end else begin\n            if (serial_clk_rise) begin\n                // Shift in data (LSB first, so new bit goes to MSB side)\n                shift_reg <= {data_in, shift_reg[63:1]};\n                bit_count <= bit_count + 7'd1;\n\n                if ((bit_count + 7'd1) == expected_bits) begin\n                    done      <= 1'b1;\n                    bit_count <= 7'd0;\n                    case (sel)\n                        3'b001:  data_out <= {56'd0, data_in, shift_reg[63:57]};\n                        3'b010:  data_out <= {48'd0, data_in, shift_reg[63:49]};\n                        3'b011:  data_out <= {32'd0, data_in, shift_reg[63:33]};\n                        3'b100:  data_out <= {data_in, shift_reg[63:1]};\n                        default: data_out <= 64'd0;\n                    endcase\n                end else begin\n                    done <= 1'b0;\n                end\n            end else if (done) begin\n                done <= 1'b1;\n            end\n        end\n    end\n\nendmodule\n\n\n//=============================================================================\n// Module: binary_to_gray_conversion\n// Description: Converts binary data to Gray code (combinational).\n//=============================================================================\nmodule binary_to_gray_conversion (\n    input  logic [63:0] data,\n    output logic [63:0] gray_out\n);\n    assign gray_out = data ^ (data >> 1);\nendmodule\n\n\n//=============================================================================\n// Module: sync_serial_communication_tx_rx (Top-Level)\n// Description: Integrates tx_block, rx_block, and binary_to_gray_conversion.\n//=============================================================================\nmodule sync_serial_communication_tx_rx (\n    input  logic        clk,\n    input  logic        reset_n,\n    input  logic [2:0]  sel,\n    input  logic [63:0] data_in,\n    output logic [63:0] data_out,\n    output logic        done,\n    output logic [63:0] gray_out\n);\n\n    // Internal signals\n    logic serial_data;\n    logic serial_clk;\n    logic tx_done;\n\n    // TX Block\n    tx_block u_tx (\n        .clk        (clk),\n        .reset_n    (reset_n),\n        .data_in    (data_in),\n        .sel        (sel),\n        .serial_out (serial_data),\n        .done       (tx_done),\n        .serial_clk (serial_clk)\n    );\n\n    // RX Block\n    rx_block u_rx (\n        .clk        (clk),\n        .reset_n    (reset_n),\n        .data_in    (serial_data),\n        .serial_clk (serial_clk),\n        .sel        (sel),\n        .done       (done),\n        .data_out   (data_out)\n    );\n\n    // Binary to Gray Conversion\n    binary_to_gray_conversion u_b2g (\n        .data     (data_out),\n        .gray_out (gray_out)\n    );\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
