h02;\nassign Rcon[2] = 8'h04;\nassign Rcon[3] = 8'h08;\nassign Rcon[4] = 8'h10;\nassign Rcon[5] = 8'h20;\nassign Rcon[6] = 8'h40;\nassign Rcon[7] = 8'h80;\nassign Rcon[8] = 8'h1b;\nassign Rcon[9] = 8'h36;\n\n// Current round key (last 128 bits of expanded key built so far)\nlogic [NBW_KEY-1:0] current_round_key;\nlogic [3:0] step_index;\nlogic active;\n\n// Determine which step we're on\nalways_comb begin\n    step_index = 4'd0;\n    active = 1'b0;\n    for(int i = 0; i <= STEPS; i++) begin\n        if(key_exp_steps_ff[i]) begin\n            step_index = i[3:0];\n            active = 1'b1;\n        end\n    end\nend\n\n// Get the current round key from the last 128 bits written\nalways_comb begin\n    if(key_exp_steps_ff[0]) begin\n        current_round_key = valid_key;\n    end else begin\n        // The last round key is at the lowest bits of what we've built\n        // After step i (0-indexed), we have (i+1) round keys after the initial one\n        // The last 128 bits of expanded_key_ff that were written\n        // Round keys are stored MSB first: expanded_key_ff[NBW_OUT-1 -: 128] is round key 0\n        // After writing step i, the latest key is at position (i+1) from the top\n        current_round_key = expanded_key_ff[NBW_OUT - step_index*NBW_KEY - 1 -: NBW_KEY];\n    end\nend\n\nlogic [NBW_WORD-1:0] RotWord;\nlogic [NBW_WORD-1:0] SubWord;\nlogic [NBW_WORD-1:0] RconXor;\nlogic [NBW_BYTE-1:0] rcon_val;\n\nassign rcon_val = (step_index < STEPS) ? Rcon[step_index] : 8'h00;\n\n// RotWord: rotate the last word of current round key left by one byte\nassign RotWord = {current_round_key[NBW_WORD-NBW_BYTE-1 : 0], current_round_key[NBW_WORD-1 -: NBW_BYTE]};\n\nsbox uu_sbox0 (\n    .i_data(RotWord[NBW_WORD-1-:NBW_BYTE]),\n    .o_data(SubWord[NBW_WORD-1-:NBW_BYTE])\n);\n\nsbox uu_sbox1 (\n    .i_data(RotWord[NBW_WORD-NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(SubWord[NBW_WORD-NBW_BYTE-1-:NBW_BYTE])\n);\n\nsbox uu_sbox2 (\n    .i_data(RotWord[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(SubWord[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE])\n);\n\nsbox uu_sbox3 (\n    .i_data(RotWord[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(SubWord[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE])\n);\n\nassign RconXor = {SubWord[NBW_WORD-1-:NBW_BYTE] ^ rcon_val, SubWord[NBW_WORD-NBW_BYTE-1-:(NBW_WORD-NBW_BYTE)]};\n\nalways_comb begin\n    step_key[NBW_KEY-1-:NBW_WORD]            = current_round_key[NBW_KEY-1-:NBW_WORD] ^ RconXor;\n    step_key[NBW_KEY-NBW_WORD-1-:NBW_WORD]   = current_round_key[NBW_KEY-NBW_WORD-1-:NBW_WORD] ^ step_key[NBW_KEY-1-:NBW_WORD];\n    step_key[NBW_KEY-2*NBW_WORD-1-:NBW_WORD] = current_round_key[NBW_KEY-2*NBW_WORD-1-:NBW_WORD] ^ step_key[NBW_KEY-NBW_WORD-1-:NBW_WORD];\n    step_key[NBW_KEY-3*NBW_WORD-1-:NBW_WORD] = current_round_key[NBW_KEY-3*NBW_WORD-1-:NBW_WORD] ^ step_key[NBW_KEY-2*NBW_WORD-1-:NBW_WORD];\nend\n\nalways_comb begin\n    expanded_key_nx = expanded_key_ff;\n    if(key_exp_steps_ff[0]) begin\n        // Store the initial key at the top\n        expanded_key_nx[NBW_OUT-1 -: NBW_KEY] = valid_key;\n    end\n    if(active && !key_exp_steps_ff[0]) begin\n        // Store the new round key\n        expanded_key_nx[NBW_OUT - (step_index+1)*NBW_KEY - 1 -: NBW_KEY] = step_key;\n    end\nend\n\nalways_comb begin : input_data\n    if (i_start) begin\n        valid_key = i_key;\n    end else begin\n        valid_key = expanded_key_ff[NBW_OUT-1-:NBW_KEY];\n    end\nend\n\nendmodule : aes128_key_expansion\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
