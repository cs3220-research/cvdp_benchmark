>> 24) ^ (seed_1 >> 21)) & 1)), 25)\n    new_seed_2 = mask(((seed_2 << 1) | (((seed_2 >> 18) ^ (seed_2 >> 13)) & 1)), 19)\n    \n    # l_ac1 <= load_data_gain + s_out_sext - l_er0[MSB -: AC1_W]\n    er0_shifted = sext(mask(l_er0 >> (ER_W - AC1_W), AC1_W) if ER_W > AC1_W else mask(l_er0, AC1_W), AC1_W)\n    # Actually: l_er0[DATA_WIDTH+A2_WIDTH-1 -: DATA_WIDTH+A1_WIDTH] = l_er0[19:3] (17 bits)\n    er0_slice = mask(l_er0 >> (ER_W - AC1_W), AC1_W)\n    er0_slice_s = sext(er0_slice, AC1_W)\n    \n    s_out_ext = s_out_signed  # sign extended to AC1_W\n    \n    new_l_ac1 = mask(load_data_gain + s_out_signed - er0_slice_s, AC1_W)\n    new_l_ac1_s = sext(new_l_ac1, AC1_W)\n    \n    # l_ac2 <= l_ac2 + sign_extend(l_ac1, AC2_W)\n    l_ac1_ext = sext(mask(l_ac1, AC1_W), AC1_W)  # old l_ac1\n    new_l_ac2 = mask(l_ac2 + l_ac1_ext, AC2_W)\n    new_l_ac2_s = sext(new_l_ac2, AC2_W)\n    \n    # l_er0 <= l_er0 + sign_extend(l_ac1, ER_W)\n    new_l_er0 = mask(l_er0 + l_ac1_ext, ER_W)\n    \n    # l_quant <= l_ac2[MSB]  (old l_ac2)\n    new_l_quant = (l_ac2 >> (AC2_W - 1)) & 1\n    \n    # left_sig <= l_quant (old l_quant)\n    new_left_sig = l_quant\n    \n    print(f"  -> new_l_ac1={new_l_ac1_s} new_l_ac2={new_l_ac2_s} new_l_er0={sext(new_l_er0,ER_W)}")\n    print(f"  -> new_l_quant={new_l_quant} new_left_sig={new_left_sig}")\n    \n    # Update\n    seed_1 = new_seed_1\n    seed_2 = new_seed_2\n    l_ac1 = new_l_ac1\n    l_ac2 = new_l_ac2\n    l_er0_prev = l_er0\n    l_er0 = new_l_er0\n    l_quant = new_l_quant\n    left_sig = new_left_sig\n\nprint(f"\\nFinal at 60ns: left_sig={left_sig}")\nPYEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
