Sending keys: ["cat > /code/rtl/multi_digit_bcd_add_sub.sv << 'EOF'\nmodule multi_digit_bcd_add_sub #(parameter N = 4) (\n    input  [4*N-1:0] A,\n    input  [4*N-1:0] B,\n    input             add_sub,\n    output [4*N-1:0] result,\n    output            carry_borrow\n);\n\n    wire [N:0] carry;\n    wire [3:0] b_digit [N-1:0];\n    wire [3:0] operand_b [N-1:0];\n\n    // In addition mode (add_sub=1), carry_in = 0\n    // In subtraction mode (add_sub=0), use 9's complement: carry_in = 1\n    assign carry[0] = ~add_sub;\n\n    genvar i;\n    generate\n        for (i = 0; i < N; i = i + 1) begin : digit\n            // Extract digit from B\n            assign b_digit[i] = B[4*i+3 : 4*i];\n\n            // In subtraction mode, compute 9's complement: 9 - b_digit\n            // In addition mode, pass b_digit through\n            assign operand_b[i] = add_sub ? b_digit[i] : (4'd9 - b_digit[i]);\n\n            bcd_adder bcd_add_inst (\n                .a(A[4*i+3 : 4*i]),\n                .b(operand_b[i]),\n                .cin(carry[i]),\n                .sum(result[4*i+3 : 4*i]),\n                .cout(carry[i+1])\n            );\n        end\n    endgenerate\n\n    assign carry_borrow = carry[N];\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
Sending keys: ["cat > /code/rtl/bcd_top.sv << 'EOF'\nmodule bcd_top #(parameter N = 4) (\n    input  [4*N-1:0] A,\n    input  [4*N-1:0] B,\n    output            A_less_B,\n    output            A_equal_B,\n    output            A_greater_B\n);\n\n    wire [4*N-1:0] sub_result;\n    wire            borrow_out;\n\n    // Compute A - B using subtraction mode (add_sub = 0)\n    multi_digit_bcd_add_sub #(.N(N)) sub_inst (\n        .A(A),\n        .B(B),\n        .add_sub(1'b0),\n        .result(sub_result),\n        .carry_borrow(borrow_out)\n    );\n\n    // In 9's complement subtraction:\n    // If carry_out (borrow_out) = 1, A >= B (result is A - B)\n    // If carry_out (borrow_out) = 0, A < B (result is 9's complement of B - A)\n    \n    // Check if result is zero\n    wire result_is_zero;\n    assign result_is_zero = (sub_result == {4*N{1'b0}});\n\n    // Comparison logic\n    // borrow_out=0 means A < B\n    // borrow_out=1 and result=0 means A == B  \n    // borrow_out=1 and result!=0 means A > B\n    assign A_less_B    = ~borrow_out;\n    assign A_equal_B   = borrow_out & result_is_zero;\n    assign A_greater_B = borrow_out & ~result_is_zero;\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
