Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'VEOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    // ----------------------------------------------------------------\n    // Pipeline stages (total latency = encoder_type + 3 clocks):\n    //   1) Input register (data_in -> data_r1)\n    //   2) Write into FIFO + zero-count + substitution decision\n    //      FIFO depth = encoder_type, takes encoder_type clocks to traverse\n    //   3) Read from FIFO -> AMI assignment (p_int, n_int)\n    //   4) Output register with gating (p_out, n_out)\n    //\n    // HDB3 (encoder_type=3): 1 + 3 + 1 + 1 = 6 clocks\n    // HDB2 (encoder_type=2): 1 + 2 + 1 + 1 = 5 clocks\n    // ----------------------------------------------------------------\n\n    // Stage 1: input register\n    logic data_r1;\n\n    // FIFO implemented as shift register\n    // Position [encoder_type-1] = write end (newest)\n    // Position [0] = read end (oldest)\n    logic [encoder_type-1:0] fifo_data;\n    logic [encoder_type-1:0] fifo_v;  // violation marker\n    logic [encoder_type-1:0] fifo_b;  // balance marker\n\n    // Zero counter\n    logic [2:0] zero_cnt;\n\n    // Counts regular data pulses since last substitution (only parity matters)\n    logic pulse_cnt_parity;\n\n    // AMI flip-flop\n    // 0 -> next AMI pulse is positive (+)\n    // 1 -> next AMI pulse is negative (-)\n    logic ami;\n\n    // Stage 3: AMI-applied signals\n    logic p_int, n_int;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_r1         <= 1'b0;\n            fifo_data       <= '0;\n            fifo_v          <= '0;\n            fifo_b          <= '0;\n            zero_cnt        <= '0;\n            pulse_cnt_parity<= 1'b0;\n            ami             <= 1'b0;\n            p_int           <= 1'b0;\n            n_int           <= 1'b0;\n            p_out           <= ~pulse_active_state;\n            n_out           <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n\n            // ========== Stage 1: Input register ==========\n            data_r1 <= data_in;\n\n            // ========== Stage 2: FIFO shift + substitution ==========\n            // Shift FIFO toward output (position 0)\n            for (int i = 0; i < encoder_type - 1; i++) begin\n                fifo_data[i] <= fifo_data[i+1];\n                fifo_v[i]    <= fifo_v[i+1];\n                fifo_b[i]    <= fifo_b[i+1];\n            end\n\n            // Insert new data at write end\n            fifo_data[encoder_type-1] <= data_r1;\n            fifo_v[encoder_type-1]    <= 1'b0;\n            fifo_b[encoder_type-1]    <= 1'b0;\n\n            // Zero counting\n            if (data_r1 == 1'b0) begin\n                if (zero_cnt == encoder_type[2:0] - 1) begin\n                    // Reached encoder_type consecutive zeros\n                    zero_cnt <= '0;\n\n                    // Place V at write end (current position)\n                    fifo_v[encoder_type-1] <= 1'b1;\n                    fifo_data[encoder_type-1] <= 1'b1;\n\n                    // Determine if B is needed\n                    if (encoder_type == 3) begin\n                        // HDB3: B00V when pulse_cnt_parity==0 (even pulses since last sub)\n                        if (pulse_cnt_parity == 1'b0) begin\n                            // B goes at the start of the zero sequence\n                            // The zero sequence started encoder_type-1 positions ago\n                            // That's at fifo position [0] (just shifted there)\n                            fifo_b[0] <= 1'b1;\n                            fifo_data[0] <= 1'b1;\n                        end\n                    end else begin\n                        // HDB2: always B0V\n                        // B at start of 3-zero sequence = position [0]\n                        fifo_b[0] <= 1'b1;\n                        fifo_data[0] <= 1'b1;\n                    end\n\n                    pulse_cnt_parity <= 1'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end else begin\n                // Data is 1\n                zero_cnt <= '0;\n                pulse_cnt_parity <= ~pulse_cnt_parity;\n            end\n\n            // ========== Stage 3: AMI polarity assignment ==========\n            // Read from FIFO position [0]\n            if (fifo_data[0]) begin\n                if (fifo_v[0]) begin\n                    // V pulse: same polarity as last pulse (violation of AMI)\n                    if (ami) begin\n                        // Last was positive -> V is positive\n                        p_int <= 1'b1;\n                        n_int <= 1'b0;\n                    end else begin\n                        // Last was negative -> V is negative\n                        p_int <= 1'b0;\n                        n_int <= 1'b1;\n                    end\n                    // Don't toggle AMI\n                end else begin\n                    // Normal or B pulse: follows AMI alternation\n                    if (ami == 1'b0) begin\n                        // Next pulse is positive\n                        p_int <= 1'b1;\n                        n_int <= 1'b0;\n                        ami   <= 1'b1;\n                    end else begin\n                        // Next pulse is negative\n                        p_int <= 1'b0;\n                        n_int <= 1'b1;\n                        ami   <= 1'b0;\n                    end\n                end\n            end else begin\n                p_int <= 1'b0;\n                n_int <= 1'b0;\n            end\n\n            // ========== Stage 4: Output with gating ==========\n            if (output_gate_in) begin\n                p_out <= p_int ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_int ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n\n        end\n    end\n\nendmodule\nVEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
