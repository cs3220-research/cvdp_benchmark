ity_error        (sw_parity_error),\n    .invalid_mapping_error(sw_invalid_mapping_error)\n  );\n\n  // ---------------------------------------------------------------\n  // Post-processing: Unpack swizzler output into lanes\n  // ---------------------------------------------------------------\n  wire [DATA_WIDTH-1:0] sw_lane [0:NUM_LANES-1];\n  genvar gi;\n  generate\n    for (gi = 0; gi < NUM_LANES; gi = gi + 1) begin : UNPACK_SW_OUT\n      assign sw_lane[gi] = sw_data_out[DATA_WIDTH*(gi+1)-1 : DATA_WIDTH*gi];\n    end\n  endgenerate\n\n  // ---------------------------------------------------------------\n  // Invert LSB of each lane\n  // ---------------------------------------------------------------\n  wire [DATA_WIDTH-1:0] post_lane [0:NUM_LANES-1];\n  generate\n    for (gi = 0; gi < NUM_LANES; gi = gi + 1) begin : INVERT_LSB\n      assign post_lane[gi] = sw_lane[gi] ^ {{(DATA_WIDTH-1){1'b0}}, 1'b1};\n    end\n  endgenerate\n\n  // ---------------------------------------------------------------\n  // Pack post-processed lanes into flat output\n  // ---------------------------------------------------------------\n  wire [NUM_LANES*DATA_WIDTH-1:0] post_packed;\n  generate\n    for (gi = 0; gi < NUM_LANES; gi = gi + 1) begin : PACK_POST\n      assign post_packed[DATA_WIDTH*(gi+1)-1 : DATA_WIDTH*gi] = post_lane[gi];\n    end\n  endgenerate\n\n  // ---------------------------------------------------------------\n  // Compute checksum: XOR of all post-processed lanes\n  // ---------------------------------------------------------------\n  reg [DATA_WIDTH-1:0] checksum;\n  integer j;\n  always @(*) begin\n    checksum = {DATA_WIDTH{1'b0}};\n    for (j = 0; j < NUM_LANES; j = j + 1) begin\n      checksum = checksum ^ post_lane[j];\n    end\n  end\n\n  // ---------------------------------------------------------------\n  // Checksum mismatch detection\n  // ---------------------------------------------------------------\n  wire checksum_mismatch = (checksum != EXPECTED_CHECKSUM);\n\n  // ---------------------------------------------------------------\n  // Output assignment: final_data_out and top_error\n  // ---------------------------------------------------------------\n  always @(*) begin\n    final_data_out = post_packed;\n  end\n\n  always @(*) begin\n    top_error = sw_parity_error | sw_invalid_mapping_error | checksum_mismatch;\n  end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
