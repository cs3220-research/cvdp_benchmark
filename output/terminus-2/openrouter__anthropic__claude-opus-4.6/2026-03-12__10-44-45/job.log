                      dc_out  = 1'b0;\n                            state   = HOLD;\n                        end else if (rlen_in == 4'd0 && size_in == 4'd0 && !dc_in) begin\n                            rlen_out = 4'd0;\n                            size_out = 4'd0;\n                            amp_out  = 12'd0;\n                            den_out  = 1'b1;\n                            dc_out   = 1'b0;\n                            state    = IDLE;\n                        end else begin\n                            rlen_out  = 4'd15;\n                            size_out  = 4'd0;\n                            amp_out   = 12'd0;\n                            den_out   = 1'b1;\n                            dc_out    = 1'b0;\n                            held_rlen = rlen_in;\n                            held_size = size_in;\n                            held_amp  = amp_in;\n                            held_dc   = dc_in;\n                            state     = RELEASE;\n                        end\n                    end else begin\n                        den_out = 1'b0;\n                        dc_out  = 1'b0;\n                    end\n                end\n                RELEASE: begin\n                    rlen_out = held_rlen;\n                    size_out = held_size;\n                    amp_out  = held_amp;\n                    den_out  = 1'b1;\n                    dc_out   = held_dc;\n                    state    = IDLE;\n                end\n                default: begin\n                    den_out = 1'b0;\n                    dc_out  = 1'b0;\n                    state   = IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
