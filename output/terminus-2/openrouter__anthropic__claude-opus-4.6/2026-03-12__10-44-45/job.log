h07FC: cfg_rd = tx_control_reg;\n            default:  cfg_rd = ram_data0_out;\n        endcase\n    end\n\n    // FSM regs\n    reg [1:0]  state;\n    reg [31:0] total_bytes;      // effective length\n    reg [31:0] bytes_sent;       // bytes already output\n    reg [31:0] real_length;      // actual data length (before padding)\n    reg        interrupt_reg;\n    reg        in_padding;       // current word is in padding region\n    reg [31:0] cached_data;      // latched RAM data\n\n    assign interrupt_out = interrupt_reg;\n\n    // Combinational AXI outputs based on state\n    wire [31:0] remaining = total_bytes - bytes_sent;\n    wire        is_last   = (remaining <= 32'd4);\n    \n    reg [3:0] strb_val;\n    always @(*) begin\n        if (remaining >= 4) strb_val = 4'b1111;\n        else case (remaining[1:0])\n            2'd1: strb_val = 4'b0001;\n            2'd2: strb_val = 4'b0011;\n            2'd3: strb_val = 4'b0111;\n            default: strb_val = 4'b1111;\n        endcase\n    end\n\n    assign axis_tvalid_out = (state == S_TX);\n    assign axis_tdata_out  = in_padding ? 32'd0 : cached_data;\n    assign axis_tstrb_out  = (state == S_TX) ? strb_val : 4'b0000;\n    assign axis_tlast_out  = (state == S_TX) && is_last;\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state          <= S_IDLE;\n            tx_length_reg  <= 0;\n            irq_enable_reg <= 0;\n            tx_control_reg <= 0;\n            total_bytes    <= 0;\n            bytes_sent     <= 0;\n            real_length    <= 0;\n            ram_addr1      <= 0;\n            interrupt_reg  <= 0;\n            in_padding     <= 0;\n            cached_data    <= 0;\n        end else begin\n            if (interrupt_reg)\n                interrupt_reg <= 0;\n\n            // Config writes\n            if (cfg_wr_in) begin\n                if (cfg_is_length)  tx_length_reg  <= cfg_data_wr_in;\n                if (cfg_is_irq_en)  irq_enable_reg <= cfg_data_wr_in;\n                if (cfg_is_control) tx_control_reg <= cfg_data_wr_in;\n            end\n\n            case (state)\n                S_IDLE: begin\n                    if (cfg_wr_in && cfg_is_control && cfg_data_wr_in[0]) begin\n                        if (cfg_data_wr_in[1]) begin\n                            // MAC PROGRAM mode\n                            interrupt_reg <= irq_enable_reg[0];\n                            state <= S_END;\n                        end else begin\n                            // Normal TX\n                            total_bytes <= eff_len;\n                            real_length <= tx_length_reg;\n                            bytes_sent  <= 0;\n                            ram_addr1   <= 0;\n                            in_padding  <= 0;\n                            // Need to wait 1 cycle for RAM data\n                            state <= S_NEXT;\n                        end\n                    end\n                end\n\n                // Wait for RAM data to be ready, then go to TX\n                S_NEXT: begin\n                    cached_data <= ram_data1_out;\n                    in_padding  <= (bytes_sent >= real_length);\n                    state       <= S_TX;\n                end\n\n                // Output current word\n                S_TX: begin\n                    if (axis_tready_in) begin\n                        if (is_last) begin\n                            // Last word\n                            if (irq_enable_reg[0])\n                                interrupt_reg <= 1;\n                            state <= S_END;\n                        end else begin\n                            // More words: advance\n                            bytes_sent <= bytes_sent + 32'd4;\n                            ram_addr1  <= ram_addr1 + 1;\n                            state      <= S_NEXT;\n                        end\n                    end\n                end\n\n                S_END: begin\n                  