Sending keys: ["cat > /code/rtl/nmea_decoder.sv << 'VERILOG_EOF'\nmodule nmea_decoder (\n    input wire clk,\n    input wire reset,\n    input wire [7:0] serial_in,         // ASCII character input\n    input wire serial_valid,            // Valid signal for character\n    input wire watchdog_timeout_en,     // Enable watchdog timeout detection\n    output reg [15:0] data_out,         // Decoded 16-bit output (ASCII)\n    output reg data_valid,              // Valid signal for output\n    output reg [15:0] data_out_bin,     // Binary converted output\n    output reg data_bin_valid,          // Valid signal for binary output\n    output reg error_overflow,          // Buffer overflow error flag\n    output reg valid_sentence,          // Indicates a valid GPRMC sentence was processed\n    output reg watchdog_timeout         // Watchdog timeout flag\n);\n\n    // FSM States\n    localparam\n        STATE_IDLE   = 2'b00,\n        STATE_PARSE  = 2'b01,\n        STATE_OUTPUT = 2'b10;\n\n    // Configuration\n    localparam MAX_BUFFER_SIZE = 80;    // Maximum NMEA sentence length\n    localparam WATCHDOG_LIMIT  = 1024;  // Watchdog timeout cycle count\n\n    integer i;\n\n    // Internal registers\n    reg [7:0] buffer [0:MAX_BUFFER_SIZE-1];  // Sentence buffer\n    reg [6:0] buffer_index;            // Current buffer index\n    reg [1:0] state, next_state;       // FSM states\n\n    // Watchdog counter\n    reg [15:0] watchdog_counter;\n\n    // Character identifiers\n    wire is_start = (serial_in == 8'h24);  // '$'\n    wire is_comma = (serial_in == 8'h2C);  // ','\n    wire is_end   = (serial_in == 8'h0D);  // '\\r'\n\n    // Combinational variables for field extraction\n    reg [6:0] comma_count_comb;\n    reg [6:0] field_index_comb;\n    reg [7:0] char0, char1;\n    reg is_gprmc;\n    reg field_found;\n\n    // Combinational field extraction logic\n    always @(*) begin\n        comma_count_comb = 0;\n        field_index_comb = 0;\n        char0 = 8'h00;\n        char1 = 8'h00;\n        is_gprmc = 0;\n        field_found = 0;\n\n        // Check if it's a GPRMC sentence\n        if (buffer[0] == 8'h47 &&  // 'G'\n            buffer[1] == 8'h50 &&  // 'P'\n            buffer[2] == 8'h52 &&  // 'R'\n            buffer[3] == 8'h4D &&  // 'M'\n            buffer[4] == 8'h43)    // 'C'\n        begin\n            is_gprmc = 1;\n            // Find first comma and extract field after it\n            for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1) begin\n                if (i[6:0] < buffer_index) begin\n                    if (buffer[i] == 8'h2C) begin\n                        comma_count_comb = comma_count_comb + 1;\n                        if (comma_count_comb == 1) begin\n                            field_index_comb = i[6:0] + 1;\n                        end\n                    end\n                end\n            end\n\n            if (field_index_comb + 1 < buffer_index) begin\n                char0 = buffer[field_index_comb];\n                char1 = buffer[field_index_comb + 1];\n                field_found = 1;\n            end\n        end\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            data_out <= 16'b0;\n            data_valid <= 0;\n            data_out_bin <= 16'b0;\n            data_bin_valid <= 0;\n            error_overflow <= 0;\n            valid_sentence <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n            for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1)\n                buffer[i] <= 8'h00;\n        end else begin\n            // Default: deassert single-cycle pulses\n            data_valid <= 0;\n            data_bin_valid <= 0;\n            valid_sentence <= 0;\n\n            // Watchdog logic\n            if (watchdog_timeout_en && (state == STATE_PARSE)) begin\n                if (serial_valid && is_end) begin\n                    watchdog_counter <= 0;\n                end else begin\n                    watchdog_counter <= watchdog_counter + 1;\n                    if (watchdog_counter >= WATCHDOG_LIMIT) begin\n                        watchdog_timeout <= 1;\n                    end\n                end\n            end else if (state == STATE_IDLE) begin\n                watchdog_counter <= 0;\n            end\n\n            case (state)\n                STATE_IDLE: begin\n                    error_overflow <= 0;\n                    if (serial_valid && is_start) begin\n                        state <= STATE_PARSE;\n                        buffer_index <= 0;\n                        watchdog_counter <= 0;\n                        watchdog_timeout <= 0;\n                    end\n                end\n\n                STATE_PARSE: begin\n                    if (serial_valid) begin\n                        if (is_end) begin\n                            state <= STATE_OUTPUT;\n                        end else if (buffer_index < MAX_BUFFER_SIZE - 1) begin\n                            buffer[buffer_index] <= serial_in;\n                            buffer_index <= buffer_index + 1;\n                        end else begin\n                            // Buffer overflow\n                            error_overflow <= 1;\n                            state <= STATE_IDLE;\n                            buffer_index <= 0;\n                        end\n                    end\n                end\n\n                STATE_OUTPUT: begin\n                    if (is_gprmc && field_found) begin\n                        data_out <= {char0, char1};\n                        data_valid <= 1;\n                        valid_sentence <= 1;\n\n                        // Binary conversion: if both chars are numeric digits\n                        if (char0 >= 8'h30 && char0 <= 8'h39 &&\n                            char1 >= 8'h30 && char1 <= 8'h39) begin\n                            data_out_bin <= (char0 - 8'h30) * 10 + (char1 - 8'h30);\n                            data_bin_valid <= 1;\n                        end else begin\n                            data_out_bin <= 16'b0;\n                            data_bin_valid <= 0;\n                        end\n                    end\n                    state <= STATE_IDLE;\n                end\n\n                default: state <= STATE_IDLE;\n            endcase\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
