irty    <= 1'b0;\n            tag_out  <= {TAG_WIDTH{1'b0}};\n            data_out <= {DATA_WIDTH{1'b0}};\n            valid    <= 1'b0;\n            error    <= 1'b0;\n        end\n        else if (enable) begin\n            // Error detection: unaligned access\n            if (offset[0] == 1'b1) begin\n                error    <= 1'b1;\n                hit      <= 1'b0;\n                dirty    <= 1'b0;\n                tag_out  <= {TAG_WIDTH{1'b0}};\n                data_out <= {DATA_WIDTH{1'b0}};\n                valid    <= 1'b0;\n            end\n            else begin\n                error <= 1'b0;\n\n                if (comp) begin\n                    // Compare mode\n                    if (write) begin\n                        // Compare Write\n                        if ((tags[index] == tag_in) && valid_bits[index]) begin\n                            // Hit\n                            hit      <= 1'b1;\n                            data_mem[index][offset >> 1] <= data_in;\n                            dirty_bits[index] <= 1'b1;\n                            dirty    <= 1'b1;\n                            tag_out  <= tags[index];\n                            data_out <= data_in;\n                            valid    <= valid_bits[index];\n                        end\n                        else begin\n                            // Miss\n                            hit      <= 1'b0;\n                            dirty    <= dirty_bits[index];\n                            tag_out  <= tags[index];\n                            data_out <= data_mem[index][offset >> 1];\n                            valid    <= valid_bits[index];\n                        end\n                    end\n                    else begin\n                        // Compare Read\n                        if ((tags[index] == tag_in) && valid_bits[index]) begin\n                            // Hit\n                            hit      <= 1'b1;\n                            tag_out  <= tags[index];\n                            data_out <= data_mem[index][offset >> 1];\n                            valid    <= valid_bits[index];\n                            dirty    <= dirty_bits[index];\n                        end\n                        else begin\n                            // Miss\n                            hit      <= 1'b0;\n                            dirty    <= dirty_bits[index];\n                            tag_out  <= tags[index];\n                            data_out <= data_mem[index][offset >> 1];\n                            valid    <= valid_bits[index];\n                        end\n                    end\n                end\n                else begin\n                    // Direct Access mode (comp=0)\n                    if (write) begin\n                        // Direct Write\n                        tags[index]       <= tag_in;\n                        data_mem[index][offset >> 1] <= data_in;\n                        valid_bits[index] <= valid_in;\n                        dirty_bits[index] <= 1'b0;\n                        hit      <= 1'b0;\n                        dirty    <= 1'b0;\n                        tag_out  <= tag_in;\n                        data_out <= data_in;\n                        valid    <= valid_in;\n                    end\n                    else begin\n                        // Direct Read\n                        hit      <= 1'b0;\n                        tag_out  <= tags[index];\n                        data_out <= data_mem[index][offset >> 1];\n                        valid    <= valid_bits[index];\n                        dirty    <= dirty_bits[index];\n                    end\n                end\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
