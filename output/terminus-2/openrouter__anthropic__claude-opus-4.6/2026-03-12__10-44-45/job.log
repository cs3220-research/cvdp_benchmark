6'b0;\n        data_valid = 0;\n\n        case (state)\n            STATE_IDLE: begin\n                if (serial_valid && is_start) begin\n                    next_state = STATE_PARSE;\n                    next_buffer_index = 0;\n                end\n            end\n\n            STATE_PARSE: begin\n                if (serial_valid) begin\n                    if (is_end) begin\n                        next_state = STATE_OUTPUT;\n                    end else if (buffer_index < MAX_BUFFER_SIZE - 1) begin\n                        next_buffer_index = buffer_index + 1;\n                    end else begin\n                        overflow_detected = 1;\n                        next_state = STATE_IDLE;\n                        next_buffer_index = 0;\n                    end\n                end\n            end\n\n            STATE_OUTPUT: begin\n                if (buffer[0] == 8'h47 &&  // 'G'\n                    buffer[1] == 8'h50 &&  // 'P'\n                    buffer[2] == 8'h52 &&  // 'R'\n                    buffer[3] == 8'h4D &&  // 'M'\n                    buffer[4] == 8'h43)    // 'C'\n                begin : gprmc_extract\n                    reg [6:0] comma_count;\n                    reg [6:0] field_index;\n                    comma_count = 0;\n                    field_index = 0;\n\n                    for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1) begin\n                        if (i[6:0] < buffer_index) begin\n                            if (buffer[i] == 8'h2C) begin\n                                comma_count = comma_count + 1;\n                                if (comma_count == 1) begin\n                                    field_index = i[6:0] + 1;\n                                end\n                            end\n                        end\n                    end\n\n                    if (field_index + 1 < buffer_index) begin\n                        data_out = {buffer[field_index], buffer[field_index + 1]};\n                        data_valid = 1;\n                    end\n                end\n                next_state = STATE_IDLE;\n            end\n\n            default: next_state = STATE_IDLE;\n        endcase\n    end\n\n    // Sequential logic (clocked)\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            buffer_index <= 0;\n            error_overflow <= 0;\n            watchdog_timeout <= 0;\n            watchdog_counter <= 0;\n            data_out_bin <= 16'b0;\n            data_bin_valid <= 0;\n            valid_sentence <= 0;\n            for (i = 0; i < MAX_BUFFER_SIZE; i = i + 1)\n                buffer[i] <= 8'h00;\n        end else begin\n            state <= next_state;\n            buffer_index <= next_buffer_index;\n\n            // Store character into buffer during PARSE\n            if (state == STATE_PARSE && serial_valid && !is_end && buffer_index < MAX_BUFFER_SIZE - 1) begin\n                buffer[buffer_index] <= serial_in;\n            end\n\n            // Error overflow detection - set on overflow, clear on new sentence start\n            if (overflow_detected) begin\n                error_overflow <= 1;\n            end else if (state == STATE_IDLE && serial_valid && is_start) begin\n                error_overflow <= 0;\n            end\n\n            // Watchdog logic\n            if (state == STATE_IDLE && serial_valid && is_start) begin\n                // Starting new sentence - reset watchdog\n                watchdog_counter <= 0;\n                watchdog_timeout <= 0;\n            end else if (state == STATE_PARSE) begin\n                if (watchdog_timeout_en) begin\n                    watchdog_counter <= watchdog_counter + 1;\n                    if (watchdog_counter >= WATCHDOG_LIMIT) begin\n                        watchdog_timeout <= 1;\n                    end\n                end\n            end\n\n            // Binary conversion outputs - registered\n            if (state == STATE_OUTPUT && data_valid) begin\n                valid_sentence <= 1;\n                if (data_out[15:8] >= 8'h30 && data_out[15:8] <= 8'h39 &&\n                    data_out[7:0] >= 8'h30 && data_out[7:0] <= 8'h39) begin\n                    data_out_bin <= (data_out[15:8] - 8'h30) * 10 + (data_out[7:0] - 8'h30);\n                    data_bin_valid <= 1;\n                end else begin\n                    data_out_bin <= 16'b0;\n                    data_bin_valid <= 0;\n                end\n            end else begin\n                data_bin_valid <= 0;\n                valid_sentence <= 0;\n            end\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
