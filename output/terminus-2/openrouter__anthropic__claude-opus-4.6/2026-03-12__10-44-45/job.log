Sending keys: ["cat > /code/rtl/dig_stopwatch.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch\n// Description: Core digital stopwatch logic with parameterizable clock frequency.\n//              Implements a clock divider to generate 1 Hz ticks, and maintains\n//              seconds (0-59), minutes (0-59), and a single-bit hour indicator.\n//              Includes start/stop control, pulse outputs, and a beep mechanism.\n//=============================================================================\n\nmodule dig_stopwatch #(\n    parameter CLK_FREQ = 50  // Input clock frequency (number of clock cycles per second)\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high synchronous reset\n    input  logic        start_stop,   // 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter (0-59)\n    output logic [5:0]  minutes,      // Minutes counter (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulse when seconds counter changes\n    output logic        minute_pulse, // Pulse when minutes counter changes\n    output logic        hour_pulse,   // Pulse when hour indicator changes\n\n    output logic        beep          // Beep signal: asserted on hour_pulse, cleared on next second_pulse\n);\n\n    //=========================================================================\n    // Local Parameters\n    //=========================================================================\n    localparam COUNTER_MAX = CLK_FREQ - 1;  // Max value for clock divider counter\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    logic [$clog2(CLK_FREQ > 1 ? CLK_FREQ : 2)-1:0] clk_counter;  // Clock divider counter\n    logic one_hz_tick;       // Combinational 1 Hz tick signal\n    logic saturated;         // Indicates stopwatch has reached maximum time (1:00:00)\n\n    //=========================================================================\n    // Saturation Detection\n    // The stopwatch saturates at 1:00:00 (hour=1, minutes=0, seconds=0).\n    // Once saturated, all counters stop incrementing.\n    //=========================================================================\n    assign saturated = (hour == 1'b1) && (minutes == 6'd0) && (seconds == 6'd0);\n\n    //=========================================================================\n    // 1 Hz Tick Generation (combinational)\n    // The tick is asserted when the clock counter has reached COUNTER_MAX\n    // and the stopwatch is running and not saturated.\n    //=========================================================================\n    assign one_hz_tick = start_stop && !saturated &&\n                         (clk_counter == COUNTER_MAX[$clog2(CLK_FREQ > 1 ? CLK_FREQ : 2)-1:0]);\n\n    //=========================================================================\n    // Clock Divider Counter\n    // Counts from 0 to COUNTER_MAX. Resets to 0 when reaching COUNTER_MAX.\n    // The counter preserves its value when paused (start_stop == 0).\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            clk_counter <= '0;\n        end else if (start_stop && !saturated) begin\n            if (clk_counter == COUNTER_MAX[$clog2(CLK_FREQ > 1 ? CLK_FREQ : 2)-1:0]) begin\n                clk_counter <= '0;\n            end else begin\n                clk_counter <= clk_counter + 1'b1;\n            end\n        end\n        // When paused or saturated: counter holds its value\n    end\n\n    //=========================================================================\n    // Seconds Counter (0-59)\n    // Increments on each 1 Hz tick. Rolls over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 6'd0;\n        end else if (one_hz_tick) begin\n            if (seconds == 6'd59) begin\n                seconds <= 6'd0;\n            end else begin\n                seconds <= seconds + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Minutes Counter (0-59)\n    // Increments when seconds rolls over from 59 to 0.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 6'd0;\n        end else if (one_hz_tick && (seconds == 6'd59)) begin\n            if (minutes == 6'd59) begin\n                minutes <= 6'd0;\n            end else begin\n                minutes <= minutes + 6'd1;\n            end\n        end\n    end\n\n    //=========================================================================\n    // Hour Indicator (single bit)\n    // Asserted when minutes rolls over from 59 to 0 (i.e., after 59:59).\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 1'b0;\n        end else if (one_hz_tick && (seconds == 6'd59) && (minutes == 6'd59)) begin\n            hour <= 1'b1;\n        end\n    end\n\n    //=========================================================================\n    // Pulse Generation (combinational, active when tick fires)\n    // second_pulse: asserted when a 1 Hz tick occurs (seconds will change).\n    // minute_pulse: asserted when seconds is at 59 and tick occurs.\n    // hour_pulse:   asserted when seconds=59, minutes=59 and tick occurs.\n    // These are combinational signals aligned with the counter updates.\n    //=========================================================================\n    assign second_pulse = one_hz_tick;\n    assign minute_pulse = one_hz_tick && (seconds == 6'd59);\n    assign hour_pulse   = one_hz_tick && (seconds == 6'd59) && (minutes == 6'd59);\n\n    //=========================================================================\n    // Beep Mechanism\n    // The beep signal is asserted when an hour_pulse occurs and is\n    // deactivated on the next second_pulse.\n    //=========================================================================\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 1'b0;\n        end else if (hour_pulse) begin\n            beep <= 1'b1;\n        end else if (second_pulse) begin\n            beep <= 1'b0;\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
