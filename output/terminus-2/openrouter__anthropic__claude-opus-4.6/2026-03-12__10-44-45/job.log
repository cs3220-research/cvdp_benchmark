                 next_state = SETUP;\n            end\n            READ_STATE: begin\n                next_state = IDLE;\n            end\n            WRITE_STATE: begin\n                next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    // Latch address and write data during SETUP phase\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            addr_latched  <= 32'b0;\n            wdata_latched <= 32'b0;\n            pwrite_latched <= 1'b0;\n        end else if (current_state == IDLE && pselx && !penable) begin\n            addr_latched  <= paddr;\n            wdata_latched <= pwdata;\n            pwrite_latched <= pwrite;\n        end\n    end\n\n    // Register write logic\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            data_reg      <= 32'b0;\n            control_reg   <= 32'b0;\n            interrupt_reg <= 32'b0;\n            isr_reg       <= 32'b0;\n        end else if (current_state == SETUP && pselx && penable && pwrite_latched) begin\n            case (addr_latched)\n                DATA_REG_ADDR:      data_reg      <= wdata_latched;\n                CONTROL_REG_ADDR:   control_reg   <= wdata_latched;\n                INTERRUPT_REG_ADDR: begin\n                    interrupt_reg <= wdata_latched;\n                    // Clear ISR bits where interrupt enable bits are written as 1\n                    isr_reg <= isr_reg & ~wdata_latched;\n                end\n                ISR_REG_ADDR: begin\n                    // Write protected - do nothing\n                end\n                default: ;\n            endcase\n        end\n    end\n\n    // Read data output\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            prdata <= 32'b0;\n        end else if (current_state == SETUP && pselx && penable && !pwrite_latched) begin\n            case (addr_latched)\n                DATA_REG_ADDR:      prdata <= data_reg;\n                CONTROL_REG_ADDR:   prdata <= control_reg;\n                INTERRUPT_REG_ADDR: prdata <= interrupt_reg;\n                ISR_REG_ADDR:       prdata <= isr_reg;\n                default:            prdata <= 32'b0;\n            endcase\n        end\n    end\n\n    // Slave error for write-protected ISR_REG\n    always_ff @(posedge pclk or negedge presetn) begin\n        if (!presetn) begin\n            pslverr <= 1'b0;\n        end else if (current_state == SETUP && pselx && penable && pwrite_latched && addr_latched == ISR_REG_ADDR) begin\n            pslverr <= 1'b1;\n        end else if (current_state == IDLE) begin\n            pslverr <= pslverr; // Hold the value\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
