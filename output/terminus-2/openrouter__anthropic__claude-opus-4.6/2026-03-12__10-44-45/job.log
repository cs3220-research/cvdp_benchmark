               prescaler_count <= prescaler_count + 4'd1;\n            end\n        end else begin\n            prescaler_count <= 4'd0;\n        end\n    end\n\n    // -------------------------------------------------------\n    // Match detection\n    // -------------------------------------------------------\n    wire match = (count == match_value) && prescaler_tick && enable;\n\n    // -------------------------------------------------------\n    // Counter logic\n    // -------------------------------------------------------\n    always @(posedge clk) begin\n        if (reset) begin\n            count <= 16'd0;\n        end else if (enable && prescaler_tick) begin\n            if (count == match_value) begin\n                if (interval_mode) begin\n                    count <= reload_value;\n                end else begin\n                    count <= count; // Hold value in single-shot mode\n                end\n            end else begin\n                count <= count + 16'd1;\n            end\n        end\n    end\n\n    // -------------------------------------------------------\n    // Status register and interrupt logic\n    // -------------------------------------------------------\n    always @(posedge clk) begin\n        if (reset) begin\n            status <= 1'b0;\n        end else if (axi_write_en && (axi_addr == ADDR_STATUS)) begin\n            // Write-to-clear: clear bits that are written as 1\n            status <= status & ~axi_wdata[0];\n        end else if (match) begin\n            status <= 1'b1;\n        end\n    end\n\n    // Interrupt output\n    always @(posedge clk) begin\n        if (reset) begin\n            interrupt <= 1'b0;\n        end else begin\n            interrupt <= status & interrupt_enable;\n        end\n    end\n\n    // -------------------------------------------------------\n    // Register write logic\n    // -------------------------------------------------------\n    always @(posedge clk) begin\n        if (reset) begin\n            match_value  <= 16'd0;\n            reload_value <= 16'd0;\n            control      <= 3'd0;\n            prescaler    <= 4'd0;\n        end else if (axi_write_en) begin\n            case (axi_addr)\n                ADDR_MATCH_VALUE:  match_value  <= axi_wdata[15:0];\n                ADDR_RELOAD_VALUE: reload_value <= axi_wdata[15:0];\n                ADDR_CONTROL:      control      <= axi_wdata[2:0];\n                ADDR_PRESCALER:    prescaler    <= axi_wdata[3:0];\n                // COUNT (0x0) is read-only\n                // STATUS (0x4) is handled separately above\n                default: ;\n            endcase\n        end\n    end\n\n    // -------------------------------------------------------\n    // Register read logic\n    // -------------------------------------------------------\n    always @(posedge clk) begin\n        if (reset) begin\n            axi_rdata <= 32'd0;\n        end else if (axi_read_en) begin\n            case (axi_addr)\n                ADDR_COUNT:        axi_rdata <= {16'd0, count};\n                ADDR_MATCH_VALUE:  axi_rdata <= {16'd0, match_value};\n                ADDR_RELOAD_VALUE: axi_rdata <= {16'd0, reload_value};\n                ADDR_CONTROL:      axi_rdata <= {29'd0, control};\n                ADDR_STATUS:       axi_rdata <= {31'd0, status};\n                ADDR_PRESCALER:    axi_rdata <= {28'd0, prescaler};\n                default:           axi_rdata <= 32'd0;\n            endcase\n        end\n    end\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
