(round_ff == 4'd12) begin\n            round_ff <= 4'd0;\n        end\n\n        for(int i = 0; i < 4; i++)\n            for(int j = 0; j < 4; j++)\n                current_data_ff[i][j] <= current_data_nx[i][j];\n    end\nend\n\nalways_comb begin : next_data\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(i_start & o_done) begin\n                current_data_nx[i][j] = in_byte[i][j];\n            end else if(round_ff == 4'd1) begin\n                current_data_nx[i][j] = current_data_ff[i][j];\n            end else if(round_ff == 4'd2) begin\n                current_data_nx[i][j] = AddRoundKey[i][j];\n            end else if(round_ff >= 4'd3 && round_ff <= 4'd11) begin\n                current_data_nx[i][j] = MixColumns[i][j];\n            end else if(round_ff == 4'd12) begin\n                current_data_nx[i][j] = SubBytes[i][j];\n            end else begin\n                current_data_nx[i][j] = current_data_ff[i][j];\n            end\n        end\n    end\nend\n\n// InvSubBytes\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : sb_row\n        for(genvar j = 0; j < 4; j++) begin : sb_col\n            inv_sbox uu_inv_sbox (\n                .i_data(ShiftRows[i][j]),\n                .o_data(SubBytes[i][j])\n            );\n        end\n    end\nendgenerate\n\nalways_comb begin : decypher_logic\n    // AddRoundKey\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(round_ff == 4'd2) begin\n                AddRoundKey[i][j] = current_data_ff[i][j] ^ cur_rk_byte[i][j];\n            end else begin\n                AddRoundKey[i][j] = SubBytes[i][j] ^ cur_rk_byte[i][j];\n            end\n        end\n    end\n\n    // InvMixColumns on AddRoundKey output\n    for(int j = 0; j < 4; j++) begin\n        for(int i = 0; i < 4; i++) begin\n            xtimes02[i][j] = {AddRoundKey[i][j][6:0], 1'b0} ^ (AddRoundKey[i][j][7] ? 8'h1B : 8'h00);\n            xtimes04[i][j] = {xtimes02[i][j][6:0], 1'b0} ^ (xtimes02[i][j][7] ? 8'h1B : 8'h00);\n            xtimes08[i][j] = {xtimes04[i][j][6:0], 1'b0} ^ (xtimes04[i][j][7] ? 8'h1B : 8'h00);\n\n            xtimes0e[i][j] = xtimes08[i][j] ^ xtimes04[i][j] ^ xtimes02[i][j];\n            xtimes0b[i][j] = xtimes08[i][j] ^ xtimes02[i][j] ^ AddRoundKey[i][j];\n            xtimes0d[i][j] = xtimes08[i][j] ^ xtimes04[i][j] ^ AddRoundKey[i][j];\n            xtimes09[i][j] = xtimes08[i][j] ^ AddRoundKey[i][j];\n        end\n\n        MixColumns[0][j] = xtimes0e[0][j] ^ xtimes0b[1][j] ^ xtimes0d[2][j] ^ xtimes09[3][j];\n        MixColumns[1][j] = xtimes09[0][j] ^ xtimes0e[1][j] ^ xtimes0b[2][j] ^ xtimes0d[3][j];\n        MixColumns[2][j] = xtimes0d[0][j] ^ xtimes09[1][j] ^ xtimes0e[2][j] ^ xtimes0b[3][j];\n        MixColumns[3][j] = xtimes0b[0][j] ^ xtimes0d[1][j] ^ xtimes09[2][j] ^ xtimes0e[3][j];\n    end\n\n    // InvShiftRows (shift rows RIGHT)\n    ShiftRows[0][0] = current_data_ff[0][0];\n    ShiftRows[0][1] = current_data_ff[0][1];\n    ShiftRows[0][2] = current_data_ff[0][2];\n    ShiftRows[0][3] = current_data_ff[0][3];\n\n    ShiftRows[1][0] = current_data_ff[1][3];\n    ShiftRows[1][1] = current_data_ff[1][0];\n    ShiftRows[1][2] = current_data_ff[1][1];\n    ShiftRows[1][3] = current_data_ff[1][2];\n\n    ShiftRows[2][0] = current_data_ff[2][2];\n    ShiftRows[2][1] = current_data_ff[2][3];\n    ShiftRows[2][2] = current_data_ff[2][0];\n    ShiftRows[2][3] = current_data_ff[2][1];\n\n    ShiftRows[3][0] = current_data_ff[3][1];\n    ShiftRows[3][1] = current_data_ff[3][2];\n    ShiftRows[3][2] = current_data_ff[3][3];\n    ShiftRows[3][3] = current_data_ff[3][0];\nend\n\naes128_key_expansion uu_aes128_key_expansion (\n    .clk           (clk                            ),\n    .rst_async_n   (rst_async_n                    ),\n    .i_start       (i_start & i_update_key & o_done),\n    .i_key         (i_key                          ),\n    .o_done        (key_done                       ),\n    .o_expand