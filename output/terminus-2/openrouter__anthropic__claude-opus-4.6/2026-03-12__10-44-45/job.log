      <= 0;\n            match_valid      <= 0;\n            matched_price    <= 0;\n            done             <= 0;\n            latency_error    <= 0;\n            best_bid         <= 0;\n            best_ask         <= 0;\n            results_captured <= 0;\n        end else begin\n            // Default: deassert single-cycle outputs\n            done          <= 0;\n            match_valid   <= 0;\n            matched_price <= 0;\n            latency_error <= 0;\n\n            if (start && !running) begin\n                running          <= 1;\n                cycle_counter    <= 1;\n                results_captured <= 0;\n            end else if (running) begin\n                cycle_counter <= cycle_counter + 1;\n\n                // When both sorters are done, capture the best bid and best ask\n                // Sorter done=1 means out_data is valid at this cycle\n                if (bid_sort_done && ask_sort_done && !results_captured) begin\n                    best_bid         <= sorted_bids[7*PRICE_WIDTH +: PRICE_WIDTH];\n                    best_ask         <= sorted_asks[0 +: PRICE_WIDTH];\n                    results_captured <= 1;\n                end\n\n                // At cycle_counter == 20, produce output\n                // best_bid and best_ask were captured at counter=19 (sorter done),\n                // so they are valid registered values at counter=20\n                if (cycle_counter == 20) begin\n                    done    <= 1;\n                    running <= 0;\n                    cycle_counter <= 0;\n                    latency_error <= 0;\n\n                    if (best_bid >= best_ask) begin\n                        match_valid   <= 1;\n                        matched_price <= best_ask;\n                    end else begin\n                        match_valid   <= 0;\n                        matched_price <= 0;\n                    end\n                end\n            end\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min