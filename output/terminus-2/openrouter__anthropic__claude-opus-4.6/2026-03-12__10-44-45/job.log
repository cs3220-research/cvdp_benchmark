       ts_count_dff <= {NBW_TS_COUNT{1'b0}};\n    else\n        ts_count_dff <= nxt_ts_count;\nend\n\n// TS count next logic\nalways_comb begin\n    if (curr_state == ST_DETECT_SEQUENCE)\n        nxt_ts_count = {NBW_TS_COUNT{1'b0}};\n    else begin\n        if (i_valid) begin\n            if (ts_count_dff == N_TS_CYCLES - 1)\n                nxt_ts_count = {NBW_TS_COUNT{1'b0}};\n            else\n                nxt_ts_count = ts_count_dff + 1'b1;\n        end else\n            nxt_ts_count = ts_count_dff;\n    end\nend\n\n// Undetected count register\nalways_ff @(posedge clk or negedge rst_async_n) begin\n    if (~rst_async_n)\n        ts_undetected_count_dff <= {NBW_TS_COUNT{1'b0}};\n    else\n        ts_undetected_count_dff <= nxt_ts_undetected_count;\nend\n\n// Undetected count next logic\nalways_comb begin\n    if (curr_state == ST_DETECT_SEQUENCE)\n        nxt_ts_undetected_count = {NBW_TS_COUNT{1'b0}};\n    else begin\n        if (ts_count_dff == N_TS_CYCLES - 1) begin\n            if (o_proc_detected)\n                nxt_ts_undetected_count = {NBW_TS_COUNT{1'b0}};\n            else\n                nxt_ts_undetected_count = ts_undetected_count_dff + 1'b1;\n        end else\n            nxt_ts_undetected_count = ts_undetected_count_dff;\n    end\nend\n\n// o_locked register\nalways_ff @(posedge clk or negedge rst_async_n) begin\n    if (~rst_async_n)\n        o_locked_reg <= 1'b0;\n    else\n        o_locked_reg <= o_locked;\nend\n\n// FSM next state and output logic\nalways_comb begin\n    // Defaults\n    nxt_state = ST_DETECT_SEQUENCE;\n    mode_nx   = 2'd0;\n    o_locked  = o_locked_reg;\n\n    case (curr_state)\n        ST_DETECT_SEQUENCE: begin\n            mode_nx  = 2'd0;\n            o_locked = o_locked_reg;\n            if (o_proc_detected && w_aware_mode)\n                nxt_state = ST_DETECT_PROC;\n            else\n                nxt_state = ST_DETECT_SEQUENCE;\n        end\n\n        ST_DETECT_PROC: begin\n            if (ts_count_dff == N_TS_CYCLES - 1 &&\n                !o_proc_detected &&\n                ts_undetected_count_dff == i_static_unlock_threshold) begin\n                nxt_state = ST_DETECT_SEQUENCE;\n                mode_nx   = 2'd0;\n                o_locked  = o_locked_reg;\n            end else if (o_proc_detected) begin\n                o_locked  = 1'b1;\n                nxt_state = ST_DETECT_PROC;\n                mode_nx   = 2'd0;\n            end else begin\n                o_locked  = o_locked_reg;\n                nxt_state = ST_DETECT_SEQUENCE;\n                mode_nx   = ts_undetected_count_dff[1:0];\n            end\n        end\n\n        default: begin\n            nxt_state = ST_DETECT_SEQUENCE;\n        end\n    endcase\nend\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
