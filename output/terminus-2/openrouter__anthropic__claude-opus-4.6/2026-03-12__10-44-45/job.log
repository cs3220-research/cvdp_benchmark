0; // Release CA to start generating\n                    end\n                end\n\n                CA_WAIT: begin\n                    // Wait one cycle for CA to produce first value\n                    // At this posedge, CA sees ca_reset=0 and computes first output\n                    // ca_out will be available next cycle\n                    sbox_cnt <= 3'd0;\n                    state <= GEN_SBOX;\n                end\n\n                GEN_SBOX: begin\n                    // Collect S-box values from CA\n                    s_box[sbox_cnt[1:0]] <= ca_out;\n                    if (sbox_cnt == 3'd3) begin\n                        state <= INIT_ADD;\n                        A <= p[15:8];\n                        B <= p[7:0];\n                    end\n                    sbox_cnt <= sbox_cnt + 1;\n                end\n\n                INIT_ADD: begin\n                    // A = A + S[0]; B = B + S[1]\n                    A <= A + s_box[0];\n                    B <= B + s_box[1];\n                    state <= COMP_MSB;\n                end\n\n                COMP_MSB: begin\n                    // A = ((A XOR B) <<< B) + S[2]\n                    A <= left_rotate(A ^ B, B) + s_box[2];\n                    state <= COMP_LSB;\n                end\n\n                COMP_LSB: begin\n                    // B = ((B XOR A) <<< A) + S[3]\n                    B <= left_rotate(B ^ A, A) + s_box[3];\n                    state <= DONE;\n                end\n\n                DONE: begin\n                    c <= {A, B};\n                    enc_done <= 1'b1;\n                    state <= IDLE;\n                end\n\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\nendmodule\n\n// CA_1 module - Cellular Automata PRNG\n// Rule combination: R90-R90-R150-R90-R150-R90-R150-R90\nmodule CA_1(\n    input wire clock,\n    input wire reset,\n    input wire [7:0] CA_seed,\n    output reg [7:0] CA_out\n);\n\n    wire q1,q2,q3,q4,q5,q6,q7,q8;\n\n    assign q1 = CA_out[6];                          //R90\n    assign q2 = CA_out[7] ^ CA_out[5];              //R90\n    assign q3 = CA_out[6] ^ CA_out[5] ^ CA_out[4];  //R150\n    assign q4 = CA_out[5] ^ CA_out[3];              //R90\n    assign q5 = CA_out[4] ^ CA_out[3] ^ CA_out[2];  //R150\n    assign q6 = CA_out[3] ^ CA_out[1];              //R90\n    assign q7 = CA_out[2] ^ CA_out[1] ^ CA_out[0];  //R150\n    assign q8 = CA_out[1];                          //R90\n\n    always @(posedge clock) begin\n        if (reset)\n            CA_out <= CA_seed;\n        else\n            CA_out <= {q1,q2,q3,q4,q5,q6,q7,q8};\n    end\n\nendmodule\nRTLEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
