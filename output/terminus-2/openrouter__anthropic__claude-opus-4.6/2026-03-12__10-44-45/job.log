d_2_reg;\n assign m_axis_tdata_3 = m_axis_tdata_3_reg;\n assign m_axis_tvalid_3 = m_axis_tvalid_3_reg;\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
