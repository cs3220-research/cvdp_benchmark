---------------------------------------------------------\n    generate\n        for (gi = 0; gi < NUM_LANES; gi = gi + 1) begin : unpack_map\n            assign swizzle_map[gi] = swizzle_map_flat[gi*LANE_SEL_WIDTH +: LANE_SEL_WIDTH];\n        end\n    endgenerate\n\n    // ---------------------------------------------------------------\n    // 3. Lane Remapping: Rearrange lanes based on swizzle map or bypass\n    // ---------------------------------------------------------------\n    integer i;\n    always @(*) begin\n        for (i = 0; i < NUM_LANES; i = i + 1) begin\n            if (bypass) begin\n                remapped_lanes[i] = data_in_lanes[i];\n            end else begin\n                remapped_lanes[i] = data_in_lanes[swizzle_map[i]];\n            end\n        end\n    end\n\n    // ---------------------------------------------------------------\n    // 4. Parity Checking (Optional)\n    // ---------------------------------------------------------------\n    integer j;\n    always @(*) begin\n        parity_error_comb = 1'b0;\n        if (ENABLE_PARITY_CHECK) begin\n            for (j = 0; j < NUM_LANES; j = j + 1) begin\n                if (^remapped_lanes[j] != 1'b0) begin\n                    parity_error_comb = 1'b1;\n                end\n            end\n        end\n    end\n\n    // ---------------------------------------------------------------\n    // 5. Output Packing: Pack remapped lanes back into flat bus\n    // ---------------------------------------------------------------\n    integer k;\n    always @(*) begin\n        for (k = 0; k < NUM_LANES; k = k + 1) begin\n            remapped_flat[k*DATA_WIDTH +: DATA_WIDTH] = remapped_lanes[k];\n        end\n    end\n\n    // ---------------------------------------------------------------\n    // 6. Output Registering (Optional)\n    // ---------------------------------------------------------------\n    generate\n        if (REGISTER_OUTPUT) begin : gen_registered_output\n            always @(posedge clk or negedge rst_n) begin\n                if (!rst_n) begin\n                    data_out     <= {(NUM_LANES*DATA_WIDTH){1'b0}};\n                    parity_error <= 1'b0;\n                end else begin\n                    data_out     <= remapped_flat;\n                    parity_error <= parity_error_comb;\n                end\n            end\n        end else begin : gen_combinational_output\n            always @(*) begin\n                data_out     = remapped_flat;\n                parity_error = parity_error_comb;\n            end\n        end\n    endgenerate\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
