1 for HDB3, encoder_type + 1 for HDB2.\n                        // 3+1=4, 2+1=3. Yes.\n                        //\n                        // So I need zero_cnt to reach encoder_type (not encoder_type-1)!\n                        // And FIFO depth needs to be encoder_type+1-1 = encoder_type\n                        // (because V replaces the last zero, so we need encoder_type\n                        // positions for the preceding zeros)\n                        //\n                        // Wait: encoder_type zeros in FIFO + V (current) = encoder_type+1.\n                        // That\'s the right count!\n                        //\n                        // So: zero_cnt counts from 0 to encoder_type.\n                        // When zero_cnt == encoder_type AND data_r1==0: substitute.\n                        // But that means encoder_type+1 zeros total (cnt went 0..encoder_type).\n                        // For HDB3: 4 zeros. Correct!\n                        //\n                        // But the FIFO is encoder_type deep. After encoder_type+1 clocks of\n                        // zeros, the 1st zero has already shifted out of the FIFO!\n                        // We need FIFO depth encoder_type+1 to hold all zeros.\n                        //\n                        // OR: trigger at zero_cnt == encoder_type - 1 and treat the\n                        // current zero as the (encoder_type)th, making encoder_type total.\n                        // For HDB3: 3 total. Wrong.\n                        //\n                        // I think the correct approach is:\n                        // FIFO depth = encoder_type\n                        // zero_cnt triggers at encoder_type\n                        // At trigger time, FIFO contains zeros at [0..encoder_type-1]\n                        // The current data_r1 is the (encoder_type+1)th zero = V\n                        // But the 1st zero has shifted out...\n                        //\n                        // Ugh. Let me just use encoder_type+1 FIFO depth.\n                        if (pulse_parity == 1\'b0) begin\n                            fifo_b[0] <= 1\'b1;\n                            fifo_d[0] <= 1\'b1;\n                        end\n                    end else begin\n                        // HDB2: always B0V\n                        fifo_b[0] <= 1\'b1;\n                        fifo_d[0] <= 1\'b1;\n                    end\n\n                    pulse_parity <= 1\'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1\'b1;\n                end\n            end else begin\n                zero_cnt <= \'0;\n                pulse_parity <= ~pulse_parity;\n            end\n\n            // ===== Stage 3: AMI assignment =====\n            if (fifo_d[0]) begin\n                if (fifo_v[0]) begin\n                    if (ami) begin\n                        p_ami <= 1\'b1;\n                        n_ami <= 1\'b0;\n                    end else begin\n                        p_ami <= 1\'b0;\n                        n_ami <= 1\'b1;\n                    end\n                end else begin\n                    if (ami == 1\'b0) begin\n                        p_ami <= 1\'b1;\n                        n_ami <= 1\'b0;\n                        ami   <= 1\'b1;\n                    end else begin\n                        p_ami <= 1\'b0;\n                        n_ami <= 1\'b1;\n                        ami   <= 1\'b0;\n                    end\n                end\n            end else begin\n                p_ami <= 1\'b0;\n                n_ami <= 1\'b0;\n            end\n\n            // ===== Stage 4: Output gating =====\n            if (output_gate_in) begin\n                p_out <= p_ami ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_ami ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n      