Sending keys: ["cat > /code/rtl/async_filo.sv << 'ENDOFFILE'\nmodule async_filo #(\n    parameter DATA_WIDTH = 16,\n    parameter DEPTH = 8\n) (\n    input  wire                  w_clk,\n    input  wire                  w_rst,\n    input  wire                  push,\n    input  wire                  r_clk,\n    input  wire                  r_rst,\n    input  wire                  pop,\n    input  wire [DATA_WIDTH-1:0] w_data,\n    output wire [DATA_WIDTH-1:0] r_data,\n    output reg                   r_empty,\n    output reg                   w_full\n);\n\n    // Address width calculation\n    localparam ADDR_WIDTH = $clog2(DEPTH);\n    localparam PTR_WIDTH  = ADDR_WIDTH + 1; // Extra bit for full/empty detection\n\n    // Memory\n    reg [DATA_WIDTH-1:0] mem [0:DEPTH-1];\n\n    // Write domain signals\n    reg [PTR_WIDTH-1:0] w_count_bin;\n    reg [PTR_WIDTH-1:0] w_ptr;       // Gray-coded write pointer\n    reg [PTR_WIDTH-1:0] wq1_rptr, wq2_rptr; // Synchronized read pointer in write domain\n\n    // Read domain signals\n    reg [PTR_WIDTH-1:0] r_count_bin;\n    reg [PTR_WIDTH-1:0] r_ptr;       // Gray-coded read pointer\n    reg [PTR_WIDTH-1:0] rq1_wptr, rq2_wptr; // Synchronized write pointer in read domain\n\n    // Binary to Gray code conversion\n    function [PTR_WIDTH-1:0] bin2gray;\n        input [PTR_WIDTH-1:0] bin;\n        begin\n            bin2gray = bin ^ (bin >> 1);\n        end\n    endfunction\n\n    // Gray code to Binary conversion\n    function [PTR_WIDTH-1:0] gray2bin;\n        input [PTR_WIDTH-1:0] gray;\n        integer i;\n        begin\n            gray2bin[PTR_WIDTH-1] = gray[PTR_WIDTH-1];\n            for (i = PTR_WIDTH-2; i >= 0; i = i - 1)\n                gray2bin[i] = gray2bin[i+1] ^ gray[i];\n        end\n    endfunction\n\n    // =========================================================================\n    // Write Domain (w_clk)\n    // =========================================================================\n\n    // Synchronize read pointer into write domain (2-stage FF)\n    always @(posedge w_clk) begin\n        if (w_rst) begin\n            wq1_rptr <= {PTR_WIDTH{1'b0}};\n            wq2_rptr <= {PTR_WIDTH{1'b0}};\n        end else begin\n            wq1_rptr <= r_ptr;\n            wq2_rptr <= wq1_rptr;\n        end\n    end\n\n    // Write pointer and memory write logic\n    wire [PTR_WIDTH-1:0] w_count_bin_next = w_count_bin + 1;\n    wire [PTR_WIDTH-1:0] w_ptr_next = bin2gray(w_count_bin_next);\n\n    // Full flag generation\n    // In FILO: full when write pointer (binary) equals DEPTH\n    // But we need to account for pops. The synchronized read pointer tells us\n    // how far back the read side has popped.\n    // \n    // Write side pushes: w_count_bin goes 0,1,2,...\n    // Read side pops: r_count_bin goes down from the synced write level\n    // The read pointer (r_ptr) represents how far down the read side has consumed\n    // \n    // For FILO with Gray code: \n    // Full when w_ptr_next has MSB inverted and rest same as wq2_rptr\n    // (standard async FIFO full condition - pointers wrapped differently)\n    //\n    // Actually for FILO, since write only increments and read only decrements,\n    // we can think of it differently:\n    // - Items available = w_count (write domain) - r_consumed (from read domain)\n    // - Full when items available == DEPTH\n    // But with Gray codes, we use the standard comparison.\n    \n    wire w_full_val = (w_ptr_next == {~wq2_rptr[PTR_WIDTH-1:PTR_WIDTH-2], wq2_rptr[PTR_WIDTH-3:0]});\n    wire w_full_cur = (w_ptr == {~wq2_rptr[PTR_WIDTH-1:PTR_WIDTH-2], wq2_rptr[PTR_WIDTH-3:0]});\n\n    always @(posedge w_clk) begin\n        if (w_rst) begin\n            w_count_bin <= {PTR_WIDTH{1'b0}};\n            w_ptr       <= {PTR_WIDTH{1'b0}};\n            w_full      <= 1'b0;\n        end else begin\n            if (push && !w_full) begin\n                mem[w_count_bin[ADDR_WIDTH-1:0]] <= w_data;\n                w_count_bin <= w_count_bin_next;\n                w_ptr       <= w_ptr_next;\n                w_full      <= w_full_val;\n            end else begin\n                w_full      <= w_full_cur;\n            end\n        end\n    end\n\n    // =========================================================================\n    // Read Domain (r_clk)\n    // =========================================================================\n\n    // Synchronize write pointer into read domain (2-stage FF)\n    always @(posedge r_clk) begin\n        if (r_rst) begin\n            rq1_wptr <= {PTR_WIDTH{1'b0}};\n            rq2_wptr <= {PTR_WIDTH{1'b0}};\n        end else begin\n            rq1_wptr <= w_ptr;\n            rq2_wptr <= rq1_wptr;\n        end\n    end\n\n    // Read pointer logic - FILO: read pointer decrements on pop\n    // The read side tracks the current stack top level.\n    // When not popping, it follows the synchronized write pointer (to know what's been pushed).\n    // When popping, it decrements from current level.\n    \n    wire [PTR_WIDTH-1:0] rq2_wptr_bin = gray2bin(rq2_wptr);\n    wire [PTR_WIDTH-1:0] r_count_bin_next = r_count_bin - 1;\n    wire [PTR_WIDTH-1:0] r_ptr_next = bin2gray(r_count_bin_next);\n\n    // Empty when r_ptr equals the zero point (nothing left to pop)\n    // In FILO: empty when r_count_bin == 0, meaning we've popped everything\n    // But we also need to consider: if nothing was pushed, it's empty.\n    // r_empty when r_ptr == 0 (binary 0 -> gray 0)\n    // Actually: empty when there's nothing to read. \n    // The read side knows:\n    //   - rq2_wptr: how much has been pushed (synced from write domain)\n    //   - r_count_bin: current read level (decrements on pop)\n    // When not popping, r_count_bin follows rq2_wptr_bin.\n    // When popping, r_count_bin decrements.\n    // Empty when r_count_bin == 0.\n    \n    wire r_empty_next = (r_count_bin_next == {PTR_WIDTH{1'b0}});\n    wire r_empty_idle = (r_count_bin == rq2_wptr_bin);\n\n    always @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= {PTR_WIDTH{1'b0}};\n            r_ptr       <= {PTR_WIDTH{1'b0}};\n            r_empty     <= 1'b1;\n        end else begin\n            if (pop && !r_empty) begin\n                r_count_bin <= r_count_bin_next;\n                r_ptr       <= r_ptr_next;\n                r_empty     <= r_empty_next;\n            end else if (!pop) begin\n                // When not popping, track the write pointer\n                r_count_bin <= rq2_wptr_bin;\n                r_ptr       <= rq2_wptr;\n                r_empty     <= (rq2_wptr_bin == {PTR_WIDTH{1'b0}});\n            end\n        end\n    end\n\n    // Read data output - continuously driven\n    // FILO reads from top of stack: mem[r_count_bin - 1]\n    // When r_count_bin > 0, read from mem[r_count_bin - 1]\n    // When r_count_bin == 0, output is undefined (empty)\n    wire [ADDR_WIDTH-1:0] r_addr = r_count_bin[ADDR_WIDTH-1:0] - 1;\n    assign r_data = mem[r_addr];\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
