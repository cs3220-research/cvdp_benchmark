            ami          <= 1\'b0;\n            p_ami        <= 1\'b0;\n            n_ami        <= 1\'b0;\n            p_out        <= ~pulse_active_state;\n            n_out        <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n\n            // ===== Stage 1: Input register =====\n            data_r1 <= data_in;\n\n            // ===== Stage 2: FIFO management =====\n            // First, shift FIFO toward output\n            for (int i = 0; i < encoder_type - 1; i++) begin\n                fifo_d[i] <= fifo_d[i+1];\n                fifo_v[i] <= fifo_v[i+1];\n                fifo_b[i] <= fifo_b[i+1];\n            end\n            // Default: write new data at top\n            fifo_d[encoder_type-1] <= data_r1;\n            fifo_v[encoder_type-1] <= 1\'b0;\n            fifo_b[encoder_type-1] <= 1\'b0;\n\n            // Zero counting and substitution\n            if (data_r1 == 1\'b0) begin\n                if (zero_cnt == encoder_type[2:0] - 1) begin\n                    // We have encoder_type consecutive zeros:\n                    // encoder_type-1 zeros already in FIFO + current zero = encoder_type total\n                    // Current zero (data_r1) is the V position\n                    zero_cnt <= \'0;\n\n                    // Mark V at write position\n                    fifo_v[encoder_type-1] <= 1\'b1;\n                    fifo_d[encoder_type-1] <= 1\'b1;\n\n                    // B placement\n                    if (encoder_type == 3) begin\n                        // HDB3: B00V or 000V\n                        // The first zero of the sequence is at fifo[0]\n                        // (it entered encoder_type-1 clocks ago)\n                        // B00V: B at [0], zeros at [1],[2-1]=[1], V at [2]\n                        // Wait for HDB3: fifo has 3 positions [0,1,2]\n                        // 1st zero -> entered 2 clocks ago, now at [0]\n                        // 2nd zero -> entered 1 clock ago, now at [1]  \n                        // 3rd zero -> current data_r1, written to [2]\n                        // But HDB3 needs 4 zeros! 3 zeros is only 3.\n                        // \n                        // Hmm, I think the issue is:\n                        // For HDB3, zero_cnt should count to 3 (4 zeros total)\n                        // But with FIFO depth 3, when zero_cnt reaches 2 (3rd zero),\n                        // only 2 zeros are in FIFO (the 1st already shifted out)\n                        //\n                        // Solution: zero_cnt counts from 0. \n                        // When we see a zero: if zero_cnt < encoder_type-1, increment.\n                        // When zero_cnt reaches encoder_type-1, that means we have\n                        // encoder_type-1 zeros in the FIFO plus the current one = encoder_type.\n                        //\n                        // For HDB3 (encoder_type=3):\n                        // zero_cnt=0: see 1st zero, cnt->1\n                        // zero_cnt=1: see 2nd zero, cnt->2  \n                        // zero_cnt=2: see 3rd zero, cnt==encoder_type-1==2, SUBSTITUTE!\n                        // That\'s only 3 zeros. But HDB3 needs 4!\n                        //\n                        // So for HDB3, we need zero_cnt to reach 3.\n                        // And FIFO depth should be encoder_type = 3.\n                        // When zero_cnt==3: 3 zeros in FIFO + current = 4.\n                        // But zero_cnt goes 0->1->2->3 which takes 4 clocks.\n                        // After 3 clocks of zeros, the FIFO has shifted 3 times.\n                        // The 1st zero entered 3 clocks ago and has shifted out!\n                        //\n                        // I need FIFO depth = encoder_type to hold all zeros.\n                        // And trigger at zero_cnt == encoder_type - 1.\n                        // This means encoder_type zeros total (cnt goes 0..encoder_type-1).\n                        //\n                  