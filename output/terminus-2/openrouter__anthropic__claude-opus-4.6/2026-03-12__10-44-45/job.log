d = irq_enable_reg;\n            16'h07FC: cfg_rd = tx_control_reg;\n            default:  cfg_rd = ram_data0_out;\n        endcase\n    end\n\n    wire [31:0] eff_len = (tx_length_reg < 32'd64) ? 32'd64 : tx_length_reg;\n\n    // FSM regs\n    reg [2:0]  state;\n    reg [31:0] total_bytes;\n    reg [31:0] bytes_sent;\n    reg [31:0] real_length;\n    reg        interrupt_reg;\n    reg [31:0] cached_data;\n    reg        cached_padding;\n\n    assign interrupt_out = interrupt_reg;\n\n    // Combinational AXI outputs\n    wire [31:0] remaining = total_bytes - bytes_sent;\n    wire        is_last   = (remaining <= 32'd4);\n\n    reg [3:0] strb_val;\n    always @(*) begin\n        if (remaining >= 32'd4) strb_val = 4'b1111;\n        else case (remaining[1:0])\n            2'd1: strb_val = 4'b0001;\n            2'd2: strb_val = 4'b0011;\n            2'd3: strb_val = 4'b0111;\n            default: strb_val = 4'b1111;\n        endcase\n    end\n\n    assign axis_tvalid_out = (state == S_TX);\n    assign axis_tdata_out  = cached_padding ? 32'd0 : cached_data;\n    assign axis_tstrb_out  = (state == S_TX) ? strb_val : 4'b0000;\n    assign axis_tlast_out  = (state == S_TX) && is_last;\n\n    always @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state          <= S_IDLE;\n            tx_length_reg  <= 0;\n            irq_enable_reg <= 0;\n            tx_control_reg <= 0;\n            total_bytes    <= 0;\n            bytes_sent     <= 0;\n            real_length    <= 0;\n            ram_addr1      <= 0;\n            interrupt_reg  <= 0;\n            cached_data    <= 0;\n            cached_padding <= 0;\n        end else begin\n            if (interrupt_reg)\n                interrupt_reg <= 0;\n\n            if (cfg_wr_in) begin\n                if (cfg_is_length)  tx_length_reg  <= cfg_data_wr_in;\n                if (cfg_is_irq_en)  irq_enable_reg <= cfg_data_wr_in;\n                if (cfg_is_control) tx_control_reg <= cfg_data_wr_in;\n            end\n\n            case (state)\n                S_IDLE: begin\n                    if (cfg_wr_in && cfg_is_control && cfg_data_wr_in[0]) begin\n                        if (cfg_data_wr_in[1]) begin\n                            interrupt_reg <= irq_enable_reg[0];\n                            state <= S_END;\n                        end else begin\n                            total_bytes <= eff_len;\n                            real_length <= tx_length_reg;\n                            bytes_sent  <= 0;\n                            ram_addr1   <= 0;\n                            state       <= S_FETCH1;\n                        end\n                    end\n                end\n\n                // Address is now on ram_addr1, RAM will latch it at next posedge\n                S_FETCH1: begin\n                    state <= S_FETCH2;\n                end\n\n                // RAM data is now available on ram_data1_out\n                S_FETCH2: begin\n                    cached_data    <= ram_data1_out;\n                    cached_padding <= (bytes_sent >= real_length);\n                    state          <= S_TX;\n                end\n\n                S_TX: begin\n                    if (axis_tready_in) begin\n                        if (is_last) begin\n                            if (irq_enable_reg[0])\n                                interrupt_reg <= 1;\n                            state <= S_END;\n                        end else begin\n                            bytes_sent <= bytes_sent + 32'd4;\n                            ram_addr1  <= ram_addr1 + 1;\n                            state      <= S_FETCH1;\n                        end\n                    end\n                end\n\n                S_END: begin\n                    tx_control_reg <= 0;\n                    state          <= S_IDLE;\n                end\n\n                default: state <= S_IDLE;\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 0.5 