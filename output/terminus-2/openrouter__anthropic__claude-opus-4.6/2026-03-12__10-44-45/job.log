Sending keys: ["cat > /code/rtl/hdbn_encoder.sv << 'VERILOGEOF'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    //=========================================================================\n    // Pipeline Architecture (encoder_type + 3 clock cycles latency)\n    //\n    // Clk 1:                Input sync register\n    // Clk 2..encoder_type+1: Shift register buffer (encoder_type deep)\n    //                        Zero counting & substitution marking happen\n    //                        when data enters the buffer\n    // Clk encoder_type+2:   AMI polarity applied to data exiting buffer\n    // Clk encoder_type+3:   Output register with gating\n    //\n    // For HDB3 (encoder_type=3): latency = 6 clocks\n    // For HDB2 (encoder_type=2): latency = 5 clocks\n    //=========================================================================\n\n    // Input sync register\n    logic data_sync;\n\n    // Shift register arrays - buffer of encoder_type+1 deep\n    // Index encoder_type = newest entry, index 0 = oldest (exits next)\n    logic [encoder_type:0] sr_data;\n    logic [encoder_type:0] sr_v;    // violation markers\n    logic [encoder_type:0] sr_b;    // balance markers\n\n    // Zero counter - counts consecutive zeros seen\n    logic [2:0] zero_cnt;\n\n    // Pulse count since last substitution (parity only matters)\n    // Tracks number of regular data 1-bits since last violation substitution\n    logic pulse_parity;  // 0=even, 1=odd\n\n    // AMI flip-flop: tracks polarity of last pulse sent\n    // 0 = last pulse was negative (or no pulse yet), next normal pulse = positive\n    // 1 = last pulse was positive, next normal pulse = negative\n    logic ami_state;\n\n    // Pre-output pipeline register\n    logic p_pre, n_pre;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_sync    <= 1'b0;\n            sr_data      <= '0;\n            sr_v         <= '0;\n            sr_b         <= '0;\n            zero_cnt     <= '0;\n            pulse_parity <= 1'b0;\n            ami_state    <= 1'b0;\n            p_pre        <= 1'b0;\n            n_pre        <= 1'b0;\n            p_out        <= ~pulse_active_state;\n            n_out        <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n\n            // ==== Stage 1: Input sync ====\n            data_sync <= data_in;\n\n            // ==== Stage 2: Shift register + zero counting + substitution ====\n            // Shift the register: move everything one position toward output\n            for (int i = 0; i < encoder_type; i++) begin\n                sr_data[i] <= sr_data[i+1];\n                sr_v[i]    <= sr_v[i+1];\n                sr_b[i]    <= sr_b[i+1];\n            end\n\n            // Default: new data enters at top position, no markers\n            sr_data[encoder_type] <= data_sync;\n            sr_v[encoder_type]    <= 1'b0;\n            sr_b[encoder_type]    <= 1'b0;\n\n            // Zero counting and substitution logic\n            if (data_sync == 1'b0) begin\n                if (zero_cnt == encoder_type[2:0] - 1) begin\n                    // This is the encoder_type-th consecutive zero\n                    // Time to substitute!\n                    zero_cnt <= '0;\n\n                    // Mark V (violation) at current position\n                    sr_v[encoder_type] <= 1'b1;\n                    sr_data[encoder_type] <= 1'b1;\n\n                    if (encoder_type == 3) begin\n                        // HDB3: 000V or B00V\n                        if (pulse_parity == 1'b0) begin\n                            // Even pulses since last sub: use B00V\n                            // B goes at position that entered encoder_type-1 clocks ago\n                            // That's sr position [1] (3 back from current encoder_type=3)\n                            sr_b[1] <= 1'b1;\n                            sr_data[1] <= 1'b1;\n                        end\n                        // Odd pulses: use 000V (no B needed)\n                    end else begin\n                        // HDB2/B3ZS: always B0V\n                        // B goes at position [encoder_type-1] (2 back from V for HDB2)\n                        // Actually for HDB2 (encoder_type=2), B is 2 positions before V\n                        // V is at [2], B should be at [0]... but [0] is about to shift out\n                        // Let me reconsider: B0V means B, then 0, then V\n                        // If V enters at [encoder_type]=2, and B is 2 positions before,\n                        // B entered 2 clocks ago. After 2 shifts, it's now at position [0]\n                        // But we already shifted it. We need to modify position [0] which\n                        // was just assigned from [1]. Hmm, this is the value about to be\n                        // processed by AMI stage.\n                        // Actually the shift register has encoder_type+1 = 3 positions [0,1,2]\n                        // V at [2] (newest), B at [0] (oldest, entering AMI next clock)\n                        sr_b[0] <= 1'b1;\n                        sr_data[0] <= 1'b1;\n                    end\n\n                    // Reset pulse parity after substitution\n                    pulse_parity <= 1'b0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end else begin\n                // Data is 1: reset zero count, toggle pulse parity\n                zero_cnt <= '0;\n                pulse_parity <= ~pulse_parity;\n            end\n\n            // ==== Stage encoder_type+2: AMI polarity assignment ====\n            // Process sr_data[0] (oldest bit exiting buffer)\n            if (sr_data[0] == 1'b1) begin\n                if (sr_v[0] == 1'b1) begin\n                    // Violation pulse: same polarity as last pulse\n                    if (ami_state == 1'b0) begin\n                        // Last was negative (or none), V = negative\n                        p_pre <= 1'b0;\n                        n_pre <= 1'b1;\n                    end else begin\n                        // Last was positive, V = positive\n                        p_pre <= 1'b1;\n                        n_pre <= 1'b0;\n                    end\n                    // Don't toggle ami_state for violation\n                end else begin\n                    // Normal pulse or B pulse: alternate polarity (AMI rule)\n                    if (ami_state == 1'b0) begin\n                        p_pre <= 1'b1;\n                        n_pre <= 1'b0;\n                        ami_state <= 1'b1;\n                    end else begin\n                        p_pre <= 1'b0;\n                        n_pre <= 1'b1;\n                        ami_state <= 1'b0;\n                    end\n                end\n            end else begin\n                // Zero bit: no pulse\n                p_pre <= 1'b0;\n                n_pre <= 1'b0;\n            end\n\n            // ==== Stage encoder_type+3: Output with gating ====\n            if (output_gate_in) begin\n                p_out <= p_pre ? pulse_active_state : ~pulse_active_state;\n                n_out <= n_pre ? pulse_active_state : ~pulse_active_state;\n            end else begin\n                p_out <= ~pulse_active_state;\n                n_out <= ~pulse_active_state;\n            end\n\n        end // clk_enable_in\n    end // always_ff\n\nendmodule\nVERILOGEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
