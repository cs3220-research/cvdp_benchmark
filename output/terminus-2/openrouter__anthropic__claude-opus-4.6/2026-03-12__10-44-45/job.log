constant indices)\nlogic [7:0] rk_byte [11][4][4];\n""")\n\n# Generate round key byte extraction\nf.write("generate\\n")\nfor r in range(11):\n    for i in range(4):\n        for j in range(4):\n            top = 1408 - r*128 - j*32 - i*8 - 1\n            f.write(f"    assign rk_byte[{r}][{i}][{j}] = expanded_key_ff[{top} -: 8];\\n")\nf.write("endgenerate\\n\\n")\n\n# Current round key bytes muxed by round_ff\nf.write("logic [7:0] cur_rk_byte [4][4];\\n")\nf.write("always_comb begin\\n")\nf.write("    case(round_ff)\\n")\nfor rf in range(2, 12):\n    rk_idx = rf - 1\n    f.write(f"        4\'d{rf}: begin\\n")\n    for i in range(4):\n        for j in range(4):\n            f.write(f"            cur_rk_byte[{i}][{j}] = rk_byte[{rk_idx}][{i}][{j}];\\n")\n    f.write(f"        end\\n")\nf.write(f"        default: begin\\n")\nfor i in range(4):\n    for j in range(4):\n        f.write(f"            cur_rk_byte[{i}][{j}] = rk_byte[0][{i}][{j}];\\n")\nf.write(f"        end\\n")\nf.write("    endcase\\n")\nf.write("end\\n\\n")\n\nf.write("assign o_done = (round_ff == 4\'d0);\\n\\n")\n\n# Output assignment - column major\nf.write("generate\\n")\nfor i in range(4):\n    for j in range(4):\n        top = 128 - (4*j+i)*8 - 1\n        f.write(f"    assign o_data[{top} -: 8] = current_data_ff[{i}][{j}];\\n")\nf.write("endgenerate\\n\\n")\n\n# Round counter and data registers\nf.write("""always_ff @(posedge clk or negedge rst_async_n) begin : cypher_regs\n    if(!rst_async_n) begin\n        round_ff <= 4\'d0;\n        for(int i = 0; i < 4; i++) begin\n            for(int j = 0; j < 4; j++) begin\n                current_data_ff[i][j] <= 8\'d0;\n            end\n        end\n    end else begin\n        if(i_start & o_done || (round_ff > 4\'d0 && round_ff < 4\'d11)) begin\n            round_ff <= round_ff + 1\'b1;\n        end else begin\n            round_ff <= 4\'d0;\n        end\n        for(int i = 0; i < 4; i++) begin\n            for(int j = 0; j < 4; j++) begin\n            