Sending keys: ["cat > /code/rtl/dig_stopwatch_top.sv << 'VERILOG_EOF'\n//=============================================================================\n// Module: dig_stopwatch_top\n// Description: Top-level wrapper for the digital stopwatch.\n//              Instantiates the core dig_stopwatch module and exposes\n//              all interface signals. The CLK_FREQ parameter allows\n//              configuration of the input clock frequency.\n//=============================================================================\n\nmodule dig_stopwatch_top #(\n    parameter CLK_FREQ = 50  // Input clock frequency (number of clock cycles per second)\n) (\n    input  logic        clk,          // System clock\n    input  logic        reset,        // Active-high synchronous reset\n    input  logic        start_stop,   // Start/Stop control: 1 = running, 0 = paused\n\n    output logic [5:0]  seconds,      // Seconds counter output (0-59)\n    output logic [5:0]  minutes,      // Minutes counter output (0-59)\n    output logic        hour,         // Single-bit hour indicator\n\n    output logic        second_pulse, // Pulse indicating seconds counter changed\n    output logic        minute_pulse, // Pulse indicating minutes counter changed\n    output logic        hour_pulse,   // Pulse indicating hour indicator changed\n\n    output logic        beep          // Beep signal: active on hour rollover\n);\n\n    //=========================================================================\n    // Core Stopwatch Instantiation\n    // The dig_stopwatch module contains all the stopwatch logic including\n    // the clock divider, time counters, pulse generators, and beep mechanism.\n    //=========================================================================\n    dig_stopwatch #(\n        .CLK_FREQ(CLK_FREQ)\n    ) u_dig_stopwatch (\n        .clk          (clk),\n        .reset        (reset),\n        .start_stop   (start_stop),\n        .seconds      (seconds),\n        .minutes      (minutes),\n        .hour         (hour),\n        .second_pulse (second_pulse),\n        .minute_pulse (minute_pulse),\n        .hour_pulse   (hour_pulse),\n        .beep         (beep)\n    );\n\nendmodule\nVERILOG_EOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
