Sending keys: ['python3 << \'PYEOF\'\ndef mask16(x): return x & 0xFFFF\ndef rol16(v, n):\n    v, n = v & 0xFFFF, n % 16\n    return ((v << n) | (v >> (16-n))) & 0xFFFF if n else v\ndef ror16(v, n):\n    v, n = v & 0xFFFF, n % 16\n    return ((v >> n) | (v << (16-n))) & 0xFFFF if n else v\n\nTARGET = 0x352454F2\nDATA = 0x12345678\nKEY = 0xABCD\nfound = False\n\n# Key schedule: rk = rol/ror(rk, round_count) ^ round_count\n# With use-before-update (NBA pattern) and update-before-use\n# f_function: all 6 orderings of (xor_rk, rot, add_rk)\n\ndef run(ks_dir, ks_use_rc_as_rot, ks_xor_offset, use_before_update, f_ops, f_rot, final_swap, swap_init):\n    if swap_init:\n        left = DATA & 0xFFFF\n        right = (DATA >> 16) & 0xFFFF\n    else:\n        left = (DATA >> 16) & 0xFFFF\n        right = DATA & 0xFFFF\n    rk = KEY\n    for r in range(8):\n        rot_n = r if ks_use_rc_as_rot else 1  # placeholder\n        xor_val = r + ks_xor_offset\n        \n        if use_before_update:\n            # Use old rk\n            t = apply_f(right, rk, f_ops, f_rot)\n            new_left = right\n            new_right = mask16(left ^ t)\n            # Update rk\n            rk = mask16(ks_dir(rk, rot_n) ^ xor_val)\n            left, right = new_left, new_right\n        else:\n            # Update rk first\n            rk = mask16(ks_dir(rk, rot_n) ^ xor_val)\n            t = apply_f(right, rk, f_ops, f_rot)\n            left, right = right, mask16(left ^ t)\n    \n    if final_swap:\n        return ((right << 16) | left) & 0xFFFFFFFF\n    else:\n        return ((left << 16) | right) & 0xFFFFFFFF\n\ndef apply_f(data, rk, ops, rot):\n    t = data\n    for op in ops:\n        if op == \'X\': t = mask16(t ^ rk)\n        elif op == \'R\': t = rol16(t, rot)\n        elif op == \'r\': t = ror16(t, rot)\n        elif op == \'A\': t = mask16(t + rk)\n        elif op == \'S\': t = mask16(t - rk)\n    return t\n\n# All orderings of XOR, ROT, ADD with rot left\nf_patterns = [\n    \'XRA\', \'XAR\', \'RXA\', \'RAX\', \'AXR\', \'ARX\',  # rol\n    \'XrA\', \'XAr\', \'rXA\', \'rAX\', \'AXr\', \'ArX\',  # ror\n]\n\ncount = 0\nfor ks_use_rc in [True]:\n    for ks_xor_off in [0, 1]:\n        for ubu in [True, False]:\n            for fp in f_patterns:\n                for fr in range(1, 16):\n                    for fs in [True, False]:\n                        for si in [False]:\n                            for kd in [rol16, ror16]:\n                                out = run(kd, ks_use_rc, ks_xor_off, ubu, fp, fr, fs, si)\n                                if out == TARGET:\n                                    dn = \'rol\' if kd==rol16 else \'ror\'\n                                    print(f"MATCH! ks_dir={dn} rc_rot={ks_use_rc} xor_off={ks_xor_off} ubu={ubu} f_ops={fp} f_rot={fr} final_swap={fs}")\n                                    found = True\n                                count += 1\n\nprint(f"Tried {count} combinations")\nif not found:\n    print("No match")\nprint("Done")\nPYEOF\n'] min_timeout_sec: 30.0 max_timeout_sec: 180.0
