Sending keys: ["cat > /code/rtl/pcie_endpoint.sv << 'ENDOFFILE'\n//=============================================================================\n// PCIe Endpoint Module\n//\n// This module implements a PCIe endpoint logic block that:\n//   - Receives and processes PCIe Transaction Layer Packets (TLPs)\n//   - Initiates and monitors DMA transfers\n//   - Triggers MSI-X interrupts on DMA completion\n//\n// It uses multiple FSMs for clean logic partitioning:\n//   1. PCIe Transaction FSM  - Handles incoming TLP reception and processing\n//   2. PCIe Data Link FSM    - Manages outgoing TLP transmission\n//   3. DMA FSM               - Manages DMA engine interactions\n//   4. MSI-X FSM             - Generates MSI-X interrupts\n//=============================================================================\n\nmodule pcie_endpoint #(\n    parameter ADDR_WIDTH = 64,   // Bit-width of the DMA address signals\n    parameter DATA_WIDTH = 128   // Bit-width of the PCIe and DMA data bus\n) (\n    // Clock and Reset\n    input  logic                  clk,\n    input  logic                  rst_n,\n\n    // PCIe Interface\n    input  logic [DATA_WIDTH-1:0] pcie_rx_tlp,     // Incoming PCIe TLP data\n    input  logic                  pcie_rx_valid,   // Indicates valid TLP on pcie_rx_tlp\n    output logic                  pcie_rx_ready,   // Endpoint ready to receive TLP\n    output logic [DATA_WIDTH-1:0] pcie_tx_tlp,     // Outgoing PCIe TLP data\n    output logic                  pcie_tx_valid,   // Valid TLP data on pcie_tx_tlp\n    input  logic                  pcie_tx_ready,   // Host ready to accept outgoing TLP\n\n    // DMA Interface\n    input  logic                  dma_request,     // Request to initiate DMA transfer\n    output logic                  dma_complete,    // DMA operation complete\n\n    // MSI-X Interrupt Interface\n    output logic                  msix_interrupt   // MSI-X interrupt after DMA completion\n);\n\n    //=========================================================================\n    // Internal Signals\n    //=========================================================================\n    logic [DATA_WIDTH-1:0] tlp_decoded_data;  // Latched copy of received PCIe TLP\n    logic                  tlp_valid;          // Valid TLP available for processing\n    logic [ADDR_WIDTH-1:0] dma_address;        // Address for DMA operation\n    logic [DATA_WIDTH-1:0] dma_data;           // Data for DMA write operation\n    logic                  dma_start;          // Trigger signal to begin DMA\n\n    //=========================================================================\n    // PCIe Transaction FSM\n    //\n    // Handles incoming PCIe TLPs:\n    //   IDLE          -> Ready to receive new TLP\n    //   RECEIVE       -> Capture incoming TLP data\n    //   PROCESS       -> Decode and process TLP, may trigger DMA\n    //   SEND_RESPONSE -> Hand off to data link FSM for response\n    //=========================================================================\n    typedef enum logic [1:0] {\n        IDLE          = 2'b00,\n        RECEIVE       = 2'b01,\n        PROCESS       = 2'b10,\n        SEND_RESPONSE = 2'b11\n    } pcie_transaction_state_t;\n\n    pcie_transaction_state_t pcie_transaction_fsm;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            pcie_transaction_fsm <= IDLE;\n            tlp_decoded_data     <= {DATA_WIDTH{1'b0}};\n            tlp_valid            <= 1'b0;\n        end else begin\n            case (pcie_transaction_fsm)\n                IDLE: begin\n                    // Wait for a valid incoming TLP\n                    tlp_valid <= 1'b0;\n                    if (pcie_rx_valid) begin\n                        pcie_transaction_fsm <= RECEIVE;\n                    end\n                end\n\n                RECEIVE: begin\n                    // Capture the incoming TLP data\n                    tlp_decoded_data <= pcie_rx_tlp;\n                    tlp_valid        <= 1'b1;\n                    pcie_transaction_fsm <= PROCESS;\n                end\n\n                PROCESS: begin\n                    // Decode and process the TLP\n                    // In this state, DMA or other operations may be triggered\n                    pcie_transaction_fsm <= SEND_RESPONSE;\n                end\n\n                SEND_RESPONSE: begin\n                    // Response has been handed to data link FSM\n                    // Return to IDLE to accept next TLP\n                    tlp_valid <= 1'b0;\n                    pcie_transaction_fsm <= IDLE;\n                end\n\n                default: begin\n                    pcie_transaction_fsm <= IDLE;\n                end\n            endcase\n        end\n    end\n\n    // pcie_rx_ready is high only when in IDLE state\n    assign pcie_rx_ready = (pcie_transaction_fsm == IDLE);\n\n    //=========================================================================\n    // PCIe Data Link FSM\n    //\n    // Manages transmission of TLPs over PCIe:\n    //   DLL_IDLE  -> Waiting for data to transmit\n    //   TRANSMIT  -> Assert pcie_tx_valid, present data\n    //   WAIT_ACK  -> Wait for pcie_tx_ready acknowledgment\n    //   RETRY     -> Retry transmission if not acknowledged\n    //=========================================================================\n    typedef enum logic [1:0] {\n        DLL_IDLE  = 2'b00,\n        TRANSMIT  = 2'b01,\n        WAIT_ACK  = 2'b10,\n        RETRY     = 2'b11\n    } pcie_data_link_state_t;\n\n    pcie_data_link_state_t pcie_data_link_fsm;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            pcie_data_link_fsm <= DLL_IDLE;\n            pcie_tx_tlp        <= {DATA_WIDTH{1'b0}};\n            pcie_tx_valid      <= 1'b0;\n        end else begin\n            case (pcie_data_link_fsm)\n                DLL_IDLE: begin\n                    pcie_tx_valid <= 1'b0;\n                    // When valid TLP data is ready from transaction FSM\n                    if (tlp_valid) begin\n                        pcie_tx_tlp        <= tlp_decoded_data;\n                        pcie_data_link_fsm <= TRANSMIT;\n                    end\n                end\n\n                TRANSMIT: begin\n                    // Assert valid and wait for ready\n                    pcie_tx_valid <= 1'b1;\n                    pcie_data_link_fsm <= WAIT_ACK;\n                end\n\n                WAIT_ACK: begin\n                    if (pcie_tx_ready) begin\n                        // Transmission acknowledged\n                        pcie_tx_valid      <= 1'b0;\n                        pcie_data_link_fsm <= DLL_IDLE;\n                    end else begin\n                        // Not acknowledged, retry\n                        pcie_data_link_fsm <= RETRY;\n                    end\n                end\n\n                RETRY: begin\n                    // Retry transmission\n                    pcie_tx_valid      <= 1'b1;\n                    pcie_data_link_fsm <= WAIT_ACK;\n                end\n\n                default: begin\n                    pcie_data_link_fsm <= DLL_IDLE;\n                end\n            endcase\n        end\n    end\n\n    //=========================================================================\n    // DMA FSM\n    //\n    // Manages interaction with the DMA engine:\n    //   DMA_IDLE    -> Waiting for DMA request\n    //   READ_DESC   -> Read DMA descriptors\n    //   FETCH_DATA  -> Fetch data from source\n    //   WRITE_DMA   -> Write data to destination, assert dma_complete\n    //=========================================================================\n    typedef enum logic [1:0] {\n        DMA_IDLE    = 2'b00,\n        READ_DESC   = 2'b01,\n        FETCH_DATA  = 2'b10,\n        WRITE_DMA   = 2'b11\n    } dma_state_t;\n\n    dma_state_t dma_fsm;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            dma_fsm      <= DMA_IDLE;\n            dma_complete <= 1'b0;\n            dma_start    <= 1'b0;\n            dma_address  <= {ADDR_WIDTH{1'b0}};\n            dma_data     <= {DATA_WIDTH{1'b0}};\n        end else begin\n            case (dma_fsm)\n                DMA_IDLE: begin\n                    dma_complete <= 1'b0;\n                    dma_start    <= 1'b0;\n                    if (dma_request) begin\n                        dma_start <= 1'b1;\n                        dma_fsm   <= READ_DESC;\n                    end\n                end\n\n                READ_DESC: begin\n                    // Read DMA descriptors - latch address from decoded TLP\n                    dma_start   <= 1'b0;\n                    dma_address <= tlp_decoded_data[ADDR_WIDTH-1:0];\n                    dma_fsm     <= FETCH_DATA;\n                end\n\n                FETCH_DATA: begin\n                    // Fetch data from source memory\n                    dma_data <= tlp_decoded_data;\n                    dma_fsm  <= WRITE_DMA;\n                end\n\n                WRITE_DMA: begin\n                    // Write data to destination, signal completion\n                    dma_complete <= 1'b1;\n                    dma_fsm      <= DMA_IDLE;\n                end\n\n                default: begin\n                    dma_fsm <= DMA_IDLE;\n                end\n            endcase\n        end\n    end\n\n    //=========================================================================\n    // MSI-X FSM\n    //\n    // Generates MSI-X interrupts after DMA completion:\n    //   MSIX_IDLE     -> Waiting for DMA completion\n    //   GENERATE_INT  -> Assert msix_interrupt for one clock cycle\n    //=========================================================================\n    typedef enum logic {\n        MSIX_IDLE     = 1'b0,\n        GENERATE_INT  = 1'b1\n    } msix_state_t;\n\n    msix_state_t msix_fsm;\n\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            msix_fsm       <= MSIX_IDLE;\n            msix_interrupt <= 1'b0;\n        end else begin\n            case (msix_fsm)\n                MSIX_IDLE: begin\n                    msix_interrupt <= 1'b0;\n                    if (dma_complete) begin\n                        msix_fsm <= GENERATE_INT;\n                    end\n                end\n\n                GENERATE_INT: begin\n                    // Assert interrupt for one clock cycle\n                    msix_interrupt <= 1'b1;\n                    msix_fsm       <= MSIX_IDLE;\n                end\n\n                default: begin\n                    msix_fsm <= MSIX_IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
