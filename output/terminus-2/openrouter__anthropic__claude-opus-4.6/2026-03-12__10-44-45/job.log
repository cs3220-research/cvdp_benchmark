rt = i_start && !busy)\n// Counter starts at 0 at cycle N+1\n// Stage1 output valid at cycle N+16 (16 pipeline stages)\n// Stage2 must capture at cycle N+16, counter=15\n// Stage2 output valid at cycle N+32\n// Stage3 must capture at cycle N+32, counter=31\n// Stage3 output valid at cycle N+48, but done must assert at cycle N+47\n// to achieve 48-cycle latency as measured by cocotb\nassign stage2_start = busy && (counter == 6'd15);\nassign stage3_start = busy && (counter == 6'd31);\n\n// Main control logic\nalways_ff @(posedge clk or negedge rst_async_n) begin\n    if (!rst_async_n) begin\n        key1_reg     <= '0;\n        key2_reg     <= '0;\n        counter      <= '0;\n        busy         <= 1'b0;\n        done_reg     <= 1'b0;\n        data_out_reg <= '0;\n    end else begin\n        if (i_start && !busy) begin\n            // Capture keys and start processing\n            key1_reg <= i_key[1:64];\n            key2_reg <= i_key[65:128];\n            counter  <= 6'd0;\n            busy     <= 1'b1;\n            done_reg <= 1'b0;\n        end else if (busy) begin\n            if (counter == 6'd46) begin\n                // Processing complete (48 cycles from i_start)\n                busy         <= 1'b0;\n                done_reg     <= 1'b1;\n                data_out_reg <= stage3_out;\n            end else begin\n                counter <= counter + 6'd1;\n            end\n        end\n    end\nend\n\nassign o_done = done_reg;\nassign o_data = data_out_reg;\n\nendmodule : des3_dec\nENDOFFILE\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
