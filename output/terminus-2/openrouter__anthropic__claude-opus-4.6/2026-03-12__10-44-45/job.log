Sending keys: ["cat > /code/rtl/axis_to_uart_tx.sv << 'ENDOFFILE'\n`timescale 1ns / 1ps\n\nmodule axis_to_uart_tx #(\n    parameter CLK_FREQ      = 100,       // Clock frequency in MHz\n    parameter BIT_RATE       = 115200,    // UART bit rate in bps\n    parameter BIT_PER_WORD   = 8,         // Number of data bits per word\n    parameter PARITY_BIT     = 0,         // 0: no parity, 1: odd, 2: even\n    parameter STOP_BITS_NUM  = 1          // Number of stop bits (1 or 2)\n) (\n    input  wire                    aclk,\n    input  wire                    aresetn,\n    input  wire [BIT_PER_WORD-1:0] tdata,\n    input  wire                    tvalid,\n    output reg                     tready,\n    output reg                     TX\n);\n\n    // Calculate the number of clock cycles per UART bit period\n    localparam integer CYCLE_PER_PERIOD = (CLK_FREQ * 1_000_000) / BIT_RATE;\n\n    // FSM state encoding\n    localparam [2:0] IDLE   = 3'd0,\n                     START  = 3'd1,\n                     DATA   = 3'd2,\n                     PARITY = 3'd3,\n                     STOP1  = 3'd4,\n                     STOP2  = 3'd5;\n\n    // State registers\n    reg [2:0] state, next_state;\n\n    // Clock counter for bit period timing\n    reg [$clog2(CYCLE_PER_PERIOD)-1:0] Clk_Count;\n    wire Clk_Count_Done;\n\n    // Data shift register and bit counter\n    reg [BIT_PER_WORD-1:0] Data;\n    reg [$clog2(BIT_PER_WORD)-1:0] Bit_Count;\n    wire Bit_Count_Done;\n\n    // Parity computation (combinational)\n    reg parity_value;\n\n    // Clock counter done when it reaches CYCLE_PER_PERIOD - 1\n    assign Clk_Count_Done = (Clk_Count == CYCLE_PER_PERIOD - 1);\n\n    // Bit counter done when all data bits have been transmitted\n    assign Bit_Count_Done = (Bit_Count == BIT_PER_WORD - 1);\n\n    // Combinational parity calculation\n    integer k;\n    always @(*) begin\n        parity_value = 0;\n        for (k = 0; k < BIT_PER_WORD; k = k + 1) begin\n            parity_value = parity_value ^ Data[k];\n        end\n        // For odd parity, invert the even parity result\n        if (PARITY_BIT == 1)\n            parity_value = ~parity_value;\n    end\n\n    // Clock counter\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Clk_Count <= 0;\n        end else begin\n            if (state == IDLE) begin\n                Clk_Count <= 0;\n            end else if (Clk_Count_Done) begin\n                Clk_Count <= 0;\n            end else begin\n                Clk_Count <= Clk_Count + 1;\n            end\n        end\n    end\n\n    // Bit counter\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Bit_Count <= 0;\n        end else begin\n            if (state == DATA) begin\n                if (Clk_Count_Done) begin\n                    if (Bit_Count_Done)\n                        Bit_Count <= 0;\n                    else\n                        Bit_Count <= Bit_Count + 1;\n                end\n            end else begin\n                Bit_Count <= 0;\n            end\n        end\n    end\n\n    // Data latching\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            Data <= 0;\n        end else begin\n            if (state == IDLE && tvalid && tready) begin\n                Data <= tdata;\n            end\n        end\n    end\n\n    // FSM state register\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            state <= IDLE;\n        end else begin\n            state <= next_state;\n        end\n    end\n\n    // FSM next state logic\n    always @(*) begin\n        next_state = state;\n        case (state)\n            IDLE: begin\n                if (tvalid)\n                    next_state = START;\n            end\n            START: begin\n                if (Clk_Count_Done)\n                    next_state = DATA;\n            end\n            DATA: begin\n                if (Clk_Count_Done && Bit_Count_Done) begin\n                    if (PARITY_BIT != 0)\n                        next_state = PARITY;\n                    else\n                        next_state = STOP1;\n                end\n            end\n            PARITY: begin\n                if (Clk_Count_Done)\n                    next_state = STOP1;\n            end\n            STOP1: begin\n                if (Clk_Count_Done) begin\n                    if (STOP_BITS_NUM == 2)\n                        next_state = STOP2;\n                    else\n                        next_state = IDLE;\n                end\n            end\n            STOP2: begin\n                if (Clk_Count_Done)\n                    next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    // TX output and tready generation\n    always @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            TX     <= 1'b1;\n            tready <= 1'b0;\n        end else begin\n            case (next_state)\n                IDLE: begin\n                    TX     <= 1'b1;\n                    tready <= 1'b1;\n                end\n                START: begin\n                    TX     <= 1'b0;\n                    tready <= 1'b0;\n                end\n                DATA: begin\n                    // When transitioning into DATA or continuing in DATA,\n                    // output the current bit from the shift register\n                    if (state == START) begin\n                        // About to enter DATA state, output bit 0\n                        TX <= Data[0];\n                    end else if (state == DATA && Clk_Count_Done && !Bit_Count_Done) begin\n                        // Moving to next bit\n                        TX <= Data[Bit_Count + 1];\n                    end\n                    tready <= 1'b0;\n                end\n                PARITY: begin\n                    TX     <= parity_value;\n               