sub_r, r_sub_g, delta_i, max_plus_min;\n\n    wire [11:0] r_scaled = {4\'b0000, r_component};\n    wire [11:0] g_scaled = {4\'b0000, g_component};\n    wire [11:0] b_scaled = {4\'b0000, b_component};\n\n    // Subtraction logic\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            g_sub_b <= 13\'d0;\n            b_sub_r <= 13\'d0;\n            r_sub_g <= 13\'d0;\n            delta_i <= 13\'d0;\n            max_plus_min <= 13\'d0;\n        end else begin\n            g_sub_b <= $signed(g_scaled) - $signed(b_scaled);\n            b_sub_r <= $signed(b_scaled) - $signed(r_scaled);\n            r_sub_g <= $signed(r_scaled) - $signed(g_scaled);\n            delta_i <= $signed(i_max) - $signed(i_min);\n            max_plus_min <= $signed(i_max) + $signed(i_min);\n        end\n    end\n\n    ////////////////////////////// HSL Channel Calculations ///////\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            hsl_channel_l <= \'d0;\n        end else begin\n            hsl_channel_l <= max_plus_min[12:1];\n        end\n    end\n\n    wire [8:0]  double_L;\n    reg  [8:0]  abs_2L_255;\n    wire [8:0]  hsl_channel_s_denom;\n    wire [24:0] inv_hsl_channel_s_denom;\n\n    assign double_L = max_plus_min[8:0];\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            abs_2L_255 <= \'d0;\n        end else begin\n            if (double_L >= 9\'d255)\n                abs_2L_255 <= (double_L - 9\'d255);\n            else\n                abs_2L_255 <= (9\'d255 - double_L);\n        end\n    end\n\n    assign hsl_channel_s_denom = 9\'d255 - abs_2L_255;\n\n    multi_port_ram inverse_component_inst (\n        .clk(clk),\n        .we(we),\n        .waddr(waddr),\n        .wdata(wdata),\n        .raddr_a(i_max[7:0]),\n        .rdata_a(inv_i_max),\n        .raddr_b(delta_i[7:0]),\n        .rdata_b(inv_delta_i),\n        .raddr_c(hsl_channel_s_denom[7:0]),\n        .rdata_c(inv_hsl_channel_s_denom)\n    );\n\n    reg signed [18:0] pre_hue_mult;\n    reg signed [18:0] pre_hue_mult_stage1;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            pre_hue_mult_stage1 <= \'d0;\n            pre_hue_mult <= \'d0;\n        end else begin\n            pre_hue_mult_stage1 <= pre_hue * $signed(19\'d60);\n            pre_hue_mult <= pre_hue_mult_stage1;\n        end\n    end\n\n    hue_mult hue_mult_inst (\n        .clk(clk),\n        .rst(rst),\n        .dataa(pre_hue_mult),\n        .datab(inv_delta_i),\n        .result(almost_hue)\n    );\n\n    reg [8:0] hue_offset_shreg [0:3];\n    integer j;\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            for (j = 0; j < 4; j = j + 1)\n                hue_offset_shreg[j] <= 9\'d0;\n        end else begin\n            hue_offset_shreg[0] <= hue_degrees_offset;\n            for (j = 1; j < 4; j = j + 1)\n                hue_offset_shreg[j] <= hue_offset_shreg[j-1];\n        end\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst)\n            hue <= 12\'d0;\n        else\n            hue <= almost_hue + {3\'b000, hue_offset_shreg[3]};\n    end\n\n    saturation_mult saturation_mult_inst (\n        .clk(clk),\n        .rst(rst),\n        .a(inv_i_max),\n        .b(delta_i[7:0]),\n        .result(saturation_result)\n    );\n\n    saturation_mult hsl_saturation_mult_inst (\n        .clk(clk),\n        .rst(rst),\n        .a(inv_hsl_channel_s_denom),\n        .b(delta_i[7:0]),\n        .result(hsl_saturation_result)\n    );\n\n    // Shift register for valid and pipeline signals\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            valid_in_shreg <= 8\'d0;\n            g_sub_b_shreg <= 13\'d0;\n            b_sub_r_shreg <= 13\'d0;\n            r_sub_g_shreg <= 13\'d0;\n            i_max_shreg <= 12\'d0;\n            i_min_shreg <= 12\'d0;\n        end else begin\n            valid_in_shreg <= {valid_in_shreg[6:0], valid_in