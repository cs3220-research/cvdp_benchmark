al signals\n// ---------------------------------------------------------------------------\n\n// Global enable (combinational)\nwire proc_enable = i_valid & i_enable;\n\n// Enable pipeline\nlogic [PIPE_DEPTH-1:0] proc_enable_dff;\n\n// Input data buffering registers\nlogic signed [NBW_DATA_IN-1:0] proc_buffer_i_dff [NS_PROC-1:0];\nlogic signed [NBW_DATA_IN-1:0] proc_buffer_q_dff [NS_PROC-1:0];\n\n// Polarity register\nlogic proc_pol_dff;\n\n// Unpack input data into 2D arrays for indexing\nlogic signed [NBW_DATA_IN-1:0] data_i_2d [NS_DATA_IN-1:0];\nlogic signed [NBW_DATA_IN-1:0] data_q_2d [NS_DATA_IN-1:0];\n\nalways_comb begin\n   for (int i = 0; i < NS_DATA_IN; i++) begin\n      data_i_2d[i] = $signed(i_data_i[(i+1)*NBW_DATA_IN-1 -: NBW_DATA_IN]);\n      data_q_2d[i] = $signed(i_data_q[(i+1)*NBW_DATA_IN-1 -: NBW_DATA_IN]);\n   end\nend\n\n// Registered position for extraction\nlogic [NBW_PILOT_POS-1:0] proc_pos_dff;\n\n// Registered versions of input data for extraction\nlogic signed [NBW_DATA_IN-1:0] data_i_2d_reg [NS_DATA_IN-1:0];\nlogic signed [NBW_DATA_IN-1:0] data_q_2d_reg [NS_DATA_IN-1:0];\n\n// ---------------------------------------------------------------------------\n// Enable Pipeline\n// ---------------------------------------------------------------------------\nalways_ff @(posedge clk or negedge rst_async_n) begin\n   if (!rst_async_n) begin\n      proc_enable_dff <= '0;\n   end else begin\n      proc_enable_dff[0] <= proc_enable;\n      for (int i = 1; i < PIPE_DEPTH; i++) begin\n         proc_enable_dff[i] <= proc_enable_dff[i-1];\n      end\n   end\nend\n\n// ---------------------------------------------------------------------------\n// Input Data Buffering & Polarity Registration\n// ---------------------------------------------------------------------------\nalways_ff @(posedge clk or negedge rst_async_n) begin\n   if (!rst_async_n) begin\n      proc_pol_dff <= 1'b0;\n      proc_pos_dff <= '0;\n      for (int i = 0; i < NS_DATA_IN; i++) begin\n         data_i_2d_reg[i] <= '0;\n         data_q_2d_reg[i] <= '0;\n      end\n   end else if (proc_enable) begin\n      proc_pol_dff  <= i_proc_pol;\n      proc_pos_dff  <= i_proc_pos;\n      for (int i = 0; i < NS_DATA_IN; i++) begin\n         data_i_2d_reg[i] <= data_i_2d[i];\n         data_q_2d_reg[i] <= data_q_2d[i];\n      end\n   end\nend\n\n// Extract NS_PROC samples starting at proc_pos_dff\nalways_comb begin\n   for (int i = 0; i < NS_PROC; i++) begin\n      proc_buffer_i_dff[i] = data_i_2d_reg[proc_pos_dff + i];\n      proc_buffer_q_dff[i] = data_q_2d_reg[proc_pos_dff + i];\n   end\nend\n\n// ---------------------------------------------------------------------------\n// Conjugate Selection (combinational, based on registered polarity)\n// ---------------------------------------------------------------------------\nlogic [NS_PROC-1:0] conj_proc_seq [1:0];\n\nalways_comb begin\n   if (proc_pol_dff) begin\n      conj_proc_seq[0] = CONJ_PROC_V_0;\n      conj_proc_seq[1] = CONJ_PROC_V_1;\n   end else begin\n      conj_proc_seq[0] = CONJ_PROC_H_0;\n      conj_proc_seq[1] = CONJ_PROC_H_1;\n   end\nend\n\n// ---------------------------------------------------------------------------\n// Flatten buffered data for cross_correlation input\n// ---------------------------------------------------------------------------\nlogic [NBW_DATA_IN*NS_PROC-1:0] proc_data_i_flat;\nlogic [NBW_DATA_IN*NS_PROC-1:0] proc_data_q_flat;\n\nalways_comb begin\n   for (int i = 0; i < NS_PROC; i++) begin\n      proc_data_i_flat[(i+1)*NBW_DATA_IN-1 -: NBW_DATA_IN] = proc_buffer_i_dff[i];\n      proc_data_q_flat[(i+1)*NBW_DATA_IN-1 -: NBW_DATA_IN] = proc_buffer_q_dff[i];\n   end\nend\n\n// ---------------------------------------------------------------------------\n// Cross-Correlation Instantiation\n// ---------------------------------------------------------------------------\nlogic [NBW_ENERGY-1:0] proc_calc_energy;\n\ncross_correlation #(\n   .NS_DATA_IN  (NS_PROC),\n   .NBW_DATA_IN (NBW