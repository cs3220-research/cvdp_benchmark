     4'd12: cur_rk = rk[0];\n        default: cur_rk = {NBW_KEY{1'b0}};\n    endcase\nend\n\n// Extract individual key bytes in column-major order\nlogic [NBW_BYTE-1:0] rk_byte [4][4];\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : rk_row\n        for(genvar j = 0; j < 4; j++) begin : rk_col\n            assign rk_byte[i][j] = cur_rk[NBW_KEY - (4*j+i)*NBW_BYTE - 1 -: NBW_BYTE];\n        end\n    end\nendgenerate\n\nassign o_done = (round_ff == 4'd0);\n\n// Output in column-major order\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : out_row\n        for(genvar j = 0; j < 4; j++) begin : out_col\n            assign o_data[NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE] = current_data_ff[i][j];\n        end\n    end\nendgenerate\n\nalways_ff @(posedge clk or negedge rst_async_n) begin : inv_cypher_regs\n    if(!rst_async_n) begin\n        round_ff <= 4'd0;\n        for(int i = 0; i < 4; i++)\n            for(int j = 0; j < 4; j++)\n                current_data_ff[i][j] <= 8'd0;\n    end else begin\n        // Round counter\n        if(i_start & o_done) begin\n            round_ff <= 4'd1;\n        end else if(round_ff == 4'd1 && !key_done) begin\n            round_ff <= 4'd1; // wait for key\n        end else if(round_ff >= 4'd1 && round_ff < 4'd12) begin\n            round_ff <= round_ff + 1'b1;\n        end else if(round_ff == 4'd12) begin\n            round_ff <= 4'd0;\n        end\n\n        // Data register\n        for(int i = 0; i < 4; i++)\n            for(int j = 0; j < 4; j++)\n                current_data_ff[i][j] <= current_data_nx[i][j];\n    end\nend\n\n// Next data mux\nalways_comb begin : next_data\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(i_start & o_done) begin\n                // Load data in column-major order\n                current_data_nx[i][j] = i_data[NBW_DATA-(4*j+i)*NBW_BYTE-1-:NBW_BYTE];\n            end else if(round_ff == 4'd1) begin\n                // Waiting for key - hold data\n                current_data_nx[i][j] = current_data_ff[i][j];\n            end else if(round_ff == 4'd2) begin\n                // Initial AddRoundKey only (no InvShiftRows/InvSubBytes/InvMixColumns)\n                current_data_nx[i][j] = AddRoundKey[i][j];\n            end else if(round_ff >= 4'd3 && round_ff <= 4'd11) begin\n                // Main rounds: InvShiftRows -> InvSubBytes -> AddRoundKey -> InvMixColumns\n                current_data_nx[i][j] = MixColumns[i][j];\n            end else if(round_ff == 4'd12) begin\n                // Final round: InvShiftRows -> InvSubBytes -> AddRoundKey (no InvMixColumns)\n                current_data_nx[i][j] = SubBytes[i][j];\n            end else begin\n                current_data_nx[i][j] = current_data_ff[i][j];\n            end\n        end\n    end\nend\n\n// InvSubBytes\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : row\n        for(genvar j = 0; j < 4; j++) begin : col\n            inv_sbox uu_inv_sbox0 (\n                .i_data(ShiftRows[i][j]),\n                .o_data(SubBytes[i][j])\n            );\n        end\n    end\nendgenerate\n\nalways_comb begin : decypher_logic\n    // AddRoundKey: XOR state with round key\n    // For rounds 3-12, AddRoundKey is applied AFTER InvSubBytes\n    // For round 2, AddRoundKey is applied directly to current_data_ff\n    // The pipeline is:\n    //   current_data_ff -> InvShiftRows -> InvSubBytes(=SubBytes) -> AddRoundKey -> InvMixColumns(=MixColumns)\n    // For round 2 (initial): current_data_ff -> AddRoundKey\n    // For rounds 3-11: current_data_ff -> ShiftRows -> SubBytes -> AddRoundKey -> MixColumns\n    // For round 12: current_data_ff -> ShiftRows -> SubBytes -> AddRoundKey (stored as SubBytes output needs AddRoundKey)\n    \n    // Wait - let me reconsider the data flow.\n    // The combinational chain for rounds 3-12 should be:\n    //   InvShiftRows(current_data_ff) -> InvSubBytes -> AddRoundKey -> InvMixColumns\n    // So AddRoundKey input should be SubBytes (which is InvSubBytes output), not current_data_ff\n    // But for round 2 (initial AddRoundKey), it's just current_data_ff XOR key\n    \n    // Let me restructure: AddRoundKey takes SubBytes as input for rounds 3-12,\n    // and current_data_ff for round 2\n    \n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            if(round_ff == 4'd2) begin\n                AddRoundKey[i][j] = current_data_ff[i][j] ^ rk_byte[i][j];\n            end else begin\n                AddRoundKey[i][j] = SubBytes[i][j] ^ rk_byte[i][j];\n            end\n        end\n    end\n\n    // InvMixColumns on AddRoundKey output\n    for(int j = 0; j < 4; j++) begin\n        for(int i = 0; i < 4; i++) begin\n            xtimes02[i][j] = {AddRoundKey[i][j][6:0], 1'b0} ^ (AddRoundKey[i][j][7] ? 8'h1B : 8'h00);\n            xtimes04[i][j] = {xtimes02[i][j][6:0], 1'b0} ^ (xtimes02[i][j][7] ? 8'h1B : 8'h00);\n            xtimes08[i][j] = {xtimes04[i][j][6:0], 1'b0} ^ (xtimes04[i][j][7] ? 8'h1B : 8'h00);\n\n            xtimes0e[i][j] = xtimes08[i][j] ^ xtimes04[i][j] ^ xtimes02[i][j];\n            xtimes0b[i][j] = xtimes08[i][j] ^ xtimes02[i][j] ^ AddRoundKey[i][j];\n            xtimes0d[i][j] = xtimes08[i][j] ^ xtimes04[i][j] ^ AddRoundKey[i][j];\n            xtimes09[i][j] = xtimes08[i][j] ^ AddRoundKey[i][j];\n        end\n\n        MixColumns[0][j] = xtimes0e[0][j] ^ xtimes0b[1][j] ^ xtimes0d[2][j] ^ xtimes09[3][j];\n        MixColumns[1][j] = xtimes09[0][j] ^ xtimes0e[1][j] ^ xtimes0b[2][j] ^ xtimes0d[3][j];\n        MixColumns[2][j] = xtimes0d[0][j] ^ xtimes09[1][j] ^ xtimes0e[2][j] ^ xtimes0b[3][j];\n        MixColumns[3][j] = xtimes0b[0][j] ^ xtimes0d[1][j] ^ xtimes09[2][j] ^ xtimes0e[3][j];\n    end\n\n    // InvShiftRows (shift rows RIGHT)\n    ShiftRows[0][0] = current_data_ff[0][0];\n    ShiftRows[0][1] = current_data_ff[0][1];\n    ShiftRows[0][2] = current_data_ff[0][2];\n    ShiftRows[0][3] = current_data_ff[0][3];\n\n    ShiftRows[1][0] = current_data_ff[1][3];\n    ShiftRows[1][1] = current_data_ff[1][0];\n    ShiftRows[1][2] = current_data_ff[1][1];\n    ShiftRows[1][3] = current_data_ff[1][2];\n\n    ShiftRows[2][0] = current_data_ff[2][2];\n    ShiftRows[2][1] = current_data_ff[2][3];\n    ShiftRows[2][2] = current_data_ff[2][0];\n    ShiftRows[2][3] = current_data_ff[2][1];\n\n    ShiftRows[3][0] = current_data_ff[3][1];\n    ShiftRows[3][1] = current_data_ff[3][2];\n    ShiftRows[3][2] = current_data_ff[3][3];\n    ShiftRows[3][3] = current_data_ff[3][0];\nend\n\naes128_key_expansion uu_aes128_key_expansion (\n    .clk           (clk                            ),\n    .rst_async_n   (rst_async_n                    ),\n    .i_start       (i_start & i_update_key & o_done),\n    .i_key         (i_key                          ),\n    .o_done        (key_done                       ),\n    .o_expanded_key(expanded_key                   )\n);\n\nendmodule : aes128_decrypt\nENDOFFILE\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
