e = PCIE_WRITE;\n            end\n\n            PCIE_WRITE: begin\n                next_state = SEND_RESPONSE;\n            end\n\n            SEND_RESPONSE: begin\n                if (bready) begin\n                    next_state = IDLE;\n                end\n            end\n\n            READ_IDLE: begin\n                if (arvalid) begin\n                    next_state = READ_ADDR_CAPTURE;\n                end\n            end\n\n            READ_ADDR_CAPTURE: begin\n                next_state = PCIE_READ;\n            end\n\n            PCIE_READ: begin\n                next_state = SEND_READ_RESPONSE;\n            end\n\n            SEND_READ_RESPONSE: begin\n                if (rready) begin\n                    next_state = READ_IDLE;\n                end\n            end\n\n            default: begin\n                next_state = IDLE;\n            end\n        endcase\n    end\n\n    // FSM Output Logic\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            awready <= 1'b0;\n            wready <= 1'b0;\n            bvalid <= 1'b0;\n            bresp <= 2'b00; // OKAY response\n            pcie_cfg_wr_en <= 1'b0;\n            pcie_cfg_wdata <= 32'h0;\n            pcie_cfg_addr <= 8'h0;\n            awaddr_reg <= 32'h0;\n            wdata_reg <= 32'h0;\n            wstrb_reg <= 4'h0;\n            rvalid <= 1'b0;\n            arready <= 1'b0;\n            rresp <= 2'b00;\n        end else begin\n            case (current_state)\n                IDLE: begin\n                    awready <= 1'b0;\n                    wready <= 1'b0;\n                    bvalid <= 1'b0;\n                    pcie_cfg_wr_en <= 1'b0;\n                end\n\n                ADDR_CAPTURE: begin\n                    awready <= 1'b1;\n                    awaddr_reg <= awaddr;\n                end\n\n                DATA_CAPTURE: begin\n                    wready <= 1'b1;\n                    wdata_reg <= wdata;\n                    wstrb_reg <