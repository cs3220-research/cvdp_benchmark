           key_position <= {($clog2(ARRAY_SIZE)+1){1\'b1}};\\\n            left_output_index <= 0;\\\n            right_output_index <= 0;\\\n            left_done <= 0;\\\n            right_done <= 0;\\\n        end else begin\\\n            case (delete_state)\\\n                S_IDLE: begin\\\n                    if (start) begin\\\n                        delete_state <= S_SEARCH_LEFT;\\\n                    end\\\n                end\\\n                S_SEARCH_LEFT: begin\\\n                    // Search logic for the left child\\\n                    if (keys[root*DATA_WIDTH +: DATA_WIDTH] == delete_key) begin\\\n                        found <= 1;\\\n                        position <= root;\\\n                        delete_state <= S_COMPLETE_DELETION;\\\n                    end else if (left_child[root*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] != {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                        root <= left_child[root*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\\\n                        delete_state <= S_SEARCH_LEFT;\\\n                    end else begin\\\n                        delete_state <= S_SEARCH_LEFT_RIGHT;\\\n                    end\\\n                end\\\n                S_SEARCH_LEFT_RIGHT: begin\\\n                    // Search logic for the right child\\\n                    if (keys[root*DATA_WIDTH +: DATA_WIDTH] == delete_key) begin\\\n                        found <= 1;\\\n                        position <= root;\\\n                        delete_state <= S_COMPLETE_DELETION;\\\n                    end else if (right_child[root*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] != {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                        root <= right_child[root*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\\\n                        delete_state <= S_SEARCH_LEFT_RIGHT;\\\n                    end else begin\\\n                        delete_state <= S_COMPLETE_DELETION;\\\n                    end\\\n                end\\\n                S_COMPLETE_DELETION: begin\\\n                    // Logic to handle completion of deletion\\\n                    if (found) begin\\\n                        // If the node has no children\\\n                        if (left_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] == {($clog2(ARRAY_SIZE)+1){1\'b1}} &&\\\n                            right_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] == {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                            keys[position*DATA_WIDTH +: DATA_WIDTH] <= {DATA_WIDTH{1\'b0}}; // Mark as deleted\\\n                        end\\\n                        // If the node has one child\\\n                        else if (left_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] != {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                            // Replace with left child\\\n                            keys[position*DATA_WIDTH +: DATA_WIDTH] <= keys[left_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)]*DATA_WIDTH +: DATA_WIDTH];\\\n                        end else if (right_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] != {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                            // Replace with right child\\\n                            keys[position*DATA_WIDTH +: DATA_WIDTH] <= keys[right_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)]*DATA_WIDTH +: DATA_WIDTH];\\\n                        end\\\n                        // If the node has two children\\\n                        else begin\\\n                            // Find the in-order successor or predecessor\\\n                            reg [$clog2(ARRAY_SIZE):0] successor_node;\\\n                            successor_node <= right_child[position*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\\\n                            while (left_child[successor_node*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)] != {($clog2(ARRAY_SIZE)+1){1\'b1}}) begin\\\n                                successor_node <= left_child[successor_node*($clog2(ARRAY_SIZE)+1) +: ($clog2(ARRAY_SIZE)+1)];\\\n                            end\\\n                            keys[position*DATA_WIDTH +: DATA_WIDTH] <= keys[successor_node*DATA_WIDTH +: DATA_WIDTH];\\\n                            delete_key <= keys[successor_node*DATA_WIDTH +: DATA_WIDTH];\\\n                            delete_state <= S_COMPLETE_DELETION;\\\n                        end\\\n                    end\\\n                    complete_deletion <= 1;\\\n                end\\\n" > search_binary_search_tree.sv\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
Sending keys: ['echo "module direct_map_cache #(\n    parameter CACHE_SIZE = 256,                 // Number of cache lines\n    parameter DATA_WIDTH = 16,                  // Width of data\n    parameter TAG_WIDTH = 5,                    // Width of the tag\n    parameter OFFSET_WIDTH = 3,                 // Width of the offset\n    localparam INDEX_WIDTH = $clog2(CACHE_SIZE) // Width of the index\n) (\n    input wire enable,                          // Enable signal\n    input wire [INDEX_WIDTH-1:0] index,         // Cache index\n    input wire [OFFSET_WIDTH-1:0] offset,       // Byte offset within the cache line\n    input wire comp,                            // Compare operation signal\n    input wire write,                           // Write operation signal\n    input wire [TAG_WIDTH-1:0] tag_in,          // Input tag for comparison and writing\n    input wire [DATA_WIDTH-1:0] data_in,        // Input data to be written\n    input wire valid_in,                        // Valid state for cache line\n    input wire clk,                             // Clock signal\n    input wire rst,                             // Reset signal (active high)\n    output reg hit,                             // Hit indication\n    output reg dirty,                           // Dirty state indication\n    output reg [TAG_WIDTH-1:0] tag_out,         // Output tag of the cache line\n    output reg [DATA_WIDTH-1:0] data_out,       // Output data from the cache line\n    output reg valid,                           // Valid state output\n    output reg error                            // Error indication for invalid accesses\n);\n\n    // Cache line definitions\n    reg [TAG_WIDTH-1:0] tags [CACHE_SIZE-1:0][1:0];                       // Tag storage for two ways\n    reg [DATA_WIDTH-1:0] data_mem [CACHE_SIZE-1:0][1:0][OFFSET_WIDTH:0];  // Data storage for two ways\n    reg valid_bits [CACHE_SIZE-1:0][1:0];                                 // Valid bits for each line in both ways\n    reg dirty_bits [CACHE_SIZE-1:0][1:0];                                 // Dirty bits for each line in both ways\n    integer i;\n    integer victimway; // Victim-way register for replacement policy\n\n    // Sequential logic for cache operations\n    always @(posedge clk) begin\n        if (rst) begin\n            // Initialize cache lines on reset\n            for (i = 0; i < CACHE_SIZE; i = i + 1) begin\n                valid_bits[i][0] <= 1\'b0;\n                valid_bits[i][1] <= 1\'b0;\n                dirty_bits[i][0] <= 1\'b0;\n                dirty_bits[i][1] <= 1\'b0;\n            end\n            hit      <= 1\'b0;\n            dirty    <= 1\'b0;\n            valid    <= 1\'b0;\n            data_out <= {DATA_WIDTH{1\'b0}};\n            victimway <= 0; // Initialize victim way\n        end\n        else if (enable) begin\n            // Check for LSB alignment error\n            if (offset[0] == 1\'b1) begin\n                error <= 1\'b1;                               // Set error if LSB of offset is 1\n                hit   <= 1\'b0;\n                dirty <= 1\'b0;\n                valid <= 1\'b0;\n                data_out <= {DATA_WIDTH{1\'b0}};\n            end\n            else begin\n                error <= 1\'b0;                               // Clear error if LSB of offset is 0\n\n                // Compare operation\n                if (comp) begin\n                    // Compare Write (comp = 1, write = 1)\n                    if (write) begin\n                        if ((tags[index][0] == tag_in) && valid_bits[index][0]) begin\n                            hit <= 1\'b1;\n                            data_mem[index][0][offset[OFFSET_WIDTH-1:1]] <= data_in;\n                            dirty_bits[index][0] <= 1\'b1;\n                            valid_bits[index][0] <= valid_in;\n                        end\n                        else if ((tags[index][1] == tag_in) && valid_bits[index][1]) begin\n                            hit <= 1\'b1;\n                            data_mem[index][1][offset[OFFSET_WIDTH-1:1]] <= data_in;\n                            dirty_bits[index][1] <= 1\'b1;\n                            valid_bits[index][1] <= valid_in;\n                        end\n                        else begin\n                            hit <= 1\'b0;\n                            // Use victim way for storing new data\n                            data_mem[index][victimway][offset[OFFSET_WIDTH-1:1]] <= data_in;\n                            tags[index][victimway] <= tag_in;\n                            valid_bits[index][victimway] <= 1\'b1;\n                            dirty_bits[index][victimway] <= 1\'b0;\n                            victimway <= ~victimway; // Toggle victim way\n                        end\n                    end\n                    else begin // Compare Read (comp = 1, write = 0)\n                        if ((tags[index][0] == tag_in) && valid_bits[index][0]) begin\n                            hit <= 1\'b1;\n                            data_out <= data_mem[index][0][offset[OFFSET_WIDTH-1:1]];\n                            valid    <= valid_bits[index][0];\n                            dirty    <= dirty_bits[index][0];\n                            tag_out  <= tags[index][0];\n                        end\n                        else if ((tags[index][1] == tag_in) && valid_bits[index][1]) begin\n                            hit <= 1\'b1;\n                            data_out <= data_mem[index][1][offset[OFFSET_WIDTH-1:1]];\n                            valid    <= valid_bits[index][1];\n                            dirty    <= dirty_bits[index][1];\n                            tag_out  <= tags[index][1];\n                        end\n                        else begin\n                            hit <= 1\'b0;\n                            valid <= valid_bits[index][0] || valid_bits[index][1];\n                            dirty <= dirty_bits[index][0] || dirty_bits[index][1];\n                            data_out <= {DATA_WIDTH{1\'b0}}; // No valid data\n                            tag_out  <= tags[index][0];\n                        end\n                    end\n                end\n                else begin //compare\n                    if (write) begin\n                        // Access Write (comp = 0, write = 1)\n                        tags[index][0]       <= tag_in;\n                        data_mem[index][0][offset[OFFSET_WIDTH-1:1]] <= data_in;\n                        valid_bits[index][0] <= valid_in;\n                        dirty_bits[index][0] <= 1\'b0;\n                        hit      <= 1\'b0;\n                        valid    <= 1\'b0;\n                        dirty    <= 1\'b0;\n                    end\n                    else begin\n                        // Access Read (comp = 0, write = 0)\n                        tag_out  <= tags[index][0];\n                        data_out <= data_mem[index][0][offset[OFFSET_WIDTH-1:1]];\n                        valid    <= valid_bits[index][0];\n                        dirty    <= dirty_bits[index][0];\n                        hit      <= 1\'b0;\n                    end\n                end\n            end\n        end\n        else begin // enable\n            // enable is low\n            for (i = 0; i < CACHE_SIZE; i = i + 1) begin\n                valid_bits[i][0] <= 1\'b0;\n                valid_bits[i][1] <= 1\'b0;\n                dirty_bits[i][0] <= 1\'b0;\n                dirty_bits[i][1] <= 1\'b0;\n            end\n\n            hit      <= 1\'b0;\n            dirty    <= 1\'b0;\n            data_out <= {DATA_WIDTH{1\'b0}};\n            valid    <= 1\'b0;\n        end\n    end\n\nendmodule" > direct_map_cache_modified.sv\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
