Sending keys: ["echo 'module rgb_color_space_hsv (\n    input               clk,\n    input               rst,\n    input               we,\n    input       [7:0]   waddr,\n    input      [24:0]   wdata,\n    input               valid_in,\n    input       [7:0]   r_component,\n    input       [7:0]   g_component,\n    input       [7:0]   b_component,\n    output reg [11:0]   h_component,\n    output reg [12:0]   s_component,\n    output reg [11:0]   v_component,\n    output reg          valid_out\n);\n\n// Internal signals\nreg [11:0] i_max, i_min, delta_i;\n\n// Normalize RGB values\nwire [11:0] r_norm = {4'b0, r_component};\nwire [11:0] g_norm = {4'b0, g_component};\nwire [11:0] b_norm = {4'b0, b_component};\n\n// Compute i_max and i_min\nalways @(*) begin\n    i_max = (r_norm > g_norm) ? ((r_norm > b_norm) ? r_norm : b_norm) : ((g_norm > b_norm) ? g_norm : b_norm);\n    i_min = (r_norm < g_norm) ? ((r_norm < b_norm) ? r_norm : b_norm) : ((g_norm < b_norm) ? g_norm : b_norm);\n    delta_i = i_max - i_min;\nend\n\n// Calculate Hue\nalways @(*) begin\n    if (delta_i == 0) begin\n        h_component = 0;\n    end else begin\n        case (i_max)\n            r_norm: h_component = 60 * ((g_norm - b_norm) / delta_i);\n            g_norm: h_component = 60 * ((b_norm - r_norm) / delta_i) + 120;\n            b_norm: h_component = 60 * ((r_norm - g_norm) / delta_i) + 240;\n        endcase\n    end\nend\n\n// Calculate Saturation\nalways @(*) begin\n    s_component = (delta_i * 4096) / i_max;\nend\n\n// Calculate Value\nalways @(*) begin\n    v_component = i_max;\nend\n\n// Output valid signal\nalways @(posedge clk or posedge rst) begin\n    if (rst) begin\n        valid_out <= 0;\n    end else if (valid_in) begin\n        valid_out <= 1;\n    end\nend\n\nendmodule' > rgb_color_space_hsv.sv\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
