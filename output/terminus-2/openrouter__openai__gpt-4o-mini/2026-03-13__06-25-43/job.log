Sending keys: ['echo "// Parameters\\nparameter NBW_WAIT = 32;\\n\\n// Interface Signals\\ninput logic clk;\\ninput logic rst_async_n;\\ninput logic i_enable;\\ninput logic i_subsampling;\\noutput logic o_subsampling;\\ninput logic i_valid;\\noutput logic o_valid;\\ninput logic i_calc_valid;\\ninput logic i_calc_fail;\\ninput logic [NBW_WAIT-1:0] i_wait;\\noutput logic o_start_calc;\\n\\n// State Definitions\\nenum logic [2:0] {\\n  PROC_CONTROL_CAPTURE_ST,\\n  PROC_DATA_CAPTURE_ST,\\n  PROC_CALC_START_ST,\\n  PROC_CALC_ST,\\n  PROC_WAIT_ST\\n} state_t;\\nstate_t current_state, next_state;\\n\\n// Counter Declarations\\nlogic [NBW_WAIT-1:0] general_counter;\\nlogic [NBW_WAIT-1:0] timeout_counter;\\n\\n// Sequential Logic (State Transition)\\nalways @(posedge clk or negedge rst_async_n) begin\\n  if (~rst_async_n) begin\\n    current_state <= PROC_CONTROL_CAPTURE_ST;\\n  end else begin\\n    current_state <= next_state;\\n  end\\nend\\n\\n// Combinational Logic for Next State\\nalways_comb begin\\n  // Default state\\n  next_state = current_state;\\n  case (current_state)\\n    PROC_CONTROL_CAPTURE_ST: begin\\n      if (i_enable) next_state = PROC_DATA_CAPTURE_ST;\\n    end\\n    PROC_DATA_CAPTURE_ST: begin\\n      if (general_counter == 0) next_state = PROC_CALC_START_ST;\\n    end\\n    PROC_CALC_START_ST: begin\\n      if (general_counter == 0) next_state = PROC_CALC_ST;\\n    end\\n    PROC_CALC_ST: begin\\n      if (i_calc_valid) next_state = PROC_WAIT_ST;\\n      else if (i_calc_fail) next_state = PROC_CONTROL_CAPTURE_ST;\\n    end\\n    PROC_WAIT_ST: begin\\n      if (timeout_counter == 0) next_state = PROC_CONTROL_CAPTURE_ST;\\n    end\\n  endcase\\nend\\n\\n// Counter Logic\\nalways_ff @(posedge clk or negedge rst_async_n) begin\\n  if (~rst_async_n) begin\\n    general_counter <= 0;\\n    timeout_counter <= 0;\\n  end else begin\\n    case (current_state)\\n      PROC_DATA_CAPTURE_ST: begin\\n        if (i_valid) begin\\n          general_counter <= general_counter - 1;\\n        end\\n      end\\n      PROC_CALC_START_ST: begin\\n        general_counter <= 16; // Fixed countdown\\n      end\\n      PROC_WAIT_ST: begin\\n        timeout_counter <= i_wait; // Preload timeout counter\\n      end\\n    endcase\\n  end\\nend\\n\\n// Output Logic\\nalways_ff @(posedge clk) begin\\n  o_valid <= (current_state == PROC_DATA_CAPTURE_ST && i_valid);\\n  o_start_calc <= (current_state == PROC_CALC_START_ST);\\n  o_subsampling <= i_subsampling;\\nend\\n" > control_fsm.sv\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
