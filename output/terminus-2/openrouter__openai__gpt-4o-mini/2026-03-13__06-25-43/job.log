lid <= 0;\n  end\nend\n\n// Parity Checking Logic\nalways @(posedge aclk) begin\n  if (state == PARITY) begin\n    parity_error <= (PARITY_BIT == 1) ? (~^Data_Shift_Reg) : (PARITY_BIT == 2) ? (^Data_Shift_Reg) : 0;\n  end\nend\n\nendmodule" > uart_rx_to_axis.sv\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
