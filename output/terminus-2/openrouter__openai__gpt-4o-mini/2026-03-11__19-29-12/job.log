Sending keys: ["echo 'module cipher (input logic clk, input logic rst_n, input logic start, input logic [31:0] data_in, input logic [15:0] key, output logic [31:0] data_out, output logic done);\n  typedef enum logic [1:0] {IDLE, ROUND, FINISH} state_t;\n  state_t current_state, next_state;\n  logic [15:0] left, right;\n  logic [15:0] round_key;\n  logic [3:0] round_counter;\n\n  always_ff @(posedge clk or negedge rst_n) begin\n    if (!rst_n) begin\n      current_state <= IDLE;\n      round_counter <= 0;\n      done <= 0;\n    end else begin\n      current_state <= next_state;\n      if (next_state == ROUND) begin\n        // Split data_in into left and right halves\n        left <= data_in[31:16];\n        right <= data_in[15:0];\n      end\n    end\n  end\n\n  always_comb begin\n    case (current_state)\n      IDLE: begin\n        if (start) next_state = ROUND;\n        else next_state = IDLE;\n      end\n      ROUND: begin\n        if (round_counter < 8) begin\n          next_state = ROUND;\n        end else begin\n          next_state = FINISH;\n        end\n      end\n      FINISH: begin\n        next_state = IDLE;\n      end\n    endcase\n  end\n\n  always_ff @(posedge clk) begin\n    if (current_state == ROUND) begin\n      // Get the round key\n      round_key <= key_schedule(key, round_counter);\n      // Apply the round function\n      logic [15:0] f_result = f_function(right, round_key);\n      // Perform XOR with left half\n      left <= left ^ f_result;\n      // Swap halves\n      {left, right} <= {right, left};\n      round_counter <= round_counter + 1;\n    end\n  end\n\n  always_ff @(posedge clk) begin\n    if (current_state == FINISH) begin\n      data_out <= {left, right};\n      done <= 1;\n    end else begin\n      done <= 0;\n    end\n  end\n\n  function logic [15:0] f_function(logic [15:0] right, logic [15:0] round_key);\n    return right ^ round_key; // Placeholder logic\n  endfunction\n\n  function logic [15:0] key_schedule(logic [15:0] key, logic [3:0] round_index);\n    return (key << round_index) ^ round_index; // Placeholder logic\n  endfunction\nendmodule' > cipher.sv\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
