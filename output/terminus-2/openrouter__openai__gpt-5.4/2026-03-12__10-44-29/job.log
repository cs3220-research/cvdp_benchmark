ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            pcie_transaction_state <= PCIE_IDLE;\n            pcie_dll_state         <= DLL_IDLE;\n            dma_state              <= DMA_IDLE;\n            msix_state             <= MSIX_IDLE;\n\n            pcie_rx_ready    <= 1'b1;\n            pcie_tx_tlp      <= '0;\n            pcie_tx_valid    <= 1'b0;\n            dma_complete     <= 1'b0;\n            msix_interrupt   <= 1'b0;\n\n            tlp_decoded_data <= '0;\n            tlp_valid        <= 1'b0;\n            dma_address      <= '0;\n            dma_data         <= '0;\n            dma_start        <= 1'b0;\n            tx_pending       <= 1'b0;\n            tx_buffer        <= '0;\n            dma_complete_d   <= 1'b0;\n        end else begin\n            dma_complete   <= 1'b0;\n            msix_interrupt <= 1'b0;\n            dma_start      <= 1'b0;\n            dma_complete_d <= dma_complete;\n\n            pcie_rx_ready <= (pcie_transaction_state == PCIE_IDLE);\n\n            case (pcie_transaction_state)\n                PCIE_IDLE: begin\n                    tlp_valid <= 1'b0;\n                    if (pcie_rx_valid) begin\n                        pcie_transaction_state <= PCIE_RECEIVE;\n                    end\n                end\n\n                PCIE_RECEIVE: begin\n                    tlp_decoded_data <= pcie_rx_tlp;\n                    dma_data         <= pcie_rx_tlp;\n                    dma_address      <= {{(ADDR_WIDTH-ADDR_LSB_WIDTH){1'b0}}, pcie_rx_tlp[ADDR_LSB_WIDTH-1:0]};\n                    tlp_valid        <= 1'b1;\n                    pcie_transaction_state <= PCIE_PROCESS;\n                end\n\n                PCIE_PROCESS: begin\n                    tx_buffer <= tlp_decoded_data;\n                    if (dma_request || tlp_decoded_data[0]) begin\n                        dma_start <= 1'b1;\n                    end\n                    pcie_transaction_state <= PCIE_SEND_RESPONSE;\n                end\n\n                PCIE_SEND_RESPONSE: begin\n                    tx_pending <= 1'b1;\n                    tlp_valid  <= 1'b0;\n                    if (pcie_dll_state == DLL_IDLE) begin\n                        pcie_transaction_state <= PCIE_IDLE;\n                    end\n                end\n\n                default: begin\n                    pcie_transaction_state <= PCIE_IDLE;\n                end\n            endcase\n\n            case (pcie_dll_state)\n                DLL_IDLE: begin\n                    pcie_tx_valid <= 1'b0;\n                    if (tx_pending) begin\n                        pcie_tx_tlp    <= tx_buffer;\n                        pcie_dll_state <= DLL_TRANSMIT;\n                    end\n                end\n\n                DLL_TRANSMIT: begin\n                    pcie_tx_valid <= 1'b1;\n                    pcie_tx_tlp   <= tx_buffer;\n                    if (pcie_tx_ready) begin\n                        pcie_dll_state <= DLL_WAIT_ACK;\n                    end\n                end\n\n                DLL_WAIT_ACK: begin\n                    pcie_tx_valid <= 1'b0;\n                    tx_pending    <= 1'b0;\n                    pcie_dll_state <= DLL_IDLE;\n                end\n\n                DLL_RETRY: begin\n                    pcie_tx_valid <= 1'b1;\n                    pcie_tx_tlp   <= tx_buffer;\n                    if (pcie_tx_ready) begin\n                        pcie_dll_state <= DLL_WAIT_ACK;\n                    end\n                end\n\n                default: begin\n                    pcie_dll_state <= DLL_IDLE;\n                end\n            endcase\n\n            case (dma_state)\n                DMA_IDLE: begin\n                    if (dma_request || dma_start) begin\n                        dma_state <= DMA_READ_DESC;\n                    end\n                end\n\n                DMA_READ_DESC: begin\n                    dma_state <= DMA_FETCH_DATA;\n                end\n\n                DMA_FETCH_DATA: begin\n     