  .start(ask_start),\n    .in_data(ask_orders),\n    .done(ask_done),\n    .out_data(ask_sorted)\n  );\n\n  always @(posedge clk or posedge rst) begin\n    if (rst) begin\n      bid_start             <= 1'b0;\n      ask_start             <= 1'b0;\n      cycle_count           <= 6'd0;\n      active                <= 1'b0;\n      pending_match_valid   <= 1'b0;\n      pending_matched_price <= {PRICE_WIDTH{1'b0}};\n      match_valid           <= 1'b0;\n      matched_price         <= {PRICE_WIDTH{1'b0}};\n      done                  <= 1'b0;\n      latency_error         <= 1'b0;\n    end else begin\n      bid_start   <= 1'b0;\n      ask_start   <= 1'b0;\n      done        <= 1'b0;\n      match_valid <= 1'b0;\n\n      if (!active) begin\n        cycle_count <= 6'd0;\n        if (start) begin\n          active      <= 1'b1;\n          bid_start   <= 1'b1;\n          ask_start   <= 1'b1;\n          cycle_count <= 6'd0;\n          if (best_bid >= best_ask) begin\n            pending_match_valid   <= 1'b1;\n            pending_matched_price <= best_ask;\n          end else begin\n            pending_match_valid   <= 1'b0;\n            pending_matched_price <= {PRICE_WIDTH{1'b0}};\n          end\n          matched_price <= {PRICE_WIDTH{1'b0}};\n          latency_error <= 1'b0;\n        end\n      end else begin\n        cycle_count <= cycle_count + 6'd1;\n        if (cycle_count == REQUIRED_LATENCY) begin\n          active        <= 1'b0;\n          done          <= 1'b1;\n          match_valid   <= pending_match_valid;\n          matched_price <= pending_matched_price;\n        end\n      end\n    end\n  end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
