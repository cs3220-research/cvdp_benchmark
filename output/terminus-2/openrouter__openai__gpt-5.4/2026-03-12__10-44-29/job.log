se (a_lsb)\n                        2'd0: extract_data = {24'd0, bus_data[7:0]};\n                        2'd1: extract_data = {24'd0, bus_data[15:8]};\n                        2'd2: extract_data = {24'd0, bus_data[23:16]};\n                        default: extract_data = {24'd0, bus_data[31:24]};\n                    endcase\n                end\n                DMA_HW: begin\n                    if (a_lsb[1])\n                        extract_data = {16'd0, bus_data[31:16]};\n                    else\n                        extract_data = {16'd0, bus_data[15:0]};\n                end\n                default: extract_data = bus_data;\n            endcase\n        end\n    endfunction\n\n    function automatic [31:0] pack_data(\n        input logic [31:0] data,\n        input logic [1:0]  size,\n        input logic [1:0]  a_lsb\n    );\n        begin\n            case (size)\n                DMA_B: begin\n                    case (a_lsb)\n                        2'd0: pack_data = {24'd0, data[7:0]};\n                        2'd1: pack_data = {16'd0, data[7:0], 8'd0};\n                        2'd2: pack_data = {8'd0, data[7:0], 16'd0};\n                        default: pack_data = {data[7:0], 24'd0};\n                    endcase\n                end\n                DMA_HW: begin\n                    if (a_lsb[1])\n                        pack_data = {data[15:0], 16'd0};\n                    else\n                        pack_data = {16'd0, data[15:0]};\n                end\n                default: pack_data = data;\n            endcase\n        end\n    endfunction\n\n    always_comb begin\n        case (addr)\n            DMA_CR_ADDR:  rd = {22'd0, dma_cr};\n            DMA_SRC_ADDR: rd = dma_src_adr;\n            DMA_DST_ADDR: rd = dma_dst_adr;\n            default:      rd = 32'd0;\n        endcase\n    end\n\n    always_comb begin\n        bus_req  = (state != ST_IDLE);\n        bus_lock = (state != ST_IDLE);\n        addr_m   = 32'd0;\n        we_m     = 1'b0