else\\n                    crc = (crc >> 1);\\n            end\\n            crc32_next_byte = crc;\\n        end\\n    endfunction\\n\\n    reg [2:0] state_q;\\n    reg       nibble_phase_q;\\n    reg [7:0] tx_byte_q;\\n    reg [2:0] preamble_cnt_q;\\n\\n    reg [31:0] crc_q;\\n    reg [31:0] crc_final_q;\\n    reg [1:0]  crc_byte_idx_q;\\n\\n    reg [31:0] word_data_q;\\n    reg [3:0]  word_strb_q;\\n    reg        word_last_q;\\n    reg        word_valid_q;\\n    reg [1:0]  byte_idx_q;\\n    reg        pop_pending_q;\\n\\n    wire [7:0] cur_byte_w;\\n    assign cur_byte_w = (byte_idx_q == 2'd0) ? word_data_q[7:0] :\\n                        (byte_idx_q == 2'd1) ? word_data_q[15:8] :\\n                        (byte_idx_q == 2'd2) ? word_data_q[23:16] :\\n                                               word_data_q[31:24];\\n\\n    always @(posedge clk_in or posedge rst_in) begin\\n        if (rst_in) begin\\n            mii_txd_out    <= 4'd0;\\n            mii_tx_en_out  <= 1'b0;\\n            fifo_rd_pop    <= 1'b0;\\n            state_q        <= ST_IDLE;\\n            nibble_phase_q <= 1'b0;\\n            tx_byte_q      <= 8'd0;\\n            preamble_cnt_q <= 3'd0;\\n            crc_q          <= 32'hFFFFFFFF;\\n            crc_final_q    <= 32'd0;\\n            crc_byte_idx_q <= 2'd0;\\n            word_data_q    <= 32'd0;\\n            word_strb_q    <= 4'd0;\\n            word_last_q    <= 1'b0;\\n            word_valid_q   <= 1'b0;\\n            byte_idx_q     <= 2'd0;\\n            pop_pending_q  <= 1'b0;\\n        end else begin\\n            fifo_rd_pop <= 1'b0;\\n\\n            if (pop_pending_q) begin\\n                word_data_q   <= fifo_rd_data[31:0];\\n                word_strb_q   <= fifo_rd_data[35:32];\\n                word_last_q   <= fifo_rd_data[36];\\n                word_valid_q  <= 1'b1;\\n                byte_idx_q    <= 2'd0;\\n                pop_pending_q <= 1'b0;\\n            end\\n\\n            case (state_q)\\n                ST_IDLE: begin\\n                    mii_tx_en_out  <= 1'b0;\\n                    mii_txd_out    <= 4'd0;\\n                    nibble_phase_q <= 1'b0;\\n                    preamble_cnt_q <= 3'd0;\\n                    crc_q          <= 32'hFFFFFFFF;\\n                    crc_byte_idx_q <= 2'd0;\\n                    word_valid_q   <= 1'b0;\\n                    byte_idx_q     <= 2'd0;\\n\\n                    if (!fifo_empty) begin\\n                        fifo_rd_pop    <= 1'b1;\\n                        pop_pending_q  <= 1'b1;\\n                        state_q        <= ST_PREAMBLE;\\n                        mii_tx_en_out  <= 1'b1;\\n                        mii_txd_out    <= 4'h5;\\n                        nibble_phase_q <= 1'b1;\\n                    end\\n                end\\n\\n                ST_PREAMBLE: begin\\n                    mii_tx_en_out <= 1'b1;\\n                    if (!nibble_phase_q) begin\\n                        mii_txd_out    <= 4'h5;\\n                        nibble_phase_q <= 1'b1;\\n                    end else begin\\n                        mii_txd_out    <= 4'h5;\\n                        nibble_phase_q <= 1'b0;\\n                        if (preamble_cnt_q == 3'd6)\\n                            state_q <= ST_SFD;\\n                        else\\n                            preamble_cnt_q <= preamble_cnt_q + 3'd1;\\n                    end\\n                end\\n\\n                ST_SFD: begin\\n                    mii_tx_en_out <= 1'b1;\\n                    if (!nibble_phase_q) begin\\n                        mii_txd_out    <= 4'h5;\\n                        tx_byte_q      <= 8'hD5;\\n                        nibble_phase_q <= 1'b1;\\n                    end else begin\\n                        mii_txd_out    <= 4'hD;\\n                        nibble_phase_q <= 1'b0;\\n                        state_q        <= ST_PAYLOAD;\\n                    end\\n                end\\n\\n                ST_PAYLOAD: begin\\n                    mii_tx_en_out <= 1'b1;\\n\\n                    if (!word_valid_q && !pop_pending_q && !fifo_empty) begin\\n                        fifo_rd_pop   <= 1'b1;\\n                        pop_pending_q <= 1'b1;\\n                    end\\n\\n                    if (word_valid_q && word_strb_q[byte_idx_q]) begin\\n                        if (!nibble_phase_q) begin\\n                            tx_byte_q      <= cur_byte_w;\\n                            mii_txd_out    <= cur_byte_w[3:0];\\n                            nibble_phase_q <= 1'b1;\\n                        end else begin\\n                            mii_txd_out    <= tx_byte_q[7:4];\\n                            nibble_phase_q <= 1'b0;\\n                            crc_q          <= crc32_next_byte(crc_q, tx_byte_q);\\n\\n                            if ((byte_idx_q == 2'd3) || !word_strb_q[byte_idx_q + 2'd1]) begin\\n                                if (word_last_q) begin\\n                                    word_valid_q   <= 1'b0;\\n                                    crc_final_q    <= crc32_next_byte(crc_q, tx_byte_q) ^ 32'hFFFFFFFF;\\n                                    crc_byte_idx_q <= 2'd0;\\n                                    state_q        <= ST_CRC;\\n                                end else begin\\n                                    word_valid_q <= 1'b0;\\n                                    byte_idx_q   <= 2'd0;\\n                                end\\n                            end else begin\\n                                byte_idx_q <= byte_idx_q + 2'd1;\\n                            end\\n                        end\\n                    end\\n                end\\n\\n                ST_CRC: begin\\n                    mii_tx_en_out <= 1'b1;\\n                    if (!nibble_phase_q) begin\\n                        case (crc_byte_idx_q)\\n                            2'd0: tx_byte_q <= crc_final_q[7:0];\\n                            2'd1: tx_byte_q <= crc_final_q[15:8];\\n                            2'd2: tx_byte_q <= crc_final_q[23:16];\\n                            default: tx_byte_q <= crc_final_q[31:24];\\n                        endcase\\n\\n                        case (crc_byte_idx_q)\\n                            2'd0: mii_txd_out <= crc_final_q[3:0];\\n                            2'd1: mii_txd_out <= crc_final_q[11:8];\\n                            2'd2: mii_txd_out <= crc_final_q[19:16];\\n                            default: mii_txd_out <= crc_final_q[27:24];\\n                        endcase\\n\\n                        nibble_phase_q <= 1'b1;\\n                    end else begin\\n                        mii_txd_out    <= tx_byte_q[7:4];\\n                        nibble_phase_q <= 1'b0;\\n                        if (crc_byte_idx_q == 2'd3) begin\\n                            mii_tx_en_out <= 1'b0;\\n                            mii_txd_out   <= 4'd0;\\n                            state_q       <= ST_IDLE;\\n                        end else begin\\n                            crc_byte_idx_q <= crc_byte_idx_q + 2'd1;\\n                        end\\n                    end\\n                end\\n\\n                default: begin\\n                    state_q <= ST_IDLE;\\n                end\\n            endcase\\n        end\\n    end\\n\\nendmodule\\n''')\nPY\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
