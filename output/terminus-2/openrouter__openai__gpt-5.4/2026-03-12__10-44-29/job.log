lt: begin sum_i[i] = -sub[i]; sum_q[i] = -add[i]; end\n                    endcase\n                end\n                2'd1: begin\n                    sum_i[i] = sub[i];\n                    sum_q[i] = sub[i];\n                end\n                2'd2: begin\n                    sum_i[i] = add[i];\n                    sum_q[i] = add[i];\n                end\n                default: begin\n                    sum_i[i] = '0;\n                    sum_q[i] = '0;\n                end\n            endcase\n        end\n    end\nendgenerate\n\nalways_comb begin\n    for (int i=0; i<NS_DATA_IN; ++i) begin\n        o_sum_i[(i+1)*NBW_ADDER_TREE_IN-1-:NBW_ADDER_TREE_IN] = sum_i[i];\n        o_sum_q[(i+1)*NBW_ADDER_TREE_IN-1-:NBW_ADDER_TREE_IN] = sum_q[i];\n    end\nend\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
