Sending keys: ["cat > src/async_filo.sv <<'SV'\nmodule async_filo #(\n    parameter int DATA_WIDTH = 16,\n    parameter int DEPTH      = 8\n) (\n    input  logic                  w_clk,\n    input  logic                  w_rst,\n    input  logic                  push,\n    input  logic                  r_clk,\n    input  logic                  r_rst,\n    input  logic                  pop,\n    input  logic [DATA_WIDTH-1:0] w_data,\n    output logic [DATA_WIDTH-1:0] r_data,\n    output logic                  r_empty,\n    output logic                  w_full\n);\n\n    localparam int PTR_W = (DEPTH <= 1) ? 1 : $clog2(DEPTH + 1);\n    localparam int ADDR_W = (DEPTH <= 1) ? 1 : $clog2(DEPTH);\n\n    logic [DATA_WIDTH-1:0] mem [0:DEPTH-1];\n\n    logic [PTR_W-1:0] w_count_bin, r_count_bin;\n    logic [PTR_W-1:0] w_ptr, r_ptr;\n    logic [PTR_W-1:0] wq1_rptr, wq2_rptr;\n    logic [PTR_W-1:0] rq1_wptr, rq2_wptr;\n\n    logic [PTR_W-1:0] w_count_bin_next, r_count_bin_next;\n    logic [PTR_W-1:0] w_ptr_next, r_ptr_next;\n    logic             w_push_fire, r_pop_fire;\n    logic             w_full_next, r_empty_next;\n\n    function automatic [PTR_W-1:0] bin2gray(input [PTR_W-1:0] bin);\n        bin2gray = bin ^ (bin >> 1);\n    endfunction\n\n    function automatic [PTR_W-1:0] gray2bin(input [PTR_W-1:0] gray);\n        integer i;\n        begin\n            gray2bin[PTR_W-1] = gray[PTR_W-1];\n            for (i = PTR_W-2; i >= 0; i = i - 1)\n                gray2bin[i] = gray2bin[i+1] ^ gray[i];\n        end\n    endfunction\n\n    function automatic [ADDR_W-1:0] sp_index(input [PTR_W-1:0] count_bin);\n        integer tmp;\n        begin\n            if (count_bin == 0) begin\n                sp_index = '0;\n            end else begin\n                tmp = count_bin - 1;\n                if (DEPTH > 1)\n                    sp_index = tmp[ADDR_W-1:0];\n                else\n                    sp_index = '0;\n            end\n        end\n    endfunction\n\n    always_comb begin\n        w_push_fire     = push && !w_full;\n        w_count_bin_next = w_count_bin + (w_push_fire ? 1'b1 : 1'b0);\n        w_ptr_next      = bin2gray(w_count_bin_next);\n\n        w_full_next = (w_count_bin_next == DEPTH);\n    end\n\n    always_ff @(posedge w_clk) begin\n        if (w_rst) begin\n            w_count_bin <= '0;\n            w_ptr       <= '0;\n            wq1_rptr    <= '0;\n            wq2_rptr    <= '0;\n            w_full      <= 1'b0;\n        end else begin\n            wq1_rptr <= r_ptr;\n            wq2_rptr <= wq1_rptr;\n\n            if (w_push_fire) begin\n                mem[w_count_bin[ADDR_W-1:0]] <= w_data;\n                w_count_bin <= w_count_bin_next;\n                w_ptr       <= w_ptr_next;\n            end\n\n            w_full <= w_full_next;\n        end\n    end\n\n    always_comb begin\n        r_pop_fire      = pop && !r_empty;\n        r_count_bin_next = r_count_bin - (r_pop_fire ? 1'b1 : 1'b0);\n        r_ptr_next      = bin2gray(r_count_bin_next);\n\n        r_empty_next = (r_count_bin_next == 0);\n    end\n\n    always_ff @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= '0;\n            r_ptr       <= '0;\n            rq1_wptr    <= '0;\n            rq2_wptr    <= '0;\n            r_empty     <= 1'b1;\n        end else begin\n            rq1_wptr <= w_ptr;\n            rq2_wptr <= rq1_wptr;\n\n            if (r_pop_fire) begin\n                r_count_bin <= r_count_bin_next;\n                r_ptr       <= r_ptr_next;\n            end\n\n            r_empty <= r_empty_next;\n        end\n    end\n\n    always_comb begin\n        if (r_count_bin == 0)\n            r_data = '0;\n        else\n            r_data = mem[sp_index(r_count_bin)];\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
