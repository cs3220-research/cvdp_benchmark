Sending keys: ['python3 - <<\'PY\'\nfrom itertools import permutations\nfrom pathlib import Path\nimport subprocess, re, sys\norig = Path(\'rtl/des3_dec.sv\').read_text()\n# define slice expressions by semantic names a,b,c corresponding to [1:64],[65:128],[129:192]\nslices = {\'a\':\'i_key[1:64]\', \'b\':\'i_key[65:128]\', \'c\':\'i_key[129:192]\'}\n# stage1 uses direct top-level slice, stage2/3 use latched aliases key_1,key_2,key_3 assigned from key_ff slices\nfor perm in permutations(\'abc\', 3):\n    s = orig\n    s = re.sub(r\'assign key_1 = key_ff\\[[^\\n]+\\nassign key_2 = key_ff\\[[^\\n]+\\nassign key_3 = key_ff\\[[^\\n]+\\n\',\n               f\'assign key_1 = key_ff[{"1:64" if perm[2]=="a" else "65:128" if perm[2]=="b" else "129:192"}];\\nassign key_2 = key_ff[{"1:64" if perm[1]=="a" else "65:128" if perm[1]=="b" else "129:192"}];\\nassign key_3 = key_ff[{"1:64" if perm[0]=="a" else "65:128" if perm[0]=="b" else "129:192"}];\\n\', s)\n    s = re.sub(r\'\\.i_key\\s*\\(i_key\\[[^\\)]*\\]\\)\', f\'.i_key      ({slices[perm[0]]})\', s, count=1)\n    Path(\'rtl/des3_dec.sv\').write_text(s)\n    cmd = \'iverilog -g2012 -o /tmp/tb3des rtl/des3_dec.sv rtl/des_dec.sv rtl/des_enc.sv rtl/S1.sv rtl/S2.sv rtl/S3.sv rtl/S4.sv rtl/S5.sv rtl/S6.sv rtl/S7.sv rtl/S8.sv verif/tb_3des_dec.sv && vvp /tmp/tb3des\'\n    r = subprocess.run(cmd, shell=True, text=True, capture_output=True)\n    out = r.stdout + r.stderr\n    print(\'perm\', perm, \'rc\', r.returncode)\n    print(out[-800:])\n    if \'FAIL!\' not in out and \'PASS!\' in out:\n        print(\'WINNER\', perm)\n        Path(\'rtl/des3_dec.sv\').write_text(s)\n        sys.exit(0)\nPath(\'rtl/des3_dec.sv\').write_text(orig)\nprint(\'no winner\')\nPY\n'] min_timeout_sec: 8.0 max_timeout_sec: 180.0
