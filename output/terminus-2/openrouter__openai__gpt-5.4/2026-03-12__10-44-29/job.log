Sending keys: ["mkdir -p rtl\ncat > rtl/signed_comparator.sv <<'SV'\nmodule signed_comparator #(\n  parameter integer DATA_WIDTH = 16,\n  parameter integer REGISTER_OUTPUT = 0,\n  parameter integer ENABLE_TOLERANCE = 0,\n  parameter integer TOLERANCE = 0,\n  parameter integer SHIFT_LEFT = 0\n)(\n  input  wire clk,\n  input  wire rst_n,\n  input  wire enable,\n  input  wire bypass,\n  input  wire signed [DATA_WIDTH-1:0] a,\n  input  wire signed [DATA_WIDTH-1:0] b,\n  output reg gt,\n  output reg lt,\n  output reg eq\n);\n\n  localparam integer INTERNAL_WIDTH = DATA_WIDTH + SHIFT_LEFT + 1;\n\n  wire signed [INTERNAL_WIDTH-1:0] a_ext;\n  wire signed [INTERNAL_WIDTH-1:0] b_ext;\n  wire signed [INTERNAL_WIDTH-1:0] a_shifted;\n  wire signed [INTERNAL_WIDTH-1:0] b_shifted;\n  wire signed [INTERNAL_WIDTH-1:0] diff;\n  wire signed [INTERNAL_WIDTH-1:0] abs_diff;\n  wire eq_tolerance;\n\n  reg gt_next;\n  reg lt_next;\n  reg eq_next;\n\n  assign a_ext     = {{(INTERNAL_WIDTH-DATA_WIDTH){a[DATA_WIDTH-1]}}, a};\n  assign b_ext     = {{(INTERNAL_WIDTH-DATA_WIDTH){b[DATA_WIDTH-1]}}, b};\n  assign a_shifted = a_ext <<< SHIFT_LEFT;\n  assign b_shifted = b_ext <<< SHIFT_LEFT;\n  assign diff      = a_shifted - b_shifted;\n  assign abs_diff  = diff[INTERNAL_WIDTH-1] ? -diff : diff;\n\n  generate\n    if (ENABLE_TOLERANCE != 0) begin : gen_tol\n      assign eq_tolerance = (abs_diff <= TOLERANCE);\n    end else begin : gen_no_tol\n      assign eq_tolerance = (a_shifted == b_shifted);\n    end\n  endgenerate\n\n  always @* begin\n    gt_next = 1'b0;\n    lt_next = 1'b0;\n    eq_next = 1'b0;\n\n    if (bypass) begin\n      gt_next = 1'b0;\n      lt_next = 1'b0;\n      eq_next = 1'b1;\n    end else if (enable) begin\n      if (eq_tolerance) begin\n        gt_next = 1'b0;\n        lt_next = 1'b0;\n        eq_next = 1'b1;\n      end else if (a_shifted > b_shifted) begin\n        gt_next = 1'b1;\n        lt_next = 1'b0;\n        eq_next = 1'b0;\n      end else if (a_shifted < b_shifted) begin\n        gt_next = 1'b0;\n        lt_next = 1'b1;\n        eq_next = 1'b0;\n      end else begin\n        gt_next = 1'b0;\n        lt_next = 1'b0;\n        eq_next = 1'b1;\n      end\n    end\n  end\n\n  generate\n    if (REGISTER_OUTPUT != 0) begin : gen_reg_out\n      always @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n          gt <= 1'b0;\n          lt <= 1'b0;\n          eq <= 1'b0;\n        end else begin\n          gt <= gt_next;\n          lt <= lt_next;\n          eq <= eq_next;\n        end\n      end\n    end else begin : gen_comb_out\n      always @* begin\n        gt = gt_next;\n        lt = lt_next;\n        eq = eq_next;\n      end\n    end\n  endgenerate\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
