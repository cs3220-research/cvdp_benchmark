d_in01),\n    .psum_out    (psum_01_to_11)\n  );\n\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe10 (\n    .clk         (clk),\n    .reset       (reset),\n    .load_weight (load_weights),\n    .valid       (valid_bot),\n    .input_in    (in_bot_col0),\n    .weight      (w10),\n    .psum_in     (psum_00_to_10),\n    .input_out   (unused_in10),\n    .psum_out    (psum_out_10)\n  );\n\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe11 (\n    .clk         (clk),\n    .reset       (reset),\n    .load_weight (load_weights),\n    .valid       (valid_bot),\n    .input_in    (in_bot_col1),\n    .weight      (w11),\n    .psum_in     (psum_01_to_11),\n    .input_out   (unused_in11),\n    .psum_out    (psum_out_11)\n  );\n\n  always @(*) begin\n    valid_top   = 1'b0;\n    valid_bot   = 1'b0;\n    in_top_col0 = zero_psum;\n    in_top_col1 = zero_psum;\n    in_bot_col0 = zero_psum;\n    in_bot_col1 = zero_psum;\n\n    if (state == S_RUN) begin\n      case (phase)\n        2'd0: begin\n          valid_top   = 1'b1;\n          in_top_col0 = x0;\n          in_top_col1 = x0;\n        end\n        2'd1: begin\n          valid_bot   = 1'b1;\n          in_bot_col0 = x1;\n          in_bot_col1 = x1;\n        end\n        default: begin\n          valid_top   = 1'b0;\n          valid_bot   = 1'b0;\n        end\n      endcase\n    end\n  end\n\n  always @(posedge clk or posedge reset) begin\n    if (reset) begin\n      state <= S_IDLE;\n      phase <= 2'd0;\n      y0    <= zero_psum;\n      y1    <= zero_psum;\n      done  <= 1'b0;\n    end else begin\n      case (state)\n        S_IDLE: begin\n          done  <= 1'b0;\n          phase <= 2'd0;\n          if (start)\n            state <= S_RUN;\n        end\n\n        S_RUN: begin\n          case (phase)\n            2'd0: phase <= 2'd1;\n            2'd1: phase <= 2'd2;\n            2'd2: begin\n              y0   <= psum_out_10;\n              y1   <= psum_out_11;\n              done <= 1'b1;\n              state <= S_DONE;\