Sending keys: ["cat > rtl/bcd_adder.sv <<'EOF'\nmodule bcd_adder(\n    input  [3:0] a,\n    input  [3:0] b,\n    input        cin,\n    output [3:0] sum,\n    output       cout\n);\n\nwire [3:0] binary_sum;\nwire       binary_cout;\nwire       correction;\nwire       unused_carry;\n\nfour_bit_adder adder1(\n    .a(a),\n    .b(b),\n    .cin(cin),\n    .sum(binary_sum),\n    .cout(binary_cout)\n);\n\nassign correction = binary_cout | (binary_sum[3] & binary_sum[2]) | (binary_sum[3] & binary_sum[1]);\nassign cout = correction;\n\nfour_bit_adder adder2(\n    .a(binary_sum),\n    .b(correction ? 4'b0110 : 4'b0000),\n    .cin(1'b0),\n    .sum(sum),\n    .cout(unused_carry)\n);\n\nendmodule\n\nmodule multi_digit_bcd_add_sub #(parameter N = 4)(\n    input  [4*N-1:0] A,\n    input  [4*N-1:0] B,\n    input            add_sub,\n    output [4*N-1:0] result,\n    output           carry_borrow\n);\n\nwire [N:0] carry;\nassign carry[0] = add_sub ? 1'b0 : 1'b1;\nassign carry_borrow = carry[N];\n\ngenvar i;\ngenerate\n    for (i = 0; i < N; i = i + 1) begin : digit_ops\n        wire [3:0] b_digit;\n        wire [3:0] b_operand;\n\n        assign b_digit = B[(4*i)+3 -: 4];\n        assign b_operand = add_sub ? b_digit : (4'd9 - b_digit);\n\n        bcd_adder digit_adder(\n            .a(A[(4*i)+3 -: 4]),\n            .b(b_operand),\n            .cin(carry[i]),\n            .sum(result[(4*i)+3 -: 4]),\n            .cout(carry[i+1])\n        );\n    end\nendgenerate\n\nendmodule\n\nmodule bcd_top #(parameter N = 4)(\n    input  [4*N-1:0] A,\n    input  [4*N-1:0] B,\n    output           A_less_B,\n    output           A_equal_B,\n    output           A_greater_B\n);\n\nwire [4*N-1:0] diff;\nwire           no_borrow;\n\nmulti_digit_bcd_add_sub #(N) cmp_subtractor (\n    .A(A),\n    .B(B),\n    .add_sub(1'b0),\n    .result(diff),\n    .carry_borrow(no_borrow)\n);\n\nassign A_equal_B   = no_borrow & (diff == {4*N{1'b0}});\nassign A_greater_B = no_borrow & (diff != {4*N{1'b0}});\nassign A_less_B    = ~no_borrow;\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
