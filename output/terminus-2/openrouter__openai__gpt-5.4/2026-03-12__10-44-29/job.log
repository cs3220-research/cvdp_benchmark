     entered_password <= {PASS_W{1'b0}};\n            digit_count      <= {COUNT_W{1'b0}};\n            fail_count       <= {FAIL_W{1'b0}};\n            door_unlock      <= 1'b0;\n            lockout          <= 1'b0;\n        end else begin\n            case (state)\n                LOCKED_OUT: begin\n                    lockout <= 1'b1;\n                    if (admin_override) begin\n                        state            <= PASSWORD_OK;\n                        door_unlock      <= 1'b1;\n                        lockout          <= 1'b0;\n                        fail_count       <= {FAIL_W{1'b0}};\n                        entered_password <= {PASS_W{1'b0}};\n                        digit_count      <= {COUNT_W{1'b0}};\n                    end\n                end\n\n                ADMIN_MODE: begin\n                    if (new_password_valid) begin\n                        stored_password  <= new_password;\n                        entered_password <= {PASS_W{1'b0}};\n                        digit_count      <= {COUNT_W{1'b0}};\n                        state            <= IDLE;\n                    end\n                    if (admin_override) begin\n                        fail_count <= {FAIL_W{1'b0}};\n                        lockout    <= 1'b0;\n                    end\n                end\n\n                default: begin\n                    if (admin_override) begin\n                        fail_count  <= {FAIL_W{1'b0}};\n                        lockout     <= 1'b0;\n                        if (admin_set_mode) begin\n                            state            <= ADMIN_MODE;\n                            entered_password <= {PASS_W{1'b0}};\n                            digit_count      <= {COUNT_W{1'b0}};\n                        end else begin\n                            state       <= PASSWORD_OK;\n                            door_unlock <= 1'b1;\n                        end\n                    end else if (confirm) begin\n                        state            <= CHECK_PASS;\n                        entered_password <= {PASS_W{1'b0}};\n                        digit_count      <= {COUNT_W{1'b0}};\n\n                        if (digit_count == PASSWORD_LENGTH && entered_password == stored_password) begin\n                            state       <= PASSWORD_OK;\n                            door_unlock <= 1'b1;\n                            fail_count  <= {FAIL_W{1'b0}};\n                            lockout     <= 1'b0;\n                        end else begin\n                            state       <= PASSWORD_FAIL;\n                            door_unlock <= 1'b0;\n                            if (fail_count + 1 >= MAX_TRIALS) begin\n                                fail_count <= fail_count + 1'b1;\n                                lockout    <= 1'b1;\n                                state      <= LOCKED_OUT;\n                            end else begin\n                                fail_count <= fail_count + 1'b1;\n                            end\n                        end\n                    end else if (key_valid && (key_input <= 4'd9) && !lockout) begin\n                        state <= ENTER_PASS;\n                        if (digit_count < PASSWORD_LENGTH) begin\n                            entered_password <= append_digit(entered_password, key_input);\n                            digit_count      <= digit_count + 1'b1;\n                        end\n                    end else if (state == PASSWORD_OK || state == PASSWORD_FAIL || state == CHECK_PASS) begin\n                        state <= IDLE;\n                    end\n                end\n            endcase\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
