tatus <= DOOR_OPEN;\n                    pending_requests[current_floor_reg] <= 1'b0;\n                    if (emergency_stop) begin\n                        state <= EMERGENCY_HALT;\n                        system_status <= EMERGENCY_HALT;\n                    end else if (overload) begin\n                        state <= DOOR_OPEN;\n                        system_status <= DOOR_OPEN;\n                        door_counter <= DOOR_OPEN_CYCLES;\n                    end else if (door_counter > 0) begin\n                        door_counter <= door_counter - 1'b1;\n                    end else if (has_above) begin\n                        state <= MOVING_UP;\n                        system_status <= MOVING_UP;\n                    end else if (has_below) begin\n                        state <= MOVING_DOWN;\n                        system_status <= MOVING_DOWN;\n                    end else begin\n                        state <= IDLE;\n                        system_status <= IDLE;\n                    end\n                end\n\n                EMERGENCY_HALT: begin\n                    system_status <= EMERGENCY_HALT;\n                    if (!emergency_stop) begin\n                        if (overload) begin\n                            state <= DOOR_OPEN;\n                            system_status <= DOOR_OPEN;\n                            door_counter <= DOOR_OPEN_CYCLES;\n                        end else begin\n                            state <= IDLE;\n                            system_status <= IDLE;\n                        end\n                    end\n                end\n\n                default: begin\n                    state <= IDLE;\n                    system_status <= IDLE;\n                end\n            endcase\n        end\n    end\n\n    always_comb begin\n        door_open = (state == DOOR_OPEN) || overload;\n        up_led = (state == MOVING_UP);\n        down_led = (state == MOVING_DOWN);\n        overload_led = overload;\n        directi