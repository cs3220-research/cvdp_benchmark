 else begin\n            done <= 1'b0;\n            case (state)\n                IDLE: begin\n                    if (start) begin\n                        left_reg  <= data_in[31:16];\n                        right_reg <= data_in[15:0];\n                        key_reg   <= key;\n                        round_idx <= 4'd0;\n                        state     <= ROUND;\n                    end\n                end\n\n                ROUND: begin\n                    left_reg  <= next_left;\n                    right_reg <= next_right;\n                    if (round_idx == 4'd7) begin\n                        state <= FINISH;\n                    end else begin\n                        round_idx <= round_idx + 4'd1;\n                    end\n                end\n\n                FINISH: begin\n                    data_out <= {right_reg, left_reg};\n                    done     <= 1'b1;\n                    state    <= IDLE;\n                end\n\n                default: begin\n                    state <= IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
