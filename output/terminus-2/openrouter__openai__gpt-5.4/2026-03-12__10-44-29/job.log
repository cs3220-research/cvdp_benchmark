Sending keys: ["cat > src/uart_rx_to_axis.sv <<'EOF'\nmodule uart_rx_to_axis #(\n    parameter int CLK_FREQ      = 100,\n    parameter int BIT_RATE      = 115200,\n    parameter int BIT_PER_WORD  = 8,\n    parameter int PARITY_BIT    = 0,\n    parameter int STOP_BITS_NUM = 1\n) (\n    input  logic                    aclk,\n    input  logic                    aresetn,\n    input  logic                    RX,\n    output logic [BIT_PER_WORD-1:0] tdata,\n    output logic                    tuser,\n    output logic                    tvalid\n);\n\n    localparam int CYCLES_PER_PERIOD = (CLK_FREQ * 1000000) / BIT_RATE;\n    localparam int HALF_PERIOD       = CYCLES_PER_PERIOD / 2;\n    localparam int CLK_CNT_W         = (CYCLES_PER_PERIOD > 1) ? $clog2(CYCLES_PER_PERIOD) : 1;\n    localparam int BIT_CNT_W         = (BIT_PER_WORD > 1) ? $clog2(BIT_PER_WORD) : 1;\n\n    typedef enum logic [2:0] {\n        IDLE    = 3'd0,\n        START   = 3'd1,\n        DATA    = 3'd2,\n        PARITY  = 3'd3,\n        STOP1   = 3'd4,\n        STOP2   = 3'd5,\n        OUT_RDY = 3'd6\n    } state_t;\n\n    state_t state;\n\n    logic [CLK_CNT_W-1:0]         clk_count;\n    logic [BIT_CNT_W-1:0]         bit_count;\n    logic [BIT_PER_WORD-1:0]      data_shift_reg;\n    logic                         parity_error;\n    logic                         frame_error;\n    logic                         rx_d;\n    logic                         start_fall;\n    logic                         parity_calc;\n\n    assign start_fall  = rx_d & ~RX;\n    assign parity_calc = ^data_shift_reg;\n\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            state          <= IDLE;\n            clk_count      <= '0;\n            bit_count      <= '0;\n            data_shift_reg <= '0;\n            parity_error   <= 1'b0;\n            frame_error    <= 1'b0;\n            tdata          <= '0;\n            tuser          <= 1'b0;\n            tvalid         <= 1'b0;\n            rx_d           <= 1'b1;\n        end else begin\n            rx_d   <= RX;\n            tvalid <= 1'b0;\n\n            case (state)\n                IDLE: begin\n                    clk_count    <= '0;\n                    bit_count    <= '0;\n                    parity_error <= 1'b0;\n                    frame_error  <= 1'b0;\n                    tuser        <= 1'b0;\n                    if (start_fall) begin\n                        state     <= START;\n                        clk_count <= '0;\n                    end\n                end\n\n                START: begin\n                    if (clk_count == HALF_PERIOD-1) begin\n                        clk_count <= '0;\n                        if (RX == 1'b0) begin\n                            state     <= DATA;\n                            bit_count <= '0;\n                        end else begin\n                            state <= IDLE;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                DATA: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count      <= '0;\n                        data_shift_reg <= {RX, data_shift_reg[BIT_PER_WORD-1:1]};\n                        if (bit_count == BIT_PER_WORD-1) begin\n                            bit_count <= '0;\n                            if (PARITY_BIT != 0)\n                                state <= PARITY;\n                            else\n                                state <= STOP1;\n                        end else begin\n                            bit_count <= bit_count + 1'b1;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                PARITY: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count <= '0;\n                        case (PARITY_BIT)\n                            1: parity_error <= (RX != ~parity_calc);\n                            2: parity_error <= (RX !=  parity_calc);\n                            default: parity_error <= 1'b0;\n                        endcase\n                        state <= STOP1;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP1: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count   <= '0;\n                        frame_error <= frame_error | (RX != 1'b1);\n                        if (STOP_BITS_NUM == 2)\n                            state <= STOP2;\n                        else\n                            state <= OUT_RDY;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP2: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count   <= '0;\n                        frame_error <= frame_error | (RX != 1'b1);\n                        state       <= OUT_RDY;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                OUT_RDY: begin\n                    tdata  <= data_shift_reg;\n                    tuser  <= parity_error | frame_error;\n                    tvalid <= 1'b1;\n                    state  <= IDLE;\n                end\n\n                default: begin\n                    state <= IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
