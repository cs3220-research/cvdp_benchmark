egin\n        integrator_next[0] = integrator_reg[0] + REG_WIDTH'(input_tdata);\n        for (int k = 1; k < N; k++) begin\n            integrator_next[k] = integrator_reg[k] + integrator_next[k-1];\n        end\n    end\n\n    always_comb begin\n        for (int k = 0; k < N; k++) begin\n            if (k == 0) begin\n                comb_in[k] = integrator_next[N-1];\n            end else begin\n                comb_in[k] = comb_next[k-1];\n            end\n            comb_next[k] = comb_in[k] - delay_reg[k][M-1];\n        end\n    end\n\n    assign output_tdata = comb_reg[N-1];\n\n    always_ff @(posedge clk) begin\n        if (rst) begin\n            cycle_reg <= '0;\n            for (i = 0; i < N; i = i + 1) begin\n                integrator_reg[i] <= '0;\n                comb_reg[i] <= '0;\n                for (j = 0; j < M; j = j + 1) begin\n                    delay_reg[i][j] <= '0;\n                end\n            end\n        end else begin\n            if (input_fire) begin\n                for (i = 0; i < N; i = i + 1) begin\n                    integrator_reg[i] <= integrator_next[i];\n                end\n\n                if (decim_point) begin\n                    if (rate_clamped > RATE_WIDTH'(1)) begin\n                        cycle_reg <= CYCLE_WIDTH'(rate_clamped - RATE_WIDTH'(1));\n                    end else begin\n                        cycle_reg <= '0;\n                    end\n                end else begin\n                    cycle_reg <= cycle_reg - CYCLE_WIDTH'(1);\n                end\n            end\n\n            if (output_fire) begin\n                for (i = 0; i < N; i = i + 1) begin\n                    comb_reg[i] <= comb_next[i];\n                    delay_reg[i][0] <= comb_in[i];\n                    for (j = 1; j < M; j = j + 1) begin\n                        delay_reg[i][j] <= delay_reg[i][j-1];\n                    end\n                end\n            end\n        end\n    end\n\nendmodule\nSV\nsed -n '1,260p' src/cic_decimator.sv\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
