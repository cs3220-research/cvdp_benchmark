Sending keys: ["cat > /code/rtl/hdbn_encoder.sv <<'SV'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n    localparam integer N = (encoder_type == 2) ? 2 : 3;\n    localparam integer PIPE_DELAY = 2*encoder_type;\n\n    logic [PIPE_DELAY-1:0] data_pipe;\n    logic                  data_d;\n    logic [N:0]            zero_cnt;\n    logic                  last_polarity;\n    logic                  pulse_pos;\n    logic                  p_int, n_int;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_pipe      <= '0;\n            zero_cnt       <= '0;\n            last_polarity  <= 1'b0;\n            p_int          <= 1'b0;\n            n_int          <= 1'b0;\n        end else if (clk_enable_in) begin\n            data_pipe <= {data_pipe[PIPE_DELAY-2:0], data_in};\n            data_d    = data_pipe[PIPE_DELAY-1];\n            p_int     <= 1'b0;\n            n_int     <= 1'b0;\n\n            if (data_d) begin\n                pulse_pos = ~last_polarity;\n                if (pulse_pos) p_int <= 1'b1; else n_int <= 1'b1;\n                last_polarity <= pulse_pos;\n                zero_cnt <= '0;\n            end else begin\n                if (zero_cnt >= N-1) begin\n                    pulse_pos = ~last_polarity;\n                    if (pulse_pos) p_int <= 1'b1; else n_int <= 1'b1;\n                    last_polarity <= pulse_pos;\n                    zero_cnt <= '0;\n                end else begin\n                    zero_cnt <= zero_cnt + 1'b1;\n                end\n            end\n        end\n    end\n\n    always_comb begin\n        p_out = (output_gate_in && p_int) ? pulse_active_state : ~pulse_active_state;\n        n_out = (output_gate_in && n_int) ? pulse_active_state : ~pulse_active_state;\n    end\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
