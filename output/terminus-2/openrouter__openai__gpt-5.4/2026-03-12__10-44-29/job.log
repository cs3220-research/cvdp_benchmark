Sending keys: ['cat > rtl/barrel_shifter.sv <<\'EOF\'\nmodule barrel_shifter (\n    input  [7:0] data_in,\n    input  [2:0] shift_bits,\n    input        left_right,\n    input        shift_mode,\n    output reg [7:0] data_out\n);\n\n    always @(*) begin\n        if (left_right) begin\n            data_out = data_in << shift_bits;\n        end else if (shift_mode) begin\n            data_out = $signed(data_in) >>> shift_bits;\n        end else begin\n            data_out = data_in >> shift_bits;\n        end\n    end\n\nendmodule\nEOF\n\ncat > verif/barrel_shifter_tb.sv <<\'EOF\'\n`timescale 1ns / 1ps\n\nmodule barrel_shifter_tb;\n\n    // Testbench Signals\n    reg [7:0] data_in;\n    reg [2:0] shift_bits;\n    reg left_right;\n    reg shift_mode;\n    wire [7:0] data_out;\n\n    // Instantiate the DUT (Device Under Test)\n    barrel_shifter uut (\n        .data_in(data_in),\n        .shift_bits(shift_bits),\n        .left_right(left_right),\n        .shift_mode(shift_mode),\n        .data_out(data_out)\n    );\n\n    // Task to calculate expected output for comparison\n    function [7:0] expected_output(\n        input [7:0] data_in,\n        input [2:0] shift_bits,\n        input left_right,\n        input shift_mode\n    );\n        begin\n            if (left_right)\n                expected_output = (data_in << shift_bits) & 8\'hFF;\n            else if (shift_mode)\n                expected_output = $signed(data_in) >>> shift_bits;\n            else\n                expected_output = (data_in >> shift_bits) & 8\'hFF;\n        end\n    endfunction\n\n    // Test procedure\n    initial begin\n        integer i;\n        reg [7:0] expected;\n\n        $display("Starting Testbench for barrel_shifter_8bit...");\n        $display("----------------------------------------------------------------");\n        $display("|  Data_in  | Shift | Left/Right | Shift Mode |  Output  | Expected |");\n        $display("----------------------------------------------------------------");\n\n        for (i = 0; i < 100; i = i + 1) begin\n            data_in = $random % 256;\n            shift_bits = $random % 8;\n            left_right = $random % 2;\n            shift_mode = $random % 2;\n\n            expected = expected_output(data_in, shift_bits, left_right, shift_mode);\n\n            #5;\n\n            $display("| %b |   %0d   |     %0d      |     %0d      | %b | %b |",\n                data_in, shift_bits, left_right, shift_mode, data_out, expected);\n\n            if (data_out !== expected) begin\n                $display("Test failed for data_in=%b, shift_bits=%0d, left_right=%0d, shift_mode=%0d. Expected=%b, Got=%b",\n                    data_in, shift_bits, left_right, shift_mode, expected, data_out);\n                $fatal;\n            end\n        end\n\n        $display("All tests passed!");\n        $finish;\n    end\nendmodule\nEOF\n\nsed -n \'1,220p\' rtl/barrel_shifter.sv\nprintf \'\\n==== UPDATED TB ====\\n\'\nsed -n \'1,260p\' verif/barrel_shifter_tb.sv\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
