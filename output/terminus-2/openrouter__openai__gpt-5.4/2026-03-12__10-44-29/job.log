eg current_floor_requested;\n    integer i;\n\n    assign current_floor = current_floor_reg;\n\n    always_comb begin\n        highest_request = {FLOOR_W{1'b0}};\n        lowest_request = N - 1;\n        has_any_request = 1'b0;\n        has_request_above = 1'b0;\n        has_request_below = 1'b0;\n        current_floor_requested = pending_requests[current_floor_reg];\n\n        for (i = 0; i < N; i = i + 1) begin\n            if (pending_requests[i]) begin\n                has_any_request = 1'b1;\n                if (i[FLOOR_W-1:0] > highest_request)\n                    highest_request = i[FLOOR_W-1:0];\n                if (i[FLOOR_W-1:0] < lowest_request)\n                    lowest_request = i[FLOOR_W-1:0];\n                if (i[FLOOR_W-1:0] > current_floor_reg)\n                    has_request_above = 1'b1;\n                if (i[FLOOR_W-1:0] < current_floor_reg)\n                    has_request_below = 1'b1;\n            end\n        end\n    end\n\n    always_comb begin\n        next_state = state;\n        current_floor_next = current_floor_reg;\n        pending_requests_next = pending_requests | call_requests;\n        door_open_counter_next = door_open_counter;\n\n        if (state == DOOR_OPEN)\n            pending_requests_next[current_floor_reg] = 1'b0;\n\n        case (state)\n            IDLE: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if ((pending_requests | call_requests)[current_floor_reg]) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                    pending_requests_next[current_floor_reg] = 1'b0;\n                end else if (has_request_above) begin\n                    next_state = MOVING_UP;\n                end else if (has_request_below) begin\n                    next_state = MOVING_DOWN;\n                end\n            end\n\n            MOVING_UP: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (current_floor_reg < N-1) begin\n                    current_floor_next = current_floor_reg + 1'b1;\n                    if (pending_requests_next[current_floor_reg + 1'b1]) begin\n                        next_state = DOOR_OPEN;\n                        door_open_counter_next = DOOR_OPEN_CYCLES;\n                    end else if ((current_floor_reg + 1'b1) >= highest_request) begin\n                        next_state = IDLE;\n                    end else begin\n                        next_state = MOVING_UP;\n                    end\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            MOVING_DOWN: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (current_floor_reg > 0) begin\n                    current_floor_next = current_floor_reg - 1'b1;\n                    if (pending_requests_next[current_floor_reg - 1'b1]) begin\n                        next_state = DOOR_OPEN;\n                        door_open_counter_next = DOOR_OPEN_CYCLES;\n                    end else if ((current_floor_reg - 1'b1) <= lowest_request) begin\n                        next_state = IDLE;\n                    end else begin\n                        next_state = MOVING_DOWN;\n                    end\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            EMERGENCY_HALT: begin\n                if (!emergency_stop)\n                    next_state = IDLE;\n            end\n\n            DOOR_OPEN: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (door_open_counter > 0) begin\n                    door_open_counter_next = door_open_counter - 1'b1;\n                    next_state = DOOR_OPEN;\n                end else if (has_request_above) begin\n                    next_state = MOVING_UP;\n                end else if (has_request_below) begin\n                    next_state = MOVING_DOWN;\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            default: begin\n                next_state = IDLE;\n            end\n        endcase\n    end\n\n    always_ff @(posedge clk or posedge reset) begin\n        if (reset) begin\n            state <= IDLE;\n            system_status <= IDLE;\n            current_floor_reg <= {FLOOR_W{1'b0}};\n            pending_requests <= {N{1'b0}};\n            door_open_counter <= {DOOR_CNT_W{1'b0}};\n        end else begin\n            state <= next_state;\n            system_status <= next_state;\n            current_floor_reg <= current_floor_next;\n            pending_requests <= pending_requests_next;\n            door_open_counter <= door_open_counter_next;\n        end\n    end\n\n    always_comb begin\n        door_open = (state == DOOR_OPEN) || (next_state == DOOR_OPEN);\n\n        if (state == MOVING_DOWN)\n            direction = 1'b0;\n        else\n            direction = 1'b1;\n\n        up_led = (state == MOVING_UP) || (next_state == MOVING_UP);\n        down_led = (state == MOVING_DOWN) || (next_state == MOVING_DOWN);\n        overload_led = overload;\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
