Sending keys: ["python3 - <<'PY'\nfrom pathlib import Path\nPath('rtl/ethernet_fifo_cdc.sv').write_text('''module ethernet_fifo_cdc #(\\n    parameter WIDTH = 38,\\n    parameter DEPTH = 512,\\n    parameter ADDR_WIDTH = $clog2(DEPTH)\\n) (\\n    input                   wr_clk_i,\\n    input                   wr_rst_i,\\n    input                   wr_push_i,\\n    input  [WIDTH-1:0]      wr_data_i,\\n    output                  wr_full_o,\\n\\n    input                   rd_clk_i,\\n    input                   rd_rst_i,\\n    input                   rd_pop_i,\\n    output [WIDTH-1:0]      rd_data_o,\\n    output                  rd_empty_o\\n);\\n\\n    reg [WIDTH-1:0] mem [0:DEPTH-1];\\n    integer i;\\n\\n    reg  [ADDR_WIDTH:0] wr_bin_q, wr_ptr_q;\\n    reg  [ADDR_WIDTH:0] rd_bin_q, rd_ptr_q;\\n\\n    wire [ADDR_WIDTH:0] wr_bin_next_w;\\n    wire [ADDR_WIDTH:0] rd_bin_next_w;\\n    wire [ADDR_WIDTH:0] wr_ptr_next_w;\\n    wire [ADDR_WIDTH:0] rd_ptr_next_w;\\n\\n    wire [ADDR_WIDTH-1:0] wr_addr_w;\\n    wire [ADDR_WIDTH-1:0] rd_addr_w;\\n\\n    reg [WIDTH-1:0] rd_data_r;\\n    assign rd_data_o = rd_data_r;\\n\\n    reg [ADDR_WIDTH:0] wr_ptr_rdclk_1, wr_ptr_rdclk_2;\\n    reg [ADDR_WIDTH:0] rd_ptr_wrclk_1, rd_ptr_wrclk_2;\\n\\n    assign wr_addr_w = wr_bin_q[ADDR_WIDTH-1:0];\\n    assign rd_addr_w = rd_bin_q[ADDR_WIDTH-1:0];\\n\\n    assign wr_bin_next_w = wr_bin_q + ((wr_push_i && !wr_full_o) ? 1'b1 : 1'b0);\\n    assign rd_bin_next_w = rd_bin_q + ((rd_pop_i && !rd_empty_o) ? 1'b1 : 1'b0);\\n\\n    assign wr_ptr_next_w = (wr_bin_next_w >> 1) ^ wr_bin_next_w;\\n    assign rd_ptr_next_w = (rd_bin_next_w >> 1) ^ rd_bin_next_w;\\n\\n    always @(posedge wr_clk_i or posedge wr_rst_i) begin\\n        if (wr_rst_i) begin\\n            wr_bin_q <= 0;\\n            wr_ptr_q <= 0;\\n            for (i = 0; i < DEPTH; i = i + 1)\\n                mem[i] <= {WIDTH{1'b0}};\\n        end else begin\\n            if (wr_push_i && !wr_full_o) begin\\n                mem[wr_addr_w] <= wr_data_i;\\n                wr_bin_q <= wr_bin_next_w;\\n                wr_ptr_q <= wr_ptr_next_w;\\n            end\\n        end\\n    end\\n\\n    always @(posedge rd_clk_i or posedge rd_rst_i) begin\\n        if (rd_rst_i) begin\\n            rd_bin_q  <= 0;\\n            rd_ptr_q  <= 0;\\n            rd_data_r <= 0;\\n        end else begin\\n            if (rd_pop_i && !rd_empty_o) begin\\n                rd_data_r <= mem[rd_addr_w];\\n                rd_bin_q  <= rd_bin_next_w;\\n                rd_ptr_q  <= rd_ptr_next_w;\\n            end\\n        end\\n    end\\n\\n    always @(posedge rd_clk_i or posedge rd_rst_i) begin\\n        if (rd_rst_i) begin\\n            wr_ptr_rdclk_1 <= 0;\\n            wr_ptr_rdclk_2 <= 0;\\n        end else begin\\n            wr_ptr_rdclk_1 <= wr_ptr_q;\\n            wr_ptr_rdclk_2 <= wr_ptr_rdclk_1;\\n        end\\n    end\\n\\n    always @(posedge wr_clk_i or posedge wr_rst_i) begin\\n        if (wr_rst_i) begin\\n            rd_ptr_wrclk_1 <= 0;\\n            rd_ptr_wrclk_2 <= 0;\\n        end else begin\\n            rd_ptr_wrclk_1 <= rd_ptr_q;\\n            rd_ptr_wrclk_2 <= rd_ptr_wrclk_1;\\n        end\\n    end\\n\\n    assign wr_full_o  = (wr_ptr_next_w == {~rd_ptr_wrclk_2[ADDR_WIDTH:ADDR_WIDTH-1], rd_ptr_wrclk_2[ADDR_WIDTH-2:0]});\\n    assign rd_empty_o = (rd_ptr_q == wr_ptr_rdclk_2);\\n\\nendmodule\\n''')\nPY\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
