\n                if (clk_count_done && bit_count_done) begin\n                    if (PARITY_BIT == 0)\n                        next_state = STOP1;\n                    else\n                        next_state = PARITY;\n                end\n            end\n            PARITY: begin\n                if (clk_count_done)\n                    next_state = STOP1;\n            end\n            STOP1: begin\n                if (clk_count_done) begin\n                    if (STOP_BITS_NUM == 2)\n                        next_state = STOP2;\n                    else\n                        next_state = IDLE;\n                end\n            end\n            STOP2: begin\n                if (clk_count_done)\n                    next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            state     <= IDLE;\n            data_reg  <= '0;\n            clk_count <= '0;\n            bit_count <= '0;\n            TX        <= 1'b1;\n        end else begin\n            state <= next_state;\n\n            if ((state == IDLE && tvalid) || (state != next_state))\n                clk_count <= '0;\n            else if (state != IDLE) begin\n                if (clk_count_done)\n                    clk_count <= '0;\n                else\n                    clk_count <= clk_count + 1'b1;\n            end else begin\n                clk_count <= '0;\n            end\n\n            if (state == IDLE && tvalid)\n                data_reg <= tdata;\n\n            if (state == IDLE) begin\n                bit_count <= '0;\n            end else if (state == START) begin\n                bit_count <= '0;\n            end else if (state == DATA && clk_count_done) begin\n                if (bit_count_done)\n                    bit_count <= '0;\n                else\n                    bit_count <= bit_count + 1'b1;\n            end\n\n            case (next_state)\n                IDLE:   TX <= 1'b1;\n                START:  TX <= 1'b0;\n                DATA:   TX <= data_reg[bit_count];\n                PARITY: TX <= parity_value;\n                STOP1:  TX <= 1'b1;\n                STOP2:  TX <= 1'b1;\n                default: TX <= 1'b1;\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
