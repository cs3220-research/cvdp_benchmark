Sending keys: ["cat > /code/rtl/hdbn_top.sv <<'SV'\nmodule hdbn_top #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n    localparam integer LOOP_DELAY = 6 + 2*encoder_type;\n    localparam integer EXT_DELAY  = 5;\n\n    logic dec_data_out;\n    logic dec_code_error_out;\n    logic [LOOP_DELAY-1:0] loop_pipe;\n    logic [EXT_DELAY-1:0]  ext_pipe;\n    logic p_out_d, n_out_d;\n    logic loopback_mode;\n    logic p_act, n_act;\n\n    hdbn_encoder #(\n        .encoder_type(encoder_type),\n        .pulse_active_state(pulse_active_state)\n    ) u_encoder (\n        .reset_in(reset_in),\n        .clk_in(clk_in),\n        .clk_enable_in(clk_enable_in),\n        .data_in(data_in),\n        .output_gate_in(output_gate_in),\n        .p_out(p_out),\n        .n_out(n_out)\n    );\n\n    hdbn_decoder #(\n        .encoder_type(encoder_type),\n        .pulse_active_state(pulse_active_state)\n    ) u_decoder (\n        .reset_in(reset_in),\n        .clk_in(clk_in),\n        .clk_enable_in(clk_enable_in),\n        .p_in(p_in),\n        .n_in(n_in),\n        .data_out(dec_data_out),\n        .code_error_out(dec_code_error_out)\n    );\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            loop_pipe <= '0;\n            ext_pipe  <= '0;\n            p_out_d   <= ~pulse_active_state;\n            n_out_d   <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            p_act     <= (p_in == pulse_active_state);\n            n_act     <= (n_in == pulse_active_state);\n            loop_pipe <= {loop_pipe[LOOP_DELAY-2:0], data_in};\n            ext_pipe  <= {ext_pipe[EXT_DELAY-2:0], (p_in == pulse_active_state) || (n_in == pulse_active_state)};\n            p_out_d   <= p_out;\n            n_out_d   <= n_out;\n        end\n    end\n\n    always_comb begin\n        loopback_mode = (p_in == p_out_d) && (n_in == n_out_d);\n        if (loopback_mode) begin\n            data_out       = loop_pipe[LOOP_DELAY-1];\n            code_error_out = dec_code_error_out;\n        end else begin\n            data_out       = ext_pipe[EXT_DELAY-1];\n            code_error_out = dec_code_error_out;\n        end\n    end\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
