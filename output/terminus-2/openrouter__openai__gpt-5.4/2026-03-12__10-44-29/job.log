'0;\n                        pending_valid <= 1'b1;\n                        pending_count <= N;\n                        if (encoder_type == 2) begin\n                            pending_sym <= SYM_BAL;\n                        end else begin\n                            hdb3_use_b00v <= ones_parity;\n                            pending_sym   <= ones_parity ? SYM_BAL : SYM_ZERO;\n                        end\n                    end else begin\n                        zero_cnt <= zero_cnt + 1'b1;\n                    end\n                end\n            end\n        end\n    end\n\n    always_comb begin\n        p_out = (output_gate_in && p_int) ? pulse_active_state : ~pulse_active_state;\n        n_out = (output_gate_in && n_int) ? pulse_active_state : ~pulse_active_state;\n    end\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ["cat > rtl/hdbn_decoder.sv <<'SV'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n    localparam integer N = (encoder_type == 2) ? 2 : 3;\n    localparam integer DELAY = 6 + 2*encoder_type;\n\n    logic [DELAY-1:0] data_pipe;\n    logic [N:0]       zero_count;\n    logic             last_mark_valid;\n    logic             last_mark_polarity;\n\n    logic p_act;\n    logic n_act;\n    logic current_polarity;\n    logic decoded_now;\n    logic error_now;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_pipe          <= '0;\n            zero_count         <= '0;\n            last_mark_valid    <= 1'b0;\n            last_mark_polarity <= 1'b0;\n            data_out           <= 1'b0;\n            code_error_out     <= 1'b0;\n        end else if (clk_enable_in) begin\n            p_act      = (p_in == pulse_active_state);\n            n_act      = (n_in == pulse_active_state);\n            decoded_now = 1'b0;\n            error_now   = 1'b0;\n\n            if (p_act && n_act) begin\n                error_now   = 1'b1;\n                decoded_now = 1'b0;\n            end else if (p_act || n_act) begin\n                current_polarity = p_act;\n                if (last_mark_valid && (current_polarity == last_mark_polarity)) begin\n                    if (zero_count != N) begin\n                        error_now = 1'b1;\n                    end\n                    decoded_now = 1'b0;\n                end else begin\n                    decoded_now = 1'b1;\n                end\n                last_mark_valid    <= 1'b1;\n                last_mark_polarity <= current_polarity;\n                zero_count         <= '0;\n            