gin\n            p_act = (p_in == pulse_active_state);\n            n_act = (n_in == pulse_active_state);\n            decoded_now = 1'b0;\n            error_now   = 1'b0;\n\n            if (p_act && n_act) begin\n                error_now = 1'b1;\n                decoded_now = 1'b0;\n            end else if (p_act || n_act) begin\n                current_polarity = p_act;\n                if (last_mark_valid && (current_polarity == last_mark_polarity)) begin\n                    if (zero_count != N) begin\n                        error_now = 1'b1;\n                    end\n                    decoded_now = 1'b0;\n                end else begin\n                    decoded_now = 1'b1;\n                end\n                last_mark_valid    <= 1'b1;\n                last_mark_polarity <= current_polarity;\n                zero_count         <= '0;\n            end else begin\n                decoded_now = 1'b0;\n                if (zero_count == N) begin\n                    error_now = 1'b1;\n                    zero_count <= zero_count;\n                end else begin\n                    zero_count <= zero_count + 1'b1;\n                end\n            end\n\n            data_pipe      <= {data_pipe[DELAY-2:0], decoded_now};\n            data_out       <= data_pipe[DELAY-1];\n            code_error_out <= error_now;\n        end\n    end\nendmodule\n\nmodule hdbn_top #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n    hdbn_encoder #(\n        .encoder_type(encoder_type),\n        .pulse_active_state(pulse_active_state)\n    ) u_encoder (\n        .reset_in(reset_in),\n        .clk_in(clk_in),\n        .clk_