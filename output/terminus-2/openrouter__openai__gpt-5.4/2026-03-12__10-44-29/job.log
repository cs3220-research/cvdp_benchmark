ck_data_d1  <= '0;\n            check_valid_d1 <= 1'b0;\n            data_out       <= '0;\n            valid_out      <= 1'b0;\n            bit_count      <= 32'd0;\n        end else begin\n            check_data_d1  <= check_data;\n            check_valid_d1 <= valid_in;\n\n            if (bypass_scrambling) begin\n                data_out  <= data_in;\n                valid_out <= valid_in;\n            end else begin\n                data_out  <= check_data_d1;\n                valid_out <= check_valid_d1;\n            end\n\n            if (valid_out)\n                bit_count <= bit_count + WIDTH;\n        end\n    end\nend\nendgenerate\n\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
