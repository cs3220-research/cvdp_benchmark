Sending keys: ["cat > /code/rtl/dig_stopwatch.sv <<'EOF'\nmodule dig_stopwatch #(\n    // Input clock frequency in Hz. A 1 Hz enable pulse is generated by\n    // counting CLK_FREQ input clock cycles.\n    parameter int unsigned CLK_FREQ = 50_000_000\n) (\n    input  logic       clk,\n    input  logic       reset,\n    input  logic       start_stop,\n    output logic [5:0] seconds,\n    output logic [5:0] minutes,\n    output logic       hour,\n    output logic       second_pulse,\n    output logic       minute_pulse,\n    output logic       hour_pulse,\n    output logic       beep\n);\n\n    // Width for the divider counter. Guard against very small CLK_FREQ values.\n    localparam int unsigned DIV_WIDTH = (CLK_FREQ <= 1) ? 1 : $clog2(CLK_FREQ);\n    localparam logic [DIV_WIDTH-1:0] COUNTER_MAX = CLK_FREQ - 1;\n\n    // Clock divider state.\n    logic [DIV_WIDTH-1:0] div_count;\n    logic                 tick_1hz;\n\n    // ------------------------------------------------------------------------\n    // 1 Hz tick generator\n    // ------------------------------------------------------------------------\n    // A single-cycle pulse is generated every CLK_FREQ clock cycles while the\n    // stopwatch is running. The divider is reset whenever the stopwatch is\n    // paused or has saturated at 1:00:00 so that resume behavior is\n    // deterministic and intuitive.\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            div_count <= '0;\n            tick_1hz  <= 1'b0;\n        end else begin\n            tick_1hz <= 1'b0;\n\n            if (!start_stop || hour) begin\n                div_count <= '0;\n            end else if (div_count == COUNTER_MAX) begin\n                div_count <= '0;\n                tick_1hz  <= 1'b1;\n            end else begin\n                div_count <= div_count + 1'b1;\n            end\n        end\n    end\n\n    // ------------------------------------------------------------------------\n    // Stopwatch counters and event pulse generation\n    // ------------------------------------------------------------------------\n    // The stopwatch tracks seconds and minutes from 00 to 59. When minutes roll\n    // over from 59 to 00, the single-bit hour indicator is asserted and the\n    // stopwatch saturates at 1:00:00.\n    //\n    // Pulse outputs are one clock cycle wide:\n    //   * second_pulse asserts on every valid 1 Hz counter update\n    //   * minute_pulse asserts whenever the minute counter changes\n    //   * hour_pulse   asserts when the hour indicator is set\n    //\n    // Beep behavior:\n    //   * asserted when hour_pulse occurs\n    //   * cleared on the next second_pulse\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds      <= 6'd0;\n            minutes      <= 6'd0;\n            hour         <= 1'b0;\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n            beep         <= 1'b0;\n        end else begin\n            // Default pulse outputs are deasserted unless an update occurs.\n            second_pulse <= 1'b0;\n            minute_pulse <= 1'b0;\n            hour_pulse   <= 1'b0;\n\n            if (tick_1hz && !hour) begin\n                second_pulse <= 1'b1;\n\n                // Clear any active beep on the next second event.\n                if (beep) begin\n                    beep <= 1'b0;\n                end\n\n                if (seconds == 6'd59) begin\n                    seconds      <= 6'd0;\n                    minute_pulse <= 1'b1;\n\n                    if (minutes == 6'd59) begin\n                        minutes    <= 6'd0;\n                        hour       <= 1'b1;\n                        hour_pulse <= 1'b1;\n                        beep       <= 1'b1;\n                    end else begin\n                        minutes <= minutes + 1'b1;\n                    end\n                end else begin\n                    seconds <= seconds + 1'b1;\n                end\n            end\n        end\n    end\n\nendmodule\nEOF\ncp /code/rtl/dig_stopwatch.sv /code/src/dig_stopwatch.sv\nsed -n '1,260p' /code/rtl/dig_stopwatch.sv\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
