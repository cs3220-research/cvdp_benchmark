   end\n    endfunction\n\n    assign valid_digit      = (key_input <= 4'd9);\n    assign password_match   = (entered_password == stored_password);\n    assign next_is_lockout  = ((fail_count + FAIL_W'(1)) >= MAX_TRIALS);\n\n    always_comb begin\n        next_state = state;\n\n        unique case (state)\n            IDLE: begin\n                if (admin_override) begin\n                    if (admin_set_mode) next_state = ADMIN_MODE;\n                    else                next_state = PASSWORD_OK;\n                end else if (key_valid && valid_digit) begin\n                    next_state = ENTER_PASS;\n                end\n            end\n\n            ENTER_PASS: begin\n                if (confirm) begin\n                    if (digit_count == PASSWORD_LENGTH) next_state = CHECK_PASS;\n                    else                                next_state = PASSWORD_FAIL;\n                end\n            end\n\n            CHECK_PASS: begin\n                if (password_match) next_state = PASSWORD_OK;\n                else                next_state = PASSWORD_FAIL;\n            end\n\n            PASSWORD_OK:   next_state = IDLE;\n            PASSWORD_FAIL: next_state = next_is_lockout ? LOCKED_OUT : IDLE;\n\n            LOCKED_OUT: begin\n                if (admin_override) next_state = PASSWORD_OK;\n            end\n\n            ADMIN_MODE: begin\n                if (new_password_valid) next_state = IDLE;\n            end\n\n            default: next_state = IDLE;\n        endcase\n    end\n\n    always_comb begin\n        entered_password_n = entered_password;\n        digit_count_n      = digit_count;\n\n        unique case (state)\n            IDLE: begin\n                entered_password_n = '0;\n                digit_count_n      = '0;\n                if (key_valid && valid_digit && !admin_override) begin\n                    entered_password_n = append_digit('0, key_input);\n                    digit_count_n      = COUNT_W'(1);\n                end\n            end\n\n            ENTER_PASS: begin\n                if (key_valid && valid_digit && (digit_count < PASSWORD_LENGTH)) begin\n                    entered_password_n = append_digit(entered_password, key_input);\n                    digit_count_n      = digit_count + COUNT_W'(1);\n                end\n            end\n\n            PASSWORD_OK,\n            PASSWORD_FAIL,\n            ADMIN_MODE: begin\n                entered_password_n = '0;\n                digit_count_n      = '0;\n            end\n\n            default: begin\n                entered_password_n = entered_password;\n                digit_count_n      = digit_count;\n            end\n        endcase\n    end\n\n    always_ff @(posedge clk) begin\n        if (srst) begin\n            state            <= IDLE;\n            stored_password  <= DEFAULT_PASSWORD;\n            entered_password <= '0;\n            digit_count      <= '0;\n            fail_count       <= '0;\n            door_unlock      <= 1'b0;\n            lockout          <= 1'b0;\n        end else begin\n            state            <= next_state;\n            entered_password <= entered_password_n;\n            digit_count      <= digit_count_n;\n\n            if (state == PASSWORD_OK) begin\n                door_unlock <= 1'b1;\n                fail_count  <= '0;\n                lockout     <= 1'b0;\n            end else if (state == PASSWORD_FAIL) begin\n                door_unlock <= 1'b0;\n                fail_count  <= fail_count + FAIL_W'(1);\n                if (next_is_lockout) lockout <= 1'b1;\n            end else if (state == LOCKED_OUT) begin\n                lockout <= 1'b1;\n                if (admin_override) begin\n                    door_unlock <= 1'b1;\n                    fail_count  <= '0;\n                    lockout     <= 1'b0;\n                end\n            end else if (state == ADMIN_MODE) begin\n                if (new_password_valid) stored_password <= new_password;\n                if (ad