Sending keys: ["cat > rtl/elevator_control_system.sv <<'EOF'\n/*\n * Elevator Control System\n *\n * FSM-based elevator controller with support for multiple floors,\n * floor request handling, emergency stop, overload protection,\n * automatic door timing, and direction/overload LED indicators.\n */\nmodule elevator_control_system #(\n    parameter N = 8,\n    parameter DOOR_OPEN_TIME_MS = 500\n) (\n    input  wire                    clk,\n    input  wire                    reset,\n    input  wire [N-1:0]            call_requests,\n    input  wire                    emergency_stop,\n    input  wire                    overload,\n    output wire [$clog2(N)-1:0]    current_floor,\n    output reg                     direction,\n    output reg                     door_open,\n    output reg [2:0]               system_status,\n    output reg                     up_led,\n    output reg                     down_led,\n    output reg                     overload_led\n);\n\n    typedef enum logic [2:0] {\n        IDLE           = 3'b000,\n        MOVING_UP      = 3'b001,\n        MOVING_DOWN    = 3'b010,\n        EMERGENCY_HALT = 3'b011,\n        DOOR_OPEN      = 3'b100\n    } state_t;\n\n    localparam integer FLOOR_W = (N <= 2) ? 1 : $clog2(N);\n`ifdef SIMULATION\n    localparam integer DOOR_OPEN_CYCLES = 5;\n`else\n    localparam integer DOOR_OPEN_CYCLES = DOOR_OPEN_TIME_MS * 100 * 1000;\n`endif\n    localparam integer DOOR_CNT_W = (DOOR_OPEN_CYCLES <= 1) ? 1 : $clog2(DOOR_OPEN_CYCLES + 1);\n\n    state_t state, next_state;\n    reg [FLOOR_W-1:0] current_floor_reg, current_floor_next;\n    reg [N-1:0] pending_requests, pending_requests_next;\n    reg [N-1:0] requests_view;\n    reg [DOOR_CNT_W-1:0] door_open_counter, door_open_counter_next;\n\n    reg [FLOOR_W-1:0] highest_request;\n    reg [FLOOR_W-1:0] lowest_request;\n    reg has_request_above;\n    reg has_request_below;\n    integer i;\n\n    assign current_floor = current_floor_reg;\n\n    always_comb begin\n        requests_view = pending_requests | call_requests;\n        if (state == DOOR_OPEN)\n            requests_view[current_floor_reg] = 1'b0;\n\n        highest_request = {FLOOR_W{1'b0}};\n        lowest_request = N - 1;\n        has_request_above = 1'b0;\n        has_request_below = 1'b0;\n\n        for (i = 0; i < N; i = i + 1) begin\n            if (requests_view[i]) begin\n                if (i[FLOOR_W-1:0] > highest_request)\n                    highest_request = i[FLOOR_W-1:0];\n                if (i[FLOOR_W-1:0] < lowest_request)\n                    lowest_request = i[FLOOR_W-1:0];\n                if (i[FLOOR_W-1:0] > current_floor_reg)\n                    has_request_above = 1'b1;\n                if (i[FLOOR_W-1:0] < current_floor_reg)\n                    has_request_below = 1'b1;\n            end\n        end\n    end\n\n    always_comb begin\n        next_state = state;\n        current_floor_next = current_floor_reg;\n        pending_requests_next = pending_requests | call_requests;\n        door_open_counter_next = door_open_counter;\n\n        if (state == DOOR_OPEN)\n            pending_requests_next[current_floor_reg] = 1'b0;\n\n        case (state)\n            IDLE: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if ((pending_requests | call_requests)[current_floor_reg]) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                    pending_requests_next[current_floor_reg] = 1'b0;\n                end else if (has_request_above) begin\n                    next_state = MOVING_UP;\n                end else if (has_request_below) begin\n                    next_state = MOVING_DOWN;\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            MOVING_UP: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (current_floor_reg < N-1) begin\n                    current_floor_next = current_floor_reg + 1'b1;\n                    if (pending_requests_next[current_floor_reg + 1'b1]) begin\n                        next_state = DOOR_OPEN;\n                        door_open_counter_next = DOOR_OPEN_CYCLES;\n                    end else begin\n                        next_state = MOVING_UP;\n                    end\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            MOVING_DOWN: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (current_floor_reg > 0) begin\n                    current_floor_next = current_floor_reg - 1'b1;\n                    if (pending_requests_next[current_floor_reg - 1'b1]) begin\n                        next_state = DOOR_OPEN;\n                        door_open_counter_next = DOOR_OPEN_CYCLES;\n                    end else begin\n                        next_state = MOVING_DOWN;\n                    end\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            EMERGENCY_HALT: begin\n                if (!emergency_stop)\n                    next_state = IDLE;\n            end\n\n            DOOR_OPEN: begin\n                if (emergency_stop) begin\n                    next_state = EMERGENCY_HALT;\n                end else if (overload) begin\n                    next_state = DOOR_OPEN;\n                    door_open_counter_next = DOOR_OPEN_CYCLES;\n                end else if (door_open_counter > 0) begin\n                    door_open_counter_next = door_open_counter - 1'b1;\n                    next_state = DOOR_OPEN;\n                end else if (has_request_above) begin\n                    next_state = MOVING_UP;\n                end else if (has_request_below) begin\n                    next_state = MOVING_DOWN;\n                end else begin\n                    next_state = IDLE;\n                end\n            end\n\n            default: next_state = IDLE;\n        endcase\n    end\n\n    always_ff @(posedge clk or posedge reset) begin\n        if (reset) begin\n            state <= IDLE;\n            system_status <= IDLE;\n            current_floor_reg <= {FLOOR_W{1'b0}};\n            pending_requests <= {N{1'b0}};\n            door_open_counter <= {DOOR_CNT_W{1'b0}};\n        end else begin\n            state <= next_state;\n            system_status <= next_state;\n            current_floor_reg <= current_floor_next;\n            pending_requests <= pending_requests_next;\n            door_open_counter <= door_open_counter_next;\n        end\n    end\n\n    always_comb begin\n        door_open = (state == DOOR_OPEN);\n        direction = (state == MOVING_DOWN) ? 1'b0 : 1'b1;\n        up_led = (state == MOVING_UP);\n        down_led = (state == MOVING_DOWN);\n        overload_led = overload;\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
