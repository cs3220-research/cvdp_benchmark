      STOP1: begin\n                    TX <= 1'b1;\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count <= '0;\n                        if (STOP_BITS_NUM == 2) begin\n                            state <= STOP2;\n                            TX    <= 1'b1;\n                        end else begin\n                            state <= IDLE;\n                            TX    <= 1'b1;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP2: begin\n                    TX <= 1'b1;\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        state     <= IDLE;\n                        clk_count <= '0;\n                        TX        <= 1'b1;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                default: begin\n                    state     <= IDLE;\n                    data_reg  <= '0;\n                    clk_count <= '0;\n                    bit_count <= '0;\n                    TX        <= 1'b1;\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
