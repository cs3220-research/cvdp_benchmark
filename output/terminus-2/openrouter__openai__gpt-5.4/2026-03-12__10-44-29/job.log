Sending keys: ["cat > /code/rtl/swizzler_supervisor.sv <<'EOF'\nmodule swizzler_supervisor #(\n  parameter integer NUM_LANES           = 4,\n  parameter integer DATA_WIDTH          = 8,\n  parameter integer REGISTER_OUTPUT     = 1,\n  parameter integer ENABLE_PARITY_CHECK = 1,\n  parameter integer OP_MODE_WIDTH       = 2,\n  parameter integer SWIZZLE_MAP_WIDTH   = $clog2(NUM_LANES)+1,\n  parameter [DATA_WIDTH-1:0] EXPECTED_CHECKSUM = 8'hA5\n)(\n  input  wire                             clk,\n  input  wire                             rst_n,\n  input  wire                             bypass,\n  input  wire [NUM_LANES*DATA_WIDTH-1:0]  data_in,\n  input  wire [NUM_LANES*SWIZZLE_MAP_WIDTH-1:0] swizzle_map_flat,\n  input  wire [OP_MODE_WIDTH-1:0]         operation_mode,\n  output reg  [NUM_LANES*DATA_WIDTH-1:0]  final_data_out,\n  output reg                              top_error\n);\n\n  // Internal lane views used for simple pre/post-processing.\n  wire [DATA_WIDTH-1:0] input_lanes     [0:NUM_LANES-1];\n  wire [DATA_WIDTH-1:0] preproc_lanes   [0:NUM_LANES-1];\n  wire [DATA_WIDTH-1:0] swizzler_lanes  [0:NUM_LANES-1];\n  wire [DATA_WIDTH-1:0] final_lanes     [0:NUM_LANES-1];\n\n  wire [NUM_LANES*DATA_WIDTH-1:0] preproc_data_flat;\n  wire [NUM_LANES*DATA_WIDTH-1:0] swizzler_data_out;\n  wire [NUM_LANES*DATA_WIDTH-1:0] final_data_comb;\n\n  wire parity_error_w;\n  wire invalid_mapping_error_w;\n  wire checksum_mismatch_w;\n\n  reg  [DATA_WIDTH-1:0] checksum_comb;\n  reg  [DATA_WIDTH-1:0] checksum_reg;\n  reg                   top_error_comb;\n\n  integer i;\n\n  // Unpack flat input into lanes.\n  genvar g;\n  generate\n    for (g = 0; g < NUM_LANES; g = g + 1) begin : GEN_INPUT_UNPACK\n      assign input_lanes[g] = data_in[g*DATA_WIDTH +: DATA_WIDTH];\n    end\n  endgenerate\n\n  // Input conditioning / formatting stage.\n  // This is intentionally a pass-through conditioning stage so the\n  // supervisor can be extended later without changing interfaces.\n  generate\n    for (g = 0; g < NUM_LANES; g = g + 1) begin : GEN_PREPROC\n      assign preproc_lanes[g] = input_lanes[g];\n      assign preproc_data_flat[g*DATA_WIDTH +: DATA_WIDTH] = preproc_lanes[g];\n    end\n  endgenerate\n\n  // Core swizzler instance.\n  swizzler #(\n    .NUM_LANES(NUM_LANES),\n    .DATA_WIDTH(DATA_WIDTH),\n    .REGISTER_OUTPUT(REGISTER_OUTPUT),\n    .ENABLE_PARITY_CHECK(ENABLE_PARITY_CHECK),\n    .OP_MODE_WIDTH(OP_MODE_WIDTH),\n    .SWIZZLE_MAP_WIDTH(SWIZZLE_MAP_WIDTH)\n  ) u_swizzler (\n    .clk(clk),\n    .rst_n(rst_n),\n    .bypass(bypass),\n    .data_in(preproc_data_flat),\n    .swizzle_map_flat(swizzle_map_flat),\n    .operation_mode(operation_mode),\n    .data_out(swizzler_data_out),\n    .parity_error(parity_error_w),\n    .invalid_mapping_error(invalid_mapping_error_w)\n  );\n\n  // Unpack swizzler output, invert the least-significant bit of each lane,\n  // and repack into the final output bus.\n  generate\n    for (g = 0; g < NUM_LANES; g = g + 1) begin : GEN_POSTPROC\n      assign swizzler_lanes[g] = swizzler_data_out[g*DATA_WIDTH +: DATA_WIDTH];\n      assign final_lanes[g]    = {swizzler_lanes[g][DATA_WIDTH-1:1], ~swizzler_lanes[g][0]};\n      assign final_data_comb[g*DATA_WIDTH +: DATA_WIDTH] = final_lanes[g];\n    end\n  endgenerate\n\n  // Compute checksum across all final lanes.\n  always @* begin\n    checksum_comb = {DATA_WIDTH{1'b0}};\n    for (i = 0; i < NUM_LANES; i = i + 1)\n      checksum_comb = checksum_comb ^ final_lanes[i];\n  end\n\n  assign checksum_mismatch_w = (checksum_comb != EXPECTED_CHECKSUM);\n\n  always @* begin\n    top_error_comb = parity_error_w | invalid_mapping_error_w | checksum_mismatch_w;\n  end\n\n  generate\n    if (REGISTER_OUTPUT) begin : GEN_REG_OUT\n      always @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n          final_data_out <= {NUM_LANES*DATA_WIDTH{1'b0}};\n          checksum_reg   <= {DATA_WIDTH{1'b0}};\n          top_error      <= 1'b0;\n        end else begin\n          final_data_out <= final_data_comb;\n          checksum_reg   <= checksum_comb;\n          top_error      <= top_error_comb;\n        end\n      end\n    end else begin : GEN_COMB_OUT\n      always @* begin\n        final_data_out = final_data_comb;\n        top_error      = top_error_comb;\n        checksum_reg   = checksum_comb;\n      end\n    end\n  endgenerate\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
