       end\n            end\n        end\n    end\nend\n\ngenerate\n    for(genvar i = 0; i < 4; i++) begin : row\n        for(genvar j = 0; j < 4; j++) begin : col\n            sbox uu_sbox0 (\n                .i_data(current_data_ff[i][j]),\n                .o_data(SubBytes[i][j])\n            );\n        end\n    end\nendgenerate\n\nalways_comb begin : cypher_logic\n    // Shift Rows\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            ShiftRows[j][i] = SubBytes[j][(i+j)%4];\n        end\n    end\n\n    // x2 and x3\n    for(int i = 0; i < 4; i++) begin\n        for(int j = 0; j < 4; j++) begin\n            xtimes02[j][i] = {ShiftRows[j][i][NBW_BYTE-2:0],1'b0}^{8'h1b&{8{ShiftRows[j][i][NBW_BYTE-1]}}};\n            xtimes03[j][i] = xtimes02[j][i]^ShiftRows[j][i];\n        end\n    end\n\n    // Mix Columns\n    for(int i = 0; i < 4; i++) begin\n        MixColumns[0][i] = xtimes02[0][i] ^ xtimes03[1][i] ^ ShiftRows[2][i] ^ ShiftRows[3][i];\n        MixColumns[1][i] = ShiftRows[0][i] ^ xtimes02[1][i] ^ xtimes03[2][i] ^ ShiftRows[3][i];\n        MixColumns[2][i] = ShiftRows[0][i] ^ ShiftRows[1][i] ^ xtimes02[2][i] ^ xtimes03[3][i];\n        MixColumns[3][i] = xtimes02[3][i] ^ xtimes03[0][i] ^ ShiftRows[1][i] ^ ShiftRows[2][i];\n    end\nend\n\n// ****************************************\n// - Key Expansion logic\n// ****************************************\n\nalways_ff @(posedge clk or negedge rst_async_n) begin : reset_regs\n    if(~rst_async_n) begin\n        expanded_key_ff <= {NBW_EX_KEY{1'b0}};\n    end else begin\n        expanded_key_ff <= expanded_key_nx;\n    end\nend\n\nassign Rcon[0] = 8'h01;\nassign Rcon[1] = 8'h02;\nassign Rcon[2] = 8'h04;\nassign Rcon[3] = 8'h08;\nassign Rcon[4] = 8'h10;\nassign Rcon[5] = 8'h20;\nassign Rcon[6] = 8'h40;\n\nassign rotword_out = {rotword_in[NBW_WORD-NBW_BYTE-1:0], rotword_in[NBW_WORD-1 -: NBW_BYTE]};\n\nsbox uu_key_sbox0 (\n    .i_data(subword_in[NBW_WORD-1-:NBW_BYTE]),\n    .o_data(subword_out[NBW_WORD-1-:NBW_BYTE])\n);\n\nsbox uu_key_sbox1 (\n    .i_data(subword_in[NBW_WORD-NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(subword_out[NBW_WORD-NBW_BYTE-1-:NBW_BYTE])\n);\n\nsbox uu_key_sbox2 (\n    .i_data(subword_in[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(subword_out[NBW_WORD-2*NBW_BYTE-1-:NBW_BYTE])\n);\n\nsbox uu_key_sbox3 (\n    .i_data(subword_in[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE]),\n    .o_data(subword_out[NBW_WORD-3*NBW_BYTE-1-:NBW_BYTE])\n);\n\nalways_comb begin : input_data\n    if (i_update_key & o_done) begin\n        valid_key = i_key;\n    end else begin\n        valid_key = expanded_key_ff[NBW_EX_KEY-1 -: NBW_KEY];\n    end\nend\n\nalways_comb begin : key_expansion\n    for(int i = 0; i < N_KEY_WORDS; i++) begin\n        key_words[i] = valid_key[NBW_KEY-1-i*NBW_WORD -: NBW_WORD];\n    end\n\n    for(int i = N_KEY_WORDS; i < N_EXP_WORDS; i++) begin\n        temp_word = key_words[i-1];\n\n        if((i % N_KEY_WORDS) == 0) begin\n            rotword_in = key_words[i-1];\n            subword_in = rotword_out;\n            temp_word  = {subword_out[31:24]^Rcon[i/N_KEY_WORDS-1], subword_out[23:0]};\n        end else if((i % N_KEY_WORDS) == 4) begin\n            subword_in = key_words[i-1];\n            temp_word  = subword_out;\n        end\n\n        key_words[i] = key_words[i-N_KEY_WORDS] ^ temp_word;\n    end\nend\n\nalways_comb begin : expanded_key_pack\n    expanded_key_nx = '0;\n    for(int i = 0; i < N_EXP_WORDS; i++) begin\n        expanded_key_nx[NBW_EX_KEY-1-i*NBW_WORD -: NBW_WORD] = key_words[i];\n    end\nend\n\nendmodule : aes_encrypt\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
