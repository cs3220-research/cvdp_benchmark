 <= 6'd0;\n                zero_run_q  <= 5'd0;\n                rlen_out    <= 4'd0;\n                size_out    <= coeff_size(din_in);\n                amp_out     <= din_in;\n                douten_out  <= 1'b1;\n                bstart_out  <= 1'b1;\n            end else begin\n                block_pos_q <= block_pos_q + 6'd1;\n                if (din_in == 12'sd0) begin\n                    if (zero_run_q == 5'd15) begin\n                        rlen_out   <= 4'd15;\n                        size_out   <= 4'd0;\n                        amp_out    <= 12'sd0;\n                        douten_out <= 1'b1;\n                        bstart_out <= 1'b0;\n                        zero_run_q <= 5'd0;\n                    end else begin\n                        zero_run_q <= zero_run_q + 5'd1;\n                        if (block_pos_q == 6'd62) begin\n                            rlen_out   <= 4'd0;\n                            size_out   <= 4'd0;\n                            amp_out    <= 12'sd0;\n                            douten_out <= 1'b1;\n                            bstart_out <= 1'b0;\n                        end\n                    end\n                end else begin\n                    rlen_out   <= zero_run_q[3:0];\n                    size_out   <= coeff_size(din_in);\n                    amp_out    <= din_in;\n                    douten_out <= 1'b1;\n                    bstart_out <= 1'b0;\n                    zero_run_q <= 5'd0;\n                end\n            end\n        end\n    end\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
