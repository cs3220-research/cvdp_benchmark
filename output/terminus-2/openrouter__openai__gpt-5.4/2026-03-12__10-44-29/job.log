Sending keys: ["cat > rtl/axis_broadcast.sv <<'EOF'\nmodule axis_broadcast (\n    input  wire       clk,\n    input  wire       rst_n,\n    input  wire [7:0] s_axis_tdata,\n    input  wire       s_axis_tvalid,\n    output wire       s_axis_tready,\n    output wire [7:0] m_axis_tdata_1,\n    output wire       m_axis_tvalid_1,\n    input  wire       m_axis_tready_1,\n    output wire [7:0] m_axis_tdata_2,\n    output wire       m_axis_tvalid_2,\n    input  wire       m_axis_tready_2,\n    output wire [7:0] m_axis_tdata_3,\n    output wire       m_axis_tvalid_3,\n    input  wire       m_axis_tready_3\n);\n\nreg [7:0] out_data_reg, out_data_next;\nreg       out_valid_reg, out_valid_next;\nreg [7:0] buf_data_reg, buf_data_next;\nreg       buf_valid_reg, buf_valid_next;\n\nwire all_ready;\nwire out_fire;\nwire in_fire;\n\nassign all_ready     = m_axis_tready_1 && m_axis_tready_2 && m_axis_tready_3;\nassign out_fire      = out_valid_reg && all_ready;\nassign s_axis_tready = !buf_valid_reg;\nassign in_fire       = s_axis_tvalid && s_axis_tready;\n\nalways @* begin\n    out_data_next  = out_data_reg;\n    out_valid_next = out_valid_reg;\n    buf_data_next  = buf_data_reg;\n    buf_valid_next = buf_valid_reg;\n\n    if (out_fire) begin\n        if (buf_valid_reg) begin\n            out_data_next  = buf_data_reg;\n            out_valid_next = 1'b1;\n            buf_valid_next = 1'b0;\n        end else begin\n            out_valid_next = 1'b0;\n        end\n    end\n\n    if (in_fire) begin\n        if (!out_valid_next) begin\n            out_data_next  = s_axis_tdata;\n            out_valid_next = 1'b1;\n        end else begin\n            buf_data_next  = s_axis_tdata;\n            buf_valid_next = 1'b1;\n        end\n    end\nend\n\nalways @(posedge clk or negedge rst_n) begin\n    if (!rst_n) begin\n        out_data_reg  <= 8'h00;\n        out_valid_reg <= 1'b0;\n        buf_data_reg  <= 8'h00;\n        buf_valid_reg <= 1'b0;\n    end else begin\n        out_data_reg  <= out_data_next;\n        out_valid_reg <= out_valid_next;\n        buf_data_reg  <= buf_data_next;\n        buf_valid_reg <= buf_valid_next;\n    end\nend\n\nassign m_axis_tdata_1  = out_data_reg;\nassign m_axis_tvalid_1 = out_valid_reg;\nassign m_axis_tdata_2  = out_data_reg;\nassign m_axis_tvalid_2 = out_valid_reg;\nassign m_axis_tdata_3  = out_data_reg;\nassign m_axis_tvalid_3 = out_valid_reg;\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
