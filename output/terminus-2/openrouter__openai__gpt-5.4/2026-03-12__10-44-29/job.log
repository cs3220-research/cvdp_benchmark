eg [7:0] byte_value_q;\\n    reg [2:0] preamble_idx_q;\\n    reg [31:0] crc_q, crc_final_q;\\n    reg [1:0] crc_idx_q;\\n\\n    reg [31:0] word_data_q;\\n    reg [3:0]  word_strb_q;\\n    reg        word_last_q;\\n    reg        word_valid_q;\\n    reg [1:0]  byte_idx_q;\\n    reg        pop_pending_q;\\n\\n    wire [7:0] selected_byte_w;\\n    assign selected_byte_w = (byte_idx_q == 2'd0) ? word_data_q[7:0] :\\n                             (byte_idx_q == 2'd1) ? word_data_q[15:8] :\\n                             (byte_idx_q == 2'd2) ? word_data_q[23:16] :\\n                                                    word_data_q[31:24];\\n\\n    always @(posedge clk_in or posedge rst_in) begin\\n        if (rst_in) begin\\n            mii_txd_out    <= 4'd0;\\n            mii_tx_en_out  <= 1'b0;\\n            fifo_rd_pop    <= 1'b0;\\n            state_q        <= ST_IDLE;\\n            nibble_sel_q   <= 1'b0;\\n            byte_value_q   <= 8'd0;\\n            preamble_idx_q <= 3'd0;\\n            crc_q          <= 32'hFFFFFFFF;\\n            crc_final_q    <= 32'd0;\\n            crc_idx_q      <= 2'd0;\\n            word_data_q    <= 32'd0;\\n            word_strb_q    <= 4'd0;\\n            word_last_q    <= 1'b0;\\n            word_valid_q   <= 1'b0;\\n            byte_idx_q     <= 2'd0;\\n            pop_pending_q  <= 1'b0;\\n        end else begin\\n            fifo_rd_pop <= 1'b0;\\n\\n            if (pop_pending_q) begin\\n                word_data_q   <= fifo_rd_data[31:0];\\n                word_strb_q   <= fifo_rd_data[35:32];\\n                word_last_q   <= fifo_rd_data[36];\\n                word_valid_q  <= 1'b1;\\n                byte_idx_q    <= 2'd0;\\n                pop_pending_q <= 1'b0;\\n            end\\n\\n            case (state_q)\\n                ST_IDLE: begin\\n                    mii_tx_en_out  <= 1'b0;\\n                    mii_txd_out    <= 4'd0;\\n                    nibble_sel_q   <= 1'b0;\\n                    preamble_idx_q <= 3'd0;\