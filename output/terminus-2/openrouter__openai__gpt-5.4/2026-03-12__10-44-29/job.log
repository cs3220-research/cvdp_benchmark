Sending keys: ["cat > rtl/phase_lut.sv <<'SV'\nmodule phase_lut #(\n   parameter int NBW_IN     = 6,\n   parameter int NBI_IN     = 1,\n   parameter int NBW_PHASE  = 9,\n   parameter int NBI_PHASE  = 1\n) (\n   input  logic                           clk,\n   input  logic                           rst_async_n,\n   input  logic signed [NBW_IN-1:0]       i_data_i,\n   input  logic signed [NBW_IN-1:0]       i_data_q,\n   output logic signed [NBW_PHASE-1:0]    o_phase\n);\n\nlocalparam int NBF_IN            = NBW_IN - NBI_IN;\nlocalparam int NBF_PHASE         = NBW_PHASE - NBI_PHASE;\nlocalparam int ABS_LEVELS        = (1 << NBF_IN) + 1;\nlocalparam int LUT_SIZE          = ABS_LEVELS * ABS_LEVELS;\nlocalparam int LUT_IDX_W         = $clog2(LUT_SIZE);\nlocalparam int signed FULL_SCALE = (1 << NBF_PHASE);\nlocalparam real PI_R             = 3.14159265358979323846;\n\nlogic                        sign_i_c;\nlogic                        sign_q_c;\nlogic [NBF_IN:0]             abs_i_c;\nlogic [NBF_IN:0]             abs_q_c;\nlogic [LUT_IDX_W-1:0]        lut_index_c;\n\nlogic                        sign_i_r;\nlogic                        sign_q_r;\nlogic [LUT_IDX_W-1:0]        lut_index_r;\nlogic signed [NBW_PHASE-1:0] lut_mem [0:LUT_SIZE-1];\nlogic signed [NBW_PHASE-1:0] lut_phase;\n\ninteger i;\ninteger q;\ninteger idx;\nreal ri;\nreal rq;\nreal phase_norm;\ninteger phase_quant;\n\nalways_comb begin\n   sign_i_c = i_data_i[NBW_IN-1];\n   sign_q_c = i_data_q[NBW_IN-1];\n\n   abs_i_c = sign_i_c ? $unsigned(-i_data_i) : $unsigned(i_data_i);\n   abs_q_c = sign_q_c ? $unsigned(-i_data_q) : $unsigned(i_data_q);\n\n   lut_index_c = abs_i_c * ABS_LEVELS + abs_q_c;\nend\n\nalways_ff @(posedge clk or negedge rst_async_n) begin\n   if (!rst_async_n) begin\n      sign_i_r    <= 1'b0;\n      sign_q_r    <= 1'b0;\n      lut_index_r <= '0;\n   end else begin\n      sign_i_r    <= sign_i_c;\n      sign_q_r    <= sign_q_c;\n      lut_index_r <= lut_index_c;\n   end\nend\n\ninitial begin\n   for (i = 0; i < ABS_LEVELS; i = i + 1) begin\n      for (q = 0; q < ABS_LEVELS; q = q + 1) begin\n         idx = i * ABS_LEVELS + q;\n         ri = i;\n         rq = q;\n         phase_norm = $atan2(rq, ri) / PI_R;\n         phase_quant = $rtoi(phase_norm * FULL_SCALE + 0.5);\n         lut_mem[idx] = phase_quant;\n      end\n   end\nend\n\nassign lut_phase = lut_mem[lut_index_r];\n\nalways_comb begin\n   unique case ({sign_i_r, sign_q_r})\n      2'b00: o_phase = lut_phase;\n      2'b01: o_phase = -lut_phase;\n      2'b10: o_phase = FULL_SCALE - lut_phase;\n      2'b11: o_phase = lut_phase - FULL_SCALE;\n      default: o_phase = '0;\n   endcase\nend\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
