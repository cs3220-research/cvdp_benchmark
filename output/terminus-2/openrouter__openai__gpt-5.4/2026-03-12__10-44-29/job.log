Sending keys: ["cat > src/control_fsm.sv <<'SV'\nmodule control_fsm #(\n    parameter int NBW_WAIT = 32\n) (\n    input  logic                clk,\n    input  logic                rst_async_n,\n    input  logic                i_enable,\n    input  logic                i_subsampling,\n    output logic                o_subsampling,\n    input  logic                i_valid,\n    output logic                o_valid,\n    input  logic                i_calc_valid,\n    input  logic                i_calc_fail,\n    input  logic [NBW_WAIT-1:0] i_wait,\n    output logic                o_start_calc\n);\n\n    localparam int NBW_CNT = 8;\n\n    localparam logic [2:0] PROC_CONTROL_CAPTURE_ST = 3'd0;\n    localparam logic [2:0] PROC_DATA_CAPTURE_ST    = 3'd1;\n    localparam logic [2:0] PROC_CALC_START_ST      = 3'd2;\n    localparam logic [2:0] PROC_CALC_ST            = 3'd3;\n    localparam logic [2:0] PROC_WAIT_ST            = 3'd4;\n\n    logic [2:0]          state_ff, next_state_ff;\n    logic [NBW_CNT-1:0]  cnt_ff;\n    logic [NBW_WAIT-1:0] timecnt_ff;\n    logic [NBW_WAIT-1:0] timecnt_ff0;\n    logic                ctrl_en;\n    logic                subsampling_ff;\n    logic                timecnt_en;\n    logic                cnt_en;\n    logic                cnt_rstctrl;\n    logic                cnt_rstproc;\n\n    assign cnt_rstproc = (state_ff == PROC_DATA_CAPTURE_ST) && (cnt_ff == 0);\n\n    always_comb begin\n        next_state_ff = state_ff;\n        unique case (state_ff)\n            PROC_CONTROL_CAPTURE_ST: begin\n                next_state_ff = i_enable ? PROC_DATA_CAPTURE_ST : PROC_CONTROL_CAPTURE_ST;\n            end\n            PROC_DATA_CAPTURE_ST: begin\n                next_state_ff = (cnt_ff == 0) ? PROC_CALC_START_ST : PROC_DATA_CAPTURE_ST;\n            end\n            PROC_CALC_START_ST: begin\n                next_state_ff = (cnt_ff == 0) ? PROC_CALC_ST : PROC_CALC_START_ST;\n            end\n            PROC_CALC_ST: begin\n                if (i_calc_fail)\n                    next_state_ff = PROC_CONTROL_CAPTURE_ST;\n                else if (i_calc_valid)\n                    next_state_ff = PROC_WAIT_ST;\n                else\n                    next_state_ff = PROC_CALC_ST;\n            end\n            PROC_WAIT_ST: begin\n                if (!i_enable || (timecnt_ff == 0))\n                    next_state_ff = PROC_CONTROL_CAPTURE_ST;\n                else\n                    next_state_ff = PROC_WAIT_ST;\n            end\n            default: next_state_ff = PROC_CONTROL_CAPTURE_ST;\n        endcase\n    end\n\n    always_comb begin\n        o_start_calc = 1'b0;\n        ctrl_en      = 1'b0;\n        cnt_rstctrl  = 1'b0;\n        cnt_en       = 1'b0;\n        timecnt_en   = 1'b0;\n\n        unique case (state_ff)\n            PROC_CONTROL_CAPTURE_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = i_enable;\n                cnt_rstctrl  = 1'b1;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n            PROC_DATA_CAPTURE_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = i_valid;\n                timecnt_en   = 1'b0;\n            end\n            PROC_CALC_START_ST: begin\n                o_start_calc = 1'b1;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b1;\n                timecnt_en   = 1'b0;\n            end\n            PROC_CALC_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n            PROC_WAIT_ST: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b1;\n            end\n            default: begin\n                o_start_calc = 1'b0;\n                ctrl_en      = 1'b0;\n                cnt_rstctrl  = 1'b0;\n                cnt_en       = 1'b0;\n                timecnt_en   = 1'b0;\n            end\n        endcase\n    end\n\n    assign o_valid       = cnt_en && (state_ff == PROC_DATA_CAPTURE_ST) && (cnt_ff > 0);\n    assign o_subsampling = subsampling_ff;\n\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            state_ff       <= PROC_CONTROL_CAPTURE_ST;\n            next_state_ff  <= PROC_CONTROL_CAPTURE_ST;\n            cnt_ff         <= '0;\n            timecnt_ff     <= '0;\n            timecnt_ff0    <= '0;\n            subsampling_ff <= 1'b0;\n        end else begin\n            if (i_calc_valid && (state_ff == PROC_CALC_ST))\n                timecnt_ff <= timecnt_ff0;\n            else if (timecnt_en)\n                timecnt_ff <= (timecnt_ff > 0) ? (timecnt_ff - 1'b1) : '0;\n\n            if (cnt_rstctrl)\n                cnt_ff <= i_subsampling ? (1 << (NBW_CNT - 1)) : 8;\n            else if (cnt_rstproc)\n                cnt_ff <= 15;\n            else if (cnt_en)\n                cnt_ff <= (cnt_ff > 0) ? (cnt_ff - 1'b1) : '0;\n\n            if (ctrl_en) begin\n                timecnt_ff0    <= i_wait;\n                subsampling_ff <= i_subsampling;\n            end\n\n            state_ff <= next_state_ff;\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
