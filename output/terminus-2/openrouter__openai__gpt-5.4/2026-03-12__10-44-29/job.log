time + 16'd10;\n\n            for (i = 0; i < 16; i = i + 1) begin\n                temp_timestamps[i] = event_timestamps[i];\n                temp_priorities[i] = event_priorities[i];\n                temp_valid[i]      = event_valid[i];\n                temp_recurring[i]  = event_recurring[i];\n                temp_intervals[i]  = event_intervals[i];\n            end\n\n            trigger_event      <= 1'b0;\n            triggered_event_id <= 4'd0;\n            error              <= 1'b0;\n            log_event_time     <= 16'd0;\n            log_event_id       <= 4'd0;\n\n            if (add_event) begin\n                if (temp_valid[event_id]) begin\n                    error <= 1'b1;\n                end else begin\n                    temp_timestamps[event_id] = timestamp;\n                    temp_priorities[event_id] = priority_in;\n                    temp_valid[event_id]      = 1'b1;\n                    temp_recurring[event_id]  = recurring_event;\n                    temp_intervals[event_id]  = recurring_interval;\n                end\n            end\n\n            if (modify_event) begin\n                if (!temp_valid[event_id]) begin\n                    error <= 1'b1;\n                end else begin\n                    temp_timestamps[event_id] = new_timestamp;\n                    temp_priorities[event_id] = new_priority;\n                    temp_recurring[event_id]  = recurring_event;\n                    temp_intervals[event_id]  = recurring_interval;\n                end\n            end\n\n            if (cancel_event) begin\n                if (!temp_valid[event_id]) begin\n                    error <= 1'b1;\n                end else begin\n                    temp_valid[event_id]      = 1'b0;\n                    temp_recurring[event_id]  = 1'b0;\n                    temp_intervals[event_id]  = 16'd0;\n                end\n            end\n\n            selected_idx = -1;\n            selected_priority = 2'd0;\n            for (i = 0; i < 16; i = i + 1) begin\n                if (temp_valid[i] && (temp_timestamps[i] <= next_time)) begin\n                    if ((selected_idx == -1) || (temp_priorities[i] > selected_priority)) begin\n                        selected_idx = i;\n                        selected_priority = temp_priorities[i];\n                    end\n                end\n            end\n\n            if (selected_idx != -1) begin\n                trigger_event      <= 1'b1;\n                triggered_event_id <= selected_idx[3:0];\n                log_event_time     <= next_time;\n                log_event_id       <= selected_idx[3:0];\n\n                if (temp_recurring[selected_idx]) begin\n                    temp_timestamps[selected_idx] = temp_timestamps[selected_idx] + temp_intervals[selected_idx];\n                end else begin\n                    temp_valid[selected_idx]      = 1'b0;\n                    temp_recurring[selected_idx]  = 1'b0;\n                    temp_intervals[selected_idx]  = 16'd0;\n                end\n            end\n\n            current_time <= next_time;\n            for (i = 0; i < 16; i = i + 1) begin\n                event_timestamps[i] <= temp_timestamps[i];\n                event_priorities[i] <= temp_priorities[i];\n                event_valid[i]      <= temp_valid[i];\n                event_recurring[i]  <= temp_recurring[i];\n                event_intervals[i]  <= temp_intervals[i];\n            end\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
