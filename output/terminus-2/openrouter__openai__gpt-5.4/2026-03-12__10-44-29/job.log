Sending keys: ["cat > src/control_fsm.sv <<'SV'\nmodule control_fsm #(\n    parameter int NBW_WAIT = 32\n) (\n    input  logic                clk,\n    input  logic                rst_async_n,\n    input  logic                i_enable,\n    input  logic                i_subsampling,\n    output logic                o_subsampling,\n    input  logic                i_valid,\n    output logic                o_valid,\n    input  logic                i_calc_valid,\n    input  logic                i_calc_fail,\n    input  logic [NBW_WAIT-1:0] i_wait,\n    output logic                o_start_calc\n);\n\n    typedef enum logic [2:0] {\n        PROC_CONTROL_CAPTURE_ST = 3'd0,\n        PROC_DATA_CAPTURE_ST    = 3'd1,\n        PROC_CALC_START_ST      = 3'd2,\n        PROC_CALC_ST            = 3'd3,\n        PROC_WAIT_ST            = 3'd4\n    } state_t;\n\n    localparam int GENCNT_W          = 9;\n    localparam logic [GENCNT_W-1:0] DATA_PRELOAD_NORM = 9'd7;\n    localparam logic [GENCNT_W-1:0] DATA_PRELOAD_SUB  = 9'd255;\n    localparam logic [GENCNT_W-1:0] CALC_START_PRELOAD = 9'd15;\n\n    state_t                state_q, state_d;\n    logic [GENCNT_W-1:0]   gen_cnt_q, gen_cnt_d;\n    logic [NBW_WAIT-1:0]   wait_cnt_q, wait_cnt_d;\n    logic [NBW_WAIT-1:0]   wait_hold_q, wait_hold_d;\n    logic                  subsampling_q, subsampling_d;\n\n    logic [GENCNT_W-1:0] data_preload;\n\n    assign data_preload = subsampling_q ? DATA_PRELOAD_SUB : DATA_PRELOAD_NORM;\n\n    always_comb begin\n        state_d       = state_q;\n        gen_cnt_d     = gen_cnt_q;\n        wait_cnt_d    = wait_cnt_q;\n        wait_hold_d   = wait_hold_q;\n        subsampling_d = subsampling_q;\n\n        case (state_q)\n            PROC_CONTROL_CAPTURE_ST: begin\n                wait_hold_d   = i_wait;\n                subsampling_d = i_subsampling;\n                gen_cnt_d     = i_subsampling ? DATA_PRELOAD_SUB : DATA_PRELOAD_NORM;\n                wait_cnt_d    = i_wait;\n                if (i_enable) begin\n                    state_d = PROC_DATA_CAPTURE_ST;\n                end\n            end\n\n            PROC_DATA_CAPTURE_ST: begin\n                if (!i_enable) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else if (i_valid) begin\n                    if (gen_cnt_q == 0) begin\n                        gen_cnt_d = CALC_START_PRELOAD;\n                        state_d   = PROC_CALC_START_ST;\n                    end else begin\n                        gen_cnt_d = gen_cnt_q - 1'b1;\n                    end\n                end\n            end\n\n            PROC_CALC_START_ST: begin\n                if (!i_enable) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else begin\n                    if (gen_cnt_q == 0) begin\n                        state_d = PROC_CALC_ST;\n                    end else begin\n                        gen_cnt_d = gen_cnt_q - 1'b1;\n                    end\n                end\n            end\n\n            PROC_CALC_ST: begin\n                if (!i_enable) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else if (i_calc_fail) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else if (i_calc_valid) begin\n                    wait_cnt_d = wait_hold_q;\n                    state_d    = PROC_WAIT_ST;\n                end\n            end\n\n            PROC_WAIT_ST: begin\n                if (!i_enable) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else if (wait_cnt_q == 0) begin\n                    state_d = PROC_CONTROL_CAPTURE_ST;\n                end else begin\n                    wait_cnt_d = wait_cnt_q - 1'b1;\n                end\n            end\n\n            default: begin\n                state_d = PROC_CONTROL_CAPTURE_ST;\n            end\n        endcase\n    end\n\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            state_q       <= PROC_CONTROL_CAPTURE_ST;\n            gen_cnt_q     <= DATA_PRELOAD_NORM;\n            wait_cnt_q    <= '0;\n            wait_hold_q   <= '0;\n            subsampling_q <= 1'b0;\n        end else begin\n            state_q       <= state_d;\n            gen_cnt_q     <= gen_cnt_d;\n            wait_cnt_q    <= wait_cnt_d;\n            wait_hold_q   <= wait_hold_d;\n            subsampling_q <= subsampling_d;\n        end\n    end\n\n    always_comb begin\n        o_start_calc  = (state_q == PROC_CALC_START_ST) && (gen_cnt_q == CALC_START_PRELOAD);\n        o_valid       = (state_q == PROC_DATA_CAPTURE_ST) && i_valid;\n        o_subsampling = subsampling_q;\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
