n\n                entered_password_n = {entered_password[PASS_W-5:0], key_input};\n                digit_count_n      = COUNT_W'(1);\n            end\n        end else if (state == ENTER_PASS) begin\n            if (key_valid && valid_digit && (digit_count < PASSWORD_LENGTH)) begin\n                entered_password_n = {entered_password[PASS_W-5:0], key_input};\n                digit_count_n      = digit_count + COUNT_W'(1);\n            end\n        end else if ((state == PASSWORD_OK) || (state == PASSWORD_FAIL) || (state == ADMIN_MODE)) begin\n            entered_password_n = '0;\n            digit_count_n      = '0;\n        end\n    end\n\n    always_ff @(posedge clk) begin\n        if (srst) begin\n            state            <= IDLE;\n            stored_password  <= DEFAULT_PASSWORD;\n            entered_password <= '0;\n            digit_count      <= '0;\n            fail_count       <= '0;\n            door_unlock      <= 1'b0;\n            lockout          <= 1'b0;\n        end else begin\n            state            <= next_state;\n            entered_password <= entered_password_n;\n            digit_count      <= digit_count_n;\n\n            door_unlock <= 1'b0;\n\n            if (admin_override) begin\n                fail_count <= '0;\n                lockout    <= 1'b0;\n            end\n\n            unique case (state)\n                IDLE: begin\n                    if (!admin_override) begin\n                        fail_count <= fail_count;\n                        lockout    <= lockout;\n                    end\n                end\n\n                CHECK_PASS: begin\n                    if (!admin_override) begin\n                        fail_count <= fail_count;\n                        lockout    <= lockout;\n                    end\n                end\n\n                PASSWORD_OK: begin\n                    door_unlock <= 1'b1;\n                    fail_count  <= '0;\n                    lockout     <= 1'b0;\n                end\n\