g       <= '0;\n            data_xor       <= 1'b0;\n            parity_bit_reg <= 1'b0;\n            parity_error   <= 1'b0;\n            frame_error    <= 1'b0;\n            tdata          <= '0;\n            tuser          <= 1'b0;\n            tvalid         <= 1'b0;\n        end else begin\n            rx_meta <= RX;\n            rx_sync <= rx_meta;\n            rx_prev <= rx_sync;\n\n            tvalid <= 1'b0;\n\n            case (state)\n                IDLE: begin\n                    clk_count      <= '0;\n                    bit_count      <= '0;\n                    data_xor       <= 1'b0;\n                    parity_bit_reg <= 1'b0;\n                    parity_error   <= 1'b0;\n                    frame_error    <= 1'b0;\n                    tuser          <= 1'b0;\n                    if (start_fall) begin\n                        state     <= START;\n                        clk_count <= '0;\n                    end\n                end\n\n                START: begin\n                    if (clk_count == HALF_PERIOD-1) begin\n                        clk_count <= '0;\n                        if (rx_sync == 1'b0) begin\n                            state          <= DATA;\n                            bit_count      <= '0;\n                            data_xor       <= 1'b0;\n                            parity_bit_reg <= 1'b0;\n                        end else begin\n                            state <= IDLE;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                DATA: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count           <= '0;\n                        data_reg[bit_count] <= rx_sync;\n                        data_xor            <= data_xor ^ rx_sync;\n                        if (bit_count == BIT_PER_WORD-1) begin\n                            bit_count <= '0;\n                            if (PARITY_BIT != 0)\n                                state <= PARITY;\n                            else\n                                state <= STOP1;\n                        end else begin\n                            bit_count <= bit_count + 1'b1;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                PARITY: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count      <= '0;\n                        parity_bit_reg <= rx_meta;\n                        case (PARITY_BIT)\n                            1: parity_error <= (rx_meta != ~data_xor);\n                            2: parity_error <= (rx_meta !=  data_xor);\n                            default: parity_error <= 1'b0;\n                        endcase\n                        state <= STOP1;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP1: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count   <= '0;\n                        frame_error <= frame_error | ~rx_sync;\n                        if (STOP_BITS_NUM == 2)\n                            state <= STOP2;\n                        else\n                            state <= OUT_RDY;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP2: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count   <= '0;\n                        frame_error <= frame_error | ~rx_sync;\n                        state       <= OUT_RDY;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                OUT_RDY: begin\n                    tdata  <= data_reg;\n                    tuser  <= parity_error | frame_error;\n                    tvalid <= 1'b1;\n                    state  <= IDLE;\n                end\n\n                default: begin\n                    state <= IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
