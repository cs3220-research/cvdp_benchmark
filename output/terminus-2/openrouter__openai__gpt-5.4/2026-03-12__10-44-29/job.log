eg [$clog2(ARRAY_SIZE+1)-1:0] left_output_index, right_output_index;\n\n    reg [PTR_W-1:0] parent_map [0:ARRAY_SIZE-1];\n    reg parent_dir [0:ARRAY_SIZE-1];\n\n    integer i;\n    reg [PTR_W-1:0] child_idx;\n\n    task automatic load_inputs;\n        integer j;\n        begin\n            for (j = 0; j < ARRAY_SIZE; j = j + 1) begin\n                key_mem[j]  = keys[j*DATA_WIDTH +: DATA_WIDTH];\n                left_mem[j] = left_child[j*PTR_W +: PTR_W];\n                right_mem[j]= right_child[j*PTR_W +: PTR_W];\n                parent_map[j] = INVALID_PTR;\n                parent_dir[j] = 1'b0;\n                left_stack[j] = INVALID_PTR;\n                right_stack[j] = INVALID_PTR;\n            end\n            for (j = 0; j < ARRAY_SIZE; j = j + 1) begin\n                if (left_mem[j] != INVALID_PTR) begin\n                    parent_map[left_mem[j]] = j[PTR_W-1:0];\n                    parent_dir[left_mem[j]] = 1'b1;\n                end\n                if (right_mem[j] != INVALID_PTR) begin\n                    parent_map[right_mem[j]] = j[PTR_W-1:0];\n                    parent_dir[right_mem[j]] = 1'b0;\n                end\n            end\n        end\n    endtask\n\n    task automatic reset_outputs_only;\n        integer j;\n        begin\n            key_position <= INVALID_PTR;\n            complete_deletion <= 1'b0;\n            delete_invalid <= 1'b0;\n            for (j = 0; j < ARRAY_SIZE; j = j + 1) begin\n                modified_keys[j*DATA_WIDTH +: DATA_WIDTH] <= INVALID_KEY;\n                modified_left_child[j*PTR_W +: PTR_W] <= INVALID_PTR;\n                modified_right_child[j*PTR_W +: PTR_W] <= INVALID_PTR;\n            end\n        end\n    endtask\n\n    task automatic pack_outputs;\n        integer j;\n        begin\n            for (j = 0; j < ARRAY_SIZE; j = j + 1) begin\n                modified_keys[j*DATA_WIDTH +: DATA_WIDTH] <= key_mem[j];\n                modified_left_child[j*PTR_W +: PTR_W] <= left_mem[j];\n      