: 0);\n\n        w_ptr_next = bin2gray(w_count_bin_next);\n        r_ptr_next = bin2gray(r_count_bin_next);\n\n        w_full_next  = ((w_count_bin_next - wq2_rbin) >= DEPTH);\n        r_empty_next = (r_count_bin_next == rq2_wbin);\n\n        w_addr = w_count_bin[ADDR_W-1:0];\n        if (r_count_bin == 0)\n            r_addr = {ADDR_W{1'b0}};\n        else\n            r_addr = (r_count_bin - 1'b1);\n    end\n\n    always @(posedge w_clk) begin\n        if (w_rst) begin\n            w_count_bin <= {PTR_W{1'b0}};\n            w_ptr       <= {PTR_W{1'b0}};\n            wq1_rptr    <= {PTR_W{1'b0}};\n            wq2_rptr    <= {PTR_W{1'b0}};\n            w_full      <= 1'b0;\n        end else begin\n            wq1_rptr <= r_ptr;\n            wq2_rptr <= wq1_rptr;\n\n            if (w_push_fire) begin\n                mem[w_addr] <= w_data;\n                w_count_bin <= w_count_bin_next;\n                w_ptr       <= w_ptr_next;\n            end\n\n            w_full <= w_full_next;\n        end\n    end\n\n    always @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= {PTR_W{1'b0}};\n            r_ptr       <= {PTR_W{1'b0}};\n            rq1_wptr    <= {PTR_W{1'b0}};\n            rq2_wptr    <= {PTR_W{1'b0}};\n            r_empty     <= 1'b1;\n        end else begin\n            rq1_wptr <= w_ptr;\n            rq2_wptr <= rq1_wptr;\n\n            if (r_pop_fire) begin\n                r_count_bin <= r_count_bin_next;\n                r_ptr       <= r_ptr_next;\n            end\n\n            r_empty <= r_empty_next;\n        end\n    end\n\n    always @(*) begin\n        if (r_count_bin == rq2_wbin)\n            r_data = {DATA_WIDTH{1'b0}};\n        else\n            r_data = mem[r_addr];\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
