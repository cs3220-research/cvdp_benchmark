*PTR_W +: PTR_W] <= current_node;\n                        sp <= sp + 1'b1;\n                        current_node <= left_child[current_node*PTR_W +: PTR_W];\n                    end else begin\n                        state <= S_POP;\n                    end\n                end\n                S_POP: begin\n                    if (sp != 0) begin\n                        sp <= sp - 1'b1;\n                        current_node <= stack[(sp-1'b1)*PTR_W +: PTR_W];\n                        sorted_out[output_index*DATA_WIDTH +: DATA_WIDTH] <= keys[stack[(sp-1'b1)*PTR_W +: PTR_W]*DATA_WIDTH +: DATA_WIDTH];\n                        output_index <= output_index + 1'b1;\n                        state <= S_RIGHT;\n                    end else begin\n                        complete <= 1;\n                        state <= S_IDLE;\n                    end\n                end\n                S_RIGHT: begin\n                    current_node <= right_child[current_node*PTR_W +: PTR_W];\n                    state <= S_LEFT;\n                end\n                default: state <= S_IDLE;\n            endcase\n        end\n    end\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
