                axis_tlast_out  <= 1'b0;\n                    axis_tstrb_out  <= 4'd0;\n\n                    if (busy_reg) begin\n                        if (program_reg) begin\n                            state_r <= ST_FINISH;\n                        end else begin\n                            tx_bytes_total_r     <= (tx_len_reg < MIN_FRAME_LEN) ? MIN_FRAME_LEN : tx_len_reg;\n                            bytes_sent_r         <= 16'd0;\n                            current_word_index_r <= {ADDR_WIDTH{1'b0}};\n                            mem_addr1_r          <= {ADDR_WIDTH{1'b0}};\n                            state_r              <= ST_WAIT_DATA;\n                        end\n                    end\n                end\n\n                ST_WAIT_DATA: begin\n                    remaining_bytes_v = tx_bytes_total_r - bytes_sent_r;\n                    next_word_bytes_v = (remaining_bytes_v > 16'd4) ? 16'd4 : remaining_bytes_v;\n\n                    axis_tdata_out       <= mem_data1_rd;\n                    axis_tvalid_out      <= 1'b1;\n                    current_word_bytes_r <= next_word_bytes_v;\n                    axis_tlast_out       <= (remaining_bytes_v <= 16'd4);\n\n                    case (next_word_bytes_v)\n                        16'd1: axis_tstrb_out <= 4'b0001;\n                        16'd2: axis_tstrb_out <= 4'b0011;\n                        16'd3: axis_tstrb_out <= 4'b0111;\n                        default: axis_tstrb_out <= 4'b1111;\n                    endcase\n\n                    state_r <= ST_SEND;\n                end\n\n                ST_SEND: begin\n                    if (axis_tvalid_out && axis_tready_in) begin\n                        if (axis_tlast_out) begin\n                            axis_tvalid_out <= 1'b0;\n                            axis_tlast_out  <= 1'b0;\n                            axis_tstrb_out  <= 4'd0;\n                            bytes_sent_r    <= bytes_sent_r + current_word_bytes_r;\n                            state_r         <= ST_FINISH;\n                        end else begin\n                            bytes_sent_r         <= bytes_sent_r + current_word_bytes_r;\n                            current_word_index_r <= current_word_index_r + 1'b1;\n                            mem_addr1_r          <= current_word_index_r + 1'b1;\n                            axis_tvalid_out      <= 1'b0;\n                            axis_tlast_out       <= 1'b0;\n                            axis_tstrb_out       <= 4'd0;\n                            state_r              <= ST_WAIT_DATA;\n                        end\n                    end\n                end\n\n                ST_FINISH: begin\n                    busy_reg        <= 1'b0;\n                    program_reg     <= 1'b0;\n                    axis_tvalid_out <= 1'b0;\n                    axis_tlast_out  <= 1'b0;\n                    axis_tstrb_out  <= 4'd0;\n                    if (irq_en_reg)\n                        interrupt_out <= 1'b1;\n                    state_r <= ST_IDLE;\n                end\n\n                default: begin\n                    state_r <= ST_IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
