          if (axi_read_en) begin\n                case (axi_addr)\n                    ADDR_COUNT:     axi_rdata <= {16'h0000, count};\n                    ADDR_MATCH:     axi_rdata <= {16'h0000, match_value};\n                    ADDR_RELOAD:    axi_rdata <= {16'h0000, reload_value};\n                    ADDR_CONTROL:   axi_rdata <= {29'h0000_0000, control};\n                    ADDR_STATUS:    axi_rdata <= {31'h0000_0000, status};\n                    ADDR_PRESCALER: axi_rdata <= {28'h0000_000, prescaler};\n                    default:        axi_rdata <= 32'h0000_0000;\n                endcase\n            end else begin\n                axi_rdata <= 32'h0000_0000;\n            end\n\n            // Write path\n            if (axi_write_en) begin\n                case (axi_addr)\n                    ADDR_MATCH: begin\n                        match_value <= axi_wdata[15:0];\n                    end\n                    ADDR_RELOAD: begin\n                        reload_value <= axi_wdata[15:0];\n                    end\n                    ADDR_CONTROL: begin\n                        control <= axi_wdata[2:0];\n                        if (!axi_wdata[0]) begin\n                            prescale_count <= 4'h0;\n                        end\n                    end\n                    ADDR_STATUS: begin\n                        if (axi_wdata[0]) begin\n                            clear_status = 1'b1;\n                        end\n                    end\n                    ADDR_PRESCALER: begin\n                        prescaler      <= axi_wdata[3:0];\n                        prescale_count <= 4'h0;\n                    end\n                    default: begin\n                    end\n                endcase\n            end\n\n            // Timer core\n            if (enable) begin\n                if (prescale_count >= prescaler) begin\n                    prescale_count <= 4'h0;\n\n                    if (count == match_value) begin\n                        match_event = 1'b1;\n                        if (interval_mode) begin\n                            next_count = reload_value;\n                        end else begin\n                            next_count = count;\n                        end\n                    end else begin\n                        next_count = count + 16'h0001;\n                        if ((count + 16'h0001) == match_value) begin\n                            match_event = 1'b1;\n                            if (interval_mode) begin\n                                next_count = reload_value;\n                            end\n                        end\n                    end\n\n                    count <= next_count;\n                end else begin\n                    prescale_count <= prescale_count + 4'h1;\n                end\n            end\n\n            // Status and interrupt handling\n            if (match_event) begin\n                status <= 1'b1;\n            end\n\n            if (clear_status) begin\n                status <= 1'b0;\n            end\n\n            interrupt <= (match_event || status) && !clear_status && interrupt_enable;\n        end\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
