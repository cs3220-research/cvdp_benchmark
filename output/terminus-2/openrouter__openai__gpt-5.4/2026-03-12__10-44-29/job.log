 .valid       (pe_valid),\n    .input_in    (left_bot_in),\n    .weight      (w10),\n    .psum_in     (psum_00_to_10),\n    .input_out   (in_10_to_11),\n    .psum_out    (psum_out_10)\n  );\n\n  weight_stationary_pe #(.DATA_WIDTH(DATA_WIDTH)) pe11 (\n    .clk         (clk),\n    .reset       (reset),\n    .load_weight (load_weights),\n    .valid       (pe_valid),\n    .input_in    (in_10_to_11),\n    .weight      (w11),\n    .psum_in     (psum_01_to_11),\n    .input_out   (),\n    .psum_out    (psum_out_11)\n  );\n\n  always @(*) begin\n    pe_valid    = 1'b0;\n    left_top_in = zero_psum;\n    left_bot_in = zero_psum;\n\n    if (state == S_RUN) begin\n      case (phase)\n        2'd0: begin\n          pe_valid    = 1'b1;\n          left_top_in = x0;\n          left_bot_in = zero_psum;\n        end\n        2'd1: begin\n          pe_valid    = 1'b1;\n          left_top_in = x1;\n          left_bot_in = x1;\n        end\n        default: begin\n          pe_valid    = 1'b0;\n          left_top_in = zero_psum;\n          left_bot_in = zero_psum;\n        end\n      endcase\n    end\n  end\n\n  always @(posedge clk or posedge reset) begin\n    if (reset) begin\n      state <= S_IDLE;\n      phase <= 2'd0;\n      y0    <= zero_psum;\n      y1    <= zero_psum;\n      done  <= 1'b0;\n    end else begin\n      case (state)\n        S_IDLE: begin\n          done  <= 1'b0;\n          phase <= 2'd0;\n          if (start)\n            state <= S_RUN;\n        end\n\n        S_RUN: begin\n          case (phase)\n            2'd0: phase <= 2'd1;\n            2'd1: phase <= 2'd2;\n            2'd2: begin\n              y0   <= psum_out_10;\n              y1   <= psum_out_11;\n              done <= 1'b1;\n              state <= S_DONE;\n              phase <= 2'd0;\n            end\n            default: phase <= 2'd0;\n          endcase\n        end\n\n        S_DONE: begin\n          done <= 1'b1;\n          if (!start) begin\n            done  <= 1'b0;\n            state <= S_ID