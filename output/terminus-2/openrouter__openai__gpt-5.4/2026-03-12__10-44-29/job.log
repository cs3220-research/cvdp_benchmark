Sending keys: ["mkdir -p rtl\ncat > rtl/queue.sv <<'EOF'\nmodule queue #(\n    parameter int unsigned DEPTH  = 4,\n    parameter int unsigned DBITS  = 32,\n    parameter int unsigned ALMOST_EMPTY_THRESHOLD = 1,\n    parameter int unsigned ALMOST_FULL_THRESHOLD  = DEPTH-1\n) (\n    input  logic              clk_i,\n    input  logic              rst_ni,\n    input  logic              clr_i,\n    input  logic              ena_i,\n    input  logic              we_i,\n    input  logic              re_i,\n    input  logic [DBITS-1:0]  d_i,\n    output logic [DBITS-1:0]  q_o,\n    output logic              empty_o,\n    output logic              full_o,\n    output logic              almost_empty_o,\n    output logic              almost_full_o\n);\n\n    localparam int unsigned COUNT_W = (DEPTH <= 1) ? 1 : $clog2(DEPTH + 1);\n    localparam int unsigned AE_LEVEL =\n        (ALMOST_EMPTY_THRESHOLD > DEPTH) ? DEPTH : ALMOST_EMPTY_THRESHOLD;\n    localparam int unsigned AF_LEVEL =\n        (ALMOST_FULL_THRESHOLD > DEPTH) ? DEPTH : ALMOST_FULL_THRESHOLD;\n\n    logic [DBITS-1:0] queue_data [0:DEPTH-1];\n    logic [COUNT_W-1:0] queue_count;\n\n    integer i;\n    always_ff @(posedge clk_i or negedge rst_ni) begin\n        if (!rst_ni) begin\n            queue_count <= '0;\n            for (i = 0; i < DEPTH; i = i + 1) begin\n                queue_data[i] <= '0;\n            end\n        end else if (clr_i) begin\n            queue_count <= '0;\n            for (i = 0; i < DEPTH; i = i + 1) begin\n                queue_data[i] <= '0;\n            end\n        end else if (ena_i) begin\n            unique case ({we_i, re_i})\n                2'b10: begin\n                    if (queue_count < DEPTH) begin\n                        queue_data[queue_count] <= d_i;\n                        queue_count <= queue_count + 1'b1;\n                    end\n                end\n\n                2'b01: begin\n                    if (queue_count != 0) begin\n                        for (i = 0; i < DEPTH-1; i = i + 1) begin\n                            queue_data[i] <= queue_data[i+1];\n                        end\n                        queue_data[DEPTH-1] <= '0;\n                        queue_count <= queue_count - 1'b1;\n                    end\n                end\n\n                2'b11: begin\n                    if (queue_count == 0) begin\n                        queue_data[0] <= d_i;\n                        for (i = 1; i < DEPTH; i = i + 1) begin\n                            queue_data[i] <= '0;\n                        end\n                        queue_count <= {{(COUNT_W-1){1'b0}}, 1'b1};\n                    end else begin\n                        for (i = 0; i < DEPTH-1; i = i + 1) begin\n                            if (i < (queue_count - 1)) begin\n                                queue_data[i] <= queue_data[i+1];\n                            end else if (i == (queue_count - 1)) begin\n                                queue_data[i] <= d_i;\n                            end else begin\n                                queue_data[i] <= queue_data[i];\n                            end\n                        end\n\n                        if (queue_count == DEPTH) begin\n                            queue_data[DEPTH-1] <= d_i;\n                        end else if ((DEPTH-1) > (queue_count - 1)) begin\n                            queue_data[DEPTH-1] <= queue_data[DEPTH-1];\n                        end\n\n                        queue_count <= queue_count;\n                    end\n                end\n\n                default: begin\n                    queue_count <= queue_count;\n                end\n            endcase\n        end\n    end\n\n    always_comb begin\n        q_o = queue_data[0];\n        empty_o = (queue_count == 0);\n        full_o  = (queue_count == DEPTH);\n        almost_empty_o = (queue_count <= AE_LEVEL);\n        almost_full_o  = (queue_count >= AF_LEVEL);\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout