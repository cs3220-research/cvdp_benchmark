n        end\n    end\n\n    always @(negedge spi_sck or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            tx_shift <= 8'h00;\n            spi_miso <= 1'b0;\n        end else if (!spi_cs_n) begin\n            tx_shift <= {tx_shift[6:0], 1'b0};\n            spi_miso <= tx_shift[6];\n        end\n    end\n\n    always @(posedge spi_cs_n or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            Ar <= 0;\n            Ai <= 0;\n            Br <= 0;\n            Bi <= 0;\n            Cr <= 0;\n            Ci <= 0;\n            byte_cnt <= 3'd0;\n        end else begin\n            case (byte_cnt)\n                3'd0: Ar[15:8] <= rx_byte_complete;\n                3'd1: Ar[7:0]  <= rx_byte_complete;\n                3'd2: Ai[15:8] <= rx_byte_complete;\n                3'd3: Ai[7:0]  <= rx_byte_complete;\n                3'd4: Br[15:8] <= rx_byte_complete;\n                3'd5: Br[7:0]  <= rx_byte_complete;\n                3'd6: Bi[15:8] <= rx_byte_complete;\n                3'd7: begin\n                    Bi[7:0] <= rx_byte_complete;\n                    Cr <= ($signed(Ar) * $signed(Br)) - ($signed(Ai) * $signed({Bi[15:8], rx_byte_complete}));\n                    Ci <= ($signed(Ar) * $signed({Bi[15:8], rx_byte_complete})) + ($signed(Ai) * $signed(Br));\n                end\n                default: begin end\n            endcase\n\n            if (byte_cnt == 3'd7)\n                byte_cnt <= 3'd0;\n            else\n                byte_cnt <= byte_cnt + 3'd1;\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
