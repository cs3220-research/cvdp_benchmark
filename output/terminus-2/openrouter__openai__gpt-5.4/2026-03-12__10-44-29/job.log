count_bin == 0))\n                top_addr_from_count = '0;\n            else\n                top_addr_from_count = (count_bin - 1'b1)[ADDR_W-1:0];\n        end\n    endfunction\n\n    always_comb begin\n        wq2_rbin        = gray2bin(wq2_rptr);\n        rq2_wbin        = gray2bin(rq2_wptr);\n\n        w_push_fire     = push && !w_full;\n        r_pop_fire      = pop  && !r_empty;\n\n        w_count_bin_next = w_count_bin + (w_push_fire ? 1'b1 : 1'b0);\n        r_count_bin_next = r_count_bin - (r_pop_fire  ? 1'b1 : 1'b0);\n\n        w_ptr_next      = bin2gray(w_count_bin_next);\n        r_ptr_next      = bin2gray(r_count_bin_next);\n\n        w_full_next     = ((w_count_bin_next - wq2_rbin) >= DEPTH);\n        r_empty_next    = (r_count_bin_next == rq2_wbin);\n    end\n\n    always_ff @(posedge w_clk) begin\n        if (w_rst) begin\n            w_count_bin <= '0;\n            w_ptr       <= '0;\n            wq1_rptr    <= '0;\n            wq2_rptr    <= '0;\n            w_full      <= 1'b0;\n        end else begin\n            wq1_rptr <= r_ptr;\n            wq2_rptr <= wq1_rptr;\n\n            if (w_push_fire) begin\n                mem[addr_from_count(w_count_bin)] <= w_data;\n                w_count_bin <= w_count_bin_next;\n                w_ptr       <= w_ptr_next;\n            end\n\n            w_full <= w_full_next;\n        end\n    end\n\n    always_ff @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= '0;\n            r_ptr       <= '0;\n            rq1_wptr    <= '0;\n            rq2_wptr    <= '0;\n            r_empty     <= 1'b1;\n        end else begin\n            rq1_wptr <= w_ptr;\n            rq2_wptr <= rq1_wptr;\n\n            if (r_pop_fire) begin\n                r_count_bin <= r_count_bin_next;\n                r_ptr       <= r_ptr_next;\n            end\n\n            r_empty <= r_empty_next;\n        end\n    end\n\n    always_comb begin\n        if (r_count_bin == rq2_wbin)\n            r_data = '0;\n        else\n            r_data = mem[top_addr_from_count(r_count_bin)];\n    end\n\nendmodule\nSV\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
