Sending keys: ["cat > src/pseudoRandGenerator_ca.sv <<'EOF'\nmodule pseudoRandGenerator_ca (\n    input  logic        clock,\n    input  logic        reset,\n    input  logic [15:0] CA_seed,\n    input  logic [1:0]  rule_sel,\n    output logic [15:0] CA_out\n);\n\n    logic [15:0] next_CA_out;\n\n    function automatic logic compute_next_bit(\n        input logic [15:0] current_state,\n        input int          idx,\n        input logic [1:0]  selected_rule\n    );\n        logic left_bit;\n        logic center_bit;\n        logic right_bit;\n        logic [2:0] neighborhood;\n        begin\n            left_bit     = current_state[(idx == 0) ? 15 : (idx - 1)];\n            center_bit   = current_state[idx];\n            right_bit    = current_state[(idx == 15) ? 0 : (idx + 1)];\n            neighborhood = {left_bit, center_bit, right_bit};\n\n            case (selected_rule)\n                2'b01: begin\n                    case (neighborhood)\n                        3'b111: compute_next_bit = 1'b0;\n                        3'b110: compute_next_bit = 1'b1;\n                        3'b101: compute_next_bit = 1'b1;\n                        3'b100: compute_next_bit = 1'b0;\n                        3'b011: compute_next_bit = 1'b1;\n                        3'b010: compute_next_bit = 1'b1;\n                        3'b001: compute_next_bit = 1'b1;\n                        3'b000: compute_next_bit = 1'b0;\n                        default: compute_next_bit = 1'b0;\n                    endcase\n                end\n                default: begin\n                    case (neighborhood)\n                        3'b111: compute_next_bit = 1'b0;\n                        3'b110: compute_next_bit = 1'b0;\n                        3'b101: compute_next_bit = 1'b0;\n                        3'b100: compute_next_bit = 1'b1;\n                        3'b011: compute_next_bit = 1'b1;\n                        3'b010: compute_next_bit = 1'b1;\n                        3'b001: compute_next_bit = 1'b1;\n                        3'b000: compute_next_bit = 1'b0;\n                        default: compute_next_bit = 1'b0;\n                    endcase\n                end\n            endcase\n        end\n    endfunction\n\n    always_comb begin\n        for (int i = 0; i < 16; i++) begin\n            next_CA_out[i] = compute_next_bit(CA_out, i, rule_sel);\n        end\n    end\n\n    always_ff @(posedge clock) begin\n        if (reset) begin\n            CA_out <= CA_seed;\n        end else begin\n            CA_out <= next_CA_out;\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
