Sending keys: ["cat > /code/rtl/security_module.v <<'EOF'\nmodule security_module #(\n    parameter p_unlock_code_0 = 8'hAB,\n    parameter p_unlock_code_1 = 8'hCD\n) (\n    input  wire       i_capture_pulse,\n    input  wire       presetn,\n    input  wire [9:0] paddr,\n    input  wire       pwrite,\n    input  wire [7:0] pwdata,\n    output reg        secure_unlocked\n);\n\n    localparam ST_LOCKED   = 2'd0;\n    localparam ST_STAGE1   = 2'd1;\n    localparam ST_UNLOCKED = 2'd2;\n\n    reg [1:0] state;\n\n    always @(posedge i_capture_pulse or negedge presetn) begin\n      if (!presetn) begin\n        state           <= ST_LOCKED;\n        secure_unlocked <= 1'b0;\n      end else begin\n        case (state)\n          ST_LOCKED: begin\n            secure_unlocked <= 1'b0;\n            if (pwrite && (paddr == 10'd0) && (pwdata == p_unlock_code_0))\n              state <= ST_STAGE1;\n            else\n              state <= ST_LOCKED;\n          end\n\n          ST_STAGE1: begin\n            secure_unlocked <= 1'b0;\n            if (pwrite && (paddr == 10'd1) && (pwdata == p_unlock_code_1))\n              state <= ST_UNLOCKED;\n            else\n              state <= ST_LOCKED;\n          end\n\n          ST_UNLOCKED: begin\n            state           <= ST_UNLOCKED;\n            secure_unlocked <= 1'b1;\n          end\n\n          default: begin\n            state           <= ST_LOCKED;\n            secure_unlocked <= 1'b0;\n          end\n        endcase\n      end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
