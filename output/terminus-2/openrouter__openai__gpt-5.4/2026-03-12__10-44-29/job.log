ff_imag [0:TAP_NUM-1]\n);\n\n    localparam int CENTER_TAP = TAP_NUM/2;\n    localparam logic signed [COEFF_WIDTH-1:0] ONE_Q213 = 16\'sd8192;\n    localparam logic signed [COEFF_WIDTH-1:0] COEFF_MAX = {1\'b0, {(COEFF_WIDTH-1){1\'b1}}};\n    localparam logic signed [COEFF_WIDTH-1:0] COEFF_MIN = {1\'b1, {(COEFF_WIDTH-1){1\'b0}}};\n\n    logic signed [COEFF_WIDTH-1:0] coeff_real_next [0:TAP_NUM-1];\n    logic signed [COEFF_WIDTH-1:0] coeff_imag_next [0:TAP_NUM-1];\n\n    function automatic logic signed [COEFF_WIDTH-1:0] sat_coeff(\n        input logic signed [COEFF_WIDTH+1:0] v\n    );\n        begin\n            if (v > COEFF_MAX)\n                sat_coeff = COEFF_MAX;\n            else if (v < COEFF_MIN)\n                sat_coeff = COEFF_MIN;\n            else\n                sat_coeff = v[COEFF_WIDTH-1:0];\n        end\n    endfunction\n\n    function automatic logic signed [DATA_WIDTH-1:0] qmul(\n        input logic signed [DATA_WIDTH-1:0] a,\n        input logic signed [DATA_WIDTH-1:0] b\n    );\n        logic signed [2*DATA_WIDTH-1:0] mult;\n        logic signed [2*DATA_WIDTH-1:0] scaled;\n        begin\n            mult   = a * b;\n            scaled = mult >>> FRAC_BITS;\n            if (scaled > $signed({1\'b0, {(DATA_WIDTH-1){1\'b1}}}))\n                qmul = {1\'b0, {(DATA_WIDTH-1){1\'b1}}};\n            else if (scaled < $signed({1\'b1, {(DATA_WIDTH-1){1\'b0}}}))\n                qmul = {1\'b1, {(DATA_WIDTH-1){1\'b0}}};\n            else\n                qmul = scaled[DATA_WIDTH-1:0];\n        end\n    endfunction\n\n    integer i;\n    logic signed [DATA_WIDTH-1:0] grad_real;\n    logic signed [DATA_WIDTH-1:0] grad_imag;\n    logic signed [DATA_WIDTH-1:0] step_real;\n    logic signed [DATA_WIDTH-1:0] step_imag;\n    logic signed [COEFF_WIDTH+1:0] acc_real;\n    logic signed [COEFF_WIDTH+1:0] acc_imag;\n\n    always_comb begin\n        for (i = 0; i < TAP_NUM; i++) begin\n            // LMS complex update using x* :\n            // w <- w + mu * e * con