nt = 1;\n                                        end else if (numeric_count == 1) begin\n                                            digit1 = buffer[i];\n                                            numeric_count = 2;\n                                        end\n                                    end\n                                end\n                            end\n\n                            if (numeric_count == 2) begin\n                                tens_digit = digit0 - 8'h30;\n                                ones_digit = digit1 - 8'h30;\n                                data_out_bin <= ((tens_digit * 10) + ones_digit)[7:0];\n                                data_bin_valid <= 1'b1;\n                            end\n                        end\n                    end\n\n                    state <= STATE_IDLE;\n                    buffer_index <= 7'd0;\n                end\n\n                default: begin\n                    state <= STATE_IDLE;\n                    buffer_index <= 7'd0;\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
