tate;\n            n_out <= ((pulse_code == 2'b01) && output_gate_in) ? pulse_active_state : ~pulse_active_state;\n        end\n    end\nendmodule\nSV\niverilog -g2012 -o /tmp/hdbn_simv /code/rtl/hdbn_top.sv /code/rtl/hdbn_encoder.sv /code/rtl/hdbn_decoder.sv\ncd /code/src && PYTHONPATH=/code/src COCOTB_TEST_MODULES=test_hdbn_top TOPLEVEL=hdbn_top COCOTB_TOPLEVEL=hdbn_top COCOTB_LOG_LEVEL=INFO vvp -M /usr/local/lib/python3.9/dist-packages/cocotb/libs -m libcocotbvpi_icarus /tmp/hdbn_simv\n"] min_timeout_sec: 30.0 max_timeout_sec: 180.0
