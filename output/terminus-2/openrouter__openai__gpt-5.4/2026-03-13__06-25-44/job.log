watchdog_count <= 32'd0;\n                end else if (watchdog_count >= WATCHDOG_TIMEOUT_CYCLES - 1) begin\n                    watchdog_timeout <= 1'b1;\n                    watchdog_count <= 32'd0;\n                    state <= STATE_IDLE;\n                    buffer_index <= 7'd0;\n                    timeout_hit = 1'b1;\n                end else begin\n                    watchdog_count <= watchdog_count + 1'b1;\n                end\n            end else begin\n                watchdog_count <= 32'd0;\n            end\n\n            if (!timeout_hit) begin\n                case (state)\n                    STATE_IDLE: begin\n                        buffer_index <= 7'd0;\n                        if (serial_valid && is_start) begin\n                            state <= STATE_PARSE;\n                            buffer_index <= 7'd0;\n                        end\n                    end\n\n                    STATE_PARSE: begin\n                        if (serial_valid) begin\n                            if (is_end) begin\n                                state <= STATE_OUTPUT;\n                            end else if (buffer_index < (MAX_BUFFER_SIZE-1)) begin\n                                buffer[buffer_index] <= serial_in;\n                                buffer_index <= buffer_index + 1'b1;\n                            end else begin\n                                error_overflow <= 1'b1;\n                                state <= STATE_IDLE;\n                                buffer_index <= 7'd0;\n                            end\n                        end\n                    end\n\n                    STATE_OUTPUT: begin\n                        sentence_match = 1'b0;\n                        end_idx = buffer_index;\n                        numeric_count = 0;\n                        value_tmp = 0;\n                        digit_a = 8'd0;\n                        digit_b = 8'd0;\n\n                        if (buffer_index >= 7'd6 &&\n                        