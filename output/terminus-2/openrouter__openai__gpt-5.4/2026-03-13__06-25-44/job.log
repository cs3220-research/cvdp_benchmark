               endcase\n                        state <= STOP1;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP1: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count <= '0;\n                        if (STOP_BITS_NUM == 2) begin\n                            state <= STOP2;\n                        end else begin\n                            tdata  <= data_shift_reg;\n                            tuser  <= parity_error;\n                            tvalid <= 1'b1;\n                            state  <= IDLE;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                STOP2: begin\n                    if (clk_count == CYCLES_PER_PERIOD-1) begin\n                        clk_count <= '0;\n                        tdata  <= data_shift_reg;\n                        tuser  <= parity_error;\n                        tvalid <= 1'b1;\n                        state  <= IDLE;\n                    end else begin\n                        clk_count <= clk_count + 1'b1;\n                    end\n                end\n\n                OUT_RDY: begin\n                    tdata  <= data_shift_reg;\n                    tuser  <= parity_error;\n                    tvalid <= 1'b1;\n                    state  <= IDLE;\n                end\n\n                default: begin\n                    state <= IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nSV\ncp src/uart_rx_to_axis.sv rtl/uart_rx_to_axis.sv\nsed -n '1,260p' src/uart_rx_to_axis.sv\n. ./cvdp_harness_env.sh && pytest -q src/test_runner.py -s\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
