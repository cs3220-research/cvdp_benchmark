Sending keys: ["mkdir -p /code/rtl\ncat > /code/rtl/hdbn_encoder.sv <<'SV'\nmodule hdbn_encoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out\n);\n\n    localparam integer N = (encoder_type == 2) ? 2 : 3;\n\n    logic last_polarity_pos;\n    integer zero_count;\n    integer pulse_count_since_violation;\n\n    integer sched_len;\n    integer sched_idx;\n    logic [1:0] sched_mem [0:3];\n\n    logic [1:0] pulse_code;\n    logic b_pol_pos;\n    logic v_pol_pos;\n\n    function automatic logic [1:0] code_from_pol(input logic pol_pos);\n        begin\n            code_from_pol = pol_pos ? 2'b10 : 2'b01; // 10=>P, 01=>N\n        end\n    endfunction\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            last_polarity_pos <= 1'b0;\n            zero_count <= 0;\n            pulse_count_since_violation <= 0;\n            sched_len <= 0;\n            sched_idx <= 0;\n            p_out <= ~pulse_active_state;\n            n_out <= ~pulse_active_state;\n        end else if (clk_enable_in) begin\n            pulse_code = 2'b00;\n\n            if (sched_idx < sched_len) begin\n                pulse_code = sched_mem[sched_idx];\n                sched_idx <= sched_idx + 1;\n                if ((sched_idx + 1) >= sched_len) begin\n                    sched_len <= 0;\n                    sched_idx <= 0;\n                end\n\n                if (pulse_code != 2'b00) begin\n                    if (pulse_code == 2'b10)\n                        last_polarity_pos <= 1'b1;\n                    else if (pulse_code == 2'b01)\n                        last_polarity_pos <= 1'b0;\n                end\n            end else begin\n                if (data_in) begin\n                    zero_count <= 0;\n                    pulse_code = code_from_pol(~last_polarity_pos);\n                    last_polarity_pos <= ~last_polarity_pos;\n                    pulse_count_since_violation <= pulse_count_since_violation + 1;\n                end else begin\n                    if (zero_count == (N-1)) begin\n                        zero_count <= 0;\n\n                        if (N == 2) begin\n                            b_pol_pos = ~last_polarity_pos;\n                            v_pol_pos = b_pol_pos;\n                            pulse_code = code_from_pol(b_pol_pos);\n                            sched_mem[0] <= 2'b00;\n                            sched_mem[1] <= code_from_pol(v_pol_pos);\n                            sched_len <= 2;\n                            sched_idx <= 0;\n                            last_polarity_pos <= b_pol_pos;\n                            pulse_count_since_violation <= 0;\n                        end else begin\n                            if (pulse_count_since_violation[0] == 1'b0) begin\n                                v_pol_pos = last_polarity_pos;\n                                pulse_code = 2'b00;\n                                sched_mem[0] <= 2'b00;\n                                sched_mem[1] <= 2'b00;\n                                sched_mem[2] <= code_from_pol(v_pol_pos);\n                                sched_len <= 3;\n                                sched_idx <= 0;\n                                last_polarity_pos <= v_pol_pos;\n                            end else begin\n                                b_pol_pos = ~last_polarity_pos;\n                                v_pol_pos = b_pol_pos;\n                                pulse_code = code_from_pol(b_pol_pos);\n                                sched_mem[0] <= 2'b00;\n                                sched_mem[1] <= 2'b00;\n                                sched_mem[2] <= code_from_pol(v_pol_pos);\n                                sched_len <= 3;\n                                sched_idx <= 0;\n                                last_polarity_pos <= b_pol_pos;\n                            end\n                            pulse_count_since_violation <= 0;\n                        end\n                    end else begin\n                        zero_count <= zero_count + 1;\n                        pulse_code = 2'b00;\n                    end\n                end\n            end\n\n            p_out <= ((pulse_code == 2'b10) && output_gate_in) ? pulse_active_state : ~pulse_active_state;\n            n_out <= ((pulse_code == 2'b01) && output_gate_in) ? pulse_active_state : ~pulse_active_state;\n        end\n    end\nendmodule\nSV\ncat > /code/rtl/hdbn_decoder.sv <<'SV'\nmodule hdbn_decoder #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    localparam integer N = (encoder_type == 2) ? 2 : 3;\n    localparam integer DECODE_DELAY = 3 + (2 * N);\n\n    logic p_act, n_act;\n    logic pulse_present;\n    logic pulse_pol_pos;\n    logic last_polarity_pos;\n    integer zero_count;\n    logic [DECODE_DELAY-1:0] data_pipe;\n    logic violation_seen;\n\n    always_ff @(posedge clk_in or posedge reset_in) begin\n        if (reset_in) begin\n            data_out <= 1'b0;\n            code_error_out <= 1'b0;\n            last_polarity_pos <= 1'b0;\n            zero_count <= 0;\n            data_pipe <= '0;\n            violation_seen <= 1'b0;\n        end else if (clk_enable_in) begin\n            p_act = (p_in == pulse_active_state);\n            n_act = (n_in == pulse_active_state);\n            pulse_present = p_act ^ n_act;\n            pulse_pol_pos = p_act;\n\n            code_error_out <= 1'b0;\n\n            if (p_act && n_act) begin\n                code_error_out <= 1'b1;\n            end\n\n            if (pulse_present) begin\n                zero_count <= 0;\n                if (pulse_pol_pos == last_polarity_pos)\n                    violation_seen <= 1'b1;\n                else\n                    violation_seen <= 1'b0;\n                last_polarity_pos <= pulse_pol_pos;\n                data_pipe <= {data_pipe[DECODE_DELAY-2:0], 1'b1};\n            end else begin\n                zero_count <= zero_count + 1;\n                if (zero_count >= N)\n                    code_error_out <= 1'b1;\n                data_pipe <= {data_pipe[DECODE_DELAY-2:0], 1'b0};\n                violation_seen <= 1'b0;\n            end\n\n            data_out <= data_pipe[DECODE_DELAY-1];\n        end\n    end\nendmodule\nSV\ncat > /code/rtl/hdbn_top.sv <<'SV'\nmodule hdbn_top #(\n    parameter integer encoder_type = 3,\n    parameter logic   pulse_active_state = 1'b1\n) (\n    input  logic reset_in,\n    input  logic clk_in,\n    input  logic clk_enable_in,\n    input  logic data_in,\n    input  logic output_gate_in,\n    output logic p_out,\n    output logic n_out,\n    input  logic p_in,\n    input  logic n_in,\n    output logic data_out,\n    output logic code_error_out\n);\n\n    hdbn_encoder #(\n        .encoder_type(encoder_type),\n        .pulse_active_state(pulse_active_state)\n    ) u_hdbn_encoder (\n        .reset_in(reset_in),\n        .clk_in(clk_in),\n        .clk_enable_in(clk_enable_in),\n        .data_in(data_in),\n        .output_gate_in(output_gate_in),\n        .p_out(p_out),\n        .n_out(n_out)\n    );\n\n    hdbn_decoder #(\n        .encoder_type(encoder_type),\n        .pulse_active_state(pulse_active_state)\n    ) u_hdbn_decoder (\n        .reset_in(reset_in),\n        .clk_in(clk_in),\n        .clk_enable_in(clk_enable_in),\n        .p_in(p_in),\n        .n_in(n_in),\n        .data_out(data_out),\n        .code_error_out(code_error_out)\n    );\nendmodule\nSV\ncd /code/src && set -a && . ./.env && set +a && pytest -q test_runner.py -s\n"] min_timeout