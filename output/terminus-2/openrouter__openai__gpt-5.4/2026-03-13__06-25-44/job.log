ase (PARITY_BIT)\n                            1: parity_error <= (RX != (~^data_shift_reg));\n                            2: parity_error <= (RX != (^data_shift_reg));\n                            default: parity_error <= 1'b0;\n                        endcase\n                        state <= STOP1;\n                    end else begin\n                        sample_count <= sample_count - 1'b1;\n                    end\n                end\n\n                STOP1: begin\n                    if (sample_now) begin\n                        if (STOP_BITS_NUM == 2) begin\n                            sample_count <= CYCLES_PER_PERIOD - 1;\n                            state        <= STOP2;\n                        end else begin\n                            tdata  <= data_shift_reg;\n                            tuser  <= parity_error;\n                            tvalid <= 1'b1;\n                            state  <= IDLE;\n                        end\n                    end else begin\n                        sample_count <= sample_count - 1'b1;\n                    end\n                end\n\n                STOP2: begin\n                    if (sample_now) begin\n                        tdata  <= data_shift_reg;\n                        tuser  <= parity_error;\n                        tvalid <= 1'b1;\n                        state  <= IDLE;\n                    end else begin\n                        sample_count <= sample_count - 1'b1;\n                    end\n                end\n\n                OUT_RDY: begin\n                    tdata  <= data_shift_reg;\n                    tuser  <= parity_error;\n                    tvalid <= 1'b1;\n                    state  <= IDLE;\n                end\n\n                default: begin\n                    state <= IDLE;\n                end\n            endcase\n        end\n    end\n\nendmodule\nSV\ncp src/uart_rx_to_axis.sv rtl/uart_rx_to_axis.sv\nsed -n '1,240p' src/uart_rx_to_axis.sv\n"] min_timeout_sec: 0.1 max_t