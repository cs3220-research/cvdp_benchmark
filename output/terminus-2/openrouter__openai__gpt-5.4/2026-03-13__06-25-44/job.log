Sending keys: ["cat > src/nbit_swizzling.sv <<'EOF'\nmodule nbit_swizzling #(\n    parameter int DATA_WIDTH = 64\n) (\n    input  logic [DATA_WIDTH-1:0] data_in,\n    input  logic [1:0]            sel,\n    output logic [DATA_WIDTH-1:0] data_out,\n    output logic [DATA_WIDTH-1:0] gray_out\n);\n\n    int segment_count;\n    int segment_width;\n    int seg;\n    int idx;\n    int base;\n\n    always_comb begin\n        // Default outputs to known values before mode-specific logic.\n        data_out = data_in;\n        gray_out = '0;\n\n        // Determine how many independent segments are reversed.\n        // 00 -> 1 full-width segment\n        // 01 -> 2 half-width segments\n        // 10 -> 4 quarter-width segments\n        // 11 -> 8 eighth-width segments\n        unique case (sel)\n            2'b00: segment_count = 1;\n            2'b01: segment_count = 2;\n            2'b10: segment_count = 4;\n            2'b11: segment_count = 8;\n            default: segment_count = 0;\n        endcase\n\n        // Implement the requested swizzle only when DATA_WIDTH can be evenly\n        // divided into the selected number of segments. Otherwise retain the\n        // pass-through default for data_out.\n        if ((segment_count > 0) && ((DATA_WIDTH % segment_count) == 0)) begin\n            segment_width = DATA_WIDTH / segment_count;\n\n            for (seg = 0; seg < segment_count; seg++) begin\n                base = seg * segment_width;\n                for (idx = 0; idx < segment_width; idx++) begin\n                    // Reverse bits within each selected segment while keeping\n                    // segment placement unchanged in the output bus.\n                    data_out[base + idx] = data_in[base + (segment_width - 1 - idx)];\n                end\n            end\n        end\n\n        // Binary-to-Gray conversion of the swizzled output.\n        // MSB passes through unchanged; each lower bit is XOR of adjacent bits.\n        gray_out[DATA_WIDTH-1] = data_out[DATA_WIDTH-1];\n        for (idx = DATA_WIDTH-2; idx >= 0; idx--) begin\n            gray_out[idx] = data_out[idx+1] ^ data_out[idx];\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
