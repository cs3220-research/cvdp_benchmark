     state <= STATE_IDLE;\n                        buffer_index <= 7'd0;\n                    end\n\n                    default: begin\n                        state <= STATE_IDLE;\n                        buffer_index <= 7'd0;\n                    end\n                endcase\n            end\n        end\n    end\n\nendmodule\nEOF\niverilog -g2012 -o /tmp/nmea_tb verif/nmea_decoder_tb.sv rtl/nmea_decoder.sv && vvp /tmp/nmea_tb\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
