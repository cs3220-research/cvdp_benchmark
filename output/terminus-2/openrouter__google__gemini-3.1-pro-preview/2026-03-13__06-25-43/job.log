n_q_reg) begin\n          phase_ext = lut_val;\n      end else if (!sign_i_reg && sign_q_reg) begin\n          phase_ext = -lut_val;\n      end else if (sign_i_reg && !sign_q_reg) begin\n          phase_ext = 11\\\'sd256 - lut_val;\n      end else begin\n          phase_ext = lut_val - 11\\\'sd256;\n      end\n      o_phase = phase_ext[NBW_PHASE-1:0];\n  end\n\nendmodule\n\'\'\')\nEOF\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
