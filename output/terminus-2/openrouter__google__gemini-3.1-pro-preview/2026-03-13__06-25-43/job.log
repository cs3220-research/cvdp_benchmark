q_reg) begin\n          o_phase = -lut_val;\n      end else if (sign_i_reg && !sign_q_reg) begin\n          o_phase = 9\\'d256 - lut_val;\n      end else begin\n          o_phase = lut_val - 9\\'d256;\n      end\n  end\n\nendmodule\n''')\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
