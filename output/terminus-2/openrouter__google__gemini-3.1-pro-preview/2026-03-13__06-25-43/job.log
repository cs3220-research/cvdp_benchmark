nt k = 0; k < NS_FAW; k++) begin\n                    extracted_data_i[k*NBW_DATA_SYMB +: NBW_DATA_SYMB] <= i_data_i[(i_proc_pos + k)*NBW_DATA_SYMB +: NBW_DATA_SYMB];\n                    extracted_data_q[k*NBW_DATA_SYMB +: NBW_DATA_SYMB] <= i_data_q[(i_proc_pos + k)*NBW_DATA_SYMB +: NBW_DATA_SYMB];\n                end\n            end\n        end\n    end\n\n    // Conjugate Selection\n    logic [NS_FAW-1:0] conj_seq_i;\n    logic [NS_FAW-1:0] conj_seq_q;\n\n    always_comb begin\n        if (proc_pol_reg) begin // Vertical\n            conj_seq_i = 23'b10011000010100101101011;\n            conj_seq_q = 23'b00101010110010110110010;\n        end else begin          // Horizontal\n            conj_seq_i = 23'b00110010010100011001010;\n            conj_seq_q = 23'b00001010101110101101011;\n        end\n    end\n\n    // Cross-Correlation Module Instantiation\n    logic [NBW_ENERGY-1:0] energy_out;\n    \n    cross_correlation #(\n        .NS_DATA_IN (NS_FAW),\n        .NBW_DATA_IN(NBW_DATA_SYMB),\n        .NBI_DATA_IN(NBI_DATA_SYMB),\n        .NBW_ENERGY (NBW_ENERGY)\n    ) u_cross_correlation (\n        .clk         (clk),\n        .i_enable    (enable_pipe[0]),\n        .i_data_i    (extracted_data_i),\n        .i_data_q    (extracted_data_q),\n        .i_conj_seq_i(conj_seq_i),\n        .i_conj_seq_q(conj_seq_q),\n        .o_energy    (energy_out)\n    );\n\n    // Cross-Correlation Output Processing\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            o_proc_detected <= 1'b0;\n        end else begin\n            if (enable_pipe[1] && (energy_out >= i_static_threshold)) begin\n                o_proc_detected <= 1'b1;\n            end else begin\n                o_proc_detected <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
