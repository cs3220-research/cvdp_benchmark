Sending keys: ["cat << 'EOF' > rtl/cross_domain_sync.sv\nmodule cross_domain_sync #(\n    parameter DATA_WIDTH = 16\n)(\n    input  wire                   clk_src,\n    input  wire                   clk_dst,\n    input  wire                   rst_n,\n    input  wire [DATA_WIDTH-1:0] data_src,\n    input  wire                   valid_src,\n\n    output wire [DATA_WIDTH-1:0] data_dst,\n    output wire                   valid_dst\n);\n\n    reg [DATA_WIDTH-1:0] mem [0:7];\n    reg [3:0] wptr, rptr;\n    wire [3:0] wptr_gray = wptr ^ (wptr >> 1);\n    wire [3:0] rptr_gray = rptr ^ (rptr >> 1);\n\n    reg [3:0] wptr_gray_sync1, wptr_gray_sync2;\n    reg [3:0] rptr_gray_sync1, rptr_gray_sync2;\n\n    wire full = (wptr_gray == {~rptr_gray_sync2[3:2], rptr_gray_sync2[1:0]});\n    wire empty = (rptr_gray == wptr_gray_sync2);\n\n    always @(posedge clk_src or negedge rst_n) begin\n        if (!rst_n) begin\n            wptr <= 0;\n        end else if (valid_src && !full) begin\n            mem[wptr[2:0]] <= data_src;\n            wptr <= wptr + 1;\n        end\n    end\n\n    always @(posedge clk_dst or negedge rst_n) begin\n        if (!rst_n) begin\n            wptr_gray_sync1 <= 0;\n            wptr_gray_sync2 <= 0;\n        end else begin\n            wptr_gray_sync1 <= wptr_gray;\n            wptr_gray_sync2 <= wptr_gray_sync1;\n        end\n    end\n\n    always @(posedge clk_dst or negedge rst_n) begin\n        if (!rst_n) begin\n            rptr <= 0;\n        end else if (!empty) begin\n            rptr <= rptr + 1;\n        end\n    end\n\n    always @(posedge clk_src or negedge rst_n) begin\n        if (!rst_n) begin\n            rptr_gray_sync1 <= 0;\n            rptr_gray_sync2 <= 0;\n        end else begin\n            rptr_gray_sync1 <= rptr_gray;\n            rptr_gray_sync2 <= rptr_gray_sync1;\n        end\n    end\n\n    assign valid_dst = !empty;\n    assign data_dst = mem[rptr[2:0]];\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
