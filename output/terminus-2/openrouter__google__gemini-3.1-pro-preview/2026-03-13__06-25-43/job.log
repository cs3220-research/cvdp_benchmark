Sending keys: ["cat << 'EOF' > rtl/sync_serial_communication_top.sv\n/**\n * Transmitter Block (tx_block)\n * \n * Function: Converts a 64-bit parallel input (data_in) into a serial bitstream,\n *           governed by the selection signal (sel).\n * Operation:\n * - Depending on sel, 8, 16, 32, or 64 bits are shifted out.\n * - Generates a serial clock (serial_clk) which is a gated version of clk.\n * - Asserts 'done' when the transmission is complete.\n */\nmodule tx_block (\n    input  logic        clk,\n    input  logic        reset_n,\n    input  logic [63:0] data_in,\n    input  logic [2:0]  sel,\n    output logic        serial_out,\n    output logic        done,\n    output logic        serial_clk\n);\n\n    logic [6:0]  bit_count;\n    logic [63:0] data_reg;\n    logic        active;\n    logic        gate;\n\n    // Gate signal for the serial clock, ensuring it aligns with the data transmission\n    always_ff @(negedge clk or negedge reset_n) begin\n        if (!reset_n) begin\n            gate <= 1'b0;\n        end else begin\n            gate <= active;\n        end\n    end\n\n    // Gated clock generation for the receiver\n    assign serial_clk = clk & gate;\n\n    // Transmission logic\n    always_ff @(posedge clk or negedge reset_n) begin\n        if (!reset_n) begin\n            bit_count  <= 7'd0;\n            data_reg   <= 64'd0;\n            serial_out <= 1'b0;\n            done       <= 1'b1;\n            active     <= 1'b0;\n        end else begin\n            if (done) begin\n                // Start a new transmission if sel is non-zero\n                if (sel != 3'd0) begin\n                    case (sel)\n                        3'd1: bit_count <= 7'd7;   // 8 bits\n                        3'd2: bit_count <= 7'd15;  // 16 bits\n                        3'd3: bit_count <= 7'd31;  // 32 bits\n                        3'd4: bit_count <= 7'd63;  // 64 bits\n                        default: bit_count <= 7'd0;\n                    endcase\n                    data_reg <= {1'b0, data_in[63:1]};\n                    serial_out <= data_in[0];\n                    done <= 1'b0;\n                    active <= 1'b1;\n                end\n            end else begin\n                // Continue shifting bits\n                if (bit_count > 7'd0) begin\n                    serial_out <= data_reg[0];\n                    data_reg   <= {1'b0, data_reg[63:1]};\n                    bit_count  <= bit_count - 7'd1;\n                end else begin\n                    // Transmission complete\n                    active <= 1'b0;\n                    done   <= 1'b1;\n                end\n            end\n        end\n    end\nendmodule\n\n\n/**\n * Receiver Block (rx_block)\n * \n * Function: Reassembles the serial bitstream into parallel form and asserts\n *           'done' once complete.\n * Operation:\n * - Samples incoming data on the rising edge of serial_clk.\n * - Counts the received bits based on the expected width (sel).\n * - Outputs the reconstructed data (data_out).\n */\nmodule rx_block (\n    input  logic        clk,\n    input  logic        reset_n,\n    input  logic        data_in,\n    input  logic        serial_clk,\n    input  logic [2:0]  sel,\n    output logic        done,\n    output logic [63:0] data_out\n);\n\n    logic [6:0]  bit_count;\n    logic [63:0] shift_reg;\n    logic [6:0]  expected_bits;\n\n    // Determine the expected number of bits based on sel\n    always_comb begin\n        case (sel)\n            3'd1: expected_bits = 7'd8;\n            3'd2: expected_bits = 7'd16;\n            3'd3: expected_bits = 7'd32;\n            3'd4: expected_bits = 7'd64;\n            default: expected_bits = 7'd0;\n        endcase\n    end\n\n    // Reception logic using serial_clk\n    always_ff @(posedge serial_clk or negedge reset_n) begin\n        if (!reset_n) begin\n            bit_count <= 7'd0;\n            shift_reg <= 64'd0;\n            done      <= 1'b0;\n            data_out  <= 64'd0;\n        end else begin\n            shift_reg[bit_count] <= data_in;\n            if (bit_count == expected_bits - 7'd1) begin\n                // All expected bits received\n                bit_count <= 7'd0;\n                done      <= 1'b1;\n                case (sel)\n                    3'd1: data_out <= {56'd0, data_in, shift_reg[6:0]};\n                    3'd2: data_out <= {48'd0, data_in, shift_reg[14:0]};\n                    3'd3: data_out <= {32'd0, data_in, shift_reg[30:0]};\n                    3'd4: data_out <= {data_in, shift_reg[62:0]};\n                    default: data_out <= 64'd0;\n                endcase\n            end else begin\n                // Continue receiving bits\n                bit_count <= bit_count + 7'd1;\n                done      <= 1'b0;\n            end\n        end\n    end\nendmodule\n\n\n/**\n * Binary to Gray Code Conversion\n * \n * Function: Converts the parallel binary data into Gray code.\n * Operation:\n * - The highest bit is copied directly.\n * - Each subsequent bit is computed as data[j+1] ^ data[j].\n */\nmodule binary_to_gray_conversion (\n    input  logic [63:0] data,\n    output logic [63:0] gray_out\n);\n    // Combinational conversion\n    assign gray_out = data ^ (data >> 1);\nendmodule\n\n\n/**\n * Top Module (sync_serial_communication_tx_rx)\n * \n * Function: Integrates tx_block, rx_block, and binary_to_gray_conversion to form\n *           a complete synchronous serial communication system.\n * Operation:\n * - Parallel data is serialized according to the bits selected by sel, sent out\n *   on serial_out, and reassembled in the receiver.\n * - Upon completion, the received data is transformed into Gray code.\n */\nmodule sync_serial_communication_tx_rx (\n    input  logic        clk,\n    input  logic        reset_n,\n    input  logic [2:0]  sel,\n    input  logic [63:0] data_in,\n    output logic [63:0] data_out,\n    output logic        done,\n    output logic [63:0] gray_out\n);\n\n    logic serial_data;\n    logic serial_clk;\n    logic tx_done;\n\n    // Instantiate Transmitter Block\n    tx_block tx_inst (\n        .clk        (clk),\n        .reset_n    (reset_n),\n        .data_in    (data_in),\n        .sel        (sel),\n        .serial_out (serial_data),\n        .done       (tx_done),\n        .serial_clk (serial_clk)\n    );\n\n    // Instantiate Receiver Block\n    rx_block rx_inst (\n        .clk        (clk),\n        .reset_n    (reset_n),\n        .data_in    (serial_data),\n        .serial_clk (serial_clk),\n        .sel        (sel),\n        .done       (done),\n        .data_out   (data_out)\n    );\n\n    // Instantiate Binary to Gray Code Converter\n    binary_to_gray_conversion b2g_inst (\n        .data     (data_out),\n        .gray_out (gray_out)\n    );\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
