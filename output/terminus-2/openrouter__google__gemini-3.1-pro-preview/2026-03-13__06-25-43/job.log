          if (axis_tready_in) begin\n                        bytes_left <= (bytes_left >= 16'd4) ? (bytes_left - 16'd4) : 16'd0;\n                        mem_ptr <= mem_ptr + 10'd1;\n                        if (bytes_left <= 16'd4 || !axis_tready_in) begin\n                            state <= PAUSE;\n                        end\n                    end else begin\n                        state <= PAUSE;\n                    end\n                end\n                PAUSE: begin\n                    if (bytes_left == 16'd0) begin\n                        state <= END_S;\n                    end else if (axis_tready_in) begin\n                        state <= READ;\n                    end\n                end\n                END_S: begin\n                    state <= IDLE;\n                end\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\n    // DP-RAM addr1_in logic\n    assign addr1_in = (state == IDLE) ? 10'd0 : mem_ptr;\n\n    // Data Padding Logic\n    logic [31:0] padded_data;\n    logic [15:0] current_byte_idx;\n    assign current_byte_idx = {4'd0, (mem_ptr - 10'd1), 2'b00};\n\n    always_comb begin\n        padded_data = data1_out;\n        if (current_byte_idx >= tx_length_reg) begin\n            padded_data = 32'd0;\n        end else begin\n            if (current_byte_idx + 16'd1 == tx_length_reg) padded_data[31:8] = 24'd0;\n            else if (current_byte_idx + 16'd2 == tx_length_reg) padded_data[31:16] = 16'd0;\n            else if (current_byte_idx + 16'd3 == tx_length_reg) padded_data[31:24] = 8'd0;\n        end\n    end\n\n    // AXI-Stream Outputs\n    assign axis_tvalid_out = (state == READ);\n    assign axis_tdata_out = padded_data;\n    assign axis_tlast_out = (state == READ) && (bytes_left <= 16'd4);\n    \n    always_comb begin\n        if (bytes_left >= 16'd4) axis_tstrb_out = 4'hF;\n        else if (bytes_left == 16'd3) axis_tstrb_out = 4'h7;\n        else if (bytes_left == 16'd2) axis_tstrb_out = 4