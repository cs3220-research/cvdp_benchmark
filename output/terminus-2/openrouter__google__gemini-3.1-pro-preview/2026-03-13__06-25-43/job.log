Sending keys: ["cat << 'EOF' > rtl/detect_sequence.sv\nmodule detect_sequence #(\n    parameter NS              = 64,\n    parameter NBW_PILOT_POS   = 6,\n    parameter NBW_DATA_IN     = 8,\n    parameter NBI_DATA_IN     = 2,\n    parameter NBW_TH_PROC     = 10,\n    parameter NBW_ENERGY      = 10,\n    parameter NS_PROC         = 23,\n    parameter NS_PROC_OVERLAP = 22\n) (\n    input  logic                                         clk,\n    input  logic                                         rst_async_n,\n    input  logic                                         i_valid,\n    input  logic                                         i_enable,\n    input  logic                                         i_proc_pol,\n    input  logic [NBW_PILOT_POS-1:0]                     i_proc_pos,\n    input  logic [NBW_TH_PROC-1:0]                       i_static_threshold,\n    input  logic [NBW_DATA_IN*(NS+NS_PROC_OVERLAP)-1:0]  i_data_i,\n    input  logic [NBW_DATA_IN*(NS+NS_PROC_OVERLAP)-1:0]  i_data_q,\n    output logic                                         o_proc_detected\n);\n\n    // Global enable\n    wire global_enable = i_valid & i_enable;\n\n    // Enable Pipeline\n    // The test expects proc_enable_dff to exist.\n    logic [2:0] proc_enable_dff;\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            proc_enable_dff <= '0;\n        end else begin\n            proc_enable_dff[0] <= global_enable;\n            proc_enable_dff[1] <= proc_enable_dff[0];\n            proc_enable_dff[2] <= proc_enable_dff[1];\n        end\n    end\n\n    // Input Data Buffering\n    logic signed [NBW_DATA_IN-1:0] proc_buffer_i_dff [NS_PROC-1:0];\n    logic signed [NBW_DATA_IN-1:0] proc_buffer_q_dff [NS_PROC-1:0];\n    logic proc_pol_dff;\n\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            proc_pol_dff <= 1'b0;\n        end else begin\n            if (global_enable) begin\n                proc_pol_dff <= i_proc_pol;\n                for (int k = 0; k < NS_PROC; k++) begin\n                    proc_buffer_i_dff[k] <= i_data_i[(i_proc_pos + k)*NBW_DATA_IN +: NBW_DATA_IN];\n                    proc_buffer_q_dff[k] <= i_data_q[(i_proc_pos + k)*NBW_DATA_IN +: NBW_DATA_IN];\n                end\n            end\n        end\n    end\n\n    // Flatten the buffered data for cross_correlation instantiation\n    logic [NBW_DATA_IN*NS_PROC-1:0] extracted_data_i;\n    logic [NBW_DATA_IN*NS_PROC-1:0] extracted_data_q;\n    always_comb begin\n        for (int k = 0; k < NS_PROC; k++) begin\n            extracted_data_i[k*NBW_DATA_IN +: NBW_DATA_IN] = proc_buffer_i_dff[k];\n            extracted_data_q[k*NBW_DATA_IN +: NBW_DATA_IN] = proc_buffer_q_dff[k];\n        end\n    end\n\n    // Conjugate Selection\n    logic [NS_PROC-1:0] conj_proc_seq [1:0]; // [0] for I, [1] for Q\n\n    always_comb begin\n        if (proc_pol_dff) begin // Vertical\n            conj_proc_seq[0] = 23'b10011000010100101101011;\n            conj_proc_seq[1] = 23'b00101010110010110110010;\n        end else begin          // Horizontal\n            conj_proc_seq[0] = 23'b00110010010100011001010;\n            conj_proc_seq[1] = 23'b00001010101110101101011;\n        end\n    end\n\n    // Cross-Correlation Module Instantiation\n    logic [NBW_ENERGY-1:0] proc_calc_energy;\n    \n    cross_correlation #(\n        .NS_DATA_IN (NS_PROC),\n        .NBW_DATA_IN(NBW_DATA_IN),\n        .NBI_DATA_IN(NBI_DATA_IN),\n        .NBW_ENERGY (NBW_ENERGY)\n    ) uu_cross_correlation (\n        .clk         (clk),\n        .i_enable    (proc_enable_dff[0]),\n        .i_data_i    (extracted_data_i),\n        .i_data_q    (extracted_data_q),\n        .i_conj_seq_i(conj_proc_seq[0]),\n        .i_conj_seq_q(conj_proc_seq[1]),\n        .o_energy    (proc_calc_energy)\n    );\n\n    // Cross-Correlation Output Processing\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            o_proc_detected <= 1'b0;\n        end else begin\n            if (proc_enable_dff[1] && (proc_calc_energy >= i_static_threshold)) begin\n                o_proc_detected <= 1'b1;\n            end else begin\n                o_proc_detected <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
