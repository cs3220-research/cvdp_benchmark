ndfunction\n\n    always @(posedge clock) begin\n        if (!reset) begin\n            state <= 0;\n            enc_done <= 0;\n            c <= 0;\n            A <= 0;\n            B <= 0;\n        end else begin\n            case (state)\n                3'd0: begin\n                    if ((enc_start || enc_start_latched) && keys_ready) begin\n                        enc_done <= 0;\n                        A <= p[15:8] + S[0];\n                        B <= p[7:0] + S[1];\n                        state <= 3'd1;\n                    end\n                end\n                3'd1: begin\n                    A <= rotl8(A ^ B, B[2:0]) + S[2];\n                    state <= 3'd2;\n                end\n                3'd2: begin\n                    B <= rotl8(B ^ A, A[2:0]) + S[3];\n                    state <= 3'd3;\n                end\n                3'd3: begin\n                    c <= {A, B};\n                    enc_done <= 1;\n                    state <= 3'd0;\n                end\n                default: state <= 3'd0;\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
