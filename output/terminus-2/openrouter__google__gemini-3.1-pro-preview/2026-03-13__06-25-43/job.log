Sending keys: ["cat << 'EOF' > rtl/poly_decimator.sv\n`timescale 1ns/1ps\n\nmodule poly_decimator #(\n  parameter M = 4,\n  parameter TAPS = 8,\n  parameter COEFF_WIDTH = 16,\n  parameter DATA_WIDTH = 16,\n  localparam ACC_WIDTH = DATA_WIDTH + COEFF_WIDTH + $clog2(TAPS),\n  localparam TOTAL_TAPS = M * TAPS\n)\n(\n  input  logic                              clk,\n  input  logic                              arst_n,\n  input  logic [DATA_WIDTH-1:0]             in_sample,\n  input  logic                              in_valid,\n  output logic                              in_ready,\n  output logic [ACC_WIDTH+$clog2(M)-1:0]    out_sample,\n  output logic                              out_valid\n);\n\n  typedef enum logic {\n    ACCUMULATE = 1'b0,\n    OUTPUT_ST  = 1'b1\n  } state_t;\n\n  state_t state;\n  logic [$clog2(M)-1:0] sample_cnt;\n\n  logic [ACC_WIDTH+$clog2(M)-1:0] tree_sum_out;\n  logic                           tree_valid_out;\n\n  assign in_ready = (state == ACCUMULATE);\n\n  // FSM and sample counter\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n) begin\n      state      <= ACCUMULATE;\n      sample_cnt <= '0;\n      out_valid  <= 1'b0;\n      out_sample <= '0;\n    end else begin\n      out_valid <= 1'b0; // Default: deassert after 1 cycle\n      \n      case (state)\n        ACCUMULATE: begin\n          if (in_valid && in_ready) begin\n            if (sample_cnt == M - 1) begin\n              state      <= OUTPUT_ST;\n              sample_cnt <= '0;\n            end else begin\n              sample_cnt <= sample_cnt + 1;\n            end\n          end\n        end\n        \n        OUTPUT_ST: begin\n          if (tree_valid_out) begin\n            out_sample <= tree_sum_out;\n            out_valid  <= 1'b1;\n            state      <= ACCUMULATE;\n          end\n        end\n        \n        default: state <= ACCUMULATE;\n      endcase\n    end\n  end\n\n  // Generate filter_start signal\n  logic filter_start;\n  always_ff @(posedge clk or negedge arst_n) begin\n    if (!arst_n)\n      filter_start <= 1'b0;\n    else if (state == ACCUMULATE && in_valid && in_ready && sample_cnt == M - 1)\n      filter_start <= 1'b1;\n    else\n      filter_start <= 1'b0;\n  end\n\n  // Shift Register\n  logic [DATA_WIDTH-1:0] shift_data [0:TOTAL_TAPS-1];\n  logic shift_data_val;\n\n  shift_register #(\n    .TAPS(TOTAL_TAPS),\n    .DATA_WIDTH(DATA_WIDTH)\n  ) u_shift_reg_decim (\n    .clk          (clk),\n    .arst_n       (arst_n),\n    .load         (in_valid && in_ready),\n    .new_sample   (in_sample),\n    .data_out     (shift_data),\n    .data_out_val (shift_data_val)\n  );\n\n  // Polyphase Filters\n  logic [ACC_WIDTH-1:0] filter_outs [M];\n  logic [M-1:0]         filter_valids;\n\n  genvar p, j;\n  generate\n    for (p = 0; p < M; p = p + 1) begin : gen_branches\n      logic [DATA_WIDTH-1:0] branch_samples [0:TAPS-1];\n      \n      for (j = 0; j < TAPS; j = j + 1) begin : gen_samples\n        assign branch_samples[j] = shift_data[p + j * M];\n      end\n\n      wire [$clog2(M)-1:0] phase_val = p;\n\n      poly_filter #(\n        .M           (M),\n        .TAPS        (TAPS),\n        .COEFF_WIDTH (COEFF_WIDTH),\n        .DATA_WIDTH  (DATA_WIDTH)\n      ) u_poly_filter (\n        .clk           (clk),\n        .arst_n        (arst_n),\n        .sample_buffer (branch_samples),\n        .valid_in      (filter_start),\n        .phase         (phase_val),\n        .filter_out    (filter_outs[p]),\n        .valid         (filter_valids[p])\n      );\n    end\n  endgenerate\n\n  // Adder Tree for Final Summation\n  adder_tree #(\n    .NUM_INPUTS (M),\n    .DATA_WIDTH (ACC_WIDTH)\n  ) u_adder_tree_decim (\n    .clk       (clk),\n    .arst_n    (arst_n),\n    .valid_in  (filter_valids[0]),\n    .data_in   (filter_outs),\n    .sum_out   (tree_sum_out),\n    .valid_out (tree_valid_out)\n  );\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
