Sending keys: ["cat << 'EOF' > rtl/rc5_enc_16bit.sv\n`timescale 1ns / 1ps\n\nmodule rc5_enc_16bit(\n    input wire clock,\n    input wire reset, // active low\n    input wire enc_start,\n    input wire [15:0] p,\n    output reg [15:0] c,\n    output reg enc_done\n);\n\n    wire ca_reset = ~reset;\n    wire [7:0] ca_out;\n    \n    CA_1 ca_inst (\n        .clock(clock),\n        .reset(ca_reset),\n        .CA_seed(8'hFF),\n        .CA_out(ca_out)\n    );\n\n    reg [2:0] key_cnt;\n    reg keys_ready;\n    reg [7:0] S [0:3];\n\n    always @(posedge clock) begin\n        if (!reset) begin\n            key_cnt <= 0;\n            keys_ready <= 0;\n        end else begin\n            if (key_cnt < 3'd4) begin\n                S[key_cnt] <= ca_out;\n                key_cnt <= key_cnt + 1;\n            end else begin\n                keys_ready <= 1;\n            end\n        end\n    end\n\n    reg wait_for_keys;\n    always @(posedge clock) begin\n        if (!reset) begin\n            wait_for_keys <= 0;\n        end else begin\n            if (enc_start && !keys_ready)\n                wait_for_keys <= 1;\n            else if (keys_ready)\n                wait_for_keys <= 0;\n        end\n    end\n\n    reg [2:0] state;\n    reg [7:0] A, B;\n\n    function [7:0] rotl8;\n        input [7:0] val;\n        input [2:0] amt;\n        begin\n            case (amt)\n                3'd0: rotl8 = val;\n                3'd1: rotl8 = {val[6:0], val[7]};\n                3'd2: rotl8 = {val[5:0], val[7:6]};\n                3'd3: rotl8 = {val[4:0], val[7:5]};\n                3'd4: rotl8 = {val[3:0], val[7:4]};\n                3'd5: rotl8 = {val[2:0], val[7:3]};\n                3'd6: rotl8 = {val[1:0], val[7:2]};\n                3'd7: rotl8 = {val[0], val[7:1]};\n            endcase\n        end\n    endfunction\n\n    always @(posedge clock) begin\n        if (!reset) begin\n            state <= 0;\n            enc_done <= 0;\n            c <= 0;\n            A <= 0;\n            B <= 0;\n        end else begin\n            case (state)\n                3'd0: begin\n                    if ((enc_start || wait_for_keys) && keys_ready) begin\n                        enc_done <= 0;\n                        A <= p[15:8] + S[0];\n                        B <= p[7:0] + S[1];\n                        state <= 3'd1;\n                    end\n                end\n                3'd1: begin\n                    A <= rotl8(A ^ B, B[2:0]) + S[2];\n                    state <= 3'd2;\n                end\n                3'd2: begin\n                    B <= rotl8(B ^ A, A[2:0]) + S[3];\n                    state <= 3'd3;\n                end\n                3'd3: begin\n                    c <= {A, B};\n                    enc_done <= 1;\n                    state <= 3'd0;\n                end\n                default: state <= 3'd0;\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
