f (i_valid) begin\n            if (ts_count_dff == N_TS_CYCLES - 1) begin\n                nxt_ts_count = \\\'0;\n            end else begin\n                nxt_ts_count = ts_count_dff + 1\'b1;\n            end\n        end\n    end\nend\n\nalways_comb begin\n    nxt_ts_undetected_count = ts_undetected_count_dff;\n    if (curr_state == ST_DETECT_TS) begin\n        nxt_ts_undetected_count = \\\'0;\n    end else begin\n        if (ts_count_dff == N_TS_CYCLES - 1) begin\n            if (proc_detected_dff) begin\n                nxt_ts_undetected_count = \\\'0;\n            end else begin\n                nxt_ts_undetected_count = ts_undetected_count_dff + 1\'b1;\n            end\n        end\n    end\nend\n\nalways_comb begin\n    nxt_state = curr_state;\n    mode_nx = w_mode;\n    nxt_o_locked = o_locked_reg;\n\n    if (curr_state == ST_DETECT_TS) begin\n        mode_nx = 2\'d0;\n        if (proc_detected_dff && w_aware_mode == 1\'b1) begin\n            nxt_state = ST_DETECT_FAW;\n        end else begin\n            nxt_state = ST_DETECT_TS;\n        end\n    end else if (curr_state == ST_DETECT_FAW) begin\n        if (ts_count_dff == N_TS_CYCLES - 1 && !proc_detected_dff && ts_undetected_count_dff == i_static_unlock_threshold) begin\n            nxt_state = ST_DETECT_TS;\n            mode_nx = 2\'d0;\n        end else if (proc_detected_dff) begin\n            nxt_o_locked = 1\'b1;\n            nxt_state = ST_DETECT_FAW;\n            mode_nx = 2\'d0;\n        end else begin\n            nxt_state = ST_DETECT_TS;\n            mode_nx = ts_undetected_count_dff[1:0];\n        end\n    end else begin\n        nxt_state = ST_DETECT_TS;\n    end\nend\n\'\'\'\n\ndet = det.replace(\n\'\'\'cross_correlation #(\'\'\',\n\'\'\'\n\'\'\' + fsm_logic + \'\'\'\ncross_correlation #(\'\'\')\n\ndet = det.replace(\n\'\'\'     .clk         (clk                 ),\n     .i_enable    (proc_enable_dff[0]  ),\n     .i_data_i    (proc_buffer_i_dff_1d),\'\'\',\n\'\'\'     .clk         (clk    