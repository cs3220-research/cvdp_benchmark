Sending keys: ['cat << \'EOF\' > modify.py\nimport sys\nimport re\n\ndef modify_rtl():\n    filepath = \'rtl/rgb_color_space_conversion.sv\'\n    with open(filepath, \'r\') as f:\n        content = f.read()\n\n    # 1. Add ports\n    ports_addition = """\n    // CMYK Output values\n    output reg [15:0]   cmyk_channel_c,  // % value = (cmyk_channel_c/(256*255)) * 100\n    output reg [15:0]   cmyk_channel_m,  // % value = (cmyk_channel_m/(256*255)) * 100\n    output reg [15:0]   cmyk_channel_y,  // % value = (cmyk_channel_y/(256*255)) * 100\n    output reg [7:0]    cmyk_channel_k,  // % value = (cmyk_channel_k/255) * 100\n\n"""\n    if \'cmyk_channel_c\' not in content:\n        content = re.sub(r\'(output\\s+reg\\s+valid_out)\', ports_addition + r\'    \\1\', content)\n\n    # 2. Add CMYK logic before endmodule of rgb_color_space_conversion\n    cmyk_logic = """\n    // ==========================================\n    // CMYK Channel Calculations\n    // ==========================================\n    \n    // 1. Black Key (K) Calculation (Available at cycle 3)\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cmyk_channel_k <= 8\'d0;\n        end else begin\n            cmyk_channel_k <= 8\'d255 - i_max[7:0];\n        end\n    end\n\n    // 2. Cyan, Magenta, Yellow (CMY) Calculation\n    \n    // Step 1: Component Subtraction (Cycle 3)\n    reg [7:0] cmy_diff_r, cmy_diff_g, cmy_diff_b;\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cmy_diff_r <= 8\'d0;\n            cmy_diff_g <= 8\'d0;\n            cmy_diff_b <= 8\'d0;\n        end else begin\n            cmy_diff_r <= i_max[7:0] - r_component;\n            cmy_diff_g <= i_max[7:0] - g_component;\n            cmy_diff_b <= i_max[7:0] - b_component;\n        end\n    end\n\n    // Step 2: Multiplication by 255 (Cycle 4)\n    reg [15:0] scaled_diff_r, scaled_diff_g, scaled_diff_b;\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            scaled_diff_r <= 16\'d0;\n            scaled_diff_g <= 16\'d0;\n            scaled_diff_b <= 16\'d0;\n        end else begin\n            scaled_diff_r <= cmy_diff_r * 8\'d255;\n            scaled_diff_g <= cmy_diff_g * 8\'d255;\n            scaled_diff_b <= cmy_diff_b * 8\'d255;\n        end\n    end\n\n    // Step 3: Inverse Lookup and Final Multiplication (Cycles 5, 6, 7)\n    reg [24:0] cmy_A_reg_c, cmy_A_reg_m, cmy_A_reg_y;\n    reg [15:0] cmy_B_reg_c, cmy_B_reg_m, cmy_B_reg_y;\n    reg [40:0] mult_result_c, mult_result_m, mult_result_y;\n    \n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cmy_A_reg_c <= 25\'d0;\n            cmy_B_reg_c <= 16\'d0;\n            cmy_A_reg_m <= 25\'d0;\n            cmy_B_reg_m <= 16\'d0;\n            cmy_A_reg_y <= 25\'d0;\n            cmy_B_reg_y <= 16\'d0;\n        end else begin\n            cmy_A_reg_c <= inv_i_max;\n            cmy_B_reg_c <= scaled_diff_r;\n            cmy_A_reg_m <= inv_i_max;\n            cmy_B_reg_m <= scaled_diff_g;\n            cmy_A_reg_y <= inv_i_max;\n            cmy_B_reg_y <= scaled_diff_b;\n        end\n    end\n    \n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            mult_result_c <= 41\'d0;\n            mult_result_m <= 41\'d0;\n            mult_result_y <= 41\'d0;\n        end else begin\n            mult_result_c <= cmy_A_reg_c * cmy_B_reg_c;\n            mult_result_m <= cmy_A_reg_m * cmy_B_reg_m;\n            mult_result_y <= cmy_A_reg_y * cmy_B_reg_y;\n        end\n    end\n    \n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            cmyk_channel_c <= 16\'d0;\n            cmyk_channel_m <= 16\'d0;\n            cmyk_channel_y <= 16\'d0;\n        end else begin\n            cmyk_channel_c <= mult_result_c[31:16] + mult_result_c[15];\n            cmyk_channel_m <= mult_result_m[31:16] + mult_result_m[15];\n            cmyk_channel_y <= mult_result_y[31:16] + mult_result_y[15];\n        end\n    end\n"""\n    if \'CMYK Channel Calculations\' not in content:\n        content = re.sub(r\'^endmodule\', cmyk_logic + \'\\nendmodule\', content, count=1, flags=re.MULTILINE)\n\n    with open(filepath, \'w\') as f:\n        f.write(content)\n\nif __name__ == \'__main__\':\n    modify_rtl()\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
