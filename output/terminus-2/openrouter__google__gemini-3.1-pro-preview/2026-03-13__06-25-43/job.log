n            // Status clear (Software clear)\n            if (axi_write_en && axi_addr == 4'h4) begin\n                status <= 1'b0;\n            end\n\n            // Counter logic\n            if (control[0] && prescaler_pulse) begin\n                if (count == match_value) begin\n                    if (control[1]) begin // Interval mode\n                        count <= reload_value;\n                    end\n                    // If single-shot mode, count stays at match_value because enable is cleared\n                end else begin\n                    count <= count + 16'd1;\n                    \n                    // Match detection (when count is about to become match_value)\n                    if (count + 16'd1 == match_value) begin\n                        status <= 1'b1; // Hardware set overrides software clear\n                        if (!control[1]) begin\n                            control[0] <= 1'b0; // Auto-clear enable in single-shot mode\n                        end\n                    end\n                end\n            end\n        end\n    end\n\n    // AXI Read\n    always @(posedge clk) begin\n        if (reset) begin\n            axi_rdata <= 32'd0;\n        end else if (axi_read_en) begin\n            case (axi_addr)\n                4'h0: axi_rdata <= {16'd0, count};\n                4'h1: axi_rdata <= {16'd0, match_value};\n                4'h2: axi_rdata <= {16'd0, reload_value};\n                4'h3: axi_rdata <= {29'd0, control};\n                4'h4: axi_rdata <= {31'd0, status};\n                4'h5: axi_rdata <= {28'd0, prescaler};\n                default: axi_rdata <= 32'd0;\n            endcase\n        end else begin\n            axi_rdata <= 32'd0;\n        end\n    end\n\n    // Interrupt output\n    assign interrupt = status & control[2];\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
