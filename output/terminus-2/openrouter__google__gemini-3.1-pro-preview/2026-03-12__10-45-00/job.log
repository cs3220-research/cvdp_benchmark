w <= q[0];\n                    end else begin // Left\n                        q <= {q[N-2:0], 1'b0};\n                        overflow <= q[N-1];\n                    end\n                end\n                3'b101: begin // Bitwise Logical Operations\n                    case (bitwise_op)\n                        2'b00: q <= q & parallel_in; // AND\n                        2'b01: q <= q | parallel_in; // OR\n                        2'b10: q <= q ^ parallel_in; // XOR\n                        2'b11: q <= ~(q ^ parallel_in); // XNOR\n                    endcase\n                    overflow <= 1'b0;\n                end\n                3'b110: begin // Bit Reversal\n                    for (i = 0; i < N; i = i + 1) begin\n                        temp_q[i] = q[N-1-i];\n                    end\n                    q <= temp_q;\n                    overflow <= 1'b0;\n                end\n                3'b111: begin // Bitwise Inversion\n                    q <= ~q;\n                    overflow <= 1'b0;\n                end\n                default: begin\n                    q <= q;\n                    overflow <= overflow;\n                end\n            endcase\n        end\n    end\n\n    assign serial_out = (shift_dir == 0) ? q[0] : q[N-1];\n    assign msb_out = q[N-1];\n    assign lsb_out = q[0];\n    assign zero_flag = (q == {N{1'b0}});\n    assign parity_out = ^q;\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
