Sending keys: ['cat << \'EOF\' > gen_lut.py\nimport math\n\ndef generate_verilog():\n    with open(\'rtl/phase_lut.sv\', \'w\') as f:\n        f.write(\'\'\'module phase_lut #(\n   parameter NBW_IN    = 6,\n   parameter NBW_PHASE = 9,\n   parameter NBI_IN    = 1,\n   parameter NBI_PHASE = 1\n)\n(\n   input  logic                 clk,\n   input  logic                 rst_async_n,\n   input  logic signed [NBW_IN-1:0]     i_data_i,\n   input  logic signed [NBW_IN-1:0]     i_data_q,\n   output logic signed [NBW_PHASE-1:0] o_phase\n);\n\n   // Absolute values can be up to 32, so we need 6 bits\n   logic [5:0] abs_i, abs_q;\n   logic sign_i, sign_q;\n   logic [10:0] lut_index;\n   \n   // Registered values\n   logic [10:0] lut_index_reg;\n   logic sign_i_reg, sign_q_reg;\n   \n   // LUT output\n   logic [NBW_PHASE-1:0] lut_out;\n   \n   always_comb begin\n      sign_i = i_data_i[NBW_IN-1];\n      sign_q = i_data_q[NBW_IN-1];\n      \n      if (sign_i)\n         abs_i = -i_data_i;\n      else\n         abs_i = i_data_i;\n         \n      if (sign_q)\n         abs_q = -i_data_q;\n      else\n         abs_q = i_data_q;\n         \n      lut_index = abs_i * 33 + abs_q;\n   end\n   \n   always_ff @(posedge clk or negedge rst_async_n) begin\n      if (!rst_async_n) begin\n         lut_index_reg <= 0;\n         sign_i_reg    <= 0;\n         sign_q_reg    <= 0;\n      end else begin\n         lut_index_reg <= lut_index;\n         sign_i_reg    <= sign_i;\n         sign_q_reg    <= sign_q;\n      end\n   end\n   \n   always_comb begin\n      case(lut_index_reg)\n\'\'\')\n        \n        for i in range(33):\n            for q in range(33):\n                idx = i * 33 + q\n                if i == 0 and q == 0:\n                    angle = 0.0\n                else:\n                    angle = math.atan2(q, i) * 180.0 / math.pi\n                \n                # Normalize angle to -256 to 256 for -180 to 180 degrees\n                # Since i and q are positive, angle is 0 to 90 degrees\n                # So normalized angle is 0 to 128\n                val = round(angle * 256.0 / 180.0)\n                f.write(f"         11\'d{idx}: lut_out = 9\'d{val};\\n")\n                \n        f.write(\'\'\'         default: lut_out = 9\'d0;\n      endcase\n   end\n   \n   always_comb begin\n      if (!sign_i_reg && !sign_q_reg) begin\n         // Both positive\n         o_phase = lut_out;\n      end else if (!sign_i_reg && sign_q_reg) begin\n         // I positive, Q negative\n         o_phase = -lut_out;\n      end else if (sign_i_reg && !sign_q_reg) begin\n         // I negative, Q positive\n         o_phase = 9\'sd256 - lut_out;\n      end else begin\n         // Both negative\n         o_phase = lut_out - 9\'sd256;\n      end\n   end\n\nendmodule\n\'\'\')\n\nif __name__ == \'__main__\':\n    generate_verilog()\nEOF\npython3 gen_lut.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
