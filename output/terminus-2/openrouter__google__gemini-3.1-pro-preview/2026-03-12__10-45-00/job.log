Sending keys: ["cat << 'EOF' > rtl/order_matching_engine.sv\nmodule order_matching_engine #(\n    parameter PRICE_WIDTH = 16  // width of the price field\n)(\n    input                      clk,\n    input                      rst,\n    input                      start,         // start matching operation\n    input  [8*PRICE_WIDTH-1:0] bid_orders,    // 8 bid orders (flat vector)\n    input  [8*PRICE_WIDTH-1:0] ask_orders,    // 8 ask orders (flat vector)\n    output reg                 match_valid,   // high if a match occurs\n    output reg [PRICE_WIDTH-1:0] matched_price, // matched price (best ask)\n    output reg                 done,          // matching engine done\n    output reg                 latency_error  // asserted if latency ≠ 20 cycles\n);\n\n    wire bid_done;\n    wire ask_done;\n    wire [8*PRICE_WIDTH-1:0] sorted_bids;\n    wire [8*PRICE_WIDTH-1:0] sorted_asks;\n\n    sorting_engine #(\n        .WIDTH(PRICE_WIDTH)\n    ) bid_sort (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(bid_orders),\n        .done(bid_done),\n        .out_data(sorted_bids)\n    );\n\n    sorting_engine #(\n        .WIDTH(PRICE_WIDTH)\n    ) ask_sort (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(ask_orders),\n        .done(ask_done),\n        .out_data(sorted_asks)\n    );\n\n    // best_bid is the highest bid (last position, ascending sort)\n    wire [PRICE_WIDTH-1:0] best_bid = sorted_bids[8*PRICE_WIDTH-1 -: PRICE_WIDTH];\n    // best_ask is the lowest ask (first position, ascending sort)\n    wire [PRICE_WIDTH-1:0] best_ask = sorted_asks[PRICE_WIDTH-1 : 0];\n\n    reg [5:0] timer;\n    reg active;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            timer <= 0;\n            active <= 0;\n            latency_error <= 0;\n            done <= 0;\n            match_valid <= 0;\n            matched_price <= 0;\n        end else begin\n            done <= 0;\n            match_valid <= 0;\n            \n            if (start) begin\n                timer <= 1;\n                active <= 1;\n                latency_error <= 0;\n            end else if (active) begin\n                timer <= timer + 1;\n                \n                if (timer == 20) begin\n                    active <= 0;\n                    done <= 1;\n                    \n                    if (best_bid >= best_ask) begin\n                        match_valid <= 1;\n                        matched_price <= best_ask;\n                    end else begin\n                        matched_price <= 0;\n                    end\n                    \n                    if (!bid_done || !ask_done) begin\n                        latency_error <= 1;\n                    end\n                end\n            end\n            \n            if (bid_done || ask_done) begin\n                if (timer != 20) begin\n                    latency_error <= 1;\n                end\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
