Sending keys: ["cat << 'EOF' > rtl/scrambler_descrambler.sv\nmodule scrambler_descrambler #(\n    parameter int POLY_LENGTH = 31,\n    parameter int POLY_TAP    = 3,\n    parameter int WIDTH       = 16,\n    parameter bit CHECK_MODE  = 0\n)(\n    input  logic             clk,\n    input  logic             rst,\n    input  logic             bypass_scrambling,\n    input  logic [WIDTH-1:0] data_in,\n    input  logic             valid_in,\n    output logic [WIDTH-1:0] data_out,\n    output logic             valid_out,\n    output logic [31:0]      bit_count\n);\n\n    // Internal signals\n    logic [WIDTH-1:0] prbs_data_out;\n    \n    logic [WIDTH-1:0] data_in_q;\n    logic             valid_in_q;\n    logic             bypass_q;\n    \n    logic [WIDTH-1:0] prbs_data_out_q;\n    logic             valid_in_q2;\n    \n    // Instantiate the PRBS Generator/Checker\n    prbs_gen_check #(\n        .CHECK_MODE  (CHECK_MODE),\n        .POLY_LENGTH (POLY_LENGTH),\n        .POLY_TAP    (POLY_TAP),\n        .WIDTH       (WIDTH)\n    ) u_prbs_gen_check (\n        .clk      (clk),\n        .rst      (rst),\n        .data_in  (data_in),\n        .data_out (prbs_data_out)\n    );\n\n    // Pipeline registers for latency management\n    always_ff @(posedge clk) begin\n        if (rst) begin\n            data_in_q       <= '0;\n            valid_in_q      <= 1'b0;\n            bypass_q        <= 1'b0;\n            \n            prbs_data_out_q <= '0;\n            valid_in_q2     <= 1'b0;\n        end else begin\n            data_in_q       <= data_in;\n            valid_in_q      <= valid_in;\n            bypass_q        <= bypass_scrambling;\n            \n            prbs_data_out_q <= prbs_data_out;\n            valid_in_q2     <= valid_in_q;\n        end\n    end\n\n    // Output MUX based on mode and bypass\n    always_comb begin\n        if (CHECK_MODE == 0) begin\n            // Generator/Scrambler Mode\n            // bypass_scrambling asserted: 1 clk latency\n            // bypass_scrambling deasserted: 1 clk latency\n            valid_out = valid_in_q;\n            data_out  = bypass_q ? data_in_q : prbs_data_out;\n        end else begin\n            // Checker Mode\n            // bypass_scrambling asserted: 1 clk latency\n            // bypass_scrambling deasserted: 2 clk latency\n            if (bypass_q) begin\n                valid_out = valid_in_q;\n                data_out  = data_in_q;\n            end else begin\n                valid_out = valid_in_q2;\n                data_out  = prbs_data_out_q;\n            end\n        end\n    end\n\n    // Bit count logic\n    always_ff @(posedge clk) begin\n        if (rst) begin\n            bit_count <= '0;\n        end else if (valid_in) begin\n            bit_count <= bit_count + WIDTH;\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
