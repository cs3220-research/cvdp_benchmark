Sending keys: ["cat << 'EOF' > rtl/poly_decimator.sv\nmodule poly_decimator #(\n    parameter M = 4,\n    parameter TAPS = 8,\n    parameter COEFF_WIDTH = 16,\n    parameter DATA_WIDTH = 16,\n    localparam ACC_WIDTH = DATA_WIDTH + COEFF_WIDTH + $clog2(TAPS),\n    localparam TOTAL_TAPS = M * TAPS\n) (\n    input  logic clk,\n    input  logic arst_n,\n    input  logic [DATA_WIDTH-1:0] in_sample,\n    input  logic in_valid,\n    output logic in_ready,\n    output logic [ACC_WIDTH+$clog2(M)-1:0] out_sample,\n    output logic out_valid\n);\n\n    // ----------------------------------------------------------------\n    // Internal signals\n    // ----------------------------------------------------------------\n    logic [DATA_WIDTH-1:0] shift_data [0:TOTAL_TAPS-1];\n    logic shift_data_val;\n\n    // FSM states\n    typedef enum logic {\n        ACCUMULATE = 1'b0,\n        OUTPUT     = 1'b1\n    } state_t;\n    \n    state_t state;\n    logic [$clog2(M+1)-1:0] sample_count;\n    logic filter_start;\n\n    // ----------------------------------------------------------------\n    // Shift Register\n    // ----------------------------------------------------------------\n    shift_register #(\n        .TAPS(TOTAL_TAPS),\n        .DATA_WIDTH(DATA_WIDTH)\n    ) u_shift_reg_decim (\n        .clk(clk),\n        .arst_n(arst_n),\n        .load(in_valid & in_ready),\n        .new_sample(in_sample),\n        .data_out(shift_data),\n        .data_out_val(shift_data_val)\n    );\n\n    // ----------------------------------------------------------------\n    // FSM\n    // ----------------------------------------------------------------\n    assign in_ready = (state == ACCUMULATE);\n\n    logic adder_valid_out;\n    logic [ACC_WIDTH+$clog2(M)-1:0] adder_sum_out;\n\n    always_ff @(posedge clk or negedge arst_n) begin\n        if (!arst_n) begin\n            state        <= ACCUMULATE;\n            sample_count <= '0;\n            filter_start <= 1'b0;\n            out_valid    <= 1'b0;\n            out_sample   <= '0;\n        end else begin\n            out_valid    <= 1'b0; // Default: clear pulse\n            filter_start <= 1'b0;\n\n            case (state)\n                ACCUMULATE: begin\n                    if (in_valid && in_ready) begin\n                        if (sample_count == M - 1) begin\n                            state        <= OUTPUT;\n                            sample_count <= '0;\n                            filter_start <= 1'b1;\n                        end else begin\n                            sample_count <= sample_count + 1'b1;\n                        end\n                    end\n                end\n\n                OUTPUT: begin\n                    if (adder_valid_out) begin\n                        out_sample <= adder_sum_out;\n                        out_valid  <= 1'b1;\n                        state      <= ACCUMULATE;\n                    end\n                end\n            endcase\n        end\n    end\n\n    // ----------------------------------------------------------------\n    // Polyphase Filters\n    // ----------------------------------------------------------------\n    logic [ACC_WIDTH-1:0] branch_out [0:M-1];\n    logic branch_valid [0:M-1];\n\n    genvar i, j;\n    generate\n        for (i = 0; i < M; i++) begin : poly_branches\n            logic [DATA_WIDTH-1:0] branch_samples [0:TAPS-1];\n            for (j = 0; j < TAPS; j++) begin : branch_taps\n                assign branch_samples[j] = shift_data[i + j * M];\n            end\n\n            logic [$clog2(M)-1:0] phase_val;\n            assign phase_val = i[$clog2(M)-1:0];\n\n            poly_filter #(\n                .M(M),\n                .TAPS(TAPS),\n                .COEFF_WIDTH(COEFF_WIDTH),\n                .DATA_WIDTH(DATA_WIDTH)\n            ) u_poly_filter (\n                .clk(clk),\n                .arst_n(arst_n),\n                .sample_buffer(branch_samples),\n                .valid_in(filter_start),\n                .phase(phase_val),\n                .filter_out(branch_out[i]),\n                .valid(branch_valid[i])\n            );\n        end\n    endgenerate\n\n    // ----------------------------------------------------------------\n    // Adder Tree\n    // ----------------------------------------------------------------\n    logic all_branches_valid;\n    always_comb begin\n        all_branches_valid = 1'b1;\n        for (int k = 0; k < M; k++) begin\n            all_branches_valid = all_branches_valid & branch_valid[k];\n        end\n    end\n\n    adder_tree #(\n        .NUM_INPUTS(M),\n        .DATA_WIDTH(ACC_WIDTH)\n    ) u_adder_tree (\n        .clk(clk),\n        .arst_n(arst_n),\n        .valid_in(all_branches_valid),\n        .data_in(branch_out),\n        .sum_out(adder_sum_out),\n        .valid_out(adder_valid_out)\n    );\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
