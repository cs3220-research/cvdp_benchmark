Sending keys: ["cat << 'EOF' > rtl/rc5_enc_16bit.sv\nmodule rc5_enc_16bit (\n    input wire clock,\n    input wire reset,\n    input wire enc_start,\n    input wire [15:0] p,\n    output reg [15:0] c,\n    output reg enc_done\n);\n\n    wire [7:0] ca_out;\n    \n    // Instantiate CA_1 for S-box generation\n    CA_1 ca_inst (\n        .clock(clock),\n        .reset(~reset),\n        .CA_seed(8'hFF),\n        .CA_out(ca_out)\n    );\n\n    reg [7:0] S [0:3];\n    reg [2:0] key_idx;\n    reg keys_ready;\n\n    always_ff @(posedge clock) begin\n        if (!reset) begin\n            key_idx <= 0;\n            keys_ready <= 0;\n        end else begin\n            if (key_idx == 0) begin\n                key_idx <= 1;\n            end else if (key_idx == 1) begin\n                S[0] <= ca_out;\n                key_idx <= 2;\n            end else if (key_idx == 2) begin\n                S[1] <= ca_out;\n                key_idx <= 3;\n            end else if (key_idx == 3) begin\n                S[2] <= ca_out;\n                key_idx <= 4;\n            end else if (key_idx == 4) begin\n                S[3] <= ca_out;\n                key_idx <= 5;\n                keys_ready <= 1;\n            end\n        end\n    end\n\n    typedef enum logic [2:0] {\n        IDLE,\n        INIT_ADD,\n        COMP_MSB,\n        COMP_LSB,\n        OUTPUT_CIPHER\n    } state_t;\n\n    state_t state;\n    reg [7:0] A_reg;\n    reg [7:0] B_reg;\n\n    function [7:0] rotl8;\n        input [7:0] value;\n        input [7:0] shift;\n        reg [2:0] s;\n        begin\n            s = shift[2:0];\n            rotl8 = (value << s) | (value >> (8 - s));\n        end\n    endfunction\n\n    always_ff @(posedge clock) begin\n        if (!reset) begin\n            state <= IDLE;\n            enc_done <= 0;\n            c <= 0;\n            A_reg <= 0;\n            B_reg <= 0;\n        end else begin\n            case (state)\n                IDLE: begin\n                    if (enc_start && keys_ready) begin\n                        state <= INIT_ADD;\n                        A_reg <= p[15:8];\n                        B_reg <= p[7:0];\n                        enc_done <= 0;\n                    end\n                end\n                INIT_ADD: begin\n                    A_reg <= A_reg + S[0];\n                    B_reg <= B_reg + S[1];\n                    state <= COMP_MSB;\n                end\n                COMP_MSB: begin\n                    A_reg <= rotl8(A_reg ^ B_reg, B_reg) + S[2];\n                    state <= COMP_LSB;\n                end\n                COMP_LSB: begin\n                    B_reg <= rotl8(B_reg ^ A_reg, A_reg) + S[3];\n                    state <= OUTPUT_CIPHER;\n                end\n                OUTPUT_CIPHER: begin\n                    c <= {A_reg, B_reg};\n                    enc_done <= 1;\n                    state <= IDLE;\n                end\n                default: state <= IDLE;\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
