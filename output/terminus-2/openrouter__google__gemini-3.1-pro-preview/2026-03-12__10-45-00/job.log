n;\n    assign w_elements_current = w_count_bin + r_sync_bin;\n    assign w_addr = w_elements_current[ADDR_WIDTH-1:0];\n\n    always_ff @(posedge w_clk) begin\n        if (w_rst) begin\n            w_count_bin <= 0;\n            w_ptr <= 0;\n            w_full <= 0;\n        end else begin\n            if (push && !w_full) begin\n                mem[w_addr] <= w_data;\n            end\n            w_count_bin <= w_count_next;\n            w_ptr <= w_ptr_next;\n            w_full <= (w_elements_next == DEPTH);\n        end\n    end\n\n    // Read domain logic\n    logic [PTR_WIDTH-1:0] w_sync_bin;\n    logic [PTR_WIDTH-1:0] r_elements_next;\n    logic [PTR_WIDTH-1:0] r_elements_current;\n    logic [ADDR_WIDTH-1:0] r_addr;\n\n    assign w_sync_bin = gray2bin(rq2_wptr);\n    assign r_count_next = (pop && !r_empty) ? r_count_bin - 1\'b1 : r_count_bin;\n    assign r_ptr_next = bin2gray(r_count_next);\n    \n    assign r_elements_next = w_sync_bin + r_count_next;\n    assign r_elements_current = w_sync_bin + r_count_bin;\n    assign r_addr = r_elements_current[ADDR_WIDTH-1:0] - 1\'b1;\n\n    always_ff @(posedge r_clk) begin\n        if (r_rst) begin\n            r_count_bin <= 0;\n            r_ptr <= 0;\n            r_empty <= 1;\n        end else begin\n            r_count_bin <= r_count_next;\n            r_ptr <= r_ptr_next;\n            r_empty <= (r_elements_next == 0);\n        end\n    end\n\n    assign r_data = mem[r_addr];\n\n    // Synchronizers\n    always_ff @(posedge w_clk) begin\n        if (w_rst) begin\n            wq1_rptr <= 0;\n            wq2_rptr <= 0;\n        end else begin\n            wq1_rptr <= r_ptr;\n            wq2_rptr <= wq1_rptr;\n        end\n    end\n\n    always_ff @(posedge r_clk) begin\n        if (r_rst) begin\n            rq1_wptr <= 0;\n            rq2_wptr <= 0;\n        end else begin\n            rq1_wptr <= w_ptr;\n            rq2_wptr <= rq1_wptr;\n        end\n    end\n\nendmodule\n"""\n\nwith open("async_filo.sv", "w") as f