f"    assign row = {{i_data[1], i_data[6]}};\\n")\n        f.write(f"    assign col = i_data[2:5];\\n")\n        f.write(f"    always_comb begin\\n")\n        f.write(f"        case ({{row, col}})\\n")\n        for r in range(4):\n            for c in range(16):\n                val = table[r * 16 + c]\n                f.write(f"            6\'d{r * 16 + c}: o_data = 4\'d{val};\\n")\n        f.write(f"            default: o_data = 4\'d0;\\n")\n        f.write(f"        endcase\\n")\n        f.write(f"    end\\n")\n        f.write(f"endmodule\\n")\n\nwith open(\'rtl/des_enc.sv\', \'w\') as f:\n    f.write("`timescale 1ns / 1ps\\n\\n")\n    f.write("module des_enc #(\\n")\n    f.write("    parameter NBW_DATA = 64,\\n")\n    f.write("    parameter NBW_KEY = 64\\n")\n    f.write(")(\\n")\n    f.write("    input  logic                clk,\\n")\n    f.write("    input  logic                rst_async_n,\\n")\n    f.write("    input  logic                i_valid,\\n")\n    f.write("    input  logic [1:NBW_DATA]   i_data,\\n")\n    f.write("    input  logic [1:NBW_KEY]    i_key,\\n")\n    f.write("    output logic                o_valid,\\n")\n    f.write("    output logic [1:NBW_DATA]   o_data\\n")\n    f.write(");\\n\\n")\n\n    f.write("    // Initial Permutation\\n")\n    f.write("    logic [1:64] ip_out;\\n")\n    for i, bit in enumerate(IP):\n        f.write(f"    assign ip_out[{i+1}] = i_data[{bit}];\\n")\n\n    f.write("\\n")\n    f.write("    // Key Schedule Initialization\\n")\n    f.write("    logic [1:28] c0, d0;\\n")\n    for i, bit in enumerate(C0):\n        f.write(f"    assign c0[{i+1}] = i_key[{bit}];\\n")\n    for i, bit in enumerate(D0):\n        f.write(f"    assign d0[{i+1}] = i_key[{bit}];\\n")\n\n    f.write("\\n")\n    f.write("    // Pipeline registers for 16 rounds\\n")\n    f.write("    logic [1:32] L [0:16];\\n")\n    f.write("    logic [1:32] R [0:16];\\n")\n    f.write("    logic [1:28] C [0:16];\\n")\n    f.write("    logic [1:28] D [0:16];\\n")\n    f.write("    logic [0:16] valid_pipe;\\n\\n")\n\n    f.write("    assign L[0] = ip_out[1:32];\\n")\n    f.write("    assign R[0] = ip_out[33:64];\\n")\n    f.write("    assign C[0] = c0;\\n")\n    f.write("    assign D[0] = d0;\\n")\n    f.write("    assign valid_pipe[0] = i_valid;\\n\\n")\n\n    f.write("    // Shift amounts per round\\n")\n    f.write("    int shifts[1:16] = \'{1, 1, 2, 2, 2, 2, 2, 2, 1, 2, 2, 2, 2, 2, 2, 1};\\n\\n")\n\n    f.write("    genvar i;\\n")\n    f.write("    generate\\n")\n    f.write("        for (i = 1; i <= 16; i++) begin : round_gen\\n")\n    f.write("            // Key rotation\\n")\n    f.write("            logic [1:28] next_c, next_d;\\n")\n    f.write("            always_comb begin\\n")\n    f.write("                if (shifts[i] == 1) begin\\n")\n    f.write("                    next_c = {C[i-1][2:28], C[i-1][1]};\\n")\n    f.write("                    next_d = {D[i-1][2:28], D[i-1][1]};\\n")\n    f.write("                end else begin\\n")\n    f.write("                    next_c = {C[i-1][3:28], C[i-1][1:2]};\\n")\n    f.write("                    next_d = {D[i-1][3:28], D[i-1][1:2]};\\n")\n    f.write("                end\\n")\n    f.write("            end\\n\\n")\n\n    f.write("            // PC-2 permutation\\n")\n    f.write("            logic [1:48] round_key;\\n")\n    f.write("            logic [1:56] cd_concat;\\n")\n    f.write("            assign cd_concat = {next_c, next_d};\\n")\n    for j, bit in enumerate(PC2):\n        f.write(f"            assign round_key[{j+1}] = cd_concat[{bit}];\\n")\n\n    f.write("\\n")\n    f.write("            // Expansion E\\n")\n    f.write("            logic [1:48] exp_r;\\n")\n    for j, bit in enumerate(E):\n        f.write(f"            assign exp_r[{j+1}] = R[i-1][{bit}];\\n")\n\n    f.write("\\n")\n    f.write("            // Key mixing\\n")\n    f.write("            logic [1:48] xor_out;\\n")\n    f.write("            assign xor_out = exp_r ^ round_key;\\n\\n")\n\n    f.write("            // S-boxes\\n")\n    f.write("            logic [1:32] sbox_out;\\n")\n    f.write("            S1 s1_inst (.i_data(xor_out[1:6]),   .o_data(sbox_out[1:4]));\\n")\n    f.write("            S2 s2_inst (.i_data(xor_out[7:12]),  .o_data(sbox_out[5:8]));\\n")\n    f.write("            S3 s3_inst (.i_data(xor_out[13:18]), .o_data(sbox_out[9:12]));\\n")\n    f.write("            S4 s4_inst (.i_data(xor_out[19:24]), .o_data(sbox_out[13:16]));\\n")\n    f.write("            S5 s5_inst (.i_data(xor_out[25:30]), .o_data(sbox_out[17:20]));\\n")\n    f.write("            S6 s6_inst (.i_data(xor_out[31:36]), .o_data(sbox_out[21:24]));\\n")\n    f.write("            S7 s7_inst (.i_data(xor_out[37:42]), .o_data(sbox_out[25:28]));\\n")\n    f.write("            S8 s8_inst (.i_data(xor_out[43:48]), .o_data(sbox_out[29:32]));\\n\\n")\n\n    f.write("            // Permutation P\\n")\n    f.write("            logic [1:32] p_out;\\n")\n    for j, bit in enumerate(P):\n        f.write(f"            assign p_out[{j+1}] = sbox_out[{bit}];\\n")\n\n    f.write("\\n")\n    f.write("            // Pipeline registers\\n")\n    f.write("            always_ff @(posedge clk or negedge rst_async_n) begin\\n")\n    f.write("                if (!rst_async_n) begin\\n")\n    f.write("                    L[i] <= \'0;\\n")\n    f.write("                    R[i] <= \'0;\\n")\n    f.write("                    C[i] <= \'0;\\n")\n    f.write("                    D[i] <= \'0;\\n")\n    f.write("                    valid_pipe[i] <= 1\'b0;\\n")\n    f.write("                end else begin\\n")\n    f.write("                    valid_pipe[i] <= valid_pipe[i-1];\\n")\n    f.write("                    L[i] <= R[i-1];\\n")\n    f.write("                    R[i] <= L[i-1] ^ p_out;\\n")\n    f.write("                    C[i] <= next_c;\\n")\n    f.write("                    D[i] <= next_d;\\n")\n    f.write("                end\\n")\n    f.write("            end\\n")\n    f.write("        end\