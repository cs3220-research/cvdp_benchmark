        next_state = GCD_WAIT;\n            end\n            GCD_WAIT: begin\n                if (gcd_done)\n                    next_state = DECISION;\n            end\n            DECISION: begin\n                if (gcd_out == 1)\n                    next_state = MODEXP_START;\n                else\n                    next_state = DONE;\n            end\n            MODEXP_START: begin\n                next_state = MODEXP_WAIT;\n            end\n            MODEXP_WAIT: begin\n                if (modexp_done)\n                    next_state = DONE;\n            end\n            DONE: begin\n                if (!start_key_check)\n                    next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    always_ff @(posedge clk) begin\n        if (rst) begin\n            key_valid <= 0;\n            done_key_check <= 0;\n            ciphertext <= 0;\n            done_encryption <= 0;\n            gcd_go <= 0;\n            modexp_start <= 0;\n        end else begin\n            case (state)\n                IDLE: begin\n                    key_valid <= 0;\n                    done_key_check <= 0;\n                    ciphertext <= 0;\n                    done_encryption <= 0;\n                    gcd_go <= 0;\n                    modexp_start <= 0;\n                end\n                GCD_START: begin\n                    gcd_go <= 1;\n                end\n                GCD_WAIT: begin\n                    gcd_go <= 0;\n                end\n                DECISION: begin\n                    done_key_check <= 1;\n                    if (gcd_out == 1) begin\n                        key_valid <= 1;\n                    end else begin\n                        key_valid <= 0;\n                        ciphertext <= 0;\n                        done_encryption <= 1;\n                    end\n                end\n                MODEXP_START: begin\n                    modexp_start <= 1;\n                end\n                MODEXP_WAIT: begin\n                    modexp_start <= 0;\n                    if (modexp_done) begin\n                        ciphertext <= modexp_result;\n                        done_encryption <= 1;\n                    end\n                end\n                DONE: begin\n                    // Hold outputs until start_key_check is deasserted\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
