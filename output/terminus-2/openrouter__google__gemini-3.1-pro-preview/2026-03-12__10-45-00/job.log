re long_trigger;\n    wire short_timer;\n    wire long_timer;\n\n    traffic_controller_fsm u_fsm (\n        .i_clk(i_clk),\n        .i_rst_b(i_rst_b),\n        .i_vehicle_sensor_input(i_vehicle_sensor_input),\n        .i_short_timer(short_timer),\n        .i_long_timer(long_timer),\n        .o_short_trigger(short_trigger),\n        .o_long_trigger(long_trigger),\n        .o_main(o_main),\n        .o_side(o_side)\n    );\n\n    timer_module #(\n        .SHORT_COUNT(SHORT_COUNT),\n        .LONG_COUNT(LONG_COUNT)\n    ) u_timer (\n        .i_clk(i_clk),\n        .i_rst_b(i_rst_b),\n        .i_short_trigger(short_trigger),\n        .i_long_trigger(long_trigger),\n        .o_short_timer(short_timer),\n        .o_long_timer(long_timer)\n    );\n\nendmodule\n"""\n\nwith open(\'rtl/timer_module.sv\', \'w\') as f:\n    f.write(timer_module)\n\nwith open(\'rtl/traffic_light_controller_top.sv\', \'w\') as f:\n    f.write(top_module)\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
