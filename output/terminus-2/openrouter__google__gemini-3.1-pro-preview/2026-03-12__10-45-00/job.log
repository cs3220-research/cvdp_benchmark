Sending keys: ['cat << \'EOF\' > generate_sv.py\nimport os\n\ncode = """\\\n`timescale 1ns / 1ps\n\nmodule uart_rx_to_axis #(\n    parameter int CLK_FREQ = 100,\n    parameter int BIT_RATE = 115200,\n    parameter int BIT_PER_WORD = 8,\n    parameter int PARITY_BIT = 0, // 0: None, 1: Odd, 2: Even\n    parameter int STOP_BITS_NUM = 1\n) (\n    input  logic aclk,\n    input  logic aresetn,\n    input  logic RX,\n    output logic [BIT_PER_WORD-1:0] tdata,\n    output logic tuser,\n    output logic tvalid\n);\n\n    localparam int Cycle_per_Period = (CLK_FREQ * 1000000) / BIT_RATE;\n    localparam int Half_Cycle = Cycle_per_Period / 2;\n\n    typedef enum logic [2:0] {\n        IDLE    = 3\'d0,\n        START   = 3\'d1,\n        DATA    = 3\'d2,\n        PARITY  = 3\'d3,\n        STOP1   = 3\'d4,\n        STOP2   = 3\'d5,\n        OUT_RDY = 3\'d6\n    } state_t;\n\n    state_t state, next_state;\n\n    logic [31:0] clk_count;\n    logic [31:0] bit_count;\n    logic [BIT_PER_WORD-1:0] data_shift_reg;\n    logic rx_sync1, rx_sync2, rx_sync3;\n    logic rx_falling_edge;\n    logic parity_err;\n    logic calc_parity;\n\n    // Synchronizers for RX\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            rx_sync1 <= 1\'b1;\n            rx_sync2 <= 1\'b1;\n            rx_sync3 <= 1\'b1;\n        end else begin\n            rx_sync1 <= RX;\n            rx_sync2 <= rx_sync1;\n            rx_sync3 <= rx_sync2;\n        end\n    end\n\n    // Falling edge detection\n    assign rx_falling_edge = rx_sync3 & ~rx_sync2;\n\n    // FSM State Transition\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            state <= IDLE;\n        end else begin\n            state <= next_state;\n        end\n    end\n\n    // FSM Next State Logic\n    always_comb begin\n        next_state = state;\n        case (state)\n            IDLE: begin\n                if (rx_falling_edge || rx_sync2 == 1\'b0)\n                    next_state = START;\n            end\n            START: begin\n                if (clk_count == Half_Cycle) begin\n                    if (rx_sync2 == 1\'b0)\n                        next_state = DATA;\n                    else\n                        next_state = IDLE;\n                end\n            end\n            DATA: begin\n                if (clk_count == Cycle_per_Period - 1) begin\n                    if (bit_count == BIT_PER_WORD - 1) begin\n                        if (PARITY_BIT != 0)\n                            next_state = PARITY;\n                        else\n                            next_state = STOP1;\n                    end\n                end\n            end\n            PARITY: begin\n                if (clk_count == Cycle_per_Period - 1) begin\n                    next_state = STOP1;\n                end\n            end\n            STOP1: begin\n                if (clk_count == Cycle_per_Period - 1) begin\n                    if (STOP_BITS_NUM == 2)\n                        next_state = STOP2;\n                    else\n                        next_state = OUT_RDY;\n                end\n            end\n            STOP2: begin\n                if (clk_count == Cycle_per_Period - 1) begin\n                    next_state = OUT_RDY;\n                end\n            end\n            OUT_RDY: begin\n                if (rx_falling_edge || rx_sync2 == 1\'b0)\n                    next_state = START;\n                else\n                    next_state = IDLE;\n            end\n            default: next_state = IDLE;\n        endcase\n    end\n\n    // Parity calculation\n    always_comb begin\n        calc_parity = ^data_shift_reg;\n        if (PARITY_BIT == 1) begin\n            calc_parity = ~calc_parity;\n        end\n    end\n\n    // FSM Outputs and Data Path\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            clk_count <= 0;\n            bit_count <= 0;\n            data_shift_reg <= 0;\n            parity_err <= 0;\n        end else begin\n            case (state)\n                IDLE: begin\n                    clk_count <= 0;\n                    bit_count <= 0;\n                    parity_err <= 0;\n                end\n                \n                START: begin\n                    parity_err <= 0;\n                    if (clk_count == Half_Cycle) begin\n                        clk_count <= 0;\n                    end else begin\n                        clk_count <= clk_count + 1;\n                    end\n                end\n                \n                DATA: begin\n                    if (clk_count == Cycle_per_Period - 1) begin\n                        clk_count <= 0;\n                        data_shift_reg <= {rx_sync2, data_shift_reg[BIT_PER_WORD-1:1]};\n                        if (bit_count == BIT_PER_WORD - 1) begin\n                            bit_count <= 0;\n                        end else begin\n                            bit_count <= bit_count + 1;\n                        end\n                    end else begin\n                        clk_count <= clk_count + 1;\n                    end\n                end\n                \n                PARITY: begin\n                    if (clk_count == Cycle_per_Period - 1) begin\n                        clk_count <= 0;\n                        if (rx_sync2 != calc_parity)\n                            parity_err <= 1\'b1;\n                        else\n                            parity_err <= 1\'b0;\n                    end else begin\n                        clk_count <= clk_count + 1;\n                    end\n                end\n                \n                STOP1: begin\n                    if (clk_count == Cycle_per_Period - 1) begin\n                        clk_count <= 0;\n                    end else begin\n                        clk_count <= clk_count + 1;\n                    end\n                end\n                \n                STOP2: begin\n                    if (clk_count == Cycle_per_Period - 1) begin\n                        clk_count <= 0;\n                    end else begin\n                        clk_count <= clk_count + 1;\n                    end\n                end\n                \n                OUT_RDY: begin\n                    clk_count <= 0;\n                end\n                \n                default: begin\n                    clk_count <= 0;\n                end\n            endcase\n        end\n    end\n\n    // AXI-Stream Outputs\n    assign tvalid = (state == OUT_RDY);\n    assign tdata  = data_shift_reg;\n    assign tuser  = (PARITY_BIT != 0) ? parity_err : 1\'b0;\n\nendmodule\n"""\n\nwith open("src/uart_rx_to_axis.sv", "w") as f:\n    f.write(code)\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
