Sending keys: ["cat << 'EOF' > rtl/swizzler_supervisor.sv\n`timescale 1ns/1ps\n\nmodule swizzler_supervisor #(\n  parameter integer NUM_LANES           = 4,\n  parameter integer DATA_WIDTH          = 8,\n  parameter integer REGISTER_OUTPUT     = 1,\n  parameter integer ENABLE_PARITY_CHECK = 1,\n  parameter integer OP_MODE_WIDTH       = 2,\n  parameter integer SWIZZLE_MAP_WIDTH   = $clog2(NUM_LANES)+1,\n  parameter [DATA_WIDTH-1:0] EXPECTED_CHECKSUM = 8'hA5\n)(\n  input  wire                           clk,\n  input  wire                           rst_n,\n  input  wire                           bypass,\n  input  wire [NUM_LANES*DATA_WIDTH-1:0] data_in,\n  input  wire [NUM_LANES*SWIZZLE_MAP_WIDTH-1:0] swizzle_map_flat,\n  input  wire [OP_MODE_WIDTH-1:0]         operation_mode,\n  output reg  [NUM_LANES*DATA_WIDTH-1:0]  final_data_out,\n  output reg                            top_error\n);\n\n  // Pre-processing: Pass-through as no specific reordering/scaling is defined\n  wire [NUM_LANES*DATA_WIDTH-1:0] pre_processed_data;\n  assign pre_processed_data = data_in;\n\n  // Internal signals from swizzler\n  wire [NUM_LANES*DATA_WIDTH-1:0] swizzler_out;\n  wire parity_error;\n  wire invalid_mapping_error;\n\n  // Instantiate the swizzler subcomponent\n  swizzler #(\n    .NUM_LANES(NUM_LANES),\n    .DATA_WIDTH(DATA_WIDTH),\n    .REGISTER_OUTPUT(REGISTER_OUTPUT),\n    .ENABLE_PARITY_CHECK(ENABLE_PARITY_CHECK),\n    .OP_MODE_WIDTH(OP_MODE_WIDTH),\n    .SWIZZLE_MAP_WIDTH(SWIZZLE_MAP_WIDTH)\n  ) u_swizzler (\n    .clk(clk),\n    .rst_n(rst_n),\n    .bypass(bypass),\n    .data_in(pre_processed_data),\n    .swizzle_map_flat(swizzle_map_flat),\n    .operation_mode(operation_mode),\n    .data_out(swizzler_out),\n    .parity_error(parity_error),\n    .invalid_mapping_error(invalid_mapping_error)\n  );\n\n  // Compute Checksum across all lanes (using addition)\n  reg [DATA_WIDTH-1:0] computed_checksum;\n  integer i;\n  always @* begin\n    computed_checksum = {DATA_WIDTH{1'b0}};\n    for (i = 0; i < NUM_LANES; i = i + 1) begin\n      computed_checksum = computed_checksum + swizzler_out[i*DATA_WIDTH +: DATA_WIDTH];\n    end\n  end\n\n  // Error Supervision\n  wire checksum_mismatch = (computed_checksum != EXPECTED_CHECKSUM);\n  \n  always @* begin\n    top_error = parity_error | invalid_mapping_error | checksum_mismatch;\n  end\n\n  // Post-processing: invert the least significant bit in each lane\n  integer j;\n  always @* begin\n    final_data_out = swizzler_out;\n    for (j = 0; j < NUM_LANES; j = j + 1) begin\n      final_data_out[j*DATA_WIDTH] = ~swizzler_out[j*DATA_WIDTH]; // Invert LSB\n    end\n  end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
