 rotl(curr_key, k_rot) : rotr(curr_key, k_rot);\n                k_i = curr_key ^ idx;\n            }\n            \n            uint16_t val1 = R ^ k_i;\n            uint16_t val2 = (f_dir == 0) ? rotl(val1, f_rot) : rotr(val1, f_rot);\n            uint16_t val3 = (val2 + k_i) & 0xFFFF;\n            \n            uint16_t next_L = R;\n            uint16_t next_R = L ^ val3;\n            L = next_L;\n            R = next_R;\n        }\n        \n        if (final_swap) {\n            uint16_t temp = L;\n            L = R;\n            R = temp;\n        }\n        \n        uint32_t out = ((uint32_t)L << 16) | R;\n        if (out == expected_out) {\n            printf("MATCH! k_rot=%d, k_dir=%d, f_rot=%d, f_dir=%d, i_start=%d, k_mode=%d, final_swap=%d\\n",\n                   k_rot, k_dir, f_rot, f_dir, i_start, k_mode, final_swap);\n            return 0;\n        }\n    }}}}}}}\n    printf("No match found.\\n");\n    return 0;\n}\nEOF\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
