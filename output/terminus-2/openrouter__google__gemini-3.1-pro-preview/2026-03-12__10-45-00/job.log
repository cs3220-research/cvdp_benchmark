 negedge presetn) begin\n        if (!presetn) begin\n            data_reg       <= 32'h0;\n            control_reg    <= 32'h0;\n            interrupt_reg  <= 32'h0;\n            isr_reg        <= 32'h0;\n            prdata         <= 32'h0;\n            pslverr        <= 1'b0;\n            latched_paddr  <= 32'h0;\n            latched_pwdata <= 32'h0;\n        end else begin\n            if (state == SETUP) begin\n                latched_paddr  <= paddr;\n                latched_pwdata <= pwdata;\n            end\n\n            if (state == WRITE_STATE) begin\n                case (latched_paddr)\n                    32'h10: begin\n                        data_reg <= latched_pwdata;\n                        pslverr  <= 1'b0;\n                    end\n                    32'h14: begin\n                        control_reg <= latched_pwdata;\n                        pslverr     <= 1'b0;\n                    end\n                    32'h18: begin\n                        interrupt_reg <= latched_pwdata;\n                        isr_reg <= isr_reg & ~latched_pwdata;\n                        pslverr <= 1'b0;\n                    end\n                    32'h1C: begin\n                        pslverr <= 1'b1;\n                    end\n                    default: begin\n                        pslverr <= 1'b0;\n                    end\n                endcase\n            end else if (state == READ_STATE) begin\n                pslverr <= 1'b0;\n                case (latched_paddr)\n                    32'h10: prdata <= data_reg;\n                    32'h14: prdata <= control_reg;\n                    32'h18: prdata <= interrupt_reg;\n                    32'h1C: prdata <= isr_reg;\n                    default: prdata <= 32'h0;\n                endcase\n            end\n            \n            // Clear pslverr at the beginning of a new transaction\n            if (state == IDLE && pselx && !penable) begin\n                pslverr <= 1'b0;\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
