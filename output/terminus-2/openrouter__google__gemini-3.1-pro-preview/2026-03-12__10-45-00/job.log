f (state == IDLE) begin\n                Bit_Count <= '0;\n            end else if (state == DATA && Clk_Count_Done) begin\n                if (Bit_Count_Done)\n                    Bit_Count <= '0;\n                else\n                    Bit_Count <= Bit_Count + 1;\n            end\n        end\n    end\n\n    assign Bit_Count_Done = (Bit_Count == BIT_PER_WORD - 1);\n\n    // Parity Computation\n    always_comb begin\n        if (PARITY_BIT == 1) begin\n            parity_calc = ~(^Data); // Odd parity\n        end else if (PARITY_BIT == 2) begin\n            parity_calc = ^Data;    // Even parity\n        end else begin\n            parity_calc = 1'b0;     // No parity\n        end\n    end\n\n    // FSM Sequential\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            state <= IDLE;\n        end else begin\n            state <= next_state;\n        end\n    end\n\n    // FSM Combinational\n    always_comb begin\n        next_state = state;\n        case (state)\n            IDLE: begin\n                if (tvalid) begin\n                    next_state = START;\n                end\n            end\n            START: begin\n                if (Clk_Count_Done) begin\n                    next_state = DATA;\n                end\n            end\n            DATA: begin\n                if (Clk_Count_Done && Bit_Count_Done) begin\n                    if (PARITY_BIT != 0) begin\n                        next_state = PARITY;\n                    end else begin\n                        next_state = STOP1;\n                    end\n                end\n            end\n            PARITY: begin\n                if (Clk_Count_Done) begin\n                    next_state = STOP1;\n                end\n            end\n            STOP1: begin\n                if (Clk_Count_Done) begin\n                    if (STOP_BITS_NUM == 2) begin\n                        next_state = STOP2;\n                    end else begin\n               