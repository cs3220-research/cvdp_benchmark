 end else begin\n              merge4_left[merge_count] <= sorted_pairs[ptr4+6];\n              ptr4 <= ptr4 + 1;\n            end\n          end else if (ptr3 < 2) begin\n            merge4_left[merge_count] <= sorted_pairs[ptr3+4];\n            ptr3 <= ptr3 + 1;\n          end else if (ptr4 < 2) begin\n            merge4_left[merge_count] <= sorted_pairs[ptr4+6];\n            ptr4 <= ptr4 + 1;\n          end\n\n          if (merge_count == 3) begin\n            merge_count <= 0;\n            ptr1        <= 0;\n            ptr2        <= 0;\n            state       <= MERGE_4;\n          end else begin\n            merge_count <= merge_count + 1;\n          end\n        end\n"""\n\ncontent = re.sub(r\'\\s*// Stage 2a:.*?// Stage 3:\', merge_2_code + \'\\n        // Stage 3:\', content, flags=re.DOTALL)\n\nwith open(\'rtl/sorting_engine.sv\', \'w\') as f:\n    f.write(content)\nEOF\npython3 modify.py\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
