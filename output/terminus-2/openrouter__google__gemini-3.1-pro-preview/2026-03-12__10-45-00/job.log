Sending keys: ["cat << 'EOF' > rtl/order_matching_engine.sv\nmodule order_matching_engine #(\n    parameter PRICE_WIDTH = 16  // width of the price field\n)(\n    input                      clk,\n    input                      rst,\n    input                      start,         // Active high. Start matching operation\n    input                      circuit_breaker, //Active high. Circuit breaker\n    input  [8*PRICE_WIDTH-1:0] bid_orders,    // 8 bid orders (flat vector)\n    input  [8*PRICE_WIDTH-1:0] ask_orders,    // 8 ask orders (flat vector)\n    output reg                 match_valid,   // High if a match occurs\n    output reg [PRICE_WIDTH-1:0] matched_price, // Matched price (best bid)\n    output reg                 done          // Active high. Matching engine done\n);\n\n    wire [8*PRICE_WIDTH-1:0] sorted_bids;\n    wire [8*PRICE_WIDTH-1:0] sorted_asks;\n    wire                     bids_done;\n    wire                     asks_done;\n\n    // Instantiate brick_sorting_engine for bids\n    brick_sorting_engine #(\n        .N(8),\n        .WIDTH(PRICE_WIDTH)\n    ) bid_sorter (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(bid_orders),\n        .done(bids_done),\n        .out_data(sorted_bids)\n    );\n\n    // Instantiate brick_sorting_engine for asks\n    brick_sorting_engine #(\n        .N(8),\n        .WIDTH(PRICE_WIDTH)\n    ) ask_sorter (\n        .clk(clk),\n        .rst(rst),\n        .start(start),\n        .in_data(ask_orders),\n        .done(asks_done),\n        .out_data(sorted_asks)\n    );\n\n    // best_bid is the highest bid (last element after ascending sort)\n    wire [PRICE_WIDTH-1:0] best_bid = sorted_bids[7*PRICE_WIDTH +: PRICE_WIDTH];\n    // best_ask is the lowest ask (first element after ascending sort)\n    wire [PRICE_WIDTH-1:0] best_ask = sorted_asks[0 +: PRICE_WIDTH];\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            match_valid   <= 1'b0;\n            matched_price <= {PRICE_WIDTH{1'b0}};\n            done          <= 1'b0;\n        end else begin\n            // Add 1 clock cycle latency on top of the sorting engine\n            done <= bids_done;\n            \n            if (bids_done) begin\n                if (best_bid >= best_ask && !circuit_breaker) begin\n                    match_valid   <= 1'b1;\n                    matched_price <= best_bid;\n                end else begin\n                    match_valid   <= 1'b0;\n                    matched_price <= {PRICE_WIDTH{1'b0}};\n                end\n            end else begin\n                match_valid   <= 1'b0;\n                matched_price <= {PRICE_WIDTH{1'b0}};\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
