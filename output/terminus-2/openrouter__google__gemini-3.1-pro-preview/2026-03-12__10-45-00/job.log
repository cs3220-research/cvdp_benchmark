Sending keys: ['cat << \'EOF\' > patch.py\nimport sys\n\nwith open(\'rtl/rgb_color_space_conversion.sv\', \'r\') as f:\n    content = f.read()\n\nold_ports = """    output reg [11:0]   hsl_channel_l,  // % value = (hsl_channel_l/255) * 100\n\n    output reg          valid_out\n);"""\n\nnew_ports = """    output reg [11:0]   hsl_channel_l,  // % value = (hsl_channel_l/255) * 100\n\n    // CMYK Output values\n    output reg [15:0]   cmyk_channel_c,  // % value = (cmyk_channel_c/(256*255)) * 100\n    output reg [15:0]   cmyk_channel_m,  // % value = (cmyk_channel_m/(256*255)) * 100\n    output reg [15:0]   cmyk_channel_y,  // % value = (cmyk_channel_y/(256*255)) * 100\n    output reg [7:0]    cmyk_channel_k,  // % value = (cmyk_channel_k/255) * 100\n\n    output reg          valid_out\n);"""\n\ncontent = content.replace(old_ports, new_ports)\n\nendmodule_idx = content.find(\'endmodule\\n\')\nif endmodule_idx == -1:\n    endmodule_idx = content.find(\'endmodule\')\n\ncmyk_logic = """\n    // CMYK Pipeline\n    reg [7:0] r_reg1, g_reg1, b_reg1;\n    reg [7:0] r_reg2, g_reg2, b_reg2;\n    reg [7:0] diff_r, diff_g, diff_b;\n    reg [15:0] diff_r_255, diff_g_255, diff_b_255;\n    reg [24:0] inv_i_max_reg;\n    reg [7:0] k_val, k_val_reg1, k_val_reg2, k_val_reg3, k_val_reg4;\n\n    wire [15:0] cmyk_channel_c_raw;\n    wire [15:0] cmyk_channel_m_raw;\n    wire [15:0] cmyk_channel_y_raw;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            r_reg1 <= 0; g_reg1 <= 0; b_reg1 <= 0;\n            r_reg2 <= 0; g_reg2 <= 0; b_reg2 <= 0;\n            diff_r <= 0; diff_g <= 0; diff_b <= 0;\n            diff_r_255 <= 0; diff_g_255 <= 0; diff_b_255 <= 0;\n            inv_i_max_reg <= 0;\n            k_val <= 0; k_val_reg1 <= 0; k_val_reg2 <= 0; k_val_reg3 <= 0; k_val_reg4 <= 0;\n            cmyk_channel_c <= 0; cmyk_channel_m <= 0; cmyk_channel_y <= 0; cmyk_channel_k <= 0;\n        end else begin\n            // Cycle 1\n            if (valid_in) begin\n                r_reg1 <= r_component;\n                g_reg1 <= g_component;\n                b_reg1 <= b_component;\n            end\n            \n            // Cycle 2\n            if (valid_in_shreg[0]) begin\n                r_reg2 <= r_reg1;\n                g_reg2 <= g_reg1;\n                b_reg2 <= b_reg1;\n            end\n            \n            // Cycle 3\n            if (valid_in_shreg[1]) begin\n                diff_r <= i_max[7:0] - r_reg2;\n                diff_g <= i_max[7:0] - g_reg2;\n                diff_b <= i_max[7:0] - b_reg2;\n                k_val  <= 8\'d255 - i_max[7:0];\n            end\n            \n            // Cycle 4\n            if (valid_in_shreg[2]) begin\n                diff_r_255 <= diff_r * 16\'d255;\n                diff_g_255 <= diff_g * 16\'d255;\n                diff_b_255 <= diff_b * 16\'d255;\n                inv_i_max_reg <= inv_i_max;\n                k_val_reg1 <= k_val;\n            end\n            \n            // Cycle 5\n            if (valid_in_shreg[3]) begin\n                k_val_reg2 <= k_val_reg1;\n            end\n            \n            // Cycle 6\n            if (valid_in_shreg[4]) begin\n                k_val_reg3 <= k_val_reg2;\n            end\n            \n            // Cycle 7\n            if (valid_in_shreg[5]) begin\n                k_val_reg4 <= k_val_reg3;\n            end\n            \n            // Cycle 8\n            if (valid_in_shreg[6]) begin\n                cmyk_channel_c <= cmyk_channel_c_raw;\n                cmyk_channel_m <= cmyk_channel_m_raw;\n                cmyk_channel_y <= cmyk_channel_y_raw;\n                cmyk_channel_k <= k_val_reg4;\n            end\n        end\n    end\n\n    cmy_mult cmy_mult_c (\n        .clk(clk),\n        .rst(rst),\n        .a(inv_i_max_reg),\n        .b(diff_r_255),\n        .result(cmyk_channel_c_raw)\n    );\n\n    cmy_mult cmy_mult_m (\n        .clk(clk),\n        .rst(rst),\n        .a(inv_i_max_reg),\n        .b(diff_g_255),\n        .result(cmyk_channel_m_raw)\n    );\n\n    cmy_mult cmy_mult_y (\n        .clk(clk),\n        .rst(rst),\n        .a(inv_i_max_reg),\n        .b(diff_b_255),\n        .result(cmyk_channel_y_raw)\n    );\n"""\n\ncontent = content[:endmodule_idx] + cmyk_logic + content[endmodule_idx:]\n\ncmy_mult_code = """\n// CMY Multiplication Module\nmodule cmy_mult (\n    input  wire         clk,\n    input  wire         rst,\n    input  wire [24:0]  a,      // inv_i_max\n    input  wire [15:0]  b,      // diff * 255\n    output [15:0]       result\n);\n    reg [24:0] A_reg;\n    reg [15:0] B_reg;\n    reg [40:0] mult_result;\n    reg [15:0] rounded_result;\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            A_reg <= 25\'d0;\n            B_reg <= 16\'d0;\n        end else begin\n            A_reg <= a;\n            B_reg <= b;\n        end\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            mult_result <= \'d0;\n        end else begin\n            mult_result <= A_reg * B_reg;\n        end\n    end\n\n    always @(posedge clk or posedge rst) begin\n        if (rst) begin\n            rounded_result <= \'d0;\n        end else begin\n            rounded_result <= mult_result[31:16] + mult_result[15];\n        end\n    end\n\n    assign result = rounded_result;\nendmodule\n"""\n\ncontent += cmy_mult_code\n\nwith open(\'rtl/rgb_color_space_conversion.sv\', \'w\') as f:\n    f.write(content)\nEOF\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
