Sending keys: ["cat << 'EOF' > rtl/dig_stopwatch.sv\nmodule dig_stopwatch #(\n    parameter CLK_FREQ = 50000000\n)(\n    input  logic clk,\n    input  logic reset,\n    input  logic start_stop,\n    output logic [5:0] seconds,\n    output logic [5:0] minutes,\n    output logic hour,\n    output logic second_pulse,\n    output logic minute_pulse,\n    output logic hour_pulse,\n    output logic beep\n);\n\n    localparam int MAX_COUNT = CLK_FREQ - 1;\n    integer counter;\n\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            counter <= 0;\n        end else if (start_stop) begin\n            if (counter >= MAX_COUNT) begin\n                counter <= 0;\n            end else begin\n                counter <= counter + 1;\n            end\n        end\n    end\n\n    assign second_pulse = (start_stop && counter == MAX_COUNT);\n    assign minute_pulse = second_pulse && (seconds == 59) && !(hour == 1 && minutes == 0 && seconds == 0);\n    assign hour_pulse   = minute_pulse && (minutes == 59);\n\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            seconds <= 0;\n        end else if (second_pulse) begin\n            if (hour == 1 && minutes == 0 && seconds == 0) begin\n                // saturated\n            end else if (seconds == 59) begin\n                seconds <= 0;\n            end else begin\n                seconds <= seconds + 1;\n            end\n        end\n    end\n\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            minutes <= 0;\n        end else if (minute_pulse) begin\n            if (minutes == 59) begin\n                minutes <= 0;\n            end else begin\n                minutes <= minutes + 1;\n            end\n        end\n    end\n\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            hour <= 0;\n        end else if (hour_pulse) begin\n            hour <= 1;\n        end\n    end\n\n    always_ff @(posedge clk) begin\n        if (reset) begin\n            beep <= 0;\n        end else begin\n            if (hour_pulse) begin\n                beep <= 1;\n            end else if (second_pulse) begin\n                beep <= 0;\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
