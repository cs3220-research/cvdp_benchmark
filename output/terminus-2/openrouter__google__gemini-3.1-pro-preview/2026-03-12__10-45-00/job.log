A_WIDTH +: DATA_WIDTH] = remapped_data_array[i];\n        end\n    endgenerate\n\n    // Parity check\n    generate\n        if (ENABLE_PARITY_CHECK) begin : gen_parity\n            always_comb begin\n                comb_parity_error = 1'b0;\n                for (int i = 0; i < NUM_LANES; i++) begin\n                    if (^remapped_data_array[i]) begin\n                        comb_parity_error = 1'b1;\n                    end\n                end\n            end\n        end else begin : gen_no_parity\n            assign comb_parity_error = 1'b0;\n        end\n    endgenerate\n\n    // Output assignment\n    generate\n        if (REGISTER_OUTPUT) begin : gen_reg_out\n            always_ff @(posedge clk or negedge rst_n) begin\n                if (!rst_n) begin\n                    data_out <= '0;\n                    parity_error <= 1'b0;\n                end else begin\n                    data_out <= remapped_data_flat;\n                    parity_error <= comb_parity_error;\n                end\n            end\n        end else begin : gen_comb_out\n            always_comb begin\n                data_out = remapped_data_flat;\n                parity_error = comb_parity_error;\n            end\n        end\n    endgenerate\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
