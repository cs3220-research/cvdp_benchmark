Sending keys: ["cat << 'EOF' > rtl/phase_rotation_viterbi.sv\nmodule phase_rotation_viterbi #(\n    parameter NBW_IN = 8,\n    parameter NBW_OUT = NBW_IN + 11\n) (\n    input  logic clk,\n    input  logic rst_async_n,\n    input  logic [NBW_IN-1:0] i_data_i,\n    input  logic [NBW_IN-1:0] i_data_q,\n    output logic [NBW_OUT-1:0] o_data_i,\n    output logic [NBW_OUT-1:0] o_data_q\n);\n\n    // power4 outputs\n    localparam NBW_POWER4_OUT = NBW_IN * 4;\n    logic signed [NBW_POWER4_OUT-1:0] data_i4_ff;\n    logic signed [NBW_POWER4_OUT-1:0] data_q4_ff;\n\n    power4 #(\n        .NBW_IN(NBW_IN),\n        .NBW_OUT(NBW_POWER4_OUT)\n    ) u_power4 (\n        .clk(clk),\n        .rst_async_n(rst_async_n),\n        .i_data_i(i_data_i),\n        .i_data_q(i_data_q),\n        .o_data_i(data_i4_ff),\n        .o_data_q(data_q4_ff)\n    );\n\n    // Saturation to 6-bit\n    logic signed [5:0] data_i4_ff_sat;\n    logic signed [5:0] data_q4_ff_sat;\n\n    saturation #(\n        .NBW_IN(NBW_POWER4_OUT),\n        .NBW_OUT(6)\n    ) u_sat_p4_i (\n        .i_data(data_i4_ff),\n        .o_data(data_i4_ff_sat)\n    );\n\n    saturation #(\n        .NBW_IN(NBW_POWER4_OUT),\n        .NBW_OUT(6)\n    ) u_sat_p4_q (\n        .i_data(data_q4_ff),\n        .o_data(data_q4_ff_sat)\n    );\n\n    // Phase LUT\n    logic signed [8:0] phase;\n    phase_lut #(\n        .NBW_IN(6),\n        .NBW_PHASE(9)\n    ) u_phase_lut (\n        .i_data_i(data_i4_ff_sat),\n        .i_data_q(data_q4_ff_sat),\n        .o_phase(phase)\n    );\n\n    // Phase division by 4\n    logic signed [8:0] phase_div4;\n    assign phase_div4 = phase >>> 2; // Signed right shift by 2\n\n    // Saturation to 7-bit\n    logic signed [6:0] phase_div4_sat;\n    saturation #(\n        .NBW_IN(9),\n        .NBW_OUT(7)\n    ) u_sat_phase (\n        .i_data(phase_div4),\n        .o_data(phase_div4_sat)\n    );\n\n    // Delay I/Q signals by 1 cycle\n    logic signed [NBW_IN-1:0] i_data_i_d1;\n    logic signed [NBW_IN-1:0] i_data_q_d1;\n\n    always_ff @(posedge clk or negedge rst_async_n) begin\n        if (!rst_async_n) begin\n            i_data_i_d1 <= '0;\n            i_data_q_d1 <= '0;\n        end else begin\n            i_data_i_d1 <= i_data_i;\n            i_data_q_d1 <= i_data_q;\n        end\n    end\n\n    // Top Phase Rotation\n    top_phase_rotation #(\n        .NBW_ANG(7),\n        .NBW_COS(10),\n        .NBW_IN_DATA(NBW_IN),\n        .NS_IN(1),\n        .NBW_OUT_DATA(NBW_OUT)\n    ) u_top_phase_rotation (\n        .clk(clk),\n        .i_data_re(i_data_i_d1),\n        .i_data_im(i_data_q_d1),\n        .i_angle(phase_div4_sat),\n        .o_data_re(o_data_i),\n        .o_data_im(o_data_q)\n    );\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
