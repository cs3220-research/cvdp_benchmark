Sending keys: ["cat << 'EOF' > /code/rtl/cache_controller.sv\nmodule cache_controller (\n    input  wire        clk,\n    input  wire        reset,\n    input  wire [31:0] address,\n    input  wire [31:0] write_data,\n    input  wire        read,\n    input  wire        write,\n    output wire [31:0] read_data,\n    output wire        hit,\n    output wire        miss,\n    output wire        mem_write,\n    output wire [31:0] mem_address,\n    output wire [31:0] mem_write_data,\n    input  wire [31:0] mem_read_data,\n    input  wire        mem_ready\n);\n\n    // Cache storage\n    reg [31:0] cache_data  [0:31];\n    reg [4:0]  cache_tag   [0:31];\n    reg        cache_valid [0:31];\n\n    wire [4:0] req_index = address[4:0];\n    wire [4:0] req_tag   = address[9:5];\n\n    integer i;\n\n    // Hit and miss logic\n    assign hit  = cache_valid[req_index] && (cache_tag[req_index] == req_tag);\n    assign miss = ~hit;\n\n    // Read data logic\n    assign read_data = (read && miss && mem_ready) ? mem_read_data : cache_data[req_index];\n\n    // Memory interface logic\n    assign mem_write      = write;\n    assign mem_address    = address;\n    assign mem_write_data = write_data;\n\n    // Sequential logic for cache updates\n    always @(posedge clk or posedge reset) begin\n        if (reset) begin\n            for (i = 0; i < 32; i = i + 1) begin\n                cache_valid[i] <= 1'b0;\n                cache_tag[i]   <= 5'b0;\n                cache_data[i]  <= 32'b0;\n            end\n        end else begin\n            if (read && miss && mem_ready) begin\n                cache_valid[req_index] <= 1'b1;\n                cache_tag[req_index]   <= req_tag;\n                cache_data[req_index]  <= mem_read_data;\n            end else if (write) begin\n                if (hit) begin\n                    cache_data[req_index] <= write_data;\n                end\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
