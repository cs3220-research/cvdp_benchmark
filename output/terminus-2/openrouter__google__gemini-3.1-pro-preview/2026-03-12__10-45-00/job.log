  next_state = current_state;\n        case (current_state)\n            IDLE: begin\n                if (awvalid && wvalid) begin\n                    next_state = ADDR_CAPTURE;\n                end else if (arvalid) begin\n                    next_state = READ_ADDR_CAPTURE;\n                end\n            end\n\n            ADDR_CAPTURE: begin\n                next_state = DATA_CAPTURE;\n            end\n\n            DATA_CAPTURE: begin\n                next_state = PCIE_WRITE;\n            end\n\n            PCIE_WRITE: begin\n                next_state = SEND_RESPONSE;\n            end\n\n            SEND_RESPONSE: begin\n                if (bready) begin\n                    next_state = IDLE;\n                end\n            end\n\n            READ_ADDR_CAPTURE: begin\n                next_state = PCIE_READ;\n            end\n\n            PCIE_READ: begin\n                next_state = READ_SEND_RESPONSE;\n            end\n\n            READ_SEND_RESPONSE: begin\n                if (rready) begin\n                    next_state = IDLE;\n                end\n            end\n\n            default: begin\n                next_state = IDLE;\n            end\n        endcase\n    end\n\n    // FSM Output Logic\n    always_ff @(posedge aclk or negedge aresetn) begin\n        if (!aresetn) begin\n            awready <= 1'b0;\n            wready <= 1'b0;\n            bvalid <= 1'b0;\n            bresp <= 2'b00; // OKAY response\n            pcie_cfg_wr_en <= 1'b0;\n            pcie_cfg_wdata <= 32'h0;\n            pcie_cfg_addr <= '0;\n            awaddr_reg <= '0;\n            wdata_reg <= 32'h0;\n            wstrb_reg <= 4'h0;\n            \n            arready <= 1'b0;\n            rvalid <= 1'b0;\n            rresp <= 2'b00;\n            rdata <= 32'h0;\n            pcie_cfg_rd_en <= 1'b0;\n            araddr_reg <= '0;\n        end else begin\n            case (current_state)\n                IDLE: begin\n                    awready <= 1'b0;\n                    wready <= 1'b0;\n                    bvalid <= 1'b0;\n                    pcie_cfg_wr_en <= 1'b0;\n                    \n                    arready <= 1'b0;\n                    rvalid <= 1'b0;\n                    pcie_cfg_rd_en <= 1'b0;\n                end\n\n                ADDR_CAPTURE: begin\n                    awready <= 1'b1;\n                    awaddr_reg <= awaddr;\n                end\n\n                DATA_CAPTURE: begin\n                    wready <= 1'b1;\n                    wdata_reg <= wdata;\n                    wstrb_reg <= wstrb;\n                end\n\n                PCIE_WRITE: begin\n                    pcie_cfg_wr_en <= 1'b1;\n                    pcie_cfg_addr <= awaddr_reg;\n\n                    // Apply wstrb to write only the selected bytes\n                    for (int i = 0; i < (DATA_WIDTH/8); i++) begin\n                        pcie_cfg_wdata[(i*8)+:8] <= (wstrb_reg[i]) ? wdata_reg[(i*8)+:8] : pcie_cfg_rdata[(i*8)+:8];\n                    end\n                end\n\n                SEND_RESPONSE: begin\n                    pcie_cfg_wr_en <= 1'b0;\n                    bvalid <= 1'b1;\n                end\n\n                READ_ADDR_CAPTURE: begin\n                    arready <= 1'b1;\n                    araddr_reg <= araddr;\n                end\n\n                PCIE_READ: begin\n                    pcie_cfg_rd_en <= 1'b1;\n                    pcie_cfg_addr <= araddr_reg;\n                end\n\n                READ_SEND_RESPONSE: begin\n                    pcie_cfg_rd_en <= 1'b0;\n                    rvalid <= 1'b1;\n                    rdata <= pcie_cfg_rdata;\n                    rresp <= 2'b00; // OKAY\n                end\n\n                default: begin\n                    // Default outputs\n                end\n            endcase\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
