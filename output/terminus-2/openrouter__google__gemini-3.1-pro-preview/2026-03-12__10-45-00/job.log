     latency_error <= 0;\n            end else if (active) begin\n                timer <= timer + 1;\n                \n                if (timer == 20) begin\n                    if (!bid_done || !ask_done) begin\n                        latency_error <= 1;\n                    end\n                    \n                    active <= 0;\n                    done <= 1;\n                    \n                    if (best_bid >= best_ask) begin\n                        match_valid <= 1;\n                        matched_price <= best_ask;\n                    end else begin\n                        match_valid <= 0;\n                        matched_price <= 0;\n                    end\n                end else begin\n                    if (bid_done || ask_done) begin\n                        latency_error <= 1;\n                    end\n                end\n            end else begin\n                if (bid_done || ask_done) begin\n                    latency_error <= 1;\n                end\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
