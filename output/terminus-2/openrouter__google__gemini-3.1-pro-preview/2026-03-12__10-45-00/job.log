       count <= 16'd0;\n            match_value <= 16'd0;\n            reload_value <= 16'd0;\n            enable <= 1'b0;\n            interval_mode <= 1'b0;\n            interrupt_enable <= 1'b0;\n            status <= 1'b0;\n            prescaler <= 4'd0;\n            prescaler_cnt <= 4'd0;\n        end else begin\n            // 1. Handle AXI Writes\n            if (axi_write_en) begin\n                case (axi_addr)\n                    4'h1: match_value <= axi_wdata[15:0];\n                    4'h2: reload_value <= axi_wdata[15:0];\n                    4'h3: begin\n                        enable <= axi_wdata[0];\n                        interval_mode <= axi_wdata[1];\n                        interrupt_enable <= axi_wdata[2];\n                    end\n                    4'h5: prescaler <= axi_wdata[3:0];\n                    default: ; // Do nothing\n                endcase\n            end\n\n            // 2. Handle Status Register\n            if (match_event || count_reloaded_to_match) begin\n                status <= 1'b1;\n            end else if (axi_write_en && axi_addr == 4'h4) begin\n                status <= 1'b0; // Write to clear\n            end\n\n            // 3. Handle Counter and Prescaler\n            if (enable) begin\n                if (prescaler_cnt == prescaler) begin\n                    prescaler_cnt <= 4'd0;\n                    if (count == match_value) begin\n                        if (interval_mode) begin\n                            count <= reload_value;\n                        end else begin\n                            count <= 16'd0;\n                            // Auto-clear enable in single-shot mode unless AXI is writing to it this cycle\n                            if (!(axi_write_en && axi_addr == 4'h3)) begin\n                                enable <= 1'b0;\n                            end\n                        end\n                    end else begin\n                        count <= count + 16'd1;\n             