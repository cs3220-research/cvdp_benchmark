g && !sign_q_reg) begin\n            o_phase = $signed(10\'d256 - lut_val);\n        end else begin\n            o_phase = $signed(lut_val - 10\'d256);\n        end\n    end\n\nendmodule\n""")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
