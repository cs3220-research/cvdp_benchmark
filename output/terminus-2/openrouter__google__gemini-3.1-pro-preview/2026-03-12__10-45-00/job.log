      end else if (fifo_wr_en && axis_last_in) begin\n            wr_frame_cnt_bin <= wr_frame_cnt_bin + 1;\n            wr_frame_cnt_gray <= (wr_frame_cnt_bin + 1) ^ ((wr_frame_cnt_bin + 1) >> 1);\n        end\n    end\n\n    logic [7:0] mii_frame_cnt_gray_sync1, mii_frame_cnt_gray_sync2;\n    always_ff @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            mii_frame_cnt_gray_sync1 <= 0;\n            mii_frame_cnt_gray_sync2 <= 0;\n        end else begin\n            mii_frame_cnt_gray_sync1 <= wr_frame_cnt_gray;\n            mii_frame_cnt_gray_sync2 <= mii_frame_cnt_gray_sync1;\n        end\n    end\n\n    logic [7:0] wr_frame_cnt_sync_bin;\n    always_comb begin\n        wr_frame_cnt_sync_bin[7] = mii_frame_cnt_gray_sync2[7];\n        for (int i = 6; i >= 0; i--) begin\n            wr_frame_cnt_sync_bin[i] = wr_frame_cnt_sync_bin[i+1] ^ mii_frame_cnt_gray_sync2[i];\n        end\n    end\n\n    logic [7:0] rd_frame_cnt;\n    wire frame_available = (rd_frame_cnt != wr_frame_cnt_sync_bin);\n\n    // CRC Function\n    function logic [31:0] next_crc32_nibble(input [3:0] data, input [31:0] crc);\n        logic [31:0] c;\n        begin\n            c = crc;\n            c = {c[30:0], 1\'b0} ^ ((data[0] ^ c[31]) ? 32\'h04C11DB7 : 32\'h0);\n            c = {c[30:0], 1\'b0} ^ ((data[1] ^ c[31]) ? 32\'h04C11DB7 : 32\'h0);\n            c = {c[30:0], 1\'b0} ^ ((data[2] ^ c[31]) ? 32\'h04C11DB7 : 32\'h0);\n            c = {c[30:0], 1\'b0} ^ ((data[3] ^ c[31]) ? 32\'h04C11DB7 : 32\'h0);\n            next_crc32_nibble = c;\n        end\n    endfunction\n\n    // MII TX FSM\n    typedef enum logic [2:0] {\n        ST_IDLE,\n        ST_PREAMBLE,\n        ST_SFD,\n        ST_DATA,\n        ST_CRC,\n        ST_IFG\n    } state_t;\n    state_t state;\n\n    logic [4:0] count;\n    logic [3:0] word_nibble_cnt;\n    logic [31:0] crc_reg;\n\n    wire [31:0] current_word = fifo_rd_data[31:0];\n    wire [3:0] current_strb = fifo_rd_data[35:32];\n    wire current_last = fifo_rd_data[36];\n\n    logic [31:0] crc_inv_rev;\n    always_comb begin\n        for (int i = 0; i < 32; i++) begin\n            crc_inv_rev[i] = ~crc_reg[31-i];\n        end\n    end\n\n    logic [3:0] crc_nibble;\n    always_comb begin\n        case (count[2:0])\n            3\'d0: crc_nibble = crc_inv_rev[3:0];\n            3\'d1: crc_nibble = crc_inv_rev[7:4];\n            3\'d2: crc_nibble = crc_inv_rev[11:8];\n            3\'d3: crc_nibble = crc_inv_rev[15:12];\n            3\'d4: crc_nibble = crc_inv_rev[19:16];\n            3\'d5: crc_nibble = crc_inv_rev[23:20];\n            3\'d6: crc_nibble = crc_inv_rev[27:24];\n            3\'d7: crc_nibble = crc_inv_rev[31:28];\n        endcase\n    end\n\n    always_ff @(posedge clk_in or posedge rst_in) begin\n        if (rst_in) begin\n            state <= ST_IDLE;\n            count <= 0;\n            word_nibble_cnt <= 0;\n            crc_reg <= 32\'hFFFFFFFF;\n            mii_txd_out <= 4\'h0;\n            mii_tx_en_out <= 1\'b0;\n            rd_frame_cnt <= 0;\n            fifo_rd_en <= 1\'b0;\n        end else begin\n            fifo_rd_en <= 1\'b0;\n            \n            case (state)\n                ST_IDLE: begin\n                    mii_txd_out <= 4\'h0;\n                    mii_tx_en_out <= 1\'b0;\n                    if (frame_available) begin\n                        state <= ST_PREAMBLE;\n                        count <= 0;\n                        crc_reg <= 32\'hFFFFFFFF;\n                        mii_txd_out <= 4\'h5;\n                        mii_tx_en_out <= 1\'b1;\n                    end\n                end\n                \n                ST_PREAMBLE: begin\n                    mii_txd_out <= 4\'h5;\n                    mii_tx_en_out <= 1\'b1;\n                    if (count == 13) begin\n                        state <= ST_SFD;\n                        count <= 0;\n                        mii_txd_out <= 4\'h5;\n                        fifo_rd_en <= 1\'b1;\n                    end else begin\n                        count <= count + 1;\n                    end\n                end\n                \n                ST_SFD: begin\n                    mii_tx_en_out <= 1\'b1;\n                    if (count == 0) begin\n                        count <= 1;\n                        mii_txd_out <= 4\'hD;\n                    end else begin\n                        state <= ST_DATA;\n                        word_nibble_cnt <= 0;\n                        mii_txd_out <= current_word[3:0];\n                        crc_reg <= next_crc32_nibble(current_word[3:0], crc_reg);\n                    end\n                end\n                \n                ST_DATA: begin\n                    mii_tx_en_out <= 1\'b1;\n                    \n                    logic [3:0] max_nibble;\n                    case (current_strb)\n                        4\'b0001: max_nibble = 4\'d1;\n                        4\'b0011: max_nibble = 4\'d3;\n                        4\'b0111: max_nibble = 4\'d5;\n                        4\'b1111: max_nibble = 4\'d7;\n                        default: max_nibble = 4\'d7;\n                    endcase\n                    \n                    if (word_nibble_cnt == max_nibble - 1 && !current_last) begin\n                        fifo_rd_en <= 1\'b1;\n                    end\n                    \n                    if (word_nibble_cnt == max_nibble) begin\n                        if (current_last) begin\n                            state <= ST_CRC;\n                            count <= 1;\n                            \n                            logic [31:0] final_crc_inv_rev;\n                            for (int i=0; i<32; i++) final_crc_inv_rev[i] = ~crc_reg[31-i];\n                            mii_txd_out <= final_crc_inv_rev[3:0];\n                            \n                            rd_frame_cnt <= rd_frame_cnt + 1;\n                        end else begin\n                            word_nibble_cnt <= 0;\n                            mii_txd_out <= current_word[3:0];\n                            crc_reg <= next_crc32_nibble(current_word[3:0], crc_reg);\n                        end\n                    end else begin\n                        word_nibble_cnt <= word_nibble_cnt + 1;\n                        logic [3:0] nxt_nibble;\n                        case (word_nibble_cnt + 1)\n                            4\'d1: nxt_nibble = current_word[7:4];\n                            4\'d2: nxt_nibble = current_word[11:8];\n                            4\'d3: nxt_nibble = current_word[15:12];\n                            4\'d4: nxt_nibble = current_word[19:16];\n                            4\'d5: nxt_nibble = current_word[23:20];\n                            4\'d6: nxt_nibble = current_word[27:24];\n                            4\'d7: nxt_nibble = current_word[31:28];\n                            default: nxt_nibble = 4\'h0;\n                        endcase\n                        mii_txd_out <= nxt_nibble;\n                        crc_reg <= next_crc32_nibble(nxt_nibble, crc_reg);\n                    end\n                end\n                \n                ST_CRC: begin\n                    mii_tx_en_out <= 1\'b1;\n                    if (count == 8) begin\n                        state <= ST_IFG;\n                        count <= 0;\n                        mii_tx_en_out <= 1\'b0;\n                        mii_txd_out <= 4\'h0;\n                    end else begin\n                        count <= count + 1;\n                        mii_txd_out <= crc_nibble;\n                    end\n                end\n                \n                ST_IFG: begin\n                    mii_txd_out <= 4\'h0;\n                    mii_tx_en_out <= 1\'b0;\n                    if (count == 23) begin\n                        if (frame_available) begin\n                            state <= ST_PREAMBLE;\n                            count <= 0;\n                            crc_reg <= 32\'hFFFFFFFF;\n                            mii_txd_out <= 4\'h5;\n                            mii_tx_en_out <= 1\'b1;\n                        end else begin\n                            state <= ST_IDLE;\n                        end\n                    end else begin\n                        count <= count + 1;\n                    end\n                end\n                \n                default: state <= ST_IDLE;\n            endcase\n        end\n    end\n\nendmodule\n"""\n\nwith open("rtl/ethernet_mii_tx.sv", "w") as f:\n    f.write(code)\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
