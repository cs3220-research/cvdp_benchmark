       if (digit_count == PASSWORD_LENGTH)\n                        next_state = CHECK_PASS;\n                    else\n                        next_state = PASSWORD_FAIL;\n                end\n            end\n            \n            CHECK_PASS: begin\n                if (entered_password == stored_password)\n                    next_state = PASSWORD_OK;\n                else\n                    next_state = PASSWORD_FAIL;\n            end\n            \n            PASSWORD_OK: begin\n                next_state = IDLE;\n            end\n            \n            PASSWORD_FAIL: begin\n                if (fail_count == MAX_TRIALS - 1)\n                    next_state = LOCKED_OUT;\n                else\n                    next_state = IDLE;\n            end\n            \n            LOCKED_OUT: begin\n                if (admin_override)\n                    next_state = PASSWORD_OK;\n            end\n            \n            ADMIN_MODE: begin\n                if (new_password_valid)\n                    next_state = IDLE;\n            end\n            \n            default: next_state = IDLE;\n        endcase\n    end\n\n    // Password Storage\n    always_ff @(posedge clk) begin\n        if (srst) begin\n            stored_password <= 4'h1;\n        end else if (state == ADMIN_MODE && new_password_valid) begin\n            stored_password <= new_password;\n        end\n    end\n\n    // Password Entry\n    always_ff @(posedge clk) begin\n        if (srst) begin\n            entered_password <= '0;\n            digit_count <= '0;\n        end else if (state == IDLE) begin\n            if (admin_override) begin\n                entered_password <= '0;\n                digit_count <= '0;\n            end else if (key_valid && key_input <= 9) begin\n                entered_password <= key_input;\n                digit_count <= 1;\n            end else begin\n                entered_password <= '0;\n                digit_count <= '0;\n            end\n        end else if (state == ENTER_PASS) begin\n            if (key_valid && key_input <= 9 && digit_count < PASSWORD_LENGTH) begin\n                entered_password <= (entered_password << 4) | key_input;\n                digit_count <= digit_count + 1;\n            end\n        end\n    end\n\n    // Fail Count\n    always_ff @(posedge clk) begin\n        if (srst) begin\n            fail_count <= '0;\n        end else if (admin_override || state == PASSWORD_OK) begin\n            fail_count <= '0;\n        end else if (state == PASSWORD_FAIL) begin\n            if (fail_count < MAX_TRIALS)\n                fail_count <= fail_count + 1'b1;\n        end\n    end\n\n    // Door Unlock\n    always_ff @(posedge clk) begin\n        if (srst)\n            door_unlock <= 1'b0;\n        else\n            door_unlock <= (state == PASSWORD_OK);\n    end\n\n    // Admin Override Delay for Lockout\n    always_ff @(posedge clk) begin\n        if (srst)\n            admin_override_d1 <= 1'b0;\n        else\n            admin_override_d1 <= admin_override;\n    end\n\n    // Lockout\n    always_ff @(posedge clk) begin\n        if (srst)\n            lockout <= 1'b0;\n        else if (admin_override_d1)\n            lockout <= 1'b0;\n        else if (state == PASSWORD_FAIL && fail_count == MAX_TRIALS - 1)\n            lockout <= 1'b1;\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
