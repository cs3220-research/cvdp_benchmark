Sending keys: ["cat << 'EOF' > /code/rtl/queue.sv\nmodule queue #(\n    parameter DEPTH = 4,\n    parameter DBITS = 32,\n    parameter ALMOST_EMPTY_THRESHOLD = 1,\n    parameter ALMOST_FULL_THRESHOLD = DEPTH - 1\n)(\n    input  logic             clk_i,\n    input  logic             rst_ni,\n    input  logic             clr_i,\n    input  logic             ena_i,\n    input  logic             we_i,\n    input  logic [DBITS-1:0] d_i,\n    input  logic             re_i,\n    output logic [DBITS-1:0] q_o,\n    output logic             empty_o,\n    output logic             full_o,\n    output logic             almost_empty_o,\n    output logic             almost_full_o\n);\n\n    localparam WADR_BITS = $clog2(DEPTH + 1);\n    \n    logic [DBITS-1:0] queue_data [0:DEPTH-1];\n    logic [WADR_BITS-1:0] queue_wadr;\n\n    assign empty_o = (queue_wadr == 0);\n    assign full_o  = (queue_wadr == DEPTH);\n    assign almost_empty_o = (queue_wadr <= ALMOST_EMPTY_THRESHOLD);\n    assign almost_full_o  = (queue_wadr >= ALMOST_FULL_THRESHOLD);\n\n    assign q_o = empty_o ? '0 : queue_data[0];\n\n    always_ff @(posedge clk_i or negedge rst_ni) begin\n        if (!rst_ni) begin\n            queue_wadr <= 0;\n            for (int i = 0; i < DEPTH; i++) begin\n                queue_data[i] <= '0;\n            end\n        end else if (clr_i) begin\n            queue_wadr <= 0;\n            for (int i = 0; i < DEPTH; i++) begin\n                queue_data[i] <= '0;\n            end\n        end else if (ena_i) begin\n            if (we_i && re_i) begin\n                if (empty_o) begin\n                    queue_data[0] <= d_i;\n                    queue_wadr <= 1;\n                end else begin\n                    for (int i = 0; i < DEPTH; i++) begin\n                        if (i == queue_wadr - 1) begin\n                            queue_data[i] <= d_i;\n                        end else if (i < DEPTH - 1) begin\n                            queue_data[i] <= queue_data[i+1];\n                        end\n                    end\n                end\n            end else if (we_i && !full_o) begin\n                queue_data[queue_wadr] <= d_i;\n                queue_wadr <= queue_wadr + 1;\n            end else if (re_i && !empty_o) begin\n                for (int i = 0; i < DEPTH - 1; i++) begin\n                    queue_data[i] <= queue_data[i+1];\n                end\n                queue_data[DEPTH-1] <= '0;\n                queue_wadr <= queue_wadr - 1;\n            end\n        end\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
