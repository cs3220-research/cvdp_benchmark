Sending keys: ["cat << 'EOF' > rtl/continuous_adder.sv\n`timescale 1ns / 1ps\n\nmodule continuous_adder #(\n    parameter integer DATA_WIDTH       = 32,\n    parameter integer ENABLE_THRESHOLD = 0,\n    parameter integer THRESHOLD        = 16,\n    parameter integer REGISTER_OUTPUT  = 0\n)(\n    input  wire clk,\n    input  wire rst_n,\n    input  wire valid_in,\n    input  wire [DATA_WIDTH-1:0] data_in,\n    input  wire accumulate_enable,\n    input  wire flush,\n    output reg  [DATA_WIDTH-1:0] sum_out,\n    output reg  sum_valid\n);\n\n    reg [DATA_WIDTH-1:0] sum_reg;\n\n    // Accumulation Logic and Flush Mechanism\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            sum_reg <= {DATA_WIDTH{1'b0}};\n        end else if (flush) begin\n            sum_reg <= {DATA_WIDTH{1'b0}};\n        end else if (valid_in && accumulate_enable) begin\n            sum_reg <= sum_reg + data_in;\n        end\n    end\n\n    // Combinational logic for outputs\n    logic [DATA_WIDTH-1:0] comb_sum_out;\n    logic comb_sum_valid;\n\n    always_comb begin\n        comb_sum_out = sum_reg;\n        if (ENABLE_THRESHOLD) begin\n            comb_sum_valid = (sum_reg >= THRESHOLD);\n        end else begin\n            comb_sum_valid = 1'b1;\n        end\n    end\n\n    // Output Registering\n    generate\n        if (REGISTER_OUTPUT) begin : gen_reg_output\n            always_ff @(posedge clk or negedge rst_n) begin\n                if (!rst_n) begin\n                    sum_out   <= {DATA_WIDTH{1'b0}};\n                    sum_valid <= 1'b0;\n                end else begin\n                    sum_out   <= comb_sum_out;\n                    sum_valid <= comb_sum_valid;\n                end\n            end\n        end else begin : gen_comb_output\n            always_comb begin\n                sum_out   = comb_sum_out;\n                sum_valid = comb_sum_valid;\n            end\n        end\n    endgenerate\n\nendmodule\nEOF\n"] min_timeout_sec: 0.2 max_timeout_sec: 180.0
