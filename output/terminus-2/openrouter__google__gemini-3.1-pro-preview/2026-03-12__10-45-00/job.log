DLE    = 1'b0,\n        GENERATE_INT = 1'b1\n    } msix_state_t;\n\n    // State registers\n    pcie_trans_state_t trans_state, trans_next;\n    pcie_dll_state_t   dll_state, dll_next;\n    dma_state_t        dma_state, dma_next;\n    msix_state_t       msix_state, msix_next;\n\n    // Retry counter for DLL FSM\n    logic [3:0] retry_cnt;\n\n    // =========================================================================\n    // PCIe Transaction FSM\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            trans_state      <= IDLE;\n            tlp_decoded_data <= '0;\n            tlp_valid        <= 1'b0;\n            dma_start        <= 1'b0;\n        end else begin\n            trans_state <= trans_next;\n            \n            // Default assignments\n            dma_start <= 1'b0;\n            \n            case (trans_state)\n                IDLE: begin\n                    if (pcie_rx_valid) begin\n                        tlp_decoded_data <= pcie_rx_tlp;\n                    end\n                end\n                RECEIVE: begin\n                    // Mark TLP as valid after reception\n                    tlp_valid <= 1'b1;\n                end\n                PROCESS: begin\n                    // Clear valid flag, decode TLP and trigger DMA if needed\n                    tlp_valid <= 1'b0;\n                    dma_start <= 1'b1; // Trigger DMA operation\n                end\n                SEND_RESPONSE: begin\n                    // Wait for the DLL FSM to accept the response\n                end\n            endcase\n        end\n    end\n\n    always_comb begin\n        trans_next = trans_state;\n        pcie_rx_ready = 1'b0;\n\n        case (trans_state)\n            IDLE: begin\n                pcie_rx_ready = 1'b1;\n                if (pcie_rx_valid) begin\n                    trans_next = RECEIVE;\n                end\n            end\n            RECEIVE: begin\n                trans_next = PROCESS;\n            end\n            PROCESS: begin\n                trans_next = SEND_RESPONSE;\n            end\n            SEND_RESPONSE: begin\n                // Hand over response to DLL FSM and return to IDLE\n                if (dll_state == DLL_IDLE) begin\n                    trans_next = IDLE;\n                end\n            end\n            default: trans_next = IDLE;\n        endcase\n    end\n\n    // =========================================================================\n    // PCIe Data Link FSM\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            dll_state <= DLL_IDLE;\n            retry_cnt <= '0;\n        end else begin\n            dll_state <= dll_next;\n            \n            if (dll_state == TRANSMIT) begin\n                retry_cnt <= '0;\n            end else if (dll_state == WAIT_ACK) begin\n                retry_cnt <= retry_cnt + 1'b1;\n            end\n        end\n    end\n\n    always_comb begin\n        dll_next      = dll_state;\n        pcie_tx_valid = 1'b0;\n        pcie_tx_tlp   = tlp_decoded_data; // Output the decoded data\n\n        case (dll_state)\n            DLL_IDLE: begin\n                if (trans_state == SEND_RESPONSE) begin\n                    dll_next = TRANSMIT;\n                end\n            end\n            TRANSMIT: begin\n                pcie_tx_valid = 1'b1;\n                if (pcie_tx_ready) begin\n                    dll_next = DLL_IDLE;\n                end else begin\n                    dll_next = WAIT_ACK;\n                end\n            end\n            WAIT_ACK: begin\n                pcie_tx_valid = 1'b1;\n                if (pcie_tx_ready) begin\n                    dll_next = DLL_IDLE;\n                end else if (retry_cnt == 4'hF) begin\n                    dll_next = RETRY;\n                end\n            end\n            RETRY: begin\n                // Retry transmission\n                dll_next = TRANSMIT;\n            end\n            default: dll_next = DLL_IDLE;\n        endcase\n    end\n\n    // =========================================================================\n    // DMA FSM\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            dma_state   <= DMA_IDLE;\n            dma_address <= '0;\n            dma_data    <= '0;\n        end else begin\n            dma_state <= dma_next;\n            \n            if (dma_state == READ_DESC) begin\n                dma_address <= dma_address + 8;\n            end else if (dma_state == FETCH_DATA) begin\n                dma_data <= {DATA_WIDTH{1'b1}};\n            end\n        end\n    end\n\n    always_comb begin\n        dma_next     = dma_state;\n        dma_complete = 1'b0;\n\n        case (dma_state)\n            DMA_IDLE: begin\n                if (dma_request || dma_start) begin\n                    dma_next = READ_DESC;\n                end\n            end\n            READ_DESC: begin\n                dma_next = FETCH_DATA;\n            end\n            FETCH_DATA: begin\n                dma_next = WRITE_DMA;\n            end\n            WRITE_DMA: begin\n                dma_complete = 1'b1;\n                dma_next     = DMA_IDLE;\n            end\n            default: dma_next = DMA_IDLE;\n        endcase\n    end\n\n    // =========================================================================\n    // MSI-X FSM\n    // =========================================================================\n    always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            msix_state <= MSIX_IDLE;\n        end else begin\n            msix_state <= msix_next;\n        end\n    end\n\n    always_comb begin\n        msix_next      = msix_state;\n        msix_interrupt = 1'b0;\n\n        case (msix_state)\n            MSIX_IDLE: begin\n                if (dma_complete) begin\n                    msix_next = GENERATE_INT;\n                end\n            end\n            GENERATE_INT: begin\n                msix_interrupt = 1'b1;\n                msix_next      = MSIX_IDLE;\n            end\n            default: msix_next = MSIX_IDLE;\n        endcase\n    end\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
