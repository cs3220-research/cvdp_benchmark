Sending keys: ["cat << 'EOF' > rtl/swizzler.sv\n`timescale 1ns/1ps\n\nmodule swizzler #(\n    parameter integer NUM_LANES = 4,\n    parameter integer DATA_WIDTH = 8,\n    parameter integer REGISTER_OUTPUT = 0,\n    parameter integer ENABLE_PARITY_CHECK = 0\n)(\n    input  wire                          clk,\n    input  wire                          rst_n,\n    input  wire                          bypass,\n    input  wire [NUM_LANES*DATA_WIDTH-1:0] data_in,\n    input  wire [NUM_LANES*$clog2(NUM_LANES)-1:0] swizzle_map_flat,\n    output reg  [NUM_LANES*DATA_WIDTH-1:0] data_out,\n    output reg                           parity_error\n);\n\n    localparam int MAP_WIDTH = ($clog2(NUM_LANES) > 0) ? $clog2(NUM_LANES) : 1;\n\n    logic [DATA_WIDTH-1:0] data_in_array [0:NUM_LANES-1];\n    logic [MAP_WIDTH-1:0]  swizzle_map_array [0:NUM_LANES-1];\n    logic [DATA_WIDTH-1:0] remapped_data_array [0:NUM_LANES-1];\n    \n    logic [NUM_LANES*DATA_WIDTH-1:0] remapped_data_flat;\n    logic                            comb_parity_error;\n\n    // Unpack data and swizzle map\n    generate\n        for (genvar i = 0; i < NUM_LANES; i++) begin : gen_unpack\n            assign data_in_array[i] = data_in[i*DATA_WIDTH +: DATA_WIDTH];\n            if (NUM_LANES > 1) begin : gen_map\n                assign swizzle_map_array[i] = swizzle_map_flat[i*$clog2(NUM_LANES) +: $clog2(NUM_LANES)];\n            end else begin : gen_map_zero\n                assign swizzle_map_array[i] = '0;\n            end\n        end\n    endgenerate\n\n    // Remap lanes\n    always_comb begin\n        for (int i = 0; i < NUM_LANES; i++) begin\n            if (bypass) begin\n                remapped_data_array[i] = data_in_array[i];\n            end else begin\n                remapped_data_array[i] = data_in_array[swizzle_map_array[i]];\n            end\n        end\n    end\n\n    // Pack output\n    generate\n        for (genvar i = 0; i < NUM_LANES; i++) begin : gen_pack\n            assign remapped_data_flat[i*DATA_WIDTH +: DATA_WIDTH] = remapped_data_array[i];\n        end\n    endgenerate\n\n    // Parity check\n    always_comb begin\n        comb_parity_error = 1'b0;\n        if (ENABLE_PARITY_CHECK) begin\n            for (int i = 0; i < NUM_LANES; i++) begin\n                if (^remapped_data_array[i]) begin\n                    comb_parity_error = 1'b1;\n                end\n            end\n        end\n    end\n\n    // Output assignment\n    generate\n        if (REGISTER_OUTPUT) begin : gen_reg_out\n            always_ff @(posedge clk or negedge rst_n) begin\n                if (!rst_n) begin\n                    data_out <= '0;\n                    parity_error <= 1'b0;\n                end else begin\n                    data_out <= remapped_data_flat;\n                    parity_error <= comb_parity_error;\n                end\n            end\n        end else begin : gen_comb_out\n            always_comb begin\n                data_out = remapped_data_flat;\n                parity_error = comb_parity_error;\n            end\n        end\n    endgenerate\n\nendmodule\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
